{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Office",
  "version": "0.1.0",
  "identifier": "me.ursb.agent-office",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent Office",
        "url": "https://ursb.me/nook?room=office",
        "width": 960,
        "height": 680,
        "minWidth": 640,
        "minHeight": 480,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousRemoteDomainIpcAccess": [
        {
          "domain": "ursb.me",
          "windows": ["main"],
          "enableTauriAPI": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
