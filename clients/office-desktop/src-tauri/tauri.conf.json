{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Office",
  "version": "0.1.0",
  "identifier": "me.ursb.agent-office",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "pet",
        "title": "Agent Office Pet",
        "url": "pet.html",
        "width": 96,
        "height": 120,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": true
      },
      {
        "label": "main",
        "title": "Agent Office",
        "url": "https://ursb.me/nook?room=office",
        "width": 960,
        "height": 680,
        "minWidth": 640,
        "minHeight": 480,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"]
  }
}
