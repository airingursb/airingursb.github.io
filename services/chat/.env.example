# Server
PORT=3000

# Auth
HMAC_SECRET=replace_with_openssl_rand_hex_32

# OpenClaw (in Docker, use service name as hostname)
OPENCLAW_URL=http://openclaw-gateway:18789
OPENCLAW_TOKEN=your_gateway_token
OPENCLAW_AGENT_ID=anling

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# CORS (comma-separated origins — empty means reject all cross-origin requests)
ALLOWED_ORIGINS=http://localhost:3000,https://your-blog-domain.com

# Trust X-Forwarded-For header for IP detection (set true when behind reverse proxy)
TRUST_PROXY=false
