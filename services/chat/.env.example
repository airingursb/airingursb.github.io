# Server
PORT=3000

# Auth
HMAC_SECRET=replace_with_openssl_rand_hex_32

# OpenClaw
OPENCLAW_URL=https://your-openclaw-instance
OPENCLAW_TOKEN=your_openclaw_bearer_token
OPENCLAW_AGENT_ID=your_agent_id

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,https://your-blog-domain.com
