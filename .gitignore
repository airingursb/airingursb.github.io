# Agent / skill / IDE state — never commit
.agents/
.claude/
.factory/
.kiro/
.superset/
skills/
skills-lock.json

# Local working / scratch
prototypes/
data/design.pen
hermes-agent-architecture.html
src/buddy/

# Tooling caches
**/__pycache__/
*.pyc
supabase/.temp/

# Photo originals — sidecar .md files ARE tracked, originals are not.
# Sidecars now live in photos-source/meta/<basename>.md (kept the top-level
# *.md exception for legacy/migration only; new sidecars go in meta/).
photos-source/*
!photos-source/.gitkeep
!photos-source/*.md
!photos-source/meta/
!photos-source/meta/*.md

# Workout data is private by default. Source HealthAutoExport JSONs and
# the synced full normalized output never leave the local machine. Only
# the explicitly opted-in subset (mdx with `public: true`) gets written
# to src/data/workouts-public/ which IS tracked, so CI can build the
# deployed site without seeing the private hikes.
workouts-source/*
!workouts-source/.gitkeep
src/data/workouts/*
!src/data/workouts/.gitkeep
src/data/workouts.json
# (workouts-public/ and workouts-public.json are deliberately NOT ignored)

# Grove 3D — generated GLBs are big binaries; host externally (COS/CDN)
public/grove3d/models/*.glb

# Grove 3D archive — chibi v1 assets, kept locally for reference
public/grove3d/models/_archive/

public/grove3d/models/_unpack/
public/grove3d/models/player/

# Gallery test screenshots (debug artifacts from interactive testing)
/v*.png
/gallery-*.png

# Room smoke-test capture dirs (regenerated per `npm run test:rooms` /
# `node --test tests/smoke/mobile_sweep.test.mjs`)
tests/smoke/_screens/
tests/smoke/_screens_mobile/

# Local debug screenshots — never commit
screenshots/
verify-waterfall.mjs
verify-pond-direct.mjs
verify-pet-hover.mjs
