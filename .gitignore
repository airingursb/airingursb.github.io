# Photo originals — sidecar .md files ARE tracked, originals are not.
# Sidecars now live in photos-source/meta/<basename>.md (kept the top-level
# *.md exception for legacy/migration only; new sidecars go in meta/).
photos-source/*
!photos-source/.gitkeep
!photos-source/*.md
!photos-source/meta/
!photos-source/meta/*.md

# Workout data is private by default. Source HealthAutoExport JSONs and
# the synced full normalized output never leave the local machine. Only
# the explicitly opted-in subset (mdx with `public: true`) gets written
# to src/data/workouts-public/ which IS tracked, so CI can build the
# deployed site without seeing the private hikes.
workouts-source/*
!workouts-source/.gitkeep
src/data/workouts/*
!src/data/workouts/.gitkeep
src/data/workouts.json
# (workouts-public/ and workouts-public.json are deliberately NOT ignored)
