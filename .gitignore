# Photo originals — sidecar .md files ARE tracked, originals are not.
# Sidecars now live in photos-source/meta/<basename>.md (kept the top-level
# *.md exception for legacy/migration only; new sidecars go in meta/).
photos-source/*
!photos-source/.gitkeep
!photos-source/*.md
!photos-source/meta/
!photos-source/meta/*.md

# Workout data is private. Source HealthAutoExport JSONs and the synced
# normalized output never leave the local machine; the dist build inlines
# them into the bundle which goes public, but the raw / structured copies
# stay out of git history. The mdx labels under src/content/workouts/ are
# user-written prose and ARE tracked.
workouts-source/*
!workouts-source/.gitkeep
src/data/workouts/*
!src/data/workouts/.gitkeep
src/data/workouts.json
