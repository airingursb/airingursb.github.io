{
  "name": "blog-homepage",
  "version": "1.0.0",
  "description": "A data-driven developer homepage that displays my digital life in real-time.",
  "main": "main.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "node --experimental-strip-types --test 'tests/*.test.mjs' 'tests/lounge/**/*.test.mjs' 'tests/workouts/**/*.test.mjs'",
    "test:rooms": "node --test tests/smoke/lounge_rooms.test.mjs",
    "test:mobile": "node --test tests/smoke/mobile_sweep.test.mjs",
    "perf:tti": "node scripts/perf/measure-tti.mjs",
    "build": "astro build && npx pagefind --site dist",
    "build:gc": "cd prototypes/heap-plaza && npm install --silent && npm run build",
    "dev:gc": "cd prototypes/heap-plaza && npm install --silent && npm run dev",
    "sync:photos": "node scripts/sync-photos.mjs",
    "sync:workouts": "node scripts/sync-workouts.mjs",
    "lounge:validate": "node scripts/lounge/validate-assets.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airingursb/airingursb.github.io.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/airingursb/airingursb.github.io/issues"
  },
  "homepage": "https://github.com/airingursb/airingursb.github.io#readme",
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@codesandbox/sandpack-react": "^2.20.0",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/supabase-js": "^2.100.1",
    "astro": "^6.0.8",
    "d3": "^7.9.0",
    "mapbox-gl": "^3.23.0",
    "markdown-it": "^14.1.1",
    "phaser": "^3.90.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanitize-html": "^2.17.2",
    "satori": "^0.26.0",
    "three": "^0.184.0",
    "unist-util-visit": "^5.1.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@google/genai": "^2.3.0",
    "@types/d3": "^7.4.3",
    "@types/mapbox-gl": "^3.4.1",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/three": "^0.184.1",
    "canvas": "^3.2.3",
    "dotenv": "^17.4.2",
    "exifr": "^7.1.3",
    "pagefind": "^1.4.0",
    "sharp": "^0.34.5"
  }
}
