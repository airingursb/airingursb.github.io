# Copy to .env and fill in real values — .env is git-ignored, this file is
# committed as a template. scripts/collect_local_data.py reads these.

# Vibe Coding: the work/server Mac that scripts/collect_local_data.py SSHes
# into to merge its Claude/Codex/Gemini usage with local. Leave empty to
# skip and report local-only numbers.
VIBE_REMOTE_HOST=
VIBE_REMOTE_USER=
VIBE_REMOTE_PASSWORD=

# Cloudflare R2 (photos sync) — see docs/superpowers/plans/2026-05-02-photos-tab.md
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ursb-photos
R2_PUBLIC_BASE=https://r2.airingdeng.com

# Mapbox public token — inlined into the client bundle by Astro/Vite via
# import.meta.env.PUBLIC_MAPBOX_TOKEN. Use a public (pk.*) token; never put
# a secret (sk.*) token here.
# Get one at https://account.mapbox.com/access-tokens/
PUBLIC_MAPBOX_TOKEN=pk.your_public_token_here

# ── Comics (四格) ──────────────────────────────────────────────
# Gemini 2.5 Flash Image (nano-banana) — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic Claude — for 4-panel script generation (claude-sonnet-4-6)
ANTHROPIC_API_KEY=

# The only Telegram user_id allowed to drive the bot
ADMIN_TELEGRAM_USER_ID=

# GitHub PAT with `repo` scope — used to fire repository_dispatch from blog-api
# Issue at: https://github.com/settings/personal-access-tokens/new
GH_DISPATCH_TOKEN=

# Public URL where Telegram webhook should POST
# (e.g. https://blog-api.ursb.me/api/webhook/telegram)
TELEGRAM_WEBHOOK_URL=
