0.06 0.082 -0.06 0.082v1.445s-0.01 0.068 0.064 0.068h1.457c0.082 0 0.076 -0.006 0.076 0.079v3.225c0 0.088 -0.007 0.081 0.082 0.081h1.43c0.09 0 0.082 0.007 0.082 -0.08v-3.27c0 -0.029 0.006 -0.035 0.033 -0.035l2.323 -0.003c0.098 0 0.191 0.02 0.28 0.061a0.46 0.46 0 0 1 0.274 0.407c0.008 0.395 0.003 0.79 0.003 1.185 0 0.259 -0.107 0.367 -0.33 0.367h-1.218c-0.023 0.002 -0.029 0.008 -0.028 0.033 0.184 0.437 0.374 0.871 0.57 1.303a0.045 0.045 0 0 0 0.04 0.026c0.17 0.005 0.34 0.002 0.51 0.003 0.15 -0.002 0.517 0.004 0.666 -0.01a2.03 2.03 0 0 0 0.408 -0.075c0.59 -0.18 0.975 -0.698 0.976 -1.313v-1.981c0 -0.128 -0.01 -0.254 -0.034 -0.38 0 0.078 -0.029 -0.641 -0.724 -0.998z"/></svg>
                </a>
                <a href="mailto:airing@ursb.me" title="Email" class="author-link-icon">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </a>
                <a href="/search" title="Search" class="author-link-icon">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                </a>
                <a href="/feed.xml" title="RSS" class="author-link-icon">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
                </a>
              </div>
            </div>
            <div class="subscribe-card">
              <p class="subscribe-desc">Subscribe to get new posts by email</p>
              <form class="subscribe-form" id="subscribe-form">
                <input
                  type="email"
                  name="email"
                  placeholder="Your email address"
                  required
                  class="subscribe-input"
                />
                <button type="submit" class="subscribe-btn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  Subscribe
                </button>
              </form>
              <p class="subscribe-msg" id="subscribe-msg"></p>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <!-- Footer -->
    <footer class="blog-footer">
      <div class="footer-inner">
        <span>&copy; 2026 Airing</span>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/archive">Archive</a>
          <a href="/feed.xml">RSS</a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement;
  const msg = document.getElementById('subscribe-msg') as HTMLParagraphElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = new FormData(form).get('email') as string;
    if (!email) return;
    msg.textContent = 'Subscribing...';
    msg.style.color = 'var(--c-text-muted)';
    try {
      const res = await fetch('https://chat.ursb.me/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (res.ok) {
        msg.textContent = 'Subscribed! Thank you.';
        msg.style.color = 'var(--accent, #4ade80)';
        form.reset();
      } else {
        msg.textContent = 'Something went wrong. Try again.';
        msg.style.color = '#f87171';
      }
    } catch {
      msg.textContent = 'Network error. Try again.';
      msg.style.color = '#f87171';
    }
  });

  // WeChat tooltip
  const wechatBtn = document.getElementById('wechatBtn');
  const wechatTooltip = document.getElementById('wechatTooltip');
  wechatBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    wechatTooltip?.classList.toggle('active');
  });
  document.addEventListener('click', () => wechatTooltip?.classList.remove('active'));

  // ── Top / Latest tab switching ──
  const tabs = document.querySelectorAll('.list-tab') as NodeListOf<HTMLButtonElement>;
  const postItems = document.querySelectorAll('.post-item') as NodeListOf<HTMLAnchorElement>;
  let viewsCache: Record<string, number> | null = null;

  // Store original order (by date descending, already rendered)
  const originalOrder = Array.from(postItems);

  tabs.forEach(tab => {
    tab.addEventListener('click', async () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      const isTop = tab.textContent?.trim() === 'Top';
      const container = postItems[0]?.parentElement;
      if (!container) return;

      if (isTop) {
        // Fetch views if not cached
        if (!viewsCache) {
          try {
            const res = await fetch('https://chat.ursb.me/api/posts/views/all');
            viewsCache = await res.json();
          } catch {
            viewsCache = {};
          }
        }

        // Sort: PV desc, then date desc
        const sorted = Array.from(postItems).sort((a, b) => {
          const pvA = viewsCache![a.dataset.slug!] || 0;
          const pvB = viewsCache![b.dataset.slug!] || 0;
          if (pvB !== pvA) return pvB - pvA;
          return new Date(b.dataset.date!).getTime() - new Date(a.dataset.date!).getTime();
        });
        sorted.forEach(item => container.appendChild(item));
      } else {
        // Restore original order (by date)
        originalOrder.forEach(item => container.appendChild(item));
      }
    });
  });
</script>

