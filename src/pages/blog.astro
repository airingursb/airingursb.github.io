---
/**
 * Blog — Magazine-style Substack-inspired listing page
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPosts = posts.filter(p => p.data.featured);
// Hero: featured first, then fill with recent
const heroPool = [...featuredPosts, ...posts.filter(p => !p.data.featured)];
const heroPosts = heroPool.slice(0, 5);
const popularPosts = [...featuredPosts, ...posts].slice(0, 4);
// Remaining for the list (skip hero posts)
const heroIds = new Set(heroPosts.map(p => p.id));
const listPosts = posts.filter(p => !heroIds.has(p.id)).slice(0, 15);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const gradientFallback = 'linear-gradient(135deg, rgba(var(--c-overlay-rgb),0.08), rgba(var(--c-overlay-rgb),0.03))';
---

<BaseLayout title="Blog | Airing">
  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&display=swap" />
  <div class="blog-page">
    <!-- Masthead -->
    <header class="masthead">
      <div class="mast-inner">
        <div class="mast-top-rule"></div>
        <div class="mast-bar">
          <a href="/blog" class="mast-brand">Airing's Blog</a>
          <span class="mast-motto">应无所住而生其心</span>
          <div class="mast-links">
            <a href="/blog">Blog</a>
            <a href="/archive">Archive</a>
            <a href="/friends">Friends</a>
          </div>
        </div>
        <div class="mast-bottom-rule"></div>
        <div class="mast-date-line">
          <span class="mast-date">{new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</span>
          <span class="mast-post-count">{posts.length} posts</span>
        </div>
      </div>
    </header>

    <!-- Magazine Hero Grid -->
    <section class="hero-section">
      <div class="hero-grid">
        <!-- Left column: 2 small cards -->
        <div class="hero-col hero-col-left">
          {heroPosts.slice(1, 3).map(post => (
            <a href={`/posts/${post.id}`} class="hero-card hero-card-sm">
              <div
                class="hc-img"
                style={`background-image:${post.data.cover ? `url(${post.data.cover})` : gradientFallback}`}
              ></div>
              <div class="hc-body">
                <h3 class="hc-title">{post.data.title}</h3>
                {post.data.description && <p class="hc-excerpt">{post.data.description}</p>}
                <div class="hc-meta">
                  <time>{formatDate(post.data.date)}</time>
                  <span>&middot;</span>
                  <span>Airing</span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Center: large hero -->
        {heroPosts[0] && (
          <a href={`/posts/${heroPosts[0].id}`} class="hero-card hero-card-lg">
            <div
              class="hc-img-full"
              style={`background-image:${heroPosts[0].data.cover ? `url(${heroPosts[0].data.cover})` : gradientFallback}`}
            >
              <div class="hc-overlay">
                <h2 class="hc-title-lg">{heroPosts[0].data.title}</h2>
                {heroPosts[0].data.description && (
                  <p class="hc-excerpt-lg">{heroPosts[0].data.description}</p>
                )}
                <div class="hc-meta-lg">
                  <time>{formatDate(heroPosts[0].data.date)}</time>
                  <span>&middot;</span>
                  <span>Airing</span>
                </div>
              </div>
            </div>
          </a>
        )}

        <!-- Right column: 2 small cards -->
        <div class="hero-col hero-col-right">
          {heroPosts.slice(3, 5).map(post => (
            <a href={`/posts/${post.id}`} class="hero-card hero-card-sm">
              <div
                class="hc-img"
                style={`background-image:${post.data.cover ? `url(${post.data.cover})` : gradientFallback}`}
              ></div>
              <div class="hc-body">
                <h3 class="hc-title">{post.data.title}</h3>
                {post.data.description && <p class="hc-excerpt">{post.data.description}</p>}
                <div class="hc-meta">
                  <time>{formatDate(post.data.date)}</time>
                  <span>&middot;</span>
                  <span>Airing</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Most Popular -->
    <section class="popular-section">
      <div class="popular-inner">
        <div class="popular-header">
          <h2 class="popular-heading">Most Popular</h2>
          <a href="/archive" class="popular-viewall">View all &rarr;</a>
        </div>
        <div class="popular-grid">
          {popularPosts.map(post => (
            <a href={`/posts/${post.id}`} class="popular-card">
              <div class="pc-body">
                <h3 class="pc-title">{post.data.title}</h3>
                <div class="pc-meta">
                  <time>{formatDate(post.data.date)}</time>
                  <span>&middot;</span>
                  <span>Airing</span>
                </div>
              </div>
              {post.data.cover && (
                <div class="pc-thumb" style={`background-image:url(${post.data.cover})`}></div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Content Area -->
    <section class="content-section">
      <div class="content-inner">
        <!-- Left: Article list -->
        <div class="article-list">
          <div class="list-tabs">
            <div class="tab-bar">
              <button class="list-tab active">Latest</button>
              <button class="list-tab">Top</button>
            </div>
            <a href="/search" class="list-search-icon" aria-label="Search posts">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </a>
          </div>

          {listPosts.map(post => (
            <a href={`/posts/${post.id}`} class="post-item">
              <div class="pi-body">
                <h3 class="pi-title">{post.data.title}</h3>
                {post.data.description && (
                  <p class="pi-desc">{post.data.description}</p>
                )}
                <div class="pi-meta">
                  <time>{formatDate(post.data.date)}</time>
                  <span>&middot;</span>
                  <span>Airing</span>
                </div>
              </div>
              {post.data.cover && (
                <div class="pi-thumb" style={`background-image:url(${post.data.cover})`}></div>
              )}
            </a>
          ))}
        </div>

        <!-- Right: Author sidebar -->
        <aside class="author-sidebar">
          <div class="sidebar-sticky">
            <div class="author-card">
              <img
                src="https://avatars.githubusercontent.com/u/10513408?v=4&s=96"
                alt="Airing"
                class="author-avatar"
                loading="lazy"
              />
              <h3 class="author-name"><a href="/">Airing</a></h3>
              <p class="author-bio">哲学硕士｜终端全栈</p>
              <div class="author-links">
                <a href="/search" title="Search" class="author-link-icon">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                </a>
                <a href="/feed.xml" title="RSS" class="author-link-icon">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
                </a>
                <a href="https://t.me/s/airingchannel" target="_blank" rel="noopener" title="Telegram" class="author-link-icon">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                </a>
              </div>
            </div>
            <div class="subscribe-card">
              <p class="subscribe-desc">Subscribe to get new posts by email</p>
              <form class="subscribe-form" id="subscribe-form">
                <input
                  type="email"
                  name="email"
                  placeholder="Your email address"
                  required
                  class="subscribe-input"
                />
                <button type="submit" class="subscribe-btn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  Subscribe
                </button>
              </form>
              <p class="subscribe-msg" id="subscribe-msg"></p>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <!-- Footer -->
    <footer class="blog-footer">
      <div class="footer-inner">
        <span>&copy; 2026 Airing</span>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/archive">Archive</a>
          <a href="/feed.xml">RSS</a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement;
  const msg = document.getElementById('subscribe-msg') as HTMLParagraphElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = new FormData(form).get('email') as string;
    if (!email) return;
    msg.textContent = 'Subscribing...';
    msg.style.color = 'var(--c-text-muted)';
    try {
      const res = await fetch('https://chat.ursb.me/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (res.ok) {
        msg.textContent = 'Subscribed! Thank you.';
        msg.style.color = 'var(--accent, #4ade80)';
        form.reset();
      } else {
        msg.textContent = 'Something went wrong. Try again.';
        msg.style.color = '#f87171';
      }
    } catch {
      msg.textContent = 'Network error. Try again.';
      msg.style.color = '#f87171';
    }
  });
</script>

<style is:global>
  body:has(.blog-page) {
    display: block;
    padding: 0;
    align-items: stretch;
    justify-content: stretch;
  }
</style>

<style>
  .blog-page {
    min-height: 100vh;
    width: 100%;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    --font-serif: 'Noto Serif SC', 'Source Han Serif CN', 'Source Han Serif SC', 'Songti SC', STSong, serif;
  }

  /* ── Nav ────────────────────────────────────────────── */
  .masthead { width: 100%; }
  .mast-inner { max-width: 1100px; margin: 0 auto; padding: 0 48px; }
  .mast-top-rule { height: 4px; background: var(--c-text); margin-top: 24px; }
  .mast-bar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 0; position: relative;
  }
  .mast-brand {
    font-size: 11px; color: var(--c-text-muted); text-decoration: none;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
  }
  .mast-brand:hover { color: var(--c-text); }
  .mast-links { display: flex; gap: 16px; }
  .mast-links a {
    font-size: 11px; color: var(--c-text-dim); text-decoration: none;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .mast-links a:hover { color: var(--c-text); }
  .mast-motto {
    font-size: 12px; color: var(--c-text-dim);
    position: absolute; left: 50%; transform: translateX(-50%);
    letter-spacing: 0.15em;
    font-family: var(--font-serif);
  }
  .mast-bottom-rule { height: 1px; background: var(--c-border); }
  .mast-date-line {
    display: flex; justify-content: space-between; align-items: center;
    padding: 8px 0; border-bottom: 1px solid var(--c-border);
  }
  .mast-date {
    font-size: 11px; color: var(--c-text-dim);
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .mast-post-count {
    font-size: 11px; color: var(--c-text-dim);
    letter-spacing: 0.06em;
  }

  /* ── Hero Grid ─────────────────────────────────────── */
  .hero-section {
    padding: 32px 0 0;
  }
  .hero-grid {
    max-width: 1100px; margin: 0 auto; padding: 0 48px;
    display: grid;
    grid-template-columns: 1fr 2.4fr 1fr;
    gap: 16px;
    min-height: 400px;
  }

  .hero-col {
    display: flex; flex-direction: column; gap: 16px;
  }

  /* Small side cards */
  .hero-card-sm {
    flex: 1;
    display: flex; flex-direction: column;
    text-decoration: none;
    border-radius: 4px;
    border: 1px solid var(--c-border);
    transition: border-color 0.2s, box-shadow 0.2s;
    background: rgba(var(--c-overlay-rgb),0.02);
  }
  .hero-card-sm:hover {
    border-color: rgba(var(--c-overlay-rgb),0.15);
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }
  .hc-img {
    height: 120px;
    background-size: cover;
    background-position: center;
    background-color: rgba(var(--c-overlay-rgb),0.04);
    flex-shrink: 0;
    border-radius: 4px 4px 0 0;
  }
  .hc-body {
    padding: 12px 14px 14px;
    display: flex; flex-direction: column;
    flex-shrink: 0;
  }
  .hc-title {
    font-size: 15px; font-weight: 700; color: var(--c-text);
    line-height: 1.4; margin: 0 0 4px;
    font-family: var(--font-serif);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hc-excerpt {
    font-size: 12px; color: var(--c-text-dim); line-height: 1.4;
    margin: 0 0 auto;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hc-meta {
    font-size: 11px; color: var(--c-text-dim); margin-top: 8px;
    display: flex; align-items: center; gap: 6px;
  }

  /* Large center hero card */
  .hero-card-lg {
    display: block; text-decoration: none;
    border-radius: 4px; overflow: hidden;
    position: relative;
  }
  .hc-img-full {
    width: 100%; height: 100%; min-height: 400px;
    background-size: cover; background-position: center;
    background-color: rgba(var(--c-overlay-rgb),0.04);
    display: flex; align-items: flex-end;
    position: relative;
  }
  .hc-img-full::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.2) 40%, transparent 70%);
    border-radius: 4px;
  }
  .hc-overlay {
    position: relative; z-index: 1;
    padding: 28px 28px;
    width: 100%;
  }
  .hc-title-lg {
    font-size: 28px; font-weight: 700; color: #fff;
    line-height: 1.2; margin: 0 0 8px;
    letter-spacing: -0.02em;
    font-family: var(--font-serif);
    text-shadow: 0 1px 3px rgba(0,0,0,0.3);
  }
  .hc-excerpt-lg {
    font-size: 15px; color: rgba(255,255,255,0.8);
    line-height: 1.55; margin: 0 0 12px;
    font-family: var(--font-serif);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hc-meta-lg {
    font-size: 13px; color: rgba(255,255,255,0.65);
    display: flex; align-items: center; gap: 6px;
  }
  .hero-card-lg:hover .hc-title-lg {
    color: var(--accent, #4ade80);
  }

  /* ── Most Popular ──────────────────────────────────── */
  .popular-section {
    padding: 40px 0 0;
    border-top: 1px solid var(--c-border);
    margin-top: 32px;
  }
  .popular-inner {
    max-width: 1100px; margin: 0 auto; padding: 0 48px;
  }
  .popular-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 20px;
  }
  .popular-heading {
    font-size: 18px; font-weight: 700; color: var(--c-text);
    margin: 0; letter-spacing: -0.01em;
    font-family: var(--font-serif);
  }
  .popular-viewall {
    font-size: 13px; color: var(--c-text-muted); text-decoration: none;
    transition: color 0.2s;
  }
  .popular-viewall:hover { color: var(--accent, #4ade80); }

  .popular-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .popular-card {
    display: flex; align-items: flex-start; gap: 12px;
    text-decoration: none;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--c-border);
    transition: opacity 0.15s;
  }
  .popular-card:hover { opacity: 0.8; }
  .pc-body { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; min-height: 48px; }
  .pc-title {
    font-size: 15px; font-weight: 700; color: var(--c-text);
    line-height: 1.4; margin: 0 0 6px;
    font-family: var(--font-serif);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pc-meta {
    font-size: 12px; color: var(--c-text-dim);
    display: flex; align-items: center; gap: 5px;
    margin-top: auto;
  }
  .pc-thumb {
    width: 48px; height: 48px; flex-shrink: 0;
    background-size: cover; background-position: center;
    border-radius: 6px;
    background-color: rgba(var(--c-overlay-rgb),0.04);
  }

  /* ── Content Area ──────────────────────────────────── */
  .content-section {
    padding: 40px 0;
    border-top: 1px solid var(--c-border);
    margin-top: 32px;
  }
  .content-inner {
    max-width: 1100px; margin: 0 auto; padding: 0 48px;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 48px;
    align-items: start;
  }

  /* Tabs */
  .list-tabs {
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--c-border);
    margin-bottom: 4px;
  }
  .tab-bar { display: flex; gap: 0; }
  .list-tab {
    background: none; border: none; cursor: pointer;
    font-size: 14px; font-weight: 600; color: var(--c-text-muted);
    padding: 12px 20px;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    font-family: inherit;
  }
  .list-tab:hover { color: var(--c-text); }
  .list-tab.active { color: var(--c-text); border-bottom-color: var(--c-text); }
  .list-search-icon {
    color: var(--c-text-muted);
    padding: 8px;
    border-radius: 6px;
    transition: all 0.15s;
    display: flex; align-items: center;
  }
  .list-search-icon:hover {
    color: var(--c-text);
    background: rgba(var(--c-overlay-rgb),0.06);
  }

  /* Post items */
  .post-item {
    display: flex; align-items: center; gap: 20px;
    text-decoration: none;
    padding: 20px 0;
    min-height: 120px;
    border-bottom: 1px solid var(--c-border);
    transition: opacity 0.15s;
  }
  .post-item:hover { opacity: 0.85; }
  .post-item:hover .pi-title { color: var(--accent, #4ade80); }
  .pi-body { flex: 1; min-width: 0; }
  .pi-title {
    font-size: 19px; font-weight: 700; color: var(--c-text);
    line-height: 1.35; margin: 0 0 6px;
    font-family: var(--font-serif);
    letter-spacing: 0.01em;
    transition: color 0.2s;
  }
  .pi-desc {
    font-size: 15px; color: var(--c-text-dim); line-height: 1.6;
    margin: 0 0 8px;
    font-family: var(--font-serif);
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pi-meta {
    font-size: 13px; color: var(--c-text-muted);
    display: flex; align-items: center; gap: 6px;
  }
  .pi-thumb {
    width: 120px; height: 80px; flex-shrink: 0;
    background-size: cover; background-position: center;
    border-radius: 4px;
    background-color: rgba(var(--c-overlay-rgb),0.04);
  }

  /* ── Author Sidebar ────────────────────────────────── */
  .author-sidebar { }
  .author-sidebar .sidebar-sticky {
    position: sticky; top: 80px;
  }
  .author-card {
    text-align: center;
    padding: 24px 0 20px;
  }
  .author-avatar {
    width: 48px; height: 48px; border-radius: 50%;
    object-fit: cover; margin-bottom: 10px;
  }
  .author-name {
    font-size: 16px; font-weight: 700; color: var(--c-text);
    margin: 0 0 4px;
  }
  .author-name a {
    color: inherit; text-decoration: none;
  }
  .author-name a:hover {
    color: var(--accent, #4ade80);
  }
  .author-links {
    display: flex; gap: 12px; justify-content: center;
    margin-top: 10px;
  }
  .author-link-icon {
    color: var(--c-text-dim); transition: color 0.2s;
    display: flex; align-items: center;
  }
  .author-link-icon:hover { color: var(--c-text); }
  .author-bio {
    font-size: 13px; color: var(--c-text-dim); margin: 0;
    line-height: 1.4;
  }

  /* Subscribe */
  .subscribe-card {
    border-top: 1px solid var(--c-border);
    padding-top: 16px;
    margin-top: 16px;
