---
import '../styles/workouts.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import LangSwitch from '../components/LangSwitch.astro';
import { siteStrings } from '../lib/i18n';
import { getCollection } from 'astro:content';
import { existsSync, readFileSync } from 'node:fs';
import { resolve as resolvePath } from 'node:path';
import { formatDistance, formatDuration, formatRelativeDate, defaultWorkoutTitle } from '../components/workouts/format.mjs';
import { WorkoutTypeIcon } from '../components/workouts/icons';
import RouteMini from '../components/workouts/RouteMini.tsx';

const s = siteStrings.zh.workouts;
// Local-first, public-fallback. Local index has every hike (including
// private); CI only ships the committed public subset.
const idxPath = resolvePath('./src/data/workouts.json');
const pubIdxPath = resolvePath('./src/data/workouts-public.json');
const idxFile = existsSync(idxPath) ? idxPath : (existsSync(pubIdxPath) ? pubIdxPath : null);
const items = (idxFile ? JSON.parse(readFileSync(idxFile, 'utf8')) : []) as Array<any>;
const contentEntries = await getCollection('workouts');
// Astro 5 lowercases content collection IDs; workout UUIDs are uppercase.
const titleById = new Map(contentEntries.map(e => [e.id.toLowerCase(), e.data.title]));

// Inline simplified route per item so RouteMini hydrates without an extra fetch.
const routesById = new Map<string, any[]>();
for (const w of items) {
  const local = resolvePath(`./src/data/workouts/${w.id}.json`);
  const pub   = resolvePath(`./src/data/workouts-public/${w.id}.json`);
  const file  = existsSync(local) ? local : (existsSync(pub) ? pub : null);
  if (!file) continue;
  const detail = JSON.parse(readFileSync(file, 'utf8'));
  routesById.set(w.id, detail.route ?? []);
}

const totalKm = items.reduce((s, w) => s + (w.stats?.distanceKm ?? 0), 0);
const totalHours = items.reduce((s, w) => s + (w.durationSec ?? 0), 0) / 3600;
---

<BaseLayout
  title={`${s.title} · Airing`}
  description={s.desc}
  lang="zh"
  hreflang={{ zh: '/workouts', en: '/en/workouts' }}
>
  <div class="workouts-page">
    <header class="masthead">
      <div class="mast-inner">
        <div class="mast-top-rule"></div>
        <div class="mast-bar">
          <a href="/blog" class="mast-brand">Airing's Blog</a>
          <div class="mast-links">
            <a href="/blog">Blog</a>
            <a href="/archive">Archive</a>
            <a href="/moments">Moment</a>
            <a href="/notes">Notes</a>
            <a href="/photos">Photos</a>
            <a href="/comics">四格</a>
            <a href="/friends">Friends</a>
          </div>
        </div>
        <div class="mast-lang-line">
          <LangSwitch lang="zh" currentPath="/workouts" hasEnVersion={true} />
        </div>
        <div class="mast-bottom-rule"></div>
      </div>
    </header>

    <main style="max-width: 760px; margin: 0 auto; padding: 24px 16px;">
      <h1 style="margin: 0 0 4px;">{s.title}</h1>
      <p style="color: var(--w-fg-muted); margin: 0 0 16px;">
        {s.totalsLabel(items.length, totalKm, totalHours)}
      </p>

      {items.length === 0 ? (
        <p style="color: var(--w-fg-muted)">{s.emptyState}</p>
      ) : (
        <ul class="workouts-list" style="list-style: none; padding: 0;">
          {items.map((w) => {
            const title = titleById.get(w.id.toLowerCase());
            const name = title?.zh ?? defaultWorkoutTitle(w.start, w.type, 'zh');
            return (
              <li>
                <a href={`/workouts/${w.id}`} class="workout-list-card">
                  <div class="track-mini-wrap">
                    <RouteMini route={routesById.get(w.id) ?? []} bbox={w.bbox} height={60} client:visible />
                  </div>
                  <div>
                    <div class="meta-name">
                      <WorkoutTypeIcon type={w.type} size={14} client:load />
                      <span style="margin-left: 6px;">{name}</span>
                    </div>
                    <div class="meta-sub">
                      {formatRelativeDate(w.start, s.dateLocale)}
                    </div>
                  </div>
                  <div style="text-align: right; font-variant-numeric: tabular-nums;">
                    <div>{formatDistance(w.stats.distanceKm)}</div>
                    <div class="meta-sub">{formatDuration(w.durationSec)}</div>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </main>
  </div>

  <style>
    .masthead { width: 100%; }
    .mast-inner { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
    .mast-top-rule { height: 4px; background: var(--c-text); margin-top: 24px; }
    .mast-bar { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; }
    .mast-brand { font-size: 11px; color: var(--c-text-muted); text-decoration: none; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600; }
    .mast-brand:hover { color: var(--c-text); }
    .mast-links { display: flex; gap: 16px; }
    .mast-links a { font-size: 11px; color: var(--c-text-dim); text-decoration: none; letter-spacing: 0.06em; text-transform: uppercase; }
    .mast-links a:hover { color: var(--c-text); }
    .mast-bottom-rule { height: 1px; background: var(--c-border); }
    .mast-lang-line { display: flex; justify-content: flex-end; padding: 4px 0 8px 0; }
    @media (max-width: 768px) { .mast-inner { padding: 0 20px; } }
  </style>
  <style is:global>
    body:has(.workouts-page) { display: block; padding: 0; align-items: stretch; justify-content: stretch; }
  </style>
</BaseLayout>
