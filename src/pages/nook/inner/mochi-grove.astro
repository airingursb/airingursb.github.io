---
// SHU-733 · Mochi's Grove · 第一个 3D pocket world
// Standalone page that mounts a React island with R3F.
// Entered from 2D Nook grove room via iframe overlay.
import App from '../../../grove3d/App'

const title = 'Airing · in the grove'
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <style is:global>
      html, body, #grove-root {
        margin: 0; padding: 0;
        width: 100vw; height: 100vh;
        overflow: hidden;
        background: #050610;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        color: #d8dee9;
      }
      canvas { display: block; touch-action: none; }
    </style>
  </head>
  <body>
    <div id="grove-root">
      <App client:only="react" />
    </div>
  </body>
</html>
