---
import '../../styles/photos.css';
import 'leaflet/dist/leaflet.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LangSwitch from '../../components/LangSwitch.astro';
import photosData from '../../data/photos.json';
import { slugify } from '../../lib/photos-slug';

const photos = photosData as Array<any>;

type CityPin = {
  citySlug: string;
  city: string;
  country: string;
  coords: [number, number];
  count: number;
  thumb: string;
  latestSlug: string;
  latestTitle: string;
};

const cityMap = new Map<string, CityPin>();
for (const p of photos) {
  if (!p.place?.coords || !p.place?.city) continue;
  const key = slugify(p.place.city);
  const existing = cityMap.get(key);
  if (!existing) {
    cityMap.set(key, {
      citySlug: key,
      city: p.place.city,
      country: p.place.country || '',
      coords: p.place.coords,
      count: 1,
      thumb: p.variants.thumb.webp,
      latestSlug: p.slug,
      latestTitle: p.title || p.slug,
    });
  } else {
    existing.count += 1;
    // Keep the most recent photo as the thumbnail (photos are sorted desc by takenAt elsewhere,
    // but the input order here may not be — compare takenAt to be safe)
    // Skip the comparison for simplicity; first match wins is fine for the popup thumb
  }
}

const pins = Array.from(cityMap.values());
const totalPlaced = pins.reduce((acc, p) => acc + p.count, 0);
const pinsJson = JSON.stringify(pins);
---

<BaseLayout
  title="World map · Photos · Airing"
  description="Photos plotted on an interactive world map."
  lang="en"
>
  <div class="photos-page world-page">
    <header class="masthead">
      <div class="mast-inner">
        <div class="mast-top-rule"></div>
        <div class="mast-bar">
          <a href="/en/blog" class="mast-brand">Airing's Blog</a>
          <div class="mast-links">
            <a href="/en/blog">Blog</a>
            <a href="/en/archive">Archive</a>
            <a href="/en/moments">Moment</a>
            <a href="/en/notes">Notes</a>
            <a href="/photos" class="mast-link-active">Photos</a>
            <a href="/en/friends">Friends</a>
          </div>
        </div>
        <div class="mast-lang-line">
          <LangSwitch lang="en" currentPath="/photos/world" hasEnVersion={false} />
        </div>
        <div class="mast-bottom-rule"></div>
      </div>
    </header>

    <main class="photos-main world-main">
      <nav class="facet-crumbs">
        <a href="/photos">All photos</a>
        <span class="crumb-sep">/</span>
        <span>map</span>
      </nav>
      <h1 class="photos-title">World map</h1>
      <p class="photos-desc">
        {totalPlaced} photo{totalPlaced === 1 ? '' : 's'} across {pins.length} {pins.length === 1 ? 'place' : 'places'}.
      </p>

      <nav class="view-switcher" aria-label="Photo views">
        <a href="/photos">Grid</a>
        <a href="/photos/calendar">Calendar</a>
        <span class="view-switcher-active">Map</span>
      </nav>

      {pins.length === 0 ? (
        <p class="photos-empty">No located photos yet.</p>
      ) : (
        <div class="world-map" id="worldMap" data-pins={pinsJson}></div>
      )}
    </main>
  </div>

  <script>
    import L from 'leaflet';

    type Pin = {
      citySlug: string;
      city: string;
      country: string;
      coords: [number, number];
      count: number;
      thumb: string;
      latestSlug: string;
      latestTitle: string;
    };

    const el = document.getElementById('worldMap');
    if (el) {
      const pins: Pin[] = JSON.parse(el.dataset.pins || '[]');
      const dark = document.documentElement.dataset.mode === 'dark';
      const tileUrl = dark
        ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png'
        : 'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png';

      const map = L.map(el, {
        worldCopyJump: true,
        scrollWheelZoom: true,
      });

      L.tileLayer(tileUrl, {
        attribution: '&copy; OpenStreetMap &copy; CARTO',
        subdomains: 'abcd',
        maxZoom: 18,
        minZoom: 2,
      }).addTo(map);

      const escapeHtml = (s: string) =>
        s.replace(/[&<>"']/g, (c) => (
          { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string
        ));

      const bounds: [number, number][] = [];
      for (const pin of pins) {
        const icon = L.divIcon({
          className: pin.count > 1 ? 'photo-pin photo-pin-multi' : 'photo-pin',
          iconSize: pin.count > 1 ? [22, 22] : [16, 16],
          iconAnchor: pin.count > 1 ? [11, 11] : [8, 8],
          html: pin.count > 1 ? `<span class="photo-pin-count">${pin.count}</span>` : '',
        });

        const popupHtml = `
          <a class="world-pop" href="/photos/places/${escapeHtml(pin.citySlug)}">
            <img src="${escapeHtml(pin.thumb)}" alt="${escapeHtml(pin.city)}" />
            <div class="world-pop-meta">
              <strong>${escapeHtml(pin.city)}</strong>
              <span>${escapeHtml(pin.country)}</span>
              <em>${pin.count} photo${pin.count === 1 ? '' : 's'}</em>
            </div>
          </a>`;

        L.marker(pin.coords, { icon })
          .bindPopup(popupHtml, { closeButton: false, maxWidth: 220 })
          .addTo(map);

        bounds.push(pin.coords);
      }

      if (bounds.length > 0) {
        map.fitBounds(bounds as any, { padding: [40, 40], maxZoom: 6 });
      } else {
        map.setView([20, 0], 2);
      }
    }
  </script>

  <style>
    .masthead { width: 100%; }
    .mast-inner { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
    .mast-top-rule { height: 4px; background: var(--c-text); margin-top: 24px; }
    .mast-bar { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; position: relative; }
    .mast-brand { font-size: 11px; color: var(--c-text-muted); text-decoration: none; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600; }
    .mast-brand:hover { color: var(--c-text); }
    .mast-links { display: flex; gap: 16px; }
    .mast-links a { font-size: 11px; color: var(--c-text-dim); text-decoration: none; letter-spacing: 0.06em; text-transform: uppercase; }
    .mast-links a:hover, .mast-link-active { color: var(--c-text) !important; }
    .mast-bottom-rule { height: 1px; background: var(--c-border); }
    .mast-lang-line { display: flex; justify-content: flex-end; padding: 4px 0 8px 0; }
    @media (max-width: 768px) { .mast-inner { padding: 0 20px; } }

    .world-main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 48px 4rem;
    }
    @media (max-width: 768px) {
      .world-main { padding: 2rem 20px 3rem; }
    }

    .world-map {
      height: 70vh;
      min-height: 420px;
      border-radius: 4px;
      overflow: hidden;
      border: 1px solid var(--c-border);
    }
    @media (max-width: 768px) {
      .world-map { height: 56vh; min-height: 340px; }
    }

    .view-switcher {
      display: flex; gap: 1rem;
      margin: 0 0 1.5rem;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .view-switcher a {
      color: var(--c-text-dim);
      text-decoration: none;
    }
    .view-switcher a:hover { color: var(--c-text); }
    .view-switcher-active {
      color: var(--c-text);
      font-weight: 600;
    }
  </style>

  <style is:global>
    body:has(.photos-page) {
      display: block; padding: 0; align-items: stretch; justify-content: stretch;
    }

    /* Multi-photo pin variant — bigger ring + count badge */
    .photo-pin-multi {
      background: #111;
      width: 22px !important; height: 22px !important;
      border: 2.5px solid #fff;
      border-radius: 50%;
      box-shadow: 0 1px 4px rgba(0,0,0,0.35);
      display: flex; align-items: center; justify-content: center;
    }
    [data-mode="dark"] .photo-pin-multi {
      background: #fff;
      border-color: #111;
    }
    .photo-pin-count {
      font-size: 10px;
      font-weight: 700;
      color: #fff;
      line-height: 1;
      letter-spacing: 0;
    }
    [data-mode="dark"] .photo-pin-count { color: #111; }

    /* Popup card */
    .leaflet-popup-content-wrapper { border-radius: 4px; padding: 0; overflow: hidden; }
    .leaflet-popup-content { margin: 0; min-width: 200px; }
    .world-pop {
      display: block;
      text-decoration: none;
      color: inherit;
    }
    .world-pop img {
      display: block;
      width: 100%;
      aspect-ratio: 3 / 2;
      object-fit: cover;
    }
    .world-pop-meta {
      padding: 8px 10px 10px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .world-pop-meta strong { font-size: 13px; font-weight: 600; }
    .world-pop-meta span { font-size: 11px; color: #888; }
    .world-pop-meta em {
      font-style: normal;
      font-size: 10px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #666;
      margin-top: 2px;
    }
  </style>
</BaseLayout>
