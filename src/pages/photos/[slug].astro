---
import '../../styles/photos.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LangSwitch from '../../components/LangSwitch.astro';
import { siteStrings } from '../../lib/i18n';
import photosData from '../../data/photos.json';

export async function getStaticPaths() {
  const photos = photosData as Array<any>;
  return photos.map((p, i) => ({
    params: { slug: p.slug },
    props: {
      photo: p,
      prev: photos[i - 1] || null,
      next: photos[i + 1] || null,
      others: photos.filter((_, j) => j !== i),
    },
  }));
}

const { photo, prev, next, others = [] } = Astro.props as any;
const s = siteStrings.en.photos;

// Sambecker-style date: "06 JUL 24 3:01PM"
function formatTakenAt(iso: string | null): string {
  if (!iso) return '';
  const d = new Date(iso);
  if (isNaN(d.getTime())) return '';
  const months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  const day = String(d.getDate()).padStart(2, '0');
  const month = months[d.getMonth()];
  const year = String(d.getFullYear()).slice(-2);
  let h = d.getHours();
  const ampm = h >= 12 ? 'PM' : 'AM';
  h = h % 12 || 12;
  const min = String(d.getMinutes()).padStart(2, '0');
  return `${day} ${month} ${year} ${h}:${min}${ampm}`;
}

const takenAtFormatted = formatTakenAt(photo.takenAt);
---

<BaseLayout
  title={`${photo.title || photo.slug} · ${s.title} · Airing`}
  description={photo.description || s.desc}
  lang="en"
>
  <div class="photo-detail-page">
    <header class="masthead">
      <div class="mast-inner">
        <div class="mast-top-rule"></div>
        <div class="mast-bar">
          <a href="/en/blog" class="mast-brand">Airing's Blog</a>
          <div class="mast-links">
            <a href="/en/blog" class="mast-hide-mobile">Blog</a>
            <a href="/en/archive" class="mast-hide-mobile">Archive</a>
            <a href="/en/moments">Moment</a>
            <a href="/en/notes">Notes</a>
            <a href="/photos" class="mast-link-active">Photos</a>
            <a href="/en/friends">Friends</a>
          </div>
        </div>
        <div class="mast-lang-line">
          <LangSwitch lang="en" currentPath={`/photos/${photo.slug}`} hasEnVersion={false} />
        </div>
        <div class="mast-bottom-rule"></div>
      </div>
    </header>

    <nav class="detail-bar">
      <div class="detail-icons">
        <a href="/photos" class="detail-icon" aria-label="All photos" title="Back to grid">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="1.5" y="1.5" width="5" height="5" /><rect x="9.5" y="1.5" width="5" height="5" />
            <rect x="1.5" y="9.5" width="5" height="5" /><rect x="9.5" y="9.5" width="5" height="5" />
          </svg>
        </a>
        <button type="button" class="detail-icon" id="fullscreenBtn" aria-label="Fullscreen" title="Fullscreen">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M1.5 5.5V1.5H5.5M14.5 5.5V1.5H10.5M1.5 10.5V14.5H5.5M14.5 10.5V14.5H10.5" stroke-linecap="round" />
          </svg>
        </button>
      </div>
      <div class="detail-nav">
        {prev
          ? <a href={`/photos/${prev.slug}`} aria-label="Previous photo" class="detail-arrow">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M10 3 L5 8 L10 13" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          : <span class="detail-arrow disabled" aria-disabled="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M10 3 L5 8 L10 13" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>}
        {next
          ? <a href={`/photos/${next.slug}`} aria-label="Next photo" class="detail-arrow">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M6 3 L11 8 L6 13" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          : <span class="detail-arrow disabled" aria-disabled="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M6 3 L11 8 L6 13" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>}
      </div>
    </nav>

    <div class="detail-layout">
      <div class="detail-stage" id="stageEl">
        <picture>
          <source type="image/avif" srcset={photo.variants.full.avif} />
          <source type="image/webp" srcset={photo.variants.full.webp} />
          <img
            src={photo.variants.full.webp}
            alt={photo.title || photo.slug}
            width={photo.width}
            height={photo.height}
            loading="eager"
            decoding="async"
          />
        </picture>
      </div>

      <aside class="detail-info">
        {photo.title && <h1>{photo.title}</h1>}
        {photo.description && <p class="detail-desc">{photo.description}</p>}

        <div class="detail-meta">
          <div class="meta-camera">
            {photo.exif.camera && (
              <div class="meta-row">
                <svg class="meta-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3">
                  <rect x="1.5" y="4.5" width="13" height="9" rx="1" />
                  <circle cx="8" cy="9" r="2.5" />
                  <path d="M5 4.5 V3 H11 V4.5" />
                </svg>
                <span>{photo.exif.camera}</span>
              </div>
            )}
            {photo.exif.lens && (
              <div class="meta-row">
                <svg class="meta-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3">
                  <circle cx="8" cy="8" r="6" />
                  <circle cx="8" cy="8" r="2.5" fill="currentColor" />
                </svg>
                <span>{photo.exif.lens}</span>
              </div>
            )}
          </div>

          <div class="meta-params">
            {photo.exif.focalLength && <div>{photo.exif.focalLength}</div>}
            {photo.exif.aperture && <div><i>ƒ</i>{photo.exif.aperture.replace(/^f/i, '')}</div>}
            {photo.exif.shutter && <div>{photo.exif.shutter}</div>}
            {photo.exif.iso != null && <div>ISO {photo.exif.iso}</div>}
          </div>
        </div>

        <div class="detail-meta-foot">
          {takenAtFormatted && <span class="meta-date">{takenAtFormatted}</span>}
          <span class="meta-dim">{photo.width} × {photo.height}</span>
        </div>

        {photo.tags && photo.tags.length > 0 && (
          <div class="detail-tags">
            {photo.tags.map((t: string) => <span class="detail-tag">#{t}</span>)}
          </div>
        )}
      </aside>

      {others.length > 0 && (
        <section class="detail-others">
          <ul class="photos-grid">
            {others.map((p: any) => (
              <li class="photo-card" style={`--dom: ${p.dominantColor}`}>
                <a href={`/photos/${p.slug}`} class="photo-link" aria-label={p.title || p.slug}>
                  <picture>
                    <source
                      type="image/avif"
                      srcset={`${p.variants.thumb.avif} 400w, ${p.variants.medium.avif} 1200w`}
                      sizes="(max-width: 768px) 50vw, (max-width: 1280px) 33vw, 25vw"
                    />
                    <source
                      type="image/webp"
                      srcset={`${p.variants.thumb.webp} 400w, ${p.variants.medium.webp} 1200w`}
                      sizes="(max-width: 768px) 50vw, (max-width: 1280px) 33vw, 25vw"
                    />
                    <img
                      src={p.variants.medium.webp}
                      alt={p.title || p.slug}
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  </div>

  <script is:inline>
    (function () {
      var btn = document.getElementById('fullscreenBtn');
      var stage = document.getElementById('stageEl');
      if (!btn || !stage) return;
      btn.addEventListener('click', function () {
        if (document.fullscreenElement) {
          document.exitFullscreen();
        } else if (stage.requestFullscreen) {
          stage.requestFullscreen();
        }
      });
    })();
  </script>

  <style>
    .masthead { width: 100%; }
    .mast-inner { /* outer .photo-detail-page provides max-width + padding */ }
    .mast-top-rule { height: 4px; background: var(--c-text); margin-top: 24px; }
    .mast-bar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 14px 0; position: relative;
    }
    .mast-brand {
      font-size: 11px; color: var(--c-text-muted); text-decoration: none;
      letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
    }
    .mast-brand:hover { color: var(--c-text); }
    .mast-links { display: flex; gap: 16px; }
    .mast-links a {
      font-size: 11px; color: var(--c-text-dim); text-decoration: none;
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .mast-links a:hover, .mast-link-active { color: var(--c-text) !important; }
    .mast-bottom-rule { height: 1px; background: var(--c-border); }
    .mast-lang-line {
      display: flex;
      justify-content: flex-end;
      padding: 4px 0 8px 0;
    }

    @media (max-width: 640px) {
      .mast-hide-mobile { display: none; }
    }
  </style>
</BaseLayout>
