  <!-- "New" badge injection for posts/notes within last 14 days -->
  <script is:inline>
    (function () {
      var WINDOW_DAYS = 14;
      // Animated NEW badge — gradient text with SMIL color cycling
      // (pink → purple → cyan, 3s loop). Source asset:
      // https://github.com/airingursb/airingursb/blob/master/assets/new-badge.svg
      var BADGE_SVG = ''
        + '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="10" viewBox="0 0 22 10" aria-hidden="true">'
        +   '<defs>'
        +     '<linearGradient id="g-newbadge" x1="0%" y1="0%" x2="100%" y2="0%">'
        +       '<stop offset="0%" stop-color="#FF0080">'
        +         '<animate attributeName="stop-color" values="#FF0080;#7928CA;#00D4FF;#7928CA;#FF0080" dur="3s" repeatCount="indefinite"/>'
        +       '</stop>'
        +       '<stop offset="100%" stop-color="#7928CA">'
        +         '<animate attributeName="stop-color" values="#7928CA;#00D4FF;#FF0080;#00D4FF;#7928CA" dur="3s" repeatCount="indefinite"/>'
        +       '</stop>'
        +     '</linearGradient>'
        +   '</defs>'
        +   '<text x="0" y="8" font-family="-apple-system,BlinkMacSystemFont,&apos;Segoe UI&apos;,Roboto,Helvetica,Arial,sans-serif" font-size="9" font-weight="700" fill="url(#g-newbadge)" letter-spacing="0.4">NEW</text>'
        + '</svg>';
      function parseDate(text) {
        if (!text) return null;
        var m = text.trim().match(/^(\d{4})\.(\d{1,2})\.(\d{1,2})/);
        if (!m) return null;
        return new Date(parseInt(m[1], 10), parseInt(m[2], 10) - 1, parseInt(m[3], 10));
      }
      function tag() {
        var now = new Date();
        var cutoff = now.getTime() - WINDOW_DAYS * 86400000;
        var items = document.querySelectorAll('.card-posts .post-item, .card-notes .post-item');
        items.forEach(function (el) {
          var dateEl = el.querySelector('.post-date');
          var titleEl = el.querySelector('.post-title');
          if (!dateEl || !titleEl) return;
          var d = parseDate(dateEl.textContent);
          if (!d) return;
          var existing = titleEl.querySelector('.new-badge');
          var isNew = d.getTime() >= cutoff && d.getTime() <= now.getTime();
          if (isNew && !existing) {
            var span = document.createElement('span');
            span.className = 'new-badge';
            span.setAttribute('aria-label', 'new');
            span.innerHTML = BADGE_SVG;
            titleEl.insertBefore(span, titleEl.firstChild);
          } else if (!isNew && existing) {
            existing.remove();
          }
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', tag);
      } else {
        tag();
      }
      window.addEventListener('langchange', tag);
    })();
  </script>

  <!-- Easter egg hint pill (only set on homepage when today maps to a holiday) -->
  <button type="button" class="easter-hint" id="easterHint" hidden>
    <span class="easter-hint-dot"></span>
    <span class="easter-hint-name"></span>
  </button>
  <script is:inline>
    (function () {
      var hit = window.__easterEggTheme;
      if (!hit) return;
      var hint = document.getElementById('easterHint');
      if (!hint) return;
      var nameEl = hint.querySelector('.easter-hint-name');
      var dateKey = window.__easterEggDateKey;
      var SS_KEY = 'easter-dismissed:' + dateKey;

      function renderLabel() {
        var lang = (window.currentLang) || localStorage.getItem('preferred_lang') || 'zh';
        nameEl.textContent = (lang === 'en' && hit.en) ? hit.en : hit.zh;
        hint.setAttribute('aria-label', nameEl.textContent + ' — ' + (lang === 'en' ? 'tap to dim' : '点一下熄灭'));
      }

      function setLit(lit) {
        if (lit) {
          document.documentElement.setAttribute('data-theme', hit.theme);
          hint.classList.remove('dimmed');
          sessionStorage.removeItem(SS_KEY);
        } else {
          document.documentElement.removeAttribute('data-theme');
          hint.classList.add('dimmed');
          sessionStorage.setItem(SS_KEY, '1');
        }
      }

      renderLabel();
      if (sessionStorage.getItem(SS_KEY)) hint.classList.add('dimmed');
      hint.removeAttribute('hidden');
      requestAnimationFrame(function () { hint.classList.add('visible'); });
      hint.addEventListener('click', function () {
        setLit(hint.classList.contains('dimmed'));
      });
      window.addEventListener('langchange', renderLabel);
    })();
  </script>
  <style>
    .easter-hint {
      position: fixed;
      bottom: 24px;
      right: 72px;
      z-index: 9999;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(var(--accent-rgb), 0.10);
      border: 1px solid rgba(var(--accent-rgb), 0.35);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      color: var(--accent);
      font: 500 12px/1 inherit;
      letter-spacing: 0.02em;
      cursor: pointer;
      user-select: none;
      opacity: 0;
      transform: translateX(8px);
      transition: opacity 0.4s ease, transform 0.4s ease, background 0.25s, border-color 0.25s, color 0.25s;
    }
    .easter-hint:hover {
      filter: brightness(1.15);
    }
    .easter-hint.visible {
      opacity: 1;
      transform: translateX(0);
    }
    .easter-hint-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      animation: easter-pulse 2s ease-in-out infinite;
      transition: background 0.25s;
    }
    @keyframes easter-pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(var(--accent-rgb), 0.5); }
      50%      { box-shadow: 0 0 0 6px rgba(var(--accent-rgb), 0); }
    }
    .easter-hint.dimmed {
      background: rgba(125, 133, 144, 0.06);
      border-color: rgba(125, 133, 144, 0.25);
      color: #7d8590;
    }
    .easter-hint.dimmed .easter-hint-dot {
      background: #7d8590;
      animation: none;
      box-shadow: none;
    }
    @media (max-width: 480px) {
      .easter-hint { display: none; }
    }
  </style>
