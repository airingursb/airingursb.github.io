      const FRAME_BLINK = FRAME_NORMAL.map(function (row, i) {
        return i === 4 ? [1,2,2,4,4,2,2,2,4,4,2,2,1] : row;
      });

      const FRAME_LOOK_LEFT = FRAME_NORMAL.map(function (row, i) {
        return i === 4 ? [1,2,4,2,2,2,2,2,4,2,2,2,1] : row;
      });

      const FRAME_LOOK_RIGHT = FRAME_NORMAL.map(function (row, i) {
        return i === 4 ? [1,2,2,2,4,2,2,2,2,2,4,2,1] : row;
      });

      const FRAME_LOOK_UP = FRAME_NORMAL.map(function (row, i) {
        if (i === 3) return [1,2,2,4,2,2,2,2,2,4,2,2,1];
        if (i === 4) return [1,2,2,2,2,2,2,2,2,2,2,2,1];
