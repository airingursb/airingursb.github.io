      <script is:inline>
      // ── Raindrop Bookmarks ──
      (function() {
        var data = window.__RAINDROP_DATA__;
        if (!data || !data.bookmarks || !data.bookmarks.length) return;

        var list = document.getElementById('raindropList');
        var items = data.bookmarks.slice(0, 6);

        items.forEach(function(b) {
          var a = document.createElement('a');
          a.className = 'rd-item';
          a.href = b.link;
          a.target = '_blank';
          a.rel = 'noopener';

          var titleDiv = document.createElement('div');
          titleDiv.className = 'rd-item-title';
          titleDiv.textContent = b.title;
          a.appendChild(titleDiv);

          var noteText = b.note || b.excerpt || '';
          if (noteText) {
            var noteDiv = document.createElement('div');
            noteDiv.className = 'rd-item-note';
            noteDiv.textContent = noteText;
            a.appendChild(noteDiv);
          }

          var metaDiv = document.createElement('div');
          metaDiv.className = 'rd-item-meta';

          var domain = document.createElement('span');
          domain.className = 'rd-item-domain';
          domain.textContent = b.domain;
          metaDiv.appendChild(domain);

          var date = document.createElement('span');
          date.className = 'rd-item-date';
          var parts = b.created.split('.');
          if (parts.length === 3) {
            var bDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
            var daysAgo = Math.floor((Date.now() - bDate.getTime()) / 86400000);
            date.textContent = b.created + ' \u00b7 ' + daysAgo + 'd ago';
          } else {
            date.textContent = b.created;
          }
          metaDiv.appendChild(date);

          a.appendChild(metaDiv);
          list.appendChild(a);
        });
      })();
      </script>

