            .addTo(map)
            .bindPopup('<b>' + city.name + '</b><br><span style="color: ' + currentColor + ';">📍 Current Location</span>');
        } else {
          // Div marker for visited cities (divIcon renders at any viewport position)
          var dotIcon = L.divIcon({
            className: 'visited-marker',
            html: '<div style="width:10px;height:10px;background:' + visitedColor + ';border-radius:50%;opacity:0.8;"></div>',
            iconSize: [10, 10],
            iconAnchor: [5, 5],
            popupAnchor: [0, -5]
          });
          L.marker([city.lat, city.lng], { icon: dotIcon })
            .addTo(map)
            .bindPopup('<b>' + city.name + '</b>');
        }
      });

    })();

    // ── Pixel Weather ──
    (function () {
      var wCanvas = document.getElementById('weatherIcon');
      var wCtx = wCanvas.getContext('2d');
      var badge = document.getElementById('weatherLine');
      var tempEl = document.getElementById('weatherTemp');
      var descEl = document.getElementById('weatherDesc');

      var SUN = '#FFD93D';
      var CLOUD_L = '#8899aa';
      var CLOUD_D = '#667788';
      var RAIN = '#5BC0EB';
      var BOLT = '#FFD93D';

      function px(x, y, color) {
        wCtx.fillStyle = color;
        wCtx.fillRect(x, y, 1, 1);
      }

      function drawIcon(type) {
        wCtx.clearRect(0, 0, 16, 16);

        if (type === 'sunny') {
          px(7,1,SUN); px(8,1,SUN);
          px(3,3,SUN); px(12,3,SUN);
          px(4,4,SUN); px(11,4,SUN);
          px(1,7,SUN); px(2,7,SUN); px(13,7,SUN); px(14,7,SUN);
          px(1,8,SUN); px(2,8,SUN); px(13,8,SUN); px(14,8,SUN);
          px(4,11,SUN); px(11,11,SUN);
          px(3,12,SUN); px(12,12,SUN);
          px(7,14,SUN); px(8,14,SUN);
          for (var y = 5; y <= 10; y++)
            for (var x = 5; x <= 10; x++) {
              if ((y===5||y===10)&&(x===5||x===10)) continue;
              px(x, y, SUN);
            }
        }

        if (type === 'cloudy') {
          px(5,4,CLOUD_L); px(6,4,CLOUD_L); px(7,4,CLOUD_L);
          px(4,5,CLOUD_L); px(5,5,CLOUD_L); px(6,5,CLOUD_L); px(7,5,CLOUD_L); px(8,5,CLOUD_L);
          for (var x2=3; x2<=10; x2++) px(x2,6,CLOUD_L);
          for (var x3=2; x3<=11; x3++) px(x3,7,CLOUD_L);
          for (var x4=2; x4<=11; x4++) px(x4,8,CLOUD_D);
          for (var x5=3; x5<=10; x5++) px(x5,9,CLOUD_D);
        }

        if (type === 'rainy') {
          px(4,2,CLOUD_L); px(5,2,CLOUD_L); px(6,2,CLOUD_L); px(7,2,CLOUD_L);
          for (var x6=3; x6<=9; x6++) px(x6,3,CLOUD_L);
          for (var x7=2; x7<=10; x7++) px(x7,4,CLOUD_L);
          for (var x8=2; x8<=10; x8++) px(x8,5,CLOUD_D);
          px(4,8,RAIN); px(7,7,RAIN); px(10,8,RAIN);
          px(3,10,RAIN); px(6,9,RAIN); px(9,10,RAIN);
          px(5,12,RAIN); px(8,11,RAIN);
        }

        if (type === 'thunder') {
          px(4,1,CLOUD_D); px(5,1,CLOUD_D); px(6,1,CLOUD_D); px(7,1,CLOUD_D);
          for (var x9=3; x9<=9; x9++) px(x9,2,CLOUD_D);
          for (var xa=2; xa<=10; xa++) px(xa,3,CLOUD_D);
          for (var xb=2; xb<=10; xb++) px(xb,4,CLOUD_D);
          px(7,5,BOLT); px(6,6,BOLT); px(7,6,BOLT);
          px(5,7,BOLT); px(6,7,BOLT); px(7,7,BOLT); px(8,7,BOLT);
          px(7,8,BOLT); px(8,8,BOLT);
          px(6,9,BOLT); px(7,9,BOLT);
          px(5,10,BOLT); px(6,10,BOLT);
          px(3,7,RAIN); px(10,8,RAIN);
          px(4,10,RAIN); px(9,11,RAIN);
        }
      }

      // WMO weather code to icon type and description
      function weatherCodeToInfo(code) {
        if (code <= 1) return { type: 'sunny', desc: 'Clear' };
        if (code <= 3) return { type: 'cloudy', desc: 'Cloudy' };
        if (code <= 49) return { type: 'cloudy', desc: 'Foggy' };
        if (code <= 59) return { type: 'rainy', desc: 'Drizzle' };
        if (code <= 69) return { type: 'rainy', desc: 'Rain' };
        if (code <= 79) return { type: 'rainy', desc: 'Snow' };
        if (code <= 84) return { type: 'rainy', desc: 'Showers' };
        if (code <= 94) return { type: 'rainy', desc: 'Snow' };
        return { type: 'thunder', desc: 'Thunderstorm' };
      }

      fetch('https://api.open-meteo.com/v1/forecast?latitude=1.29&longitude=103.85&current_weather=true')
