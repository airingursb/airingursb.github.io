      function showTooltip(pi, e) {
        var period = data.periods[pi];
        tooltipPeriod.textContent = period.label;

        if (!period.tracks || !period.tracks.length) {
          tooltip.classList.remove('visible');
          return;
        }

        var maxCount = period.tracks[0].plays;
        var html = '';
        period.tracks.forEach(function (t, i) {
          var barW = maxCount > 0 ? (t.plays / maxCount * 100) : 0;
          var rankClass = i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : '';
          var color = getColor(t.artist);
          var display = t.artist + ' - ' + t.name;

          html += '<div class="music-tooltip-wrap">' +
            '<div class="music-tooltip-item">' +
            '<span class="music-tooltip-rank ' + rankClass + '">' + (i + 1) + '</span>' +
            '<span class="music-tooltip-name">' + display + '</span>' +
            '<span class="music-tooltip-count">' + t.plays + '</span>' +
            '</div>' +
            '<div class="music-tooltip-minibar" style="width:' + barW + '%;background:' + color + ';opacity:0.4"></div>' +
            '</div>';
