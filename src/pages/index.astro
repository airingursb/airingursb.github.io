        tooltipList.innerHTML = html;
        positionTooltip(e);
        tooltip.classList.add('visible');
      }

      function positionTooltip(e) {
        var pw = 280;
        var ph = tooltip.offsetHeight || 300;
        var x = e.clientX + 16;
        var y = e.clientY - ph / 2;

        if (x + pw > window.innerWidth - 12) {
          x = e.clientX - pw - 16;
        }
        if (y < 12) y = 12;
        if (y + ph > window.innerHeight - 12) {
          y = window.innerHeight - ph - 12;
