---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import photosData from '../data/photos.json';
import '../styles/workouts.css';
import WorkoutCardPreview from '../components/workouts/WorkoutCardPreview.astro';
import { FIXED_DATES, FLOATING_DATES } from '../lib/easter-egg-themes';
import { fetchComics } from '../lib/comics';
import { FootprintsMap } from '../components/footprints/FootprintsMap';
import { cities as footprintCities } from '../data/footprints';

const recentPhotos = (photosData as Array<any>)
  .slice()
  .sort((a, b) => new Date(b.takenAt).getTime() - new Date(a.takenAt).getTime())
  .slice(0, 12);

const allComics = await fetchComics();
const latestComic = allComics[0];
const formatComicDate = (s: string, locale: 'zh' | 'en') =>
  new Date(s).toLocaleDateString(locale === 'zh' ? 'zh-CN' : 'en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  });

// Footer "data updated on …" — was a hardcoded i18n string that never moved.
// Read the most recent mtime in src/data/ (everything in there is generated
// by scripts/update_feed.py + collect_local_data.py, so newest mtime IS the
// last data refresh).
const dataDir = path.resolve('./src/data');
let latestDataMs = 0;
try {
  for (const f of fs.readdirSync(dataDir)) {
    const stat = fs.statSync(path.join(dataDir, f));
    if (stat.mtimeMs > latestDataMs) latestDataMs = stat.mtimeMs;
  }
} catch {}
const dataUpdatedDate = latestDataMs ? new Date(latestDataMs) : new Date();
const dataUpdatedZh = `${dataUpdatedDate.getFullYear()} 年 ${dataUpdatedDate.getMonth() + 1} 月 ${dataUpdatedDate.getDate()} 日`;
const dataUpdatedEn = dataUpdatedDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<BaseLayout title="Hi, folks | Airing">
  <Fragment slot="head">
    <script is:inline define:vars={{ FIXED_DATES, FLOATING_DATES }}>
      // Homepage easter egg: pick an accent color based on today's holiday.
      // Runs before <slot name="head"> closes, so data-theme is set before paint.
      // Preview any day with ?eggDate=YYYY-MM-DD.
      (function () {
        var d = new Date();
        var override = new URLSearchParams(location.search).get('eggDate');
        if (override) {
          var t = new Date(override + 'T12:00:00');
          if (!isNaN(t)) d = t;
        }
        var y = d.getFullYear();
        var m = String(d.getMonth() + 1).padStart(2, '0');
        var dy = String(d.getDate()).padStart(2, '0');
        var dateKey = y + '-' + m + '-' + dy;
        var hit = FLOATING_DATES[dateKey] || FIXED_DATES[m + '-' + dy];
        if (hit) {
          window.__easterEggTheme = hit;
          window.__easterEggDateKey = dateKey;
          if (!sessionStorage.getItem('easter-dismissed:' + dateKey)) {
            document.documentElement.setAttribute('data-theme', hit.theme);
          }
        }
      })();
    </script>
  </Fragment>
  <style is:global>
    /* ===== Cyber Glitch Effects (homepage only) ===== */
    /* Spec: docs/superpowers/specs/2026-05-06-cyber-glitch-effects-design.md */

    body.fx-rgb { will-change: transform, filter; }

    /* RGB chromatic aberration. JS sets --rx / --cx / --c-r / --c-c per frame. */
    body.fx-rgb .greeting,
    body.fx-rgb .name,
    body.fx-rgb .role,
    body.fx-rgb .chat-prompt,
    body.fx-rgb .chat-input,
    body.fx-rgb .fake-cursor,
    body.fx-rgb .chat-suggestion-chip,
    body.fx-rgb .chat-area,
    body.fx-rgb .chat-error,
    body.fx-rgb .links a,
    body.fx-rgb .sep,
    body.fx-rgb .section-title,
    body.fx-rgb .gh-name,
    body.fx-rgb .gh-bio,
    body.fx-rgb .gh-stat-val,
    body.fx-rgb .gh-stat-label,
    body.fx-rgb .mf-tagline,
    body.fx-rgb .mf-desc,
    body.fx-rgb .mf-feature,
    body.fx-rgb .mf-tag,
    body.fx-rgb .mf-link,
    body.fx-rgb .mf-link-appstore,
    body.fx-rgb .post-title,
    body.fx-rgb .post-date,
    body.fx-rgb .weather-line,
    body.fx-rgb .np-corner-track,
    body.fx-rgb .np-corner-artist,
    body.fx-rgb .np-corner-now,
    body.fx-rgb .np-corner-label,
    body.fx-rgb .online-line {
      text-shadow:
        var(--rx, 0) 0 var(--c-r, transparent),
        var(--cx, 0) 0 var(--c-c, transparent);
    }

    .fx-band {
      position: fixed;
      left: 0;
      right: 0;
      height: 14px;
      pointer-events: none;
      z-index: 9999;
      background: linear-gradient(180deg,
        transparent,
        rgba(0, 220, 255, 0.07) 35%,
        rgba(255, 0, 110, 0.07) 65%,
        transparent);
      mix-blend-mode: screen;
    }

    .fx-scan {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9998;
      background: repeating-linear-gradient(0deg,
        transparent 0 5px,
        rgba(255, 0, 110, 0.035) 5px 6px);
    }

    [data-glitch-flash] { position: relative; }
    [data-glitch-flash]::after {
      content: '';
      position: absolute;
      left: -4px; right: -4px; top: -2px; bottom: -2px;
      background: rgba(var(--accent-rgb), 0.10);
      pointer-events: none;
      opacity: 0;
      border-radius: 2px;
      transition: opacity 0.4s;
    }
    [data-glitch-flash][data-glitch-flashing]::after {
      opacity: 1;
      transition: opacity 0.05s;
    }
  </style>

  <div class="lang-toggle" id="langToggle">
    <button data-lang="en" class="active">EN</button>
    <button data-lang="zh">CN</button>
  </div>
  <script is:inline>
  // ── i18n ──
  (function() {
    var LANG_KEY = 'preferred_lang';
    var translations = { en: {}, zh: {} };

    function detectLang() {
      var saved = localStorage.getItem(LANG_KEY);
      if (saved === 'en' || saved === 'zh') return saved;
      var nav = (navigator.language || navigator.userLanguage || 'en').toLowerCase();
      return nav.startsWith('zh') ? 'zh' : 'en';
    }

    var currentLang = detectLang();

    window.t = function(key) {
      var dict = translations[currentLang] || translations.en;
      return dict[key] !== undefined ? dict[key] : (translations.en[key] !== undefined ? translations.en[key] : key);
    };

    window.currentLang = currentLang;

    // Load translations from external JSON files
    function loadTranslations() {
      return Promise.all([
        fetch('/i18n/en.json').then(function(r) { return r.json(); }),
        fetch('/i18n/zh.json').then(function(r) { return r.json(); })
      ]).then(function(results) {
        translations.en = results[0];
        translations.zh = results[1];
      });
    }

    window._i18nReady = loadTranslations();

    function applyTranslations() {
      var currentLang = (document.documentElement.lang || 'zh').toLowerCase().startsWith('en') ? 'en' : 'zh';
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n');
        var val = t(key);
        // {date} placeholder — current users: data_updated. Element provides
        // both languages via data-date-zh / data-date-en so we can swap on
        // lang change without rebuilding.
        if (val.indexOf('{date}') !== -1) {
          var d = el.getAttribute('data-date-' + currentLang) || el.getAttribute('data-date-zh') || '';
          val = val.replace('{date}', d);
        }
        if (key === 'letter_paid_desc' || key === 'chat_limit') {
          el.innerHTML = val;
        } else {
          el.textContent = val;
        }
      });

      var chatInput = document.getElementById('chatInput');
      if (chatInput) chatInput.placeholder = t('chat_placeholder');

      var gbName = document.getElementById('gbName');
      if (gbName) gbName.placeholder = t('gb_anonymous');

      var gbMsg = document.getElementById('gbMessage');
      if (gbMsg) gbMsg.placeholder = t('gb_msg_placeholder');

      var gbEmail = document.getElementById('gbEmail');
      if (gbEmail) gbEmail.placeholder = t('gb_email_placeholder');

      document.documentElement.lang = currentLang === 'zh' ? 'zh-CN' : 'en';

      // Rewrite language-aware links so EN labels go to /en/* routes
      document.querySelectorAll('[data-href-zh][data-href-en]').forEach(function(el) {
        var href = el.getAttribute(currentLang === 'zh' ? 'data-href-zh' : 'data-href-en');
        if (href) el.setAttribute('href', href);
      });

      // Toggle bilingual cards (posts + notes) by language
      ['posts', 'notes'].forEach(function(cardId) {
        var card = document.getElementById(cardId);
        if (!card) return;
        var zhItems = card.querySelectorAll('.post-item-zh');
        var enItems = card.querySelectorAll('.post-item-en');
        if (enItems.length > 0) {
          zhItems.forEach(function(el) { el.style.display = currentLang === 'zh' ? '' : 'none'; });
          enItems.forEach(function(el) { el.style.display = currentLang === 'en' ? '' : 'none'; });
        }
      });

      // Toggle comics card titles by language
      var comicsCard = document.getElementById('comics-card');
      if (comicsCard) {
        comicsCard.querySelectorAll('.comics-strip-title-zh').forEach(function(el) {
          el.style.display = currentLang === 'zh' ? '' : 'none';
        });
        comicsCard.querySelectorAll('.comics-strip-title-en').forEach(function(el) {
          el.style.display = currentLang === 'en' ? '' : 'none';
        });
      }
    }

    window.switchLang = function(lang) {
      currentLang = lang;
      window.currentLang = lang;
      localStorage.setItem(LANG_KEY, lang);
      applyTranslations();
      if (typeof umami !== 'undefined') {
        umami.track('lang-switch', { lang: lang });
        umami.identify({ language: lang });
      }

      document.querySelectorAll('#langToggle button').forEach(function(btn) {
        btn.classList.toggle('active', btn.getAttribute('data-lang') === lang);
      });

      window.dispatchEvent(new CustomEvent('langchange', { detail: { lang: lang } }));
    };

    function onReady() {
      window._i18nReady.then(function() {
        applyTranslations();
        initToggle();
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', onReady);
    } else {
      onReady();
    }

    function initToggle() {
      var toggle = document.getElementById('langToggle');
      if (!toggle) return;

      toggle.querySelectorAll('button').forEach(function(btn) {
        btn.classList.toggle('active', btn.getAttribute('data-lang') === currentLang);
      });

      toggle.addEventListener('click', function(e) {
        var btn = e.target.closest('button[data-lang]');
        if (!btn) return;
        switchLang(btn.getAttribute('data-lang'));
      });
    }
  })();
  </script>
  <script is:inline>
  // ── Block scramble (faithful port of anime.js v4 scrambleText, no dep) ──
  // Source: https://esm.sh/animejs@4.4.1/.../text/scramble.mjs
  // Each char gets a per-position start/end time (with perturbation jitter),
  // a "cursor density" settle phase (█→▓→▒→░), and ~30Hz scramble updates.
  (function() {
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // Full block range ▀-▟ for random scramble pool
    var POOL = '';
    for (var b = 0x2580; b <= 0x259F; b++) POOL += String.fromCharCode(b);
    var POOL_MAX = POOL.length - 1;
    // Cursor (settle) gradient — light to full block, played in reverse: █→▓→▒→░
    var CURSOR = '░▒▓█'; // ░▒▓█
    var CURSOR_LEN = CURSOR.length;
    var SETTLE_RATE = 30; // scramble char update Hz

    function rint(min, max) { return min + Math.floor(Math.random() * (max - min + 1)); }

    function scramble(el, text, opts) {
      if (!el || text == null) return;
      if (reduce) { el.textContent = text; return; }
      if (el.__scrambleId) cancelAnimationFrame(el.__scrambleId);

      opts = opts || {};
      var from = opts.from || 'random';
      var duration = opts.duration || 780;
      var perturbation = opts.perturbation != null ? opts.perturbation : 0.22;
      var settleDuration = opts.settleDuration || 220;

      var n = text.length;
      if (n === 0) { el.textContent = ''; return; }

      // Reveal order: u[c] = rank slot for char c (0..n-1)
      var u = new Array(n);
      if (from === 'random') {
        for (var i = 0; i < n; i++) u[i] = i;
        for (var i = n - 1; i > 0; i--) {
          var j = rint(0, i);
          var tmp = u[i]; u[i] = u[j]; u[j] = tmp;
        }
      } else {
        var anchor = from === 'right' ? n - 1
                   : from === 'center' ? (n - 1) / 2
                   : 0;
        var pos = [];
        for (var i = 0; i < n; i++) pos.push(i);
        pos.sort(function(a, b) { return Math.abs(a - anchor) - Math.abs(b - anchor); });
        for (var i = 0; i < n; i++) u[pos[i]] = i;
      }

      var H = settleDuration / duration;     // settle phase fraction
      var J = (1 - H) / n;                   // per-char step fraction
      var Ct = CURSOR_LEN * J;               // cursor pass duration per char (in 0..1)
      var K = 1000 / (SETTLE_RATE * duration);
      if (!isFinite(K) || K <= 0) K = 0.001;

      var N = new Float32Array(n); // start time per char (0..1 progress)
      var X = new Float32Array(n); // end time per char
      var Z = perturbation * H;
      for (var i = 0; i < n; i++) {
        var jit1 = Z > 0 ? (rint(0, 2000) - 1000) / 1000 * Z : 0;
        var jit2 = Z > 0 ? (rint(0, 2000) - 1000) / 1000 * Z : 0;
        N[i] = u[i] * J + jit1;
        X[i] = Math.ceil((N[i] + H + jit2) / K) * K;
      }

      var L = new Array(n);
      for (var i = 0; i < n; i++) L[i] = POOL.charAt(rint(0, POOL_MAX));

      // Pre-render initial scrambled state so first paint isn't original text
      var initial = '';
      for (var c = 0; c < n; c++) {
        var ch = text.charAt(c);
        initial += (ch === ' ' ? ' ' : L[c]);
      }
      el.textContent = initial;

      var startTime = performance.now();
      var lastR = -1;

      function tick(now) {
        var t = (now - startTime) / duration;
        if (t >= 1) {
          el.textContent = text;
          el.__scrambleId = 0;
          return;
        }
        var r = (t / K) | 0;
        var aChanged = r !== lastR;
        if (aChanged) lastR = r;
        var l = t; // linear ease

        var s = '';
        for (var c = 0; c < n; c++) {
          var ch = text.charAt(c);
          var cs = N[c], ce = X[c];

          if (l >= ce) { s += ch; continue; }
          if (ch === ' ') { s += ' '; continue; }

          if (l < cs) {
            // before this char's window: continue scramble at K-rate
            if (aChanged) L[c] = POOL.charAt(rint(0, POOL_MAX));
            s += L[c];
            continue;
          }
          // in [cs, ce): cursor settle then optional scramble tail
          var dt = l - cs;
          if (dt < Ct) {
            var idx = (dt / J) | 0;
            if (idx >= CURSOR_LEN) idx = CURSOR_LEN - 1;
            s += CURSOR.charAt(CURSOR_LEN - 1 - idx); // █→▓→▒→░
          } else {
            if (aChanged) L[c] = POOL.charAt(rint(0, POOL_MAX));
            s += L[c];
          }
        }
        el.textContent = s;
        el.__scrambleId = requestAnimationFrame(tick);
      }
      el.__scrambleId = requestAnimationFrame(tick);
    }

    function txt(el) { return el ? (el.textContent || '').trim() : ''; }

    // Scramble while preserving inner HTML structure (e.g. .online-dot span).
    function scrambleEl(el, opts) {
      if (!el || reduce) return;
      opts = opts || {};
      var text = txt(el);
      if (!text) return;
      if (opts.preserveHTML) {
        var originalHTML = el.innerHTML;
        el.textContent = text;
        scramble(el, text, opts);
        var d = (opts.duration || 780) + 60;
        setTimeout(function() {
          if (!el.__scrambleId && txt(el) === text) el.innerHTML = originalHTML;
        }, d);
      } else {
        scramble(el, text, opts);
      }
    }

    // Watch an element for its first non-empty text fill, then scramble once.
    function watchFirstFill(el, opts) {
      if (!el || reduce) return;
      if (txt(el)) { scrambleEl(el, opts); return; }
      var obs = new MutationObserver(function() {
        if (txt(el)) {
          obs.disconnect();
          scrambleEl(el, opts);
        }
      });
      obs.observe(el, { childList: true, characterData: true, subtree: true });
    }

    function getEls() {
      return {
        greeting: document.querySelector('.card-intro .greeting'),
        name: document.querySelector('.card-intro .name'),
        role: document.querySelector('.card-intro .role')
      };
    }

    // Match the reference page's "DECRYPT" payload tempo:
    //   top    → from:left,   duration:680
    //   subtitle → from:center, duration:900
    //   bottom → from:right,  duration:760
    function playIntro() {
      var els = getEls();
      if (els.greeting) scramble(els.greeting, txt(els.greeting), { from: 'left',   duration: 680 });
      if (els.name)     scramble(els.name,     txt(els.name),     { from: 'center', duration: 900 });
      if (els.role)     scramble(els.role,     txt(els.role),     { from: 'right',  duration: 760 });
    }

    function playBearMeta() {
      var weatherSpans = document.querySelectorAll('#weatherLine span');
      var sg = weatherSpans[0]; // "Singapore" — static
      var temp = document.getElementById('weatherTemp');
      var desc = document.getElementById('weatherDesc');
      var online = document.querySelector('.online-line');

      if (sg) scramble(sg, txt(sg), { from: 'left', duration: 640 });
      if (temp) watchFirstFill(temp, { from: 'center', duration: 540 });
      if (desc) watchFirstFill(desc, { from: 'right',  duration: 720 });
      if (online) watchFirstFill(online, { from: 'random', duration: 820, preserveHTML: true });
    }

    function initHover() {
      var name = document.querySelector('.card-intro .name');
      if (!name || reduce) return;
      var locked = false;
      name.addEventListener('mouseenter', function() {
        if (locked) return;
        locked = true;
        scramble(name, txt(name), { from: 'center', duration: 560 });
        setTimeout(function() { locked = false; }, 700);
      });
    }

    function ready() {
      var run = function() {
        // rAF pushes past i18n's applyTranslations on the same tick
        requestAnimationFrame(function() {
          playIntro();
          playBearMeta();
          initHover();
        });
      };
      if (window._i18nReady && window._i18nReady.then) {
        window._i18nReady.then(run);
      } else {
        run();
      }

      window.addEventListener('langchange', function() {
        requestAnimationFrame(function() {
          var els = getEls();
          if (els.greeting) scramble(els.greeting, txt(els.greeting), { from: 'left',  duration: 680 });
          if (els.role)     scramble(els.role,     txt(els.role),     { from: 'right', duration: 760 });
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', ready);
    } else {
      ready();
    }

    // Expose for cyber-glitch effect E (spec: 2026-05-06-cyber-glitch-effects-design.md)
    window.__heroScramble = scramble;
  })();
  </script>

  <script is:inline>
  /* ============================================================
   * Cyber Glitch Effects (A: chromatic burst, E: scramble bursts)
   * Spec: docs/superpowers/specs/2026-05-06-cyber-glitch-effects-design.md
   * Scope: homepage only (this file).
   * ========================================================== */
  (function() {
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function isDark() {
      return document.documentElement.getAttribute('data-mode') !== 'light';
    }

    var P = {
      GLITCH_MIN:    60000,
      GLITCH_MAX:    120000,
      GLITCH_WARMUP: 30000,
      HOVER_COOLDOWN:   800,
      HERO_DELAY:     1200,
      DWELL_THR:     30000,
      AMBIENT_MIN:    8000,
      AMBIENT_MAX:    12000,
      SCROLL_THR:     1500,
      SCROLL_COOLDOWN:  700
    };

    function rand(a, b) { return a + Math.random() * (b - a); }
    function randInt(a, b) { return Math.floor(rand(a, b + 1)); }
    function randSign() { return Math.random() < 0.5 ? -1 : 1; }
    function pickWeighted(arr) {
      var total = arr.reduce(function(s, f) { return s + f.w; }, 0);
      var r = Math.random() * total;
      for (var i = 0; i < arr.length; i++) {
        r -= arr[i].w;
        if (r <= 0) return arr[i];
      }
      return arr[arr.length - 1];
    }

    /* ============================================================
     * Effect A: GLITCH (chromatic burst)
     * ========================================================== */

    var FLAVORS = [
      { name: 'hum',    w: 35, scene: 0,    rgb: 0.55, hue: 0,  band: 0,   scan: 0, dur: [200, 280] },
      { name: 'pulse',  w: 22, scene: 1.0,  rgb: 0.6,  hue: 0,  band: 0,   scan: 0, dur: [220, 320] },
      { name: 'chroma', w: 15, scene: 0,    rgb: 0.7,  hue: 6,  band: 0,   scan: 0, dur: [300, 400] },
      { name: 'slice',  w: 12, scene: 0,    rgb: 0.45, hue: 0,  band: 1.0, scan: 0, dur: [260, 360] },
      { name: 'jolt',   w:  8, scene: 1.4,  rgb: 0,    hue: 12, band: 0,   scan: 0, dur: [240, 340] },
      { name: 'full',   w:  8, scene: 1.6,  rgb: 0.75, hue: 14, band: 1.0, scan: 1, dur: [380, 500] }
    ];

    var RGB_PAIRS = [
      ['rgba(255, 0, 110, _A_)',  'rgba(0, 220, 255, _A_)'],
      ['rgba(255, 80, 180, _A_)', 'rgba(60, 180, 255, _A_)'],
      ['rgba(255, 180, 40, _A_)', 'rgba(80, 255, 255, _A_)']
    ];

    function sceneShake(intensity, durMs) {
      var n = randInt(4, 7);
      var amp = 1.2 * intensity;
      var keyframes = [{ transform: 'translate(0,0)' }];
      for (var i = 1; i < n - 1; i++) {
        var x = (Math.random() * 2 - 1) * amp;
        var y = (Math.random() * 2 - 1) * amp * 0.7;
        keyframes.push({ transform: 'translate(' + x.toFixed(2) + 'px,' + y.toFixed(2) + 'px)' });
      }
      keyframes.push({ transform: 'translate(0,0)' });
      try {
        document.body.animate(keyframes, {
          duration: durMs,
          easing: 'steps(' + n + ', end)',
          fill: 'none'
        });
      } catch (e) { /* WAAPI not supported */ }
    }

    function rgbShift(intensity, durMs) {
      var maxPx = 1 + intensity * 2.5;
      var pair = RGB_PAIRS[randInt(0, RGB_PAIRS.length - 1)];
      var alpha = 0.45 + intensity * 0.25;
      var cR = pair[0].replace('_A_', alpha.toFixed(2));
      var cC = pair[1].replace('_A_', alpha.toFixed(2));
      var b = document.body;
      b.style.setProperty('--c-r', cR);
      b.style.setProperty('--c-c', cC);
      b.classList.add('fx-rgb');
      var start = performance.now();
      function tick(now) {
        var t = (now - start) / durMs;
        if (t >= 1) { b.classList.remove('fx-rgb'); return; }
        var rx = (Math.random() * 2 - 1) * maxPx * (1 - t * 0.5);
        var cx = (Math.random() * 2 - 1) * maxPx * (1 - t * 0.5);
        b.style.setProperty('--rx', rx.toFixed(2) + 'px');
        b.style.setProperty('--cx', cx.toFixed(2) + 'px');
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    function hueShift(deg, durMs) {
      var dir = randSign();
      var b = document.body;
      var start = performance.now();
      function tick(now) {
        var t = (now - start) / durMs;
        if (t >= 1) { b.style.filter = ''; return; }
        var k = Math.sin(t * Math.PI);
        b.style.filter = 'hue-rotate(' + (dir * deg * k).toFixed(2) + 'deg)';
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    function sliceBand(durMs) {
      var band = document.createElement('div');
      band.className = 'fx-band';
      band.style.top = (10 + Math.random() * 60) + '%';
      document.body.appendChild(band);
      var dx = (Math.random() * 60 + 20) * randSign();
      try {
        var anim = band.animate([
          { transform: 'translateX(0)', opacity: 0 },
          { transform: 'translateX(' + (dx * 0.3).toFixed(0) + 'px)', opacity: 1, offset: 0.15 },
          { transform: 'translateX(' + dx.toFixed(0) + 'px)', opacity: 1, offset: 0.7 },
          { transform: 'translateX(' + (dx * 1.1).toFixed(0) + 'px)', opacity: 0 }
        ], { duration: durMs, easing: 'steps(6, end)' });
        anim.onfinish = function() { band.remove(); };
      } catch (e) {
        setTimeout(function() { band.remove(); }, durMs);
      }
    }

    function scanPulse(durMs) {
      var s = document.createElement('div');
      s.className = 'fx-scan';
      document.body.appendChild(s);
      try {
        var anim = s.animate([
          { opacity: 0, transform: 'translateY(0)' },
          { opacity: 1, transform: 'translateY(-4px)', offset: 0.3 },
          { opacity: 0.6, transform: 'translateY(2px)', offset: 0.7 },
          { opacity: 0, transform: 'translateY(0)' }
        ], { duration: durMs, easing: 'steps(8, end)' });
        anim.onfinish = function() { s.remove(); };
      } catch (e) {
        setTimeout(function() { s.remove(); }, durMs);
      }
    }

    var glitchActive = false;

    function fireGlitch(forceFlavor) {
      if (reduce || !isDark() || document.hidden) return;
      var flavor = forceFlavor || pickWeighted(FLAVORS);
      var dur = rand(flavor.dur[0], flavor.dur[1]);
      glitchActive = true;
      setTimeout(function() { glitchActive = false; }, dur + 20);
      if (flavor.scene > 0) sceneShake(flavor.scene, dur);
      if (flavor.rgb > 0)   rgbShift(flavor.rgb, dur);
      if (flavor.hue > 0)   hueShift(flavor.hue, dur);
      if (flavor.band > 0)  sliceBand(dur);
      if (flavor.scan > 0)  scanPulse(dur);
    }

    /* ============================================================
     * Effect E: SCRAMBLE BURSTS
     * ========================================================== */

    var SCRAMBLE_SELECTORS = [
      '.greeting',
      '.role',
      '.links a',
      '.section-title',
      '.gh-bio',
      '.mf-desc',
      '.mf-feature',
      '.mf-tag',
      '.mf-tagline',
      '.post-title',
      '.post-date'
    ].join(',');

    var allScrambles = [];
    function bindScrambles() {
      Array.prototype.forEach.call(
        document.querySelectorAll(SCRAMBLE_SELECTORS),
        function(el) {
          if (el.__bound) return;
          el.__bound = true;
          el.setAttribute('data-glitch-flash', '');
          allScrambles.push(el);
        }
      );
    }

    function flash(el) {
      el.setAttribute('data-glitch-flashing', '');
      setTimeout(function() { el.removeAttribute('data-glitch-flashing'); }, 60);
    }

    function scrambleEl(el, opts) {
      if (!el || reduce) return;
      if (glitchActive) return;
      if (typeof window.__heroScramble !== 'function') return;
      var t = (el.textContent || '').trim();
      if (!t) return;
      flash(el);
      window.__heroScramble(el, t, opts || { duration: 600 });
    }

    function visibleScrambles() {
      var out = [];
      for (var i = 0; i < allScrambles.length; i++) {
        var el = allScrambles[i];
        var r = el.getBoundingClientRect();
        if (r.bottom > 60 && r.top < window.innerHeight - 40) out.push(el);
      }
      return out;
    }

    function burstVisible(count) {
      var v = visibleScrambles();
      if (!v.length) return;
      for (var i = 0; i < count && v.length; i++) {
        var idx = Math.floor(Math.random() * v.length);
        var el = v.splice(idx, 1)[0];
        scrambleEl(el, { duration: 460, from: 'random', settleDuration: 140 });
      }
    }

    /* --- Scroll velocity trigger --- */
    var scrollLastY = window.scrollY;
    var scrollLastT = performance.now();
    var lastScrollBurst = 0;
    window.addEventListener('scroll', function() {
      var now = performance.now();
      var dt = Math.max(8, now - scrollLastT);
      var v = Math.abs(window.scrollY - scrollLastY) / dt * 1000;
      scrollLastY = window.scrollY;
      scrollLastT = now;
      if (v > P.SCROLL_THR && now - lastScrollBurst > P.SCROLL_COOLDOWN) {
        lastScrollBurst = now;
        burstVisible(2);
      }
    }, { passive: true });

    /* --- Dwell ticker + ambient mode --- */
    var visibleTime = 0;
    var lastVisTick = performance.now();
    var ambientStarted = false;
    var ambientTimer = null;

    function scheduleAmbient() {
      clearTimeout(ambientTimer);
      var delay = P.AMBIENT_MIN + Math.random() * (P.AMBIENT_MAX - P.AMBIENT_MIN);
      ambientTimer = setTimeout(function() {
        if (!document.hidden) burstVisible(1);
        scheduleAmbient();
      }, delay);
    }

    function tickDwell() {
      var now = performance.now();
      if (!document.hidden) visibleTime += now - lastVisTick;
      lastVisTick = now;
      if (!ambientStarted && visibleTime >= P.DWELL_THR) {
        ambientStarted = true;
        scheduleAmbient();
      }
    }
    setInterval(tickDwell, 250);

    /* ============================================================
     * Triggers + scheduling + lifecycle
     * ========================================================== */

    /* --- Hero weekly gate --- */
    var HERO_KEY = 'glitch-hero-week';
    function currentWeekId() {
      return Math.floor(Date.now() / 604800000);
    }
    function heroFiredThisWeek() {
      try { return localStorage.getItem(HERO_KEY) === String(currentWeekId()); }
      catch (e) { return true; }
    }
    function markHeroFired() {
      try { localStorage.setItem(HERO_KEY, String(currentWeekId())); }
      catch (e) { /* silently ignore */ }
    }
    function tryHeroGlitch() {
      if (reduce || !isDark() || document.hidden) return;
      if (heroFiredThisWeek()) return;
      var soft = FLAVORS.filter(function(f) {
        return f.name === 'hum' || f.name === 'pulse' || f.name === 'chroma';
      });
      var f = pickWeighted(soft);
      fireGlitch(f);
      markHeroFired();
    }

    /* --- Scheduled A --- */
    var glitchTimer = null;
    function scheduleGlitch(initial) {
      clearTimeout(glitchTimer);
      var base = initial ? P.GLITCH_WARMUP : 0;
      var delay = base + P.GLITCH_MIN + Math.random() * (P.GLITCH_MAX - P.GLITCH_MIN);
      glitchTimer = setTimeout(function() {
        if (!document.hidden) fireGlitch();
        scheduleGlitch(false);
      }, delay);
    }

    /* --- Hover trigger (existing initHover scramble still fires too) --- */
    var lastHoverFire = 0;
    function bindHover() {
      var name = document.querySelector('.card-intro .name');
      if (!name) return;
      name.addEventListener('mouseenter', function() {
        var now = performance.now();
        if (now - lastHoverFire < P.HOVER_COOLDOWN) return;
        lastHoverFire = now;
        fireGlitch();
      });
    }

    /* --- Visibility --- */
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) {
        clearTimeout(glitchTimer);
        clearTimeout(ambientTimer);
      } else {
        scheduleGlitch(false);
        if (ambientStarted) scheduleAmbient();
      }
      lastVisTick = performance.now();
    });

    /* --- Boot --- */
    function bootGlitch() {
      bindScrambles();
      bindHover();
      if (!reduce) {
        setTimeout(tryHeroGlitch, P.HERO_DELAY);
        scheduleGlitch(true);
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootGlitch);
    } else {
      bootGlitch();
    }
  })();
  </script>

