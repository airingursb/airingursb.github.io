    // ── Now Playing Card ──
    (function () {
      var LASTFM_KEY = 'f1d1edd883ce6098652b5f10f1ff42c4';
      var LASTFM_USER = 'airingursb';
      var POLL_INTERVAL = 30000; // 30s
      var listEl = document.getElementById('rtList');
      var heroEl = document.getElementById('npHero');
      var vinylEl = document.getElementById('npVinyl');
      var vinylHole = document.getElementById('npVinylHole');
      var npTrackEl = document.getElementById('npTrack');
      var npArtistEl = document.getElementById('npArtist');
      // Corner widget (intro card)
      var cornerEl = document.getElementById('npCorner');
      var cornerVinyl = document.getElementById('npCornerVinyl');
      var cornerHole = document.getElementById('npCornerHole');
      var cornerTrack = document.getElementById('npCornerTrack');
      var cornerArtist = document.getElementById('npCornerArtist');
      if (!listEl) return;

      function timeAgo(uts) {
        if (!uts) return '';
        var diff = Math.floor(Date.now() / 1000) - parseInt(uts, 10);
        if (diff < 0) return '0s';
        if (diff < 60) return diff + 's';
        if (diff < 3600) return Math.floor(diff / 60) + 'm';
        if (diff < 86400) return Math.floor(diff / 3600) + 'h';
        return Math.floor(diff / 86400) + 'd';
      }

      function escHtml(s) {
        var d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      function setVinylImage(vinylContainer, holeEl, imageUrl, alt) {
        var existing = vinylContainer.querySelector('img');
        if (imageUrl) {
          if (!existing) {
            existing = document.createElement('img');
            vinylContainer.appendChild(existing);
          }
          existing.src = imageUrl;
          existing.alt = alt || '';
          if (holeEl) holeEl.style.display = 'none';
        } else {
          if (existing) existing.remove();
          if (holeEl) holeEl.style.display = '';
        }
      }

      function renderTracks(tracks) {
        var nowTrack = null;
        var rest = [];
        tracks.forEach(function (t) {
          if (t.nowplaying) nowTrack = t;
          else rest.push(t);
        });

        // Hero section in Now Playing card
        if (nowTrack && heroEl) {
          heroEl.classList.remove('np-hidden');
          if (nowTrack.url) {
            heroEl.style.cursor = 'pointer';
            heroEl.onclick = function () { window.open(nowTrack.url, '_blank'); };
          }
          npTrackEl.textContent = nowTrack.name;
          npArtistEl.textContent = nowTrack.artist;
          setVinylImage(vinylEl, vinylHole, nowTrack.image, nowTrack.album);
          vinylEl.style.animationPlayState = 'running';
        } else if (heroEl) {
          heroEl.classList.add('np-hidden');
          heroEl.onclick = null;
          vinylEl.style.animationPlayState = 'paused';
        }

        // Corner widget in intro card
        if (nowTrack && cornerEl) {
          cornerEl.classList.add('visible');
          cornerEl.href = nowTrack.url || '#';
          cornerTrack.textContent = nowTrack.name;
          cornerArtist.textContent = nowTrack.artist;
          setVinylImage(cornerVinyl, cornerHole, nowTrack.image, nowTrack.album);
        } else if (cornerEl) {
          cornerEl.classList.remove('visible');
        }

        // Track list
        listEl.innerHTML = '';
        rest.forEach(function (t) {
          var tag = t.url ? 'a' : 'div';
          var el = document.createElement(tag);
          el.className = 'rt-item';
          if (t.url) {
            el.href = t.url;
            el.target = '_blank';
            el.rel = 'noopener';
            el.style.textDecoration = 'none';
            el.style.color = 'inherit';
          }
          el.innerHTML = '<span class="rt-time">' + timeAgo(t.ts) + '</span>' +
            '<span class="rt-track">' + escHtml(t.name) + '</span>' +
            '<span class="rt-sep">-</span>' +
            '<span class="rt-artist">' + escHtml(t.artist) + '</span>';
          listEl.appendChild(el);
        });
      }

      function parseTracks(data) {
        var raw = data && data.recenttracks && data.recenttracks.track;
        if (!raw || !raw.length) return [];
        return raw.slice(0, 6).map(function (t) {
          var np = t['@attr'] && t['@attr'].nowplaying === 'true';
          var artist = typeof t.artist === 'object' ? (t.artist['#text'] || '') : String(t.artist || '');
          var album = typeof t.album === 'object' ? (t.album['#text'] || '') : String(t.album || '');
          var image = '';
          if (t.image && t.image.length) {
            var img = t.image[1] || t.image[0];
            image = img['#text'] || '';
          }
          return {
            name: t.name || '',
            artist: artist,
            album: album,
            image: image,
            url: t.url || '',
            nowplaying: np,
            ts: np ? '' : (t.date && t.date.uts || ''),
          };
        });
      }

      function fetchAndRender() {
        var url = 'https://ws.audioscrobbler.com/2.0/?method=user.getrecenttracks' +
          '&user=' + LASTFM_USER + '&api_key=' + LASTFM_KEY +
          '&format=json&limit=6';
        fetch(url).then(function (r) { return r.json(); }).then(function (data) {
          var tracks = parseTracks(data);
          if (tracks.length) renderTracks(tracks);
        }).catch(function () {});
      }

      // Initial render from pre-built data
      var prebuilt = window.__NOWPLAYING_DATA__;
      if (prebuilt && prebuilt.length) renderTracks(prebuilt);

      // Live poll
      fetchAndRender();
      setInterval(fetchAndRender, POLL_INTERVAL);
    })();
  </script>

  <script is:inline>
    // ── Uptime ──
    (function () {
      var START = new Date('2014-12-02T00:00:00+08:00').getTime();
      var el = document.getElementById('uptimeText');
      if (!el) return;

      function pad(n) { return n < 10 ? '0' + n : '' + n; }

      function update() {
        var diff = Date.now() - START;
        var s = Math.floor(diff / 1000);
        var m = Math.floor(s / 60); s %= 60;
        var h = Math.floor(m / 60); m %= 60;
        var d = Math.floor(h / 24); h %= 24;
        var y = Math.floor(d / 365); d %= 365;

        var parts = [];
        if (y > 0) parts.push('<span class="uptime-num">' + y + '</span>y');
        parts.push('<span class="uptime-num">' + d + '</span>d');
        parts.push('<span class="uptime-num">' + pad(h) + '</span>h');
        parts.push('<span class="uptime-num">' + pad(m) + '</span>m');
        parts.push('<span class="uptime-num">' + pad(s) + '</span>s');

        el.innerHTML = t('uptime_prefix') + ' ' + parts.join(' ');
      }

      update();
      setInterval(update, 1000);
    })();

    // ── AI Chat ──
    (function () {
      var CHAT_API_BASE = 'https://chat.ursb.me';

      var chatArea = document.getElementById('chatArea');
      var chatInput = document.getElementById('chatInput');
      var chatError = document.getElementById('chatError');
      var chatRounds = document.getElementById('chatRounds');
      var chatPrompt = document.getElementById('chatPrompt');
      var chatSuggestions = document.getElementById('chatSuggestions');

      // ── Fake cursor & Airing_ cursor coordination ──
      var nameCursor = document.querySelector('.cursor');
      var chatActivated = false;

      function updateNameCursor() {
        // Show Airing_ if user has interacted with chat or chat is no longer usable
        nameCursor.style.display = chatActivated ? '' : 'none';
      }

      chatInput.addEventListener('focus', function () {
        chatPrompt.classList.add('hide-cursor');
        chatActivated = true;
        updateNameCursor();
      });
      chatInput.addEventListener('blur', function () {
        if (!chatInput.value) {
          chatPrompt.classList.remove('hide-cursor');
        }
      });

      // Initially hide Airing_ since chat input cursor is visible
      updateNameCursor();

      // ── Suggestion chips ──
      chatSuggestions.addEventListener('click', function (e) {
        var chip = e.target.closest('.chat-suggestion-chip');
        if (!chip) return;
        if (typeof umami !== 'undefined') umami.track('chat-suggestion', { text: chip.textContent });
        submitChat(chip.textContent);
      });

      function hideSuggestions() {
        chatSuggestions.style.display = 'none';
      }

      var TOKEN_KEY = 'chat_visitor_token';
      var MAX_ROUNDS = 10;
      var roundCount = 0;

      // ── Token management ──
      function getToken() {
        return localStorage.getItem(TOKEN_KEY);
      }

      function setToken(token) {
        localStorage.setItem(TOKEN_KEY, token);
      }

      function ensureToken() {
        var existing = getToken();
        if (existing) return Promise.resolve(existing);
        return fetch(CHAT_API_BASE + '/api/chat/init', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        })
          .then(function (r) {
            if (!r.ok) throw new Error('init_failed');
            return r.json();
          })
          .then(function (data) {
            setToken(data.token);
            return data.token;
          });
      }

      // ── History ──
      function loadHistory() {
        var token = getToken();
        if (!token) return;
        fetch(CHAT_API_BASE + '/api/chat/history', {
          headers: { 'X-Visitor-Token': token }
        })
          .then(function (r) {
            if (!r.ok) return;
            return r.json();
          })
          .then(function (data) {
            if (!data || !data.messages) return;
            data.messages.forEach(function (msg) {
              appendMessage(msg.role, msg.content, false);
            });
            if (data.messages.length > 0) hideSuggestions();
            roundCount = data.rounds || 0;
            if (data.maxRounds) MAX_ROUNDS = data.maxRounds;
            updateRoundsDisplay();
            if (roundCount >= MAX_ROUNDS) {
              showLimitReached();
            }
          })
          .catch(function () { /* silently ignore history load errors */ });
      }

      // ── Render markdown (lightweight inline only) ──
      function escapeHtml(str) {
        return str
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function renderMarkdown(text) {
        var escaped = escapeHtml(text);
        // inline code: `code`
        escaped = escaped.replace(/`([^`]+)`/g, '<code>$1</code>');
        // bold: **text**
        escaped = escaped.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        // italic: *text*
        escaped = escaped.replace(/\*([^*]+)\*/g, '<em>$1</em>');
        // links: [text](url)
        escaped = escaped.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g,
          '<a href="$2" target="_blank" rel="noopener">$1</a>');
        // unordered list items: "- item" at line start
        escaped = escaped.replace(/^- (.+)$/gm, '<li>$1</li>');
        escaped = escaped.replace(/((?:<li>.*<\/li>\n?)+)/g, '<ul>$1</ul>');
        // headings (unlikely but handle): ### heading
        escaped = escaped.replace(/^### (.+)$/gm, '<strong>$1</strong>');
        escaped = escaped.replace(/^## (.+)$/gm, '<strong>$1</strong>');
        // strip newlines inside <ul> blocks to prevent extra <br> between list items
        escaped = escaped.replace(/<ul>([\s\S]*?)<\/ul>/g, function(match, inner) {
          return '<ul>' + inner.replace(/\n/g, '') + '</ul>';
        });
        // double newline = paragraph break, single newline = line break
        escaped = escaped.replace(/\n\n/g, '<br><br>');
        escaped = escaped.replace(/\n/g, '<br>');
        return escaped;
      }

      // ── Append message ──
      function appendMessage(role, content, animate) {
        var msg = document.createElement('div');
        msg.className = 'chat-msg';

        var roleSpan = document.createElement('span');
        roleSpan.className = role === 'user' ? 'chat-role-user' : 'chat-role-ai';
        roleSpan.textContent = role === 'user' ? t('chat_role_user') : t('chat_role_ai');

        var contentSpan = document.createElement('span');
        contentSpan.className = 'chat-content';
        if (animate) {
          contentSpan.className += ' chat-typing';
          contentSpan.innerHTML = '';
        } else {
          contentSpan.innerHTML = renderMarkdown(content);
        }

        msg.appendChild(roleSpan);
        msg.appendChild(contentSpan);
        chatArea.appendChild(msg);

        if (!chatArea.classList.contains('active')) {
          chatArea.classList.add('active');
        }

        chatArea.scrollTop = chatArea.scrollHeight;
        return contentSpan;
      }

      // ── Rounds display ──
      function updateRoundsDisplay() {
        if (roundCount > 0) {
          chatRounds.textContent = roundCount + '/' + MAX_ROUNDS;
        } else {
          chatRounds.textContent = '';
        }
      }

      // ── Show limit reached ──
      function showLimitReached() {
        chatInput.disabled = true;
        chatInput.style.display = 'none';
        document.querySelector('.chat-prompt').style.display = 'none';
        chatActivated = true;
        updateNameCursor();
        var limitMsg = document.createElement('div');
        limitMsg.className = 'chat-limit-msg';
        limitMsg.innerHTML = t('chat_limit');
        chatInput.parentNode.appendChild(limitMsg);
      }

      // ── Send message ──
      function sendMessage(message) {
        chatError.textContent = '';
        chatInput.disabled = true;

        var contentEl = appendMessage('ai', '', true);

        ensureToken()
          .then(function (token) {
            var controller = new AbortController();
            var timeoutId = setTimeout(function () { controller.abort(); }, 30000);

            return fetch(CHAT_API_BASE + '/api/chat', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-Visitor-Token': token
              },
              body: JSON.stringify({ message: message }),
              signal: controller.signal
            })
              .then(function (r) {
                clearTimeout(timeoutId);
                if (!r.ok) {
                  return r.json().then(function (err) {
                    throw err;
                  });
                }

                var reader = r.body.getReader();
                var decoder = new TextDecoder();
                var buffer = '';
                var accumulated = '';

                function pump() {
                  return reader.read().then(function (result) {
                    if (result.done) {
                      contentEl.classList.remove('chat-typing');
                      contentEl.innerHTML = renderMarkdown(accumulated);
                      chatArea.scrollTop = chatArea.scrollHeight;
                      updateRoundsDisplay();
                      if (roundCount >= MAX_ROUNDS) {
                        showLimitReached();
                      } else {
                        chatInput.disabled = false;
                        chatInput.focus();
                      }
                      return;
                    }

                    buffer += decoder.decode(result.value, { stream: true });
                    var lines = buffer.split('\n');
                    buffer = lines.pop();

                    lines.forEach(function (line) {
                      if (!line.startsWith('data:')) return;
                      var data = line.slice(5).trim();
                      if (!data) return;
                      try {
                        var evt = JSON.parse(data);
                        if (evt.type === 'delta' && evt.text) {
                          accumulated += evt.text;
                          contentEl.innerHTML = renderMarkdown(accumulated) + '<span class="chat-typing"></span>';
                          chatArea.scrollTop = chatArea.scrollHeight;
                        } else if (evt.type === 'done') {
                          if (evt.round) roundCount = evt.round;
                          if (evt.maxRounds) MAX_ROUNDS = evt.maxRounds;
                        } else if (evt.type === 'error') {
                          throw { code: evt.code || 'STREAM_ERROR', message: evt.message };
                        }
                      } catch (e) {
                        if (e.code) throw e;
                      }
                    });

                    return pump();
                  });
                }

                return pump();
              });
          })
          .catch(function (err) {
            contentEl.classList.remove('chat-typing');
            if (contentEl.textContent === '') {
              contentEl.parentNode.remove();
            }

            var code = err && err.code;
            if (code === 'RATE_LIMITED') {
              chatError.textContent = t('chat_err_rate');
            } else if (code === 'LIMIT_REACHED') {
              showLimitReached();
            } else if (code === 'INVALID_TOKEN') {
              localStorage.removeItem(TOKEN_KEY);
              chatError.textContent = t('chat_err_expired');
            } else if (err && err.name === 'AbortError') {
              chatError.textContent = t('chat_err_timeout');
            } else {
              chatError.textContent = t('chat_err_fail');
            }

            chatInput.disabled = false;
            chatInput.focus();
          });
      }

      // ── Submit chat message ──
      function submitChat(text) {
        var message = text.trim();
        if (!message) return;
        chatInput.value = '';
        hideSuggestions();
        appendMessage('user', message, false);
        sendMessage(message);
      }

      chatInput.addEventListener('keydown', function (e) {
        if (e.key !== 'Enter') return;
        submitChat(chatInput.value);
      });

      // ── Init ──
      loadHistory();
    })();
  </script>

  <!-- Highlights -->
  <script is:inline>
    (function () {
      var data = window.__HIGHLIGHTS_DATA__;
      if (!data || !data.highlights || !data.highlights.length) return;

      var log = document.getElementById('hlLog');
      var btn = document.getElementById('hlShuffle');
      var highlights = data.highlights;
      var shown = new Set();
      var INITIAL = 3;

      function escapeHtml(s) {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }

      function createEntry(h) {
        var div = document.createElement('div');
        div.className = 'hl-entry';

        var meta = '';
        if (h.title) {
          var source = h.url
            ? '<a href="' + escapeHtml(h.url) + '" target="_blank">' + escapeHtml(h.title) + '</a>'
            : escapeHtml(h.title);
          if (h.author) source += ' — ' + escapeHtml(h.author);
          if (h.date) {
            source += ' · ' + h.date;
            // Calculate days ago
            var parts = h.date.split('.');
            if (parts.length === 3) {
              var hDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
              var daysAgo = Math.floor((Date.now() - hDate.getTime()) / 86400000);
              if (daysAgo >= 0) source += ' · ' + daysAgo + 'd ago';
            }
          }
          meta = '<div class="hl-entry-meta">' + source + '</div>';
        }

        div.innerHTML =
          '<span class="hl-entry-prompt">▍</span>' +
          '<div class="hl-entry-content">' +
            '<div class="hl-entry-text">' + escapeHtml(h.text) + '</div>' +
            meta +
          '</div>';
        return div;
      }

      // Show initial 3 (latest)
      for (var i = 0; i < Math.min(INITIAL, highlights.length); i++) {
        log.appendChild(createEntry(highlights[i]));
        shown.add(highlights[i].id);
      }

      // Shuffle: append one random unshown highlight
      btn.addEventListener('click', function () {
        var pool = highlights.filter(function (h) { return !shown.has(h.id); });
        if (pool.length === 0) {
          // All shown, reset
          shown.clear();
          pool = highlights;
        }
        var pick = pool[Math.floor(Math.random() * pool.length)];
        shown.add(pick.id);
        var entry = createEntry(pick);
        log.appendChild(entry);
        entry.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    })();
  </script>

  <script is:inline>
    // ── Vibe Coding + Life Cards ──
    (function() {
      var data = window.__LOCAL_DATA__;
      if (!data) return;

      var el = function(id) { return document.getElementById(id); };

      function fmtTokens(n) {
        if (n >= 1e9) return (n / 1e9).toFixed(1) + 'B';
        if (n >= 1e6) return (n / 1e6).toFixed(0) + 'M';
        if (n >= 1e3) return (n / 1e3).toFixed(0) + 'K';
        return String(n);
      }

      function fmtNum(n) {
        return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      }

      // ── Vibe Coding ──
      var vc = data.vibeCoding;
      if (vc) {
        var daily = vc.daily || {};
        var dates = Object.keys(daily).sort();
        var maxCost = 0;
        for (var k in daily) { if (daily[k].cost > maxCost) maxCost = daily[k].cost; }

        // Header
        var numWeeks = Math.ceil(dates.length > 0 ? ((new Date(dates[dates.length-1]) - new Date(dates[0])) / 86400000 / 7) : 0);
        el('vcTotal').innerHTML = 'Past ' + Math.max(numWeeks, 1) + ' weeks &middot; <strong>$' + vc.totalCost.toFixed(2) + '</strong>';

        // Stats
        el('vcTokens').textContent = fmtTokens(vc.totalTokens);
        el('vcCost').textContent = '$' + Math.round(vc.totalCost);
        el('vcAvg').textContent = '$' + Math.round(vc.avgWeekCost);

        // Models
        var modelsEl = el('vcModels');
        (vc.models || []).forEach(function(m) {
          var tag = document.createElement('span');
          tag.className = 'vc-model-tag';
          tag.innerHTML = '<span class="vc-model-dot" style="background:' + m.color + ';"></span>' + m.name;
          modelsEl.appendChild(tag);
        });

        // Heatmap - calculate weeks to fit container (10px cell + 2px gap = 12px per col)
        var heatmap = el('vcHeatmap');
        var today = new Date();
        var heatmapWidth = heatmap.offsetWidth || 480;
        var totalWeeks = Math.floor((heatmapWidth + 2) / 12);
        totalWeeks = Math.max(8, Math.min(totalWeeks, 52));
        var endDay = new Date(today);
        endDay.setDate(endDay.getDate() + (6 - endDay.getDay()));
        var startDay = new Date(endDay);
        startDay.setDate(startDay.getDate() - (totalWeeks * 7 - 1));

        var cursor = new Date(startDay);
        for (var w = 0; w < totalWeeks; w++) {
          var weekEl = document.createElement('div');
          weekEl.className = 'vc-heatmap-week';
          for (var d = 0; d < 7; d++) {
            var cell = document.createElement('div');
            cell.className = 'vc-heatmap-cell';
            var key = cursor.toISOString().slice(0, 10);
            var entry = daily[key];
            if (entry) {
              var ratio = entry.cost / maxCost;
              if (ratio > 0.6) cell.classList.add('l4');
              else if (ratio > 0.35) cell.classList.add('l3');
              else if (ratio > 0.15) cell.classList.add('l2');
              else cell.classList.add('l1');
              var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
              var dd = new Date(key);
              var label = months[dd.getMonth()] + ' ' + dd.getDate();
              var tip = document.createElement('div');
              tip.className = 'vc-tooltip';
              tip.innerHTML = '<span class="vc-tooltip-date">' + label + '</span><br><span class="vc-tooltip-cost">$' + entry.cost.toFixed(2) + '</span> · ' + fmtTokens(entry.tokens) + ' tokens';
              cell.appendChild(tip);
            }
            if (cursor > today) cell.style.opacity = '0.3';
            weekEl.appendChild(cell);
            cursor.setDate(cursor.getDate() + 1);
          }
          heatmap.appendChild(weekEl);
        }
      }

      // ── Mood ──
      var mood = data.mood;
      if (mood) {
        var dotsEl = el('moodDots');
        var tooltipEl = el('moodTooltip');
        var moodLabels = { rad: 'mood_rad', good: 'mood_good', meh: 'mood_meh', bad: 'mood_bad', awful: 'mood_awful' };
        var moodValues = { rad: 5, good: 4, meh: 3, bad: 2, awful: 1 };
        var moodColors = { rad: '#fbbf24', good: 'var(--accent)', meh: '#38bdf8', bad: '#f472b6', awful: '#ef4444' };
        var moods = mood.recentMoods || [];
        var today = new Date();

        moods.forEach(function(m, i) {
          var dot = document.createElement('div');
          dot.className = 'mood-dot ' + m;
          // Infer date: most recent first, one entry per day
          var d = new Date(today);
          d.setDate(d.getDate() - i);
          var dateStr = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
          dot.addEventListener('mouseenter', function() {
            tooltipEl.innerHTML = '<span class="mood-tt-mood" style="color:' + (moodColors[m] || 'var(--c-text-muted)') + '">' + t(moodLabels[m] || m) + '</span> · ' + dateStr;
            tooltipEl.classList.add('visible');
          });
          dot.addEventListener('mouseleave', function() {
            tooltipEl.classList.remove('visible');
          });
          dotsEl.appendChild(dot);
        });

        el('moodEntries').textContent = fmtNum(mood.totalEntries);
        el('moodSince').textContent = mood.since;

        // Mood trend chart (last 30 days as SVG line)
        var chartWrap = el('moodChart');
        if (chartWrap && moods.length > 1) {
          var chartDays = Math.min(moods.length, 30);
          var pts = [];
          for (var ci = chartDays - 1; ci >= 0; ci--) {
            pts.push(moodValues[moods[ci]] || 3);
          }
          var w = chartWrap.offsetWidth || 300;
          var h = 60;
          var padY = 6;
          var stepX = w / (pts.length - 1);
          var minV = 1, maxV = 5;
          function yPos(v) { return padY + (maxV - v) / (maxV - minV) * (h - padY * 2); }

          var pathD = pts.map(function(v, i) {
            return (i === 0 ? 'M' : 'L') + (i * stepX).toFixed(1) + ',' + yPos(v).toFixed(1);
          }).join(' ');

          // Area fill
          var areaD = pathD + ' L' + ((pts.length - 1) * stepX).toFixed(1) + ',' + h + ' L0,' + h + ' Z';

          var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
          svg.setAttribute('viewBox', '0 0 ' + w + ' ' + h);
          svg.setAttribute('preserveAspectRatio', 'none');
          svg.style.width = '100%';
          svg.style.height = h + 'px';

          // Gradient
          var defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
          var grad = document.createElementNS('http://www.w3.org/2000/svg', 'linearGradient');
          grad.id = 'moodGrad';
          grad.setAttribute('x1', '0'); grad.setAttribute('y1', '0');
          grad.setAttribute('x2', '0'); grad.setAttribute('y2', '1');
          var stop1 = document.createElementNS('http://www.w3.org/2000/svg', 'stop');
          stop1.setAttribute('offset', '0%'); stop1.setAttribute('stop-color', 'var(--accent)'); stop1.setAttribute('stop-opacity', '0.2');
          var stop2 = document.createElementNS('http://www.w3.org/2000/svg', 'stop');
          stop2.setAttribute('offset', '100%'); stop2.setAttribute('stop-color', 'var(--accent)'); stop2.setAttribute('stop-opacity', '0');
          grad.appendChild(stop1); grad.appendChild(stop2);
          defs.appendChild(grad);
          svg.appendChild(defs);

          // Area
          var area = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          area.setAttribute('d', areaD);
          area.setAttribute('fill', 'url(#moodGrad)');
          svg.appendChild(area);

          // Line
          var line = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          line.setAttribute('d', pathD);
          line.setAttribute('fill', 'none');
          line.setAttribute('stroke', 'var(--accent)');
          line.setAttribute('stroke-width', '1.5');
          line.setAttribute('stroke-linecap', 'round');
          line.setAttribute('stroke-linejoin', 'round');
          svg.appendChild(line);

          // Interactive dots on the line
          var chartTooltip = document.createElement('div');
          chartTooltip.className = 'mood-tooltip';
          chartTooltip.style.position = 'absolute';
          chartTooltip.style.top = '-16px';
          chartTooltip.style.left = '0';
          chartTooltip.style.pointerEvents = 'none';
          chartWrap.appendChild(chartTooltip);

          pts.forEach(function(v, i) {
            var cx = i * stepX;
            var cy = yPos(v);
            var moodKey = moods[chartDays - 1 - i];
            var circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            circle.setAttribute('cx', cx.toFixed(1));
            circle.setAttribute('cy', cy.toFixed(1));
            circle.setAttribute('r', '3');
            circle.setAttribute('fill', moodColors[moodKey] || 'var(--accent)');
            circle.setAttribute('stroke', 'var(--c-bg)');
            circle.setAttribute('stroke-width', '1');
            circle.style.cursor = 'pointer';
            circle.style.opacity = '0';
            circle.style.transition = 'opacity 0.15s';

            var dd = new Date(today);
            dd.setDate(dd.getDate() - (chartDays - 1 - i));
            var dlabel = dd.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

            circle.addEventListener('mouseenter', function() {
              circle.style.opacity = '1';
              chartTooltip.innerHTML = '<span style="color:' + (moodColors[moodKey] || 'var(--c-text-muted)') + '">' + t(moodLabels[moodKey] || moodKey) + '</span> · ' + dlabel;
              chartTooltip.classList.add('visible');
              chartTooltip.style.left = Math.min(cx, w - 80) + 'px';
            });
            circle.addEventListener('mouseleave', function() {
              circle.style.opacity = '0';
              chartTooltip.classList.remove('visible');
            });
            svg.appendChild(circle);
          });

          chartWrap.appendChild(svg);
        }
      }

      // ── Activity ──
      var health = data.health;
      if (health) {
        el('actMove').textContent = health.activeEnergy + ' kJ';
        el('actExercise').textContent = health.exerciseMin + ' min';
        el('actStand').textContent = health.standHours + ' hr';

        el('actSteps').textContent = fmtNum(health.steps);
        el('actSleep').textContent = health.sleep + 'h';
        el('actHR').textContent = health.restingHR + ' bpm';
        el('actSpO2').textContent = health.spo2 + '%';

        // Activity rings (proportional arcs)
        // Move: goal ~1500 kJ, Exercise: goal 30 min, Stand: goal 12 hr
        var moveRatio = Math.min(health.activeEnergy / 1500, 1);
        var exRatio = Math.min(health.exerciseMin / 30, 1);
        var standRatio = Math.min(health.standHours / 12, 1);

        var moveCirc = 2 * Math.PI * 24; // ~150.8
        var exCirc = 2 * Math.PI * 18;   // ~113.1
        var standCirc = 2 * Math.PI * 12; // ~75.4

        el('ringMove').setAttribute('stroke-dasharray', (moveRatio * moveCirc).toFixed(1) + ' ' + moveCirc.toFixed(1));
        el('ringExercise').setAttribute('stroke-dasharray', (exRatio * exCirc).toFixed(1) + ' ' + exCirc.toFixed(1));
        el('ringStand').setAttribute('stroke-dasharray', (standRatio * standCirc).toFixed(1) + ' ' + standCirc.toFixed(1));
      }

      // Workouts
      var workouts = data.workouts;
      if (workouts && workouts.recentWorkouts) {
        var wEl = el('actWorkouts');
        workouts.recentWorkouts.forEach(function(w) {
          var tag = document.createElement('span');
          tag.className = 'life-tag';
          tag.textContent = w.name;
          wEl.appendChild(tag);
        });
      }
    })();
  </script>

  <script is:inline>
    // ── GitHub Card ──
    (function() {
      var data = window.__GITHUB_DATA__;
      if (!data || !data.login) return;

      function fmt(n) {
        if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
        return String(n);
      }

      function fmtNum(n) {
        return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      }

      var el = function(id) { return document.getElementById(id); };
      if (data.avatar) el('ghAvatar').src = data.avatar + '&s=40';
      el('ghLink').textContent = data.login;
      el('ghLink').href = 'https://github.com/' + data.login;
      if (data.bio) el('ghBio').textContent = data.bio;
      el('ghFollowers').textContent = fmtNum(data.followers);
      el('ghRepos').textContent = fmt(data.repos);
      el('ghFollowing').textContent = fmt(data.following);
      if (data.sinceYear) {
        var sinceDate = new Date(parseInt(data.sinceYear), 0, 1);
        var days = Math.floor((new Date() - sinceDate) / 86400000);
        var yrs = (days / 365.25).toFixed(2);
        el('ghSince').textContent = fmtNum(days) + 'd';
      }
    })();
  </script>

  <!-- Online presence (site-wide, tiered + i18n) -->
  <script is:inline>
    (function () {
      var DOT = '<span class="online-dot"></span>';
      var N = '<span class="online-count">{n}</span>';
      var tiersZh = [
        { max: 1,   html: '✦ 此刻仅你一人在此' },
        { max: 9,   html: DOT + '此刻有 ' + N + ' 人在站' },
        { max: 19,  html: DOT + N + ' 人在站 · 热闹了起来' },
        { max: 29,  html: DOT + '人潮汇聚 · ' + N + ' 人在站' },
        { max: 99,  html: '🔥 ' + N + ' 人在线 · 站点活跃' },
        { max: Infinity, html: '🔥 ' + N + ' 人在线 · 史无前例' }
      ];
      var tiersEn = [
        { max: 1,   html: '✦ Just you here right now' },
        { max: 9,   html: DOT + N + ' online' },
        { max: 19,  html: DOT + N + ' online · getting busy' },
        { max: 29,  html: DOT + 'a small crowd · ' + N + ' online' },
        { max: 99,  html: '🔥 ' + N + ' online · alive' },
        { max: Infinity, html: '🔥 ' + N + ' online · unprecedented' }
      ];
      function pickTiers() {
        return (window.currentLang === 'zh') ? tiersZh : tiersEn;
      }
      function applyOnlineLocale() {
        var el = document.querySelector('.online-line[data-online-countries="popover"]');
        if (!el) return;
        if (window.currentLang === 'zh') {
          el.setAttribute('data-online-region-label', '地区');
          el.setAttribute('data-online-popover-title', '此刻访客分布');
          el.setAttribute('data-online-total-template', '{n} 人在线');
          el.setAttribute('data-online-locale', 'zh-CN');
        } else {
          el.setAttribute('data-online-region-label', 'regions');
          el.setAttribute('data-online-popover-title', 'Visitors by region');
          el.setAttribute('data-online-total-template', '{n} visitors online');
          el.setAttribute('data-online-locale', 'en');
        }
      }
      applyOnlineLocale();
      window.__ONLINE_CONFIG__ = {
        pageId: null,
        tiers: pickTiers(),
        demoCountries: { SG: 2, US: 1, CN: 1 }
      };
      window.addEventListener('langchange', function () {
        window.__ONLINE_CONFIG__.tiers = pickTiers();
        applyOnlineLocale();
        if (window.__onlineRefresh) window.__onlineRefresh();
      });
    })();
  </script>
