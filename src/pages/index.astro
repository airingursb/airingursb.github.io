  <!-- Easter egg hint pill (only set on homepage when today maps to a holiday) -->
  <button type="button" class="easter-hint" id="easterHint" hidden>
    <span class="easter-hint-dot"></span>
    <span class="easter-hint-name"></span>
  </button>
  <script is:inline>
    (function () {
      var hit = window.__easterEggTheme;
      if (!hit) return;
      var hint = document.getElementById('easterHint');
      if (!hint) return;
      var nameEl = hint.querySelector('.easter-hint-name');
      var dateKey = window.__easterEggDateKey;
      var SS_KEY = 'easter-dismissed:' + dateKey;

      function renderLabel() {
        var lang = (window.currentLang) || localStorage.getItem('preferred_lang') || 'zh';
        nameEl.textContent = (lang === 'en' && hit.en) ? hit.en : hit.zh;
        hint.setAttribute('aria-label', nameEl.textContent + ' — ' + (lang === 'en' ? 'tap to dim' : '点一下熄灭'));
      }

      function setLit(lit) {
        if (lit) {
          document.documentElement.setAttribute('data-theme', hit.theme);
          hint.classList.remove('dimmed');
          sessionStorage.removeItem(SS_KEY);
        } else {
          document.documentElement.removeAttribute('data-theme');
          hint.classList.add('dimmed');
          sessionStorage.setItem(SS_KEY, '1');
        }
      }

      renderLabel();
      if (sessionStorage.getItem(SS_KEY)) hint.classList.add('dimmed');
      hint.removeAttribute('hidden');
      requestAnimationFrame(function () { hint.classList.add('visible'); });
      hint.addEventListener('click', function () {
        setLit(hint.classList.contains('dimmed'));
      });
      window.addEventListener('langchange', renderLabel);
    })();
  </script>
  <style>
    .easter-hint {
      position: fixed;
      bottom: 24px;
      right: 72px;
      z-index: 9999;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(var(--accent-rgb), 0.10);
      border: 1px solid rgba(var(--accent-rgb), 0.35);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      color: var(--accent);
      font: 500 12px/1 inherit;
      letter-spacing: 0.02em;
      cursor: pointer;
      user-select: none;
      opacity: 0;
      transform: translateX(8px);
      transition: opacity 0.4s ease, transform 0.4s ease, background 0.25s, border-color 0.25s, color 0.25s;
    }
    .easter-hint:hover {
      filter: brightness(1.15);
    }
    .easter-hint.visible {
      opacity: 1;
      transform: translateX(0);
    }
    .easter-hint-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      animation: easter-pulse 2s ease-in-out infinite;
      transition: background 0.25s;
    }
    @keyframes easter-pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(var(--accent-rgb), 0.5); }
      50%      { box-shadow: 0 0 0 6px rgba(var(--accent-rgb), 0); }
    }
    .easter-hint.dimmed {
      background: rgba(125, 133, 144, 0.06);
      border-color: rgba(125, 133, 144, 0.25);
      color: #7d8590;
    }
    .easter-hint.dimmed .easter-hint-dot {
      background: #7d8590;
      animation: none;
      box-shadow: none;
    }
    @media (max-width: 480px) {
      .easter-hint { display: none; }
    }
  </style>
