    // ── Guestbook ──
    (function () {
      var CHAT_API = 'https://chat.ursb.me';
      var SLUG = 'guestbook';

      var messagesEl = document.getElementById('guestbookMessages');
      var form = document.getElementById('guestbookForm');
      var nameInput = document.getElementById('gbName');
      var emailInput = document.getElementById('gbEmail');
      var msgInput = document.getElementById('gbMessage');
      var submitBtn = form.querySelector('.gb-submit');
      var pendingEl = document.getElementById('gbPending');

      // --- User identity persistence (shared with PostLayout) ---
      var USER_KEY = 'blog-user-identity';
      function getSavedIdentity() {
        try { return JSON.parse(localStorage.getItem(USER_KEY)) || {}; } catch(e) { return {}; }
      }
      function saveIdentity(nickname, email) {
        localStorage.setItem(USER_KEY, JSON.stringify({ nickname: nickname, email: email }));
      }
      (function restoreGuestbookIdentity() {
        var id = getSavedIdentity();
        if (id.nickname) nameInput.value = id.nickname;
        if (id.email) emailInput.value = id.email;
      })();

      // Client-side rate limit: max 5 messages per 10 minutes
      var RATE_LIMIT = 5;
      var RATE_WINDOW = 10 * 60 * 1000;
      function checkRateLimit() {
        var now = Date.now();
        var timestamps = JSON.parse(localStorage.getItem('gb_timestamps') || '[]');
        timestamps = timestamps.filter(function (t) { return now - t < RATE_WINDOW; });
        if (timestamps.length >= RATE_LIMIT) return false;
        timestamps.push(now);
        localStorage.setItem('gb_timestamps', JSON.stringify(timestamps));
        return true;
      }

      function timeAgo(dateStr) {
        var diff = Date.now() - new Date(dateStr).getTime();
        var s = Math.floor(diff / 1000);
        if (s < 60) return t('time_just_now');
        var m = Math.floor(s / 60);
        if (m < 60) return m + ' ' + t('time_min_ago');
        var h = Math.floor(m / 60);
        if (h < 24) return h + ' ' + t('time_h_ago');
        var d = Math.floor(h / 24);
        if (d < 30) return d + ' ' + t('time_d_ago');
        return new Date(dateStr).toLocaleDateString();
      }

      function escapeHtml(s) {
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(s));
        return div.innerHTML;
      }

      function renderMessages(comments) {
        // Filter only root comments (no replies) for the homepage mini view
        var roots = comments.filter(function(c) { return !c.parent_id; });
        if (!roots || roots.length === 0) {
          messagesEl.innerHTML = '<div class="gb-empty">' + t('gb_empty') + '</div>';
          return;
        }
        messagesEl.innerHTML = roots.map(function (m) {
          return '<div class="gb-msg">' +
            '<div class="gb-meta">' +
              '<span class="gb-name">&gt; ' + escapeHtml(m.nickname || t('gb_anonymous')) + '</span>' +
              '<span class="gb-time">' + timeAgo(m.created_at) + '</span>' +
            '</div>' +
            '<div class="gb-text">' + escapeHtml(m.content) + '</div>' +
          '</div>';
        }).join('');
        messagesEl.scrollTop = messagesEl.scrollHeight;
      }

      function loadMessages() {
        fetch(CHAT_API + '/api/comments?post_slug=' + encodeURIComponent(SLUG), {
          headers: { 'Origin': location.origin }
        })
        .then(function (r) { return r.json(); })
        .then(function (data) { renderMessages(data.comments || []); })
        .catch(function () { messagesEl.innerHTML = '<div class="gb-empty">' + t('gb_load_fail') + '</div>'; });
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var nickname = nameInput.value.trim() || 'anonymous';
        var email = emailInput.value.trim();
        var message = msgInput.value.trim();
        if (!message) return;

        if (!checkRateLimit()) {
          alert(t('gb_too_many'));
          return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = '...';

        var body = {
          post_slug: SLUG,
          nickname: nickname,
          email: email || undefined,
          content: message
        };

        fetch(CHAT_API + '/api/comments', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
          if (res.comment) {
            saveIdentity(nickname, email);
            msgInput.value = '';
            loadMessages();
          } else {
            throw new Error('No comment returned');
          }
        })
        .catch(function () {
          alert(t('gb_send_fail'));
        })
        .finally(function () {
          submitBtn.disabled = false;
          submitBtn.textContent = '↵';
        });
      });

      loadMessages();

      window.addEventListener('langchange', function() {
        loadMessages();
      });
    })();

    // ── Subscribe ──
    (function () {
      var SUBSCRIBE_API = 'https://chat.ursb.me/api/subscribe';
      var form = document.getElementById('subscribeForm');
      var nameInput = document.getElementById('subName');
      var emailInput = document.getElementById('subEmail');
      var btn = document.getElementById('subBtn');
      var successEl = document.getElementById('subSuccess');
