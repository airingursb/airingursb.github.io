      const FRAME_SLEEP_SIT = FRAME_NORMAL.map(function (row, i) {
        if (i === 4) return [1,2,2,4,4,2,2,2,4,4,2,2,1];
        if (i === 9) return [0,0,1,1,2,2,2,2,2,1,1,0,0];
        if (i === 10) return [0,0,1,2,2,3,3,3,2,2,1,0,0];
