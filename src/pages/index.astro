      /* Fireworks overlay */
      var fireworkCanvas = null;
      var fireworkCtx = null;
      var fireworkParticles = [];
      var fireworkActive = false;

      /* Particle overlay canvas */
      var particleCanvas = null;
      var particleCtx = null;

      /* Sleep Z spawn timer */
      var zSpawnTimer = 0;

      var bearWrapper = document.getElementById('bearWrapper');

      function randomBlinkDelay() {
        return 2000 + Math.random() * 3000;
      }

      function resetInteraction() {
        var wasSleeping = bearState === 'sleeping' || bearState === 'sleepy';
        lastInteractionTime = Date.now();
        if (wasSleeping) {
          wakeUp();
        }
      }

      function wakeUp() {
        bearState = 'idle';
        jumpVel = -2;
        jumpY = -0.1;
        wakeBlinkCount = 4;
        wakeBlinkTimer = 0;
        particles = particles.filter(function (p) { return p.type !== 'z'; });
      }

      /* ── Eye tracking ── */
      function updateEyeDirection() {
        var rect = canvas.getBoundingClientRect();
        var cx = rect.left + rect.width / 2;
        var cy = rect.top + rect.height / 2;
        var dx = mouseX - cx;
        var dy = mouseY - cy;
        var threshold = 30;
        if (dy < -threshold && Math.abs(dx) < threshold * 1.5) {
          eyeDirection = 'up';
        } else if (dx < -threshold) {
          eyeDirection = 'left';
        } else if (dx > threshold) {
          eyeDirection = 'right';
        } else {
          eyeDirection = 'center';
        }
      }

      function getEyeFrame() {
        switch (eyeDirection) {
          case 'left': return FRAME_LOOK_LEFT;
          case 'right': return FRAME_LOOK_RIGHT;
          case 'up': return FRAME_LOOK_UP;
          default: return FRAME_NORMAL;
        }
      }

      document.addEventListener('mousemove', function (e) {
        mouseX = e.clientX;
        mouseY = e.clientY;
        resetInteraction();
      });

      document.addEventListener('touchmove', function (e) {
        if (e.touches.length > 0) {
          mouseX = e.touches[0].clientX;
          mouseY = e.touches[0].clientY;
        }
      }, { passive: true });

      /* ── Shared tap/click handler ── */
      function handleTap() {
        resetInteraction();
        tapCount++;
        if (tapTimer) clearTimeout(tapTimer);
        tapTimer = setTimeout(function () {
          if (tapCount === 1) {
            if (jumpY >= 0 && jumpVel >= 0) {
              jumpVel = -3;
              jumpY = -0.1;
            }
          } else if (tapCount === 2) {
            flipActive = true;
            flipStart = Date.now();
          } else if (tapCount >= 3) {
            dizzyUntil = Date.now() + 2000;
            bearState = 'dizzy';
            dizzyPhase = 0;
          }
          tapCount = 0;
          tapTimer = null;
        }, 300);
      }

      bearWrapper.addEventListener('click', function (e) {
        // Skip if this click was already handled by touchend
        if (lastTapSource === 'touch') { lastTapSource = ''; return; }
        lastTapSource = 'mouse';
        handleTap();
      });

      /* ── Touch gestures ── */
      bearWrapper.addEventListener('touchstart', function (e) {
        resetInteraction();
        if (e.touches.length === 1) {
          var t = e.touches[0];
          touchStartX = t.clientX;
          touchStartY = t.clientY;
          touchStartTime = Date.now();
          isTouching = true;
          longPressTimer = setTimeout(function () {
            if (isTouching) {
              blushActive = true;
              blushUntil = Date.now() + 1500;
              bearState = 'blushing';
              spawnHearts();
            }
          }, 800);
        }
        e.preventDefault();
      }, { passive: false });

      bearWrapper.addEventListener('touchmove', function (e) {
        e.preventDefault();
        if (e.touches.length > 0) {
          mouseX = e.touches[0].clientX;
          mouseY = e.touches[0].clientY;
        }
      }, { passive: false });

      bearWrapper.addEventListener('touchend', function (e) {
        isTouching = false;
        if (longPressTimer) { clearTimeout(longPressTimer); longPressTimer = null; }
        var dt = Date.now() - touchStartTime;
        if (dt >= 800) return;
        var lastTouch = e.changedTouches[0];
        var deltaX = lastTouch.clientX - touchStartX;
        var deltaY = lastTouch.clientY - touchStartY;

        if (Math.abs(deltaX) > 30 && Math.abs(deltaX) > Math.abs(deltaY)) {
          walkDirection = deltaX > 0 ? 1 : -1;
          walkOffset = walkDirection * 3;
          walkDecay = Date.now();
        } else if (deltaY < -30 && Math.abs(deltaY) > Math.abs(deltaX)) {
          jumpVel = -5;
          jumpY = -0.1;
        } else if (deltaY > 30 && Math.abs(deltaY) > Math.abs(deltaX)) {
          crouchActive = true;
          crouchUntil = Date.now() + 300;
          bearState = 'crouching';
        } else {
          // No swipe detected — treat as tap
          lastTapSource = 'touch';
          handleTap();
        }
      });

      bearWrapper.addEventListener('touchcancel', function () {
        isTouching = false;
        if (longPressTimer) { clearTimeout(longPressTimer); longPressTimer = null; }
      });

      /* ── Heart particles ── */
      function spawnHearts() {
        var rect = canvas.getBoundingClientRect();
        var count = 3 + Math.floor(Math.random() * 3);
        for (var i = 0; i < count; i++) {
          particles.push({
            type: 'heart',
            x: rect.left + rect.width / 2 + (Math.random() - 0.5) * 40,
            y: rect.top + rect.height * 0.3,
            vx: (Math.random() - 0.5) * 1.5,
            vy: -1.5 - Math.random() * 1,
            color: '#FF6B8A',
            life: 1000,
            maxLife: 1000,
            size: 3 + Math.random() * 2
          });
        }
      }

      /* ── Sleep Z particles ── */
      function spawnZ() {
        var rect = canvas.getBoundingClientRect();
        particles.push({
          type: 'z',
          x: rect.left + rect.width * 0.7 + Math.random() * 10,
          y: rect.top + rect.height * 0.15,
          vx: 0.3 + Math.random() * 0.3,
          vy: -0.8 - Math.random() * 0.4,
          color: 'var(--c-text-muted)',
          life: 1500,
          maxLife: 1500,
          size: 6 + Math.random() * 4
        });
      }

      /* ── Keyboard sequences ── */
      document.addEventListener('keydown', function (e) {
        resetInteraction();
        keyBuffer.push(e.key);
        if (keyBufferTimer) clearTimeout(keyBufferTimer);
        keyBufferTimer = setTimeout(function () { keyBuffer = []; }, 3000);

        var bufStr = keyBuffer.join(',');

        var konami = 'ArrowUp,ArrowUp,ArrowDown,ArrowDown,ArrowLeft,ArrowRight,ArrowLeft,ArrowRight,b,a';
        if (bufStr.indexOf(konami) !== -1) {
          keyBuffer = [];
          triggerKonami();
          return;
        }

        var zoom = 'ArrowUp,ArrowUp,ArrowDown,ArrowDown';
        if (bufStr.indexOf(zoom) !== -1 && keyBuffer.length === 4) {
          keyBuffer = [];
          triggerPixelZoom();
          return;
        }

        var bear = 'b,e,a,r';
        if (bufStr.indexOf(bear) !== -1) {
          keyBuffer = [];
          triggerDance();
          return;
        }
      });

      function triggerDance() {
        danceActive = true;
        danceUntil = Date.now() + 4000;
        dancePhase = 0;
        bearState = 'dancing';
      }

      function triggerPixelZoom() {
        canvas.style.transition = 'transform 0.5s ease';
        canvas.style.transform = 'scale(3)';
        setTimeout(function () {
          canvas.style.transform = 'scale(1)';
          setTimeout(function () {
            canvas.style.transition = '';
          }, 500);
        }, 1500);
      }

      function triggerKonami() {
        sunglassesActive = true;
        sunglassesUntil = Date.now() + 10000;

        fireworkCanvas = document.createElement('canvas');
        fireworkCanvas.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:9999;';
        fireworkCanvas.width = window.innerWidth;
        fireworkCanvas.height = window.innerHeight;
        document.body.appendChild(fireworkCanvas);
        fireworkCtx = fireworkCanvas.getContext('2d');
        fireworkActive = true;
        fireworkParticles = [];

        var burstCount = 0;
        var burstInterval = setInterval(function () {
          spawnFirework();
          burstCount++;
          if (burstCount >= 8) clearInterval(burstInterval);
        }, 600);

        setTimeout(function () {
          fireworkActive = false;
          if (fireworkCanvas && fireworkCanvas.parentNode) {
            fireworkCanvas.parentNode.removeChild(fireworkCanvas);
          }
          fireworkCanvas = null;
          fireworkCtx = null;
          fireworkParticles = [];
        }, 10000);
      }

      function spawnFirework() {
        if (!fireworkCanvas) return;
        var cx = Math.random() * fireworkCanvas.width;
        var cy = Math.random() * fireworkCanvas.height * 0.6 + fireworkCanvas.height * 0.1;
        var colors = ['#FF6B6B','#4ECDC4','#45B7D1','#96CEB4','#FFEAA7','#DDA0DD','#98D8C8','#F7DC6F','var(--accent)'];
        var count = 30 + Math.floor(Math.random() * 20);
        for (var i = 0; i < count; i++) {
          var angle = (Math.PI * 2 * i) / count + (Math.random() - 0.5) * 0.3;
          var speed = 2 + Math.random() * 4;
          fireworkParticles.push({
            x: cx, y: cy,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            color: colors[Math.floor(Math.random() * colors.length)],
            life: 1200 + Math.random() * 800,
            maxLife: 1200 + Math.random() * 800,
            size: 2 + Math.random() * 2
          });
        }
      }

      /* ── Draw function ── */
      function draw(frame, offsetY, offsetX) {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        var oy = PAD_TOP + Math.round(offsetY);
        var ox = Math.round(offsetX || 0);
        for (var r = 0; r < H; r++) {
          for (var c = 0; c < W; c++) {
            var ci = frame[r][c];
            if (ci === 0) continue;
            ctx.fillStyle = C[ci];
            ctx.fillRect(c + ox, r + oy, 1, 1);
          }
        }
      }

      /* ── Update particles ── */
      function updateParticles(dt) {
        for (var i = particles.length - 1; i >= 0; i--) {
          var p = particles[i];
          p.life -= dt;
          if (p.life <= 0) {
            particles.splice(i, 1);
            continue;
          }
          p.x += p.vx;
          p.y += p.vy;
        }
      }

      /* ── Draw particles on overlay ── */
      function drawParticlesOnPage() {
        if (particles.length === 0) {
          if (particleCtx) particleCtx.clearRect(0, 0, particleCanvas.width, particleCanvas.height);
          return;
        }
        if (!particleCanvas) {
          particleCanvas = document.createElement('canvas');
          particleCanvas.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:9998;';
          particleCanvas.width = window.innerWidth;
          particleCanvas.height = window.innerHeight;
          document.body.appendChild(particleCanvas);
          particleCtx = particleCanvas.getContext('2d');
        }
        particleCtx.clearRect(0, 0, particleCanvas.width, particleCanvas.height);

        for (var i = 0; i < particles.length; i++) {
          var p = particles[i];
          var alpha = Math.max(0, p.life / p.maxLife);
          particleCtx.globalAlpha = alpha;
          particleCtx.fillStyle = p.color;
          if (p.type === 'z') {
            particleCtx.font = Math.round(p.size) + 'px monospace';
            particleCtx.fillText('z', p.x, p.y);
          } else if (p.type === 'heart') {
            var s = p.size;
            particleCtx.fillRect(p.x - s / 2, p.y - s / 2, s, s);
            particleCtx.fillRect(p.x - s, p.y - s, s, s);
            particleCtx.fillRect(p.x, p.y - s, s, s);
          }
        }
        particleCtx.globalAlpha = 1;
      }

      /* ── Update fireworks ── */
      function updateFireworks(dt) {
        if (!fireworkActive || !fireworkCtx) return;
        fireworkCtx.clearRect(0, 0, fireworkCanvas.width, fireworkCanvas.height);
        for (var i = fireworkParticles.length - 1; i >= 0; i--) {
          var p = fireworkParticles[i];
          p.life -= dt;
          if (p.life <= 0) {
            fireworkParticles.splice(i, 1);
            continue;
          }
          p.vy += 0.05;
          p.x += p.vx;
          p.y += p.vy;
          var alpha = Math.max(0, p.life / p.maxLife);
          fireworkCtx.globalAlpha = alpha;
          fireworkCtx.fillStyle = p.color;
          fireworkCtx.fillRect(p.x, p.y, p.size, p.size);
        }
        fireworkCtx.globalAlpha = 1;
      }

      /* ── Handle window resize ── */
      window.addEventListener('resize', function () {
        if (particleCanvas) {
          particleCanvas.width = window.innerWidth;
          particleCanvas.height = window.innerHeight;
        }
        if (fireworkCanvas) {
          fireworkCanvas.width = window.innerWidth;
          fireworkCanvas.height = window.innerHeight;
        }
      });

      /* ── Main animate loop ── */
      function animate(ts) {
        requestAnimationFrame(animate);
        var dt = ts - lastTime;
        if (dt < 50) return;
        lastTime = ts;

        var now = Date.now();

        // Bob
        bobPhase += dt * 0.002;
        var bobY = Math.sin(bobPhase) * 1;

        // Blink timer
        if (wakeBlinkCount > 0) {
          wakeBlinkTimer -= dt;
          if (wakeBlinkTimer <= 0) {
            isBlinking = !isBlinking;
            wakeBlinkTimer = 100;
            if (!isBlinking) wakeBlinkCount--;
          }
        } else {
          blinkTimer -= dt;
          if (blinkTimer <= 0) {
            isBlinking = true;
            setTimeout(function () { isBlinking = false; }, 150);
            blinkTimer = randomBlinkDelay();
          }
        }

        // Jump physics
        if (jumpY < 0 || jumpVel < 0) {
          jumpVel += 0.3;
          jumpY += jumpVel;
          if (jumpY > 0) { jumpY = 0; jumpVel = 0; }
        }

        // Walk offset decay
        if (walkOffset !== 0) {
          var walkElapsed = now - walkDecay;
          if (walkElapsed > 400) {
            walkOffset *= 0.85;
            if (Math.abs(walkOffset) < 0.1) walkOffset = 0;
          }
        }

        // Update timed states
        if (danceActive && now > danceUntil) {
          danceActive = false;
          if (bearState === 'dancing') bearState = 'idle';
        }
        if (dizzyUntil > 0 && now > dizzyUntil) {
          dizzyUntil = 0;
          if (bearState === 'dizzy') bearState = 'idle';
        }
        if (flipActive && now > flipStart + flipDuration) {
          flipActive = false;
          canvas.style.transform = '';
        }
        if (crouchActive && now > crouchUntil) {
          crouchActive = false;
          if (bearState === 'crouching') bearState = 'idle';
        }
        if (blushActive && now > blushUntil) {
          blushActive = false;
          if (bearState === 'blushing') bearState = 'idle';
        }
        if (sunglassesActive && now > sunglassesUntil) {
          sunglassesActive = false;
        }

        // Check idle time for sleep states (only when no active interaction state)
        var idleTime = now - lastInteractionTime;
        if (bearState === 'idle' || bearState === 'sleepy' || bearState === 'sleeping') {
          if (idleTime > 60000) {
            bearState = 'sleeping';
          } else if (idleTime > 30000) {
            bearState = 'sleepy';
          } else {
            bearState = 'idle';
          }
        }

        // Update eye direction
        updateEyeDirection();

        // Determine frame based on state priority:
        // dancing > dizzy > flipping > blushing > crouching > sleeping > sleepy > eye-tracking > idle
        var frame = FRAME_NORMAL;
        var extraOffsetX = 0;
        var extraOffsetY = 0;

        if (danceActive) {
          dancePhase += dt;
          var danceCycle = Math.floor(dancePhase / 200) % 2;
          frame = danceCycle === 0 ? FRAME_DANCE_L : FRAME_DANCE_R;
          extraOffsetY = Math.abs(Math.sin(dancePhase * 0.01)) * -1;
        } else if (dizzyUntil > 0 && now < dizzyUntil) {
          dizzyPhase += dt * 0.01;
          frame = FRAME_DIZZY;
          extraOffsetX = Math.sin(dizzyPhase * 5) * 1;
        } else if (flipActive) {
          var flipProgress = (now - flipStart) / flipDuration;
          var scaleY = Math.cos(flipProgress * Math.PI * 2);
          canvas.style.transform = 'scaleY(' + scaleY.toFixed(3) + ')';
          frame = isBlinking ? FRAME_BLINK : FRAME_NORMAL;
        } else if (sunglassesActive) {
          frame = FRAME_SUNGLASSES;
        } else if (blushActive) {
          frame = FRAME_BLUSH;
        } else if (crouchActive) {
          frame = FRAME_CROUCH;
        } else if (bearState === 'sleeping') {
          frame = FRAME_SLEEP_SIT;
          zSpawnTimer -= dt;
          if (zSpawnTimer <= 0) {
            spawnZ();
            zSpawnTimer = 800 + Math.random() * 400;
          }
        } else if (bearState === 'sleepy') {
          frame = FRAME_SLEEPY;
          sleepyNodPhase += dt * 0.003;
          var nodAmount = Math.sin(sleepyNodPhase) * 1.5;
          var deepDip = Math.sin(sleepyNodPhase * 0.3) > 0.8 ? 1 : 0;
          extraOffsetY = nodAmount + deepDip;
        } else {
          // idle: eye tracking or walk animation
          if (walkOffset !== 0) {
            frame = walkDirection > 0 ? FRAME_DANCE_R : FRAME_DANCE_L;
          } else if (isBlinking) {
            frame = FRAME_BLINK;
          } else {
            frame = getEyeFrame();
          }
        }

        // Override with blink in non-priority states
        if (!danceActive && !(dizzyUntil > 0 && now < dizzyUntil) && !flipActive &&
            !sunglassesActive && !blushActive && !crouchActive &&
            bearState !== 'sleeping' && bearState !== 'sleepy' &&
            isBlinking && walkOffset === 0) {
          frame = FRAME_BLINK;
        }

        draw(frame, bobY + jumpY + extraOffsetY, extraOffsetX + walkOffset);

        // Particles
        updateParticles(dt);
        drawParticlesOnPage();
        updateFireworks(dt);
      }

      requestAnimationFrame(animate);
    })();

    // ── World Map ──
    (function () {
      var map = L.map('worldMap', {
        center: [1.35, 103.82],
        zoom: 3,
