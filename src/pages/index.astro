  <!-- Music Tooltip -->
  <div class="music-tooltip" id="musicTooltip">
    <div class="music-tooltip-title">
      <span data-i18n="music_top10">Top 10 Tracks</span>
      <span class="music-tooltip-period" id="musicTooltipPeriod"></span>
    </div>
