---
import '../styles/photos.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import LangSwitch from '../components/LangSwitch.astro';
import { siteStrings } from '../lib/i18n';
import photosData from '../data/photos.json';

const s = siteStrings.en.photos;
const c = siteStrings.en.common;
const photos = photosData as Array<any>;
---

<BaseLayout
  title={`${s.title} · Airing`}
  description={s.desc}
  lang="en"
>
  <div class="photos-page">
    <header class="masthead">
      <div class="mast-inner">
        <div class="mast-top-rule"></div>
        <div class="mast-bar">
          <a href="/en/blog" class="mast-brand">Airing's Blog</a>
          <div class="mast-links">
            <a href="/en/blog" class="mast-hide-mobile">Blog</a>
            <a href="/en/archive" class="mast-hide-mobile">Archive</a>
            <a href="/en/moments">Moment</a>
            <a href="/en/notes">Notes</a>
            <a href="/photos" class="mast-link-active">Photos</a>
            <a href="/en/friends">Friends</a>
          </div>
        </div>
        <div class="mast-lang-line">
          <LangSwitch lang="en" currentPath="/photos" hasEnVersion={false} />
        </div>
        <div class="mast-bottom-rule"></div>
      </div>
    </header>

    <main class="photos-main">
      <h1 class="photos-title">{s.title}</h1>
      <p class="photos-desc">{s.desc}</p>

      {photos.length === 0 ? (
        <p class="photos-empty">{s.noPhotos}</p>
      ) : (
        <ul class="photos-grid">
          {photos.map((p) => (
            <li class="photo-card" style={`--dom: ${p.dominantColor}`}>
              <a href={`#photo-${p.slug}`} data-slug={p.slug} class="photo-link">
                <div class="photo-frame" style={`aspect-ratio: ${p.width} / ${p.height}`}>
                  <picture>
                    <source
                      type="image/avif"
                      srcset={`${p.variants.thumb.avif} 400w, ${p.variants.medium.avif} 1200w`}
                      sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 33vw"
                    />
                    <source
                      type="image/webp"
                      srcset={`${p.variants.thumb.webp} 400w, ${p.variants.medium.webp} 1200w`}
                      sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 33vw"
                    />
                    <img
                      src={p.variants.medium.webp}
                      alt={p.title || p.slug}
                      width={p.width}
                      height={p.height}
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                </div>
                {(p.exif.camera || p.exif.shutter) && (
                  <div class="photo-exif">
                    {p.exif.camera && <span class="exif-cam">{p.exif.camera}</span>}
                    {p.exif.lens && <span class="exif-lens">{p.exif.lens}</span>}
                    <span class="exif-trio">
                      {p.exif.focalLength || s.exifFallback}
                      <span class="exif-sep">·</span>
                      {p.exif.aperture || s.exifFallback}
                      <span class="exif-sep">·</span>
                      {p.exif.shutter || s.exifFallback}
                      <span class="exif-sep">·</span>
                      ISO {p.exif.iso ?? s.exifFallback}
                    </span>
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>
  </div>

  <style>
    /* Nav */
    .masthead { width: 100%; }
    .mast-inner { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
    .mast-top-rule { height: 4px; background: var(--c-text); margin-top: 24px; }
    .mast-bar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 14px 0; position: relative;
    }
    .mast-brand {
      font-size: 11px; color: var(--c-text-muted); text-decoration: none;
      letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
    }
    .mast-brand:hover { color: var(--c-text); }
    .mast-links { display: flex; gap: 16px; }
    .mast-links a {
      font-size: 11px; color: var(--c-text-dim); text-decoration: none;
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .mast-links a:hover, .mast-link-active { color: var(--c-text) !important; }
    .mast-bottom-rule { height: 1px; background: var(--c-border); }
    .mast-lang-line {
      display: flex;
      justify-content: flex-end;
      padding: 4px 0 8px 0;
    }

    @media (max-width: 640px) {
      .mast-inner { padding: 0 20px; }
      .mast-hide-mobile { display: none; }
    }
  </style>
</BaseLayout>
