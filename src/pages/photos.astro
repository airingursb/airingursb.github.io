---
import '../styles/photos.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import LangSwitch from '../components/LangSwitch.astro';
import { siteStrings } from '../lib/i18n';
import photosData from '../data/photos.json';

const s = siteStrings.en.photos;
const photos = photosData as Array<any>;
---

<BaseLayout
  title={`${s.title} · Airing`}
  description={s.desc}
  lang="en"
>
  <div class="photos-page">
    <header class="masthead">
      <div class="mast-inner">
        <div class="mast-top-rule"></div>
        <div class="mast-bar">
          <a href="/en/blog" class="mast-brand">Airing's Blog</a>
          <button type="button" class="mast-toggle" id="mastToggle" aria-label="Open menu" aria-expanded="false" aria-controls="mastLinks">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M2 4h12 M2 8h12 M2 12h12" />
            </svg>
          </button>
          <div class="mast-links" id="mastLinks">
            <a href="/en/blog">Blog</a>
            <a href="/en/archive">Archive</a>
            <a href="/en/moments">Moment</a>
            <a href="/en/notes">Notes</a>
            <a href="/photos" class="mast-link-active">Photos</a>
            <a href="/en/friends">Friends</a>
          </div>
        </div>
        <div class="mast-lang-line">
          <LangSwitch lang="en" currentPath="/photos" hasEnVersion={false} />
        </div>
        <div class="mast-bottom-rule"></div>
      </div>
    </header>

    <script is:inline>
      (function () {
        var btn = document.getElementById('mastToggle');
        var links = document.getElementById('mastLinks');
        if (!btn || !links) return;
        btn.addEventListener('click', function (e) {
          e.stopPropagation();
          var open = links.classList.toggle('open');
          btn.setAttribute('aria-expanded', String(open));
        });
        document.addEventListener('click', function (e) {
          if (!links.contains(e.target) && !btn.contains(e.target)) {
            links.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
          }
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && links.classList.contains('open')) {
            links.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
          }
        });
      })();
    </script>

    <main class="photos-main">
      <h1 class="photos-title">{s.title}</h1>
      <p class="photos-desc">{s.desc}</p>

      {photos.length === 0 ? (
        <p class="photos-empty">{s.noPhotos}</p>
      ) : (
        <ul class="photos-grid">
          {photos.map((p) => (
            <li class="photo-card" style={`--dom: ${p.dominantColor}`}>
              <a href={`/photos/${p.slug}`} class="photo-link" aria-label={p.title || p.slug}>
                <picture>
                  <source
                    type="image/avif"
                    srcset={`${p.variants.thumb.avif} 400w, ${p.variants.medium.avif} 1200w`}
                    sizes="(max-width: 768px) 50vw, (max-width: 1280px) 33vw, 25vw"
                  />
                  <source
                    type="image/webp"
                    srcset={`${p.variants.thumb.webp} 400w, ${p.variants.medium.webp} 1200w`}
                    sizes="(max-width: 768px) 50vw, (max-width: 1280px) 33vw, 25vw"
                  />
                  <img
                    src={p.variants.medium.webp}
                    alt={p.title || p.slug}
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>
  </div>

  <style>
    /* Nav — matches site convention (max-width 1200 + 768px breakpoint) */
    .masthead { width: 100%; }
    .mast-inner { /* outer .photos-page provides max-width + padding */ }
    .mast-top-rule { height: 4px; background: var(--c-text); margin-top: 24px; }
    .mast-bar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 14px 0; position: relative;
    }
    .mast-brand {
      font-size: 11px; color: var(--c-text-muted); text-decoration: none;
      letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
    }
    .mast-brand:hover { color: var(--c-text); }
    .mast-links { display: flex; gap: 16px; }
    .mast-links a {
      font-size: 11px; color: var(--c-text-dim); text-decoration: none;
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .mast-links a:hover, .mast-link-active { color: var(--c-text) !important; }
    .mast-bottom-rule { height: 1px; background: var(--c-border); }
    .mast-lang-line {
      display: flex;
      justify-content: flex-end;
      padding: 4px 0 8px 0;
    }

    /* Hamburger menu button — desktop hidden, mobile visible */
    .mast-toggle {
      display: none;
      background: transparent;
      border: 0;
      color: var(--c-text);
      cursor: pointer;
      padding: 4px;
      align-items: center;
      justify-content: center;
    }

    @media (max-width: 768px) {
      .mast-toggle { display: inline-flex; }
      .mast-bar { position: relative; }
      .mast-links {
        position: absolute;
        top: calc(100% + 4px);
        right: 0;
        flex-direction: column;
        gap: 0;
        background: var(--c-bg, #0a0a0a);
        border: 1px solid var(--c-border, #2a2a2a);
        border-radius: 6px;
        padding: 4px 0;
        min-width: 160px;
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.35);
        z-index: 50;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-4px);
        transition: opacity 150ms, transform 150ms, visibility 150ms;
      }
      .mast-links.open {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }
      .mast-links a {
        padding: 10px 16px;
        font-size: 12px;
      }
      .mast-links a:hover {
        background: var(--c-bg-elev, #141414);
      }
    }
  </style>
</BaseLayout>
