---
import BaseLayout from '../layouts/BaseLayout.astro';
import Lounge from '../components/Lounge.astro';
---

<BaseLayout title="Lounge · Airing" description="A pixel room where everyone here right now is hanging out.">
  <div class="lounge-page">
    <Lounge />
  </div>
</BaseLayout>

<style is:global>
  body:has(.lounge-page) {
    overflow: hidden;
    background: #0d1117;
  }
  .lounge-page {
    position: fixed;
    inset: 0;
    z-index: 1;
  }
</style>
