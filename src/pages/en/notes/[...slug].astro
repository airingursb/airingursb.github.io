---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { getBacklinks } from '../../../lib/backlinks';
import LangSwitch from '../../../components/LangSwitch.astro';
import { tSite } from '../../../lib/i18n';

export async function getStaticPaths() {
  const notes = await getCollection('notesEn', ({ data }) => data.public && !data.draft);
  const sorted = notes.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
  const zhNotes = await getCollection('notes', ({ data }) => data.public && !data.draft);
  const zhNoteIds = new Set(zhNotes.map(n => n.id));
  return sorted.map(note => ({
    params: { slug: note.id },
    props: {
      note,
      allNotes: sorted,
      hasZh: zhNoteIds.has(note.id),
    },
  }));
}

const { note, allNotes, hasZh } = Astro.props;
const { Content, headings } = await render(note);

const backlinkMap = await getBacklinks('en');
const noteBacklinks = backlinkMap.get(note.data.title.toLowerCase()) || [];

// Related notes: backlinks + notes sharing tags (deduplicated)
const relatedSlugs = new Set(noteBacklinks.map(bl => bl.slug));
const relatedFromTags = allNotes
  .filter(n => n.id !== note.id && !relatedSlugs.has(n.id) && n.data.tags.some(t => note.data.tags.includes(t)))
  .slice(0, 5);
const relatedNotes = [
  ...noteBacklinks.map(bl => ({ title: bl.title, slug: bl.slug })),
  ...relatedFromTags.map(n => ({ title: n.data.title, slug: n.id })),
].slice(0, 8);

const s = tSite('en').notes;

// Reading time: EN pure word count
const wordCount = (note.body ?? '').split(/\s+/).filter(Boolean).length;
const readingTime = s.readingTime(Math.max(1, Math.ceil(wordCount / 200)));

const hreflang = hasZh ? {
  zh: new URL(`/notes/${note.id}/`, Astro.site).href,
  en: new URL(`/en/notes/${note.id}/`, Astro.site).href,
} : undefined;
---
<BaseLayout title={`${note.data.title} | ${s.siteTitle}`} ogImage={`${Astro.site || 'https://ursb.me/'}og/notes/${note.id}.png`} ogType="article" lang="en" hreflang={hreflang}>
  <div class="note-detail-page">
    <header class="masthead">
      <div class="mast-inner">
        <div class="mast-top-rule"></div>
        <div class="mast-bar">
          <a href="/en/blog" class="mast-brand">Airing's Blog</a>
          <div class="mast-links">
            <a href="/en/blog" class="mast-hide-mobile">Blog</a>
            <a href="/en/archive" class="mast-hide-mobile">Archive</a>
            <a href="/en/moments">Moment</a>
            <a href="/en/notes">Notes</a>
            <a href="/en/friends">Friends</a>
          </div>
        </div>
        <div class="mast-lang-line">
          <LangSwitch lang="en" currentPath={`/en/notes/${note.id}`} hasEnVersion={true} />
        </div>
        <div class="mast-bottom-rule"></div>
      </div>
    </header>

    <main class="detail-main">
      <div class="three-col">
        <!-- Left: Note list -->
        <aside class="note-sidebar">
          <div class="sidebar-inner">
            <a href="/en/notes" class="sidebar-back">{s.backToList}</a>
            <div class="sidebar-list">
              {allNotes.map(n => (
                <a
                  href={`/en/notes/${n.id}`}
                  class:list={['sl-item', { active: n.id === note.id }]}
                >
                  <span class="sl-title">{n.data.title}</span>
                  <span class="sl-date">{n.data.date.replace(/-/g, '.')}</span>
                </a>
              ))}
            </div>
          </div>
        </aside>

        <!-- Center: Article -->
        <div class="article-col">
          <header class="article-header">
            <h1>{note.data.title}</h1>
            <div class="article-meta">
              <span>{note.data.date.replace(/-/g, '.')}</span>
              <span class="dot"></span>
              <span>{readingTime}</span>
            </div>
          </header>

          <article class="prose">
            <Content />
          </article>
        </div>

        <!-- Right: TOC + Meta -->
        <aside class="meta-sidebar">
          <div class="meta-inner">
            {headings.length > 0 && (
              <div class="meta-section">
                <div class="meta-label">{s.toc}</div>
                <ul class="toc-list">
                  {headings
                    .filter(h => h.depth <= 3)
                    .map(h => (
                      <li class:list={[{ 'toc-h3': h.depth === 3 }]}>
                        <a href={`#${h.slug}`}>{h.text}</a>
                      </li>
                    ))}
                </ul>
              </div>
            )}

            <div class="meta-section">
              <div class="meta-label">{s.tagsLabel}</div>
              <div class="meta-tags">
                {note.data.tags.map(tag => (
                  <a href={`/en/notes?tag=${encodeURIComponent(tag)}`} class="meta-tag">{tag}</a>
                ))}
              </div>
            </div>

            <!-- Stats block -->
            <div class="meta-section" id="noteStatsBlock" style="display:none;">
              <div class="meta-label">Stats</div>
              <div class="meta-stats">
                <span id="noteViewsDisplay"></span>
                <span id="noteLikesDisplay"></span>
                <span id="noteCommentsDisplay"></span>
              </div>
            </div>

            {relatedNotes.length > 0 && (
              <div class="meta-section">
                <div class="meta-label">{s.relatedNotes}</div>
                <div class="related-list">
                  {relatedNotes.map(r => (
                    <a href={`/en/notes/${r.slug}`} class="related-item">→ {r.title}</a>
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Comment cards rail (absolutely positioned within .meta-sidebar) -->
          <div class="cr-cards" id="commentCards"></div>
        </aside>
      </div>
    </main>

    <!-- Article Like -->
    <div class="article-like-section">
      <div class="al-rule"></div>
      <button class="article-like-btn" id="articleLikeBtn">
        <svg class="al-icon" viewBox="0 0 24 24" fill="none" width="22" height="22">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5" fill="none"/>
        </svg>
        <span class="al-count" id="articleLikeCount">0</span>
        <span class="al-label">likes</span>
      </button>
      <div class="al-rule"></div>
    </div>

    <!-- Bottom Comment Section -->
    <section class="bottom-comments" id="bottomComments">
      <div class="bc-inner">
        <div class="bc-header">
          <h2 class="bc-title">Comments</h2>
          <span class="bc-count" id="bcCount">0 comments</span>
        </div>
        <div class="bc-thread" id="bcThread"></div>
        <div class="bc-compose">
          <div class="bc-compose-avatar">
            <img id="bcComposeAvatar" src="https://gravatar.com/avatar/00000000000000000000000000000000?d=robohash&s=80" alt="" class="bc-avatar-img" />
          </div>
          <div class="bc-compose-form">
            <div class="bc-compose-fields">
              <input type="text" class="bc-input" id="bcNickname" placeholder="Nickname" />
              <input type="email" class="bc-input" id="bcEmail" placeholder="Email" />
              <input type="url" class="bc-input" id="bcWebsite" placeholder="Website (optional)" />
            </div>
            <textarea class="bc-textarea" id="bcTextarea" placeholder="Write a comment..." rows="4"></textarea>
            <div class="bc-compose-footer">
              <label class="bc-notify-label">
                <input type="checkbox" id="bcNotify" />
                <span>Notify me of replies via email</span>
              </label>
              <button class="bc-submit" id="bcSubmit">Submit</button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- FAB button -->
  <button class="fab-comment" id="fabComment" aria-label="Add comment">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
      <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>

  <!-- Comment input popover (desktop) -->
  <div class="comment-input-popover" id="commentPopover">
    <div class="cip-header">
      <span class="cip-selected" id="cipSelectedText"></span>
    </div>
    <div class="cip-identity">
      <input type="text" class="cip-input" id="cipNickname" placeholder="Nickname" />
      <input type="email" class="cip-input" id="cipEmail" placeholder="Email" />
    </div>
    <textarea class="cip-textarea" id="cipTextarea" placeholder="Write a comment..." rows="3"></textarea>
    <div class="cip-actions">
      <button class="cip-cancel" id="cipCancel">Cancel</button>
      <button class="cip-submit" id="cipSubmit">Comment</button>
    </div>
  </div>

  <!-- Mobile bottom sheet -->
  <div class="mobile-sheet-overlay" id="mobileOverlay"></div>
  <div class="mobile-sheet" id="mobileSheet">
    <div class="ms-handle"></div>
    <div class="ms-quote" id="msQuote"></div>
    <div class="ms-body" id="msBody"></div>
    <div class="ms-author" id="msAuthor"></div>
    <div class="ms-time" id="msTime"></div>
    <div class="ms-replies" id="msReplies"></div>
    <button class="ms-reply-toggle" id="msReplyToggle">Reply</button>
    <div class="ms-reply-form" id="msReplyForm" style="display:none;">
      <div class="ms-rf-identity">
        <input type="text" class="ms-rf-input" id="msRfNickname" placeholder="Nickname" />
        <input type="email" class="ms-rf-input" id="msRfEmail" placeholder="Email" />
      </div>
      <textarea class="ms-rf-textarea" id="msRfTextarea" placeholder="Write a reply..." rows="2"></textarea>
      <label class="ms-rf-notify"><input type="checkbox" id="msRfNotify" checked /> Notify me of replies</label>
      <div class="ms-rf-actions">
        <button class="ms-rf-cancel" id="msRfCancel">Cancel</button>
        <button class="ms-rf-submit" id="msRfSubmit">Reply</button>
      </div>
    </div>
  </div>

  <script is:inline>
  (function() {
    // TOC active state highlighting
    var tocLinks = document.querySelectorAll('.toc-list a');
    if (tocLinks.length) {
      var headingEls = Array.from(tocLinks).map(function(a) {
        var id = decodeURIComponent(a.getAttribute('href').slice(1));
        return document.getElementById(id);
      }).filter(Boolean);

      var current = '';
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) current = entry.target.id;
        });
        tocLinks.forEach(function(link) {
          var li = link.parentElement;
          var id = decodeURIComponent(link.getAttribute('href').slice(1));
          if (id === current) li.classList.add('active');
          else li.classList.remove('active');
        });
      }, { rootMargin: '0px 0px -70% 0px', threshold: 0 });

      headingEls.forEach(function(el) { observer.observe(el); });
    }
  })();
  </script>

  <script is:inline>
  (function() {
    var API = 'https://chat.ursb.me';
    var NOTE_SLUG = 'note/' + location.pathname.replace(/^\/(?:en\/)?notes\//, '').replace(/\/$/, '');
    var USER_KEY = 'blog-user-identity';

    // Track pageview (fire-and-forget)
    fetch(API + '/api/posts/' + encodeURIComponent(NOTE_SLUG) + '/view', { method: 'POST' }).catch(function() {});

    // Fetch and display view count
    fetch(API + '/api/posts/' + encodeURIComponent(NOTE_SLUG) + '/views')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var pv = d.pv || 0;
        if (pv > 0) {
          var el = document.getElementById('noteViewsDisplay');
          if (el) { el.textContent = pv.toLocaleString() + ' views'; el.style.display = 'block'; }
          showStatsBlock();
        }
      })
      .catch(function() {});

    function showStatsBlock() {
      var block = document.getElementById('noteStatsBlock');
      if (block) block.style.display = '';
    }

    var postContent = document.querySelector('.prose');
    var contentGrid = document.querySelector('.three-col');
    var commentRail = document.querySelector('.meta-sidebar');
    var commentCards = document.getElementById('commentCards');
    var fab = document.getElementById('fabComment');
    var popover = document.getElementById('commentPopover');
    var cipText = document.getElementById('cipSelectedText');
    var cipNickname = document.getElementById('cipNickname');
    var cipEmailInput = document.getElementById('cipEmail');
    var cipArea = document.getElementById('cipTextarea');
    var cipCancel = document.getElementById('cipCancel');
    var cipSubmit = document.getElementById('cipSubmit');
    var mobileOverlay = document.getElementById('mobileOverlay');
    var mobileSheet = document.getElementById('mobileSheet');
    var msQuote = document.getElementById('msQuote');
    var msBody = document.getElementById('msBody');
    var msAuthor = document.getElementById('msAuthor');
    var msTime = document.getElementById('msTime');

    // Bottom comments
    var bcThread = document.getElementById('bcThread');
    var bcCount = document.getElementById('bcCount');
    var bcNickname = document.getElementById('bcNickname');
    var bcEmail = document.getElementById('bcEmail');
    var bcWebsite = document.getElementById('bcWebsite');
    var bcTextarea = document.getElementById('bcTextarea');
    var bcNotify = document.getElementById('bcNotify');
    var bcSubmit = document.getElementById('bcSubmit');
    var bcComposeAvatar = document.getElementById('bcComposeAvatar');

    // Article like
    var articleLikeBtn = document.getElementById('articleLikeBtn');
    var articleLikeCount = document.getElementById('articleLikeCount');

    var pendingRange = null;
    var activeMobileCommentId = null;
    var inlineComments = [];
    var bottomComments = [];

    function isMobile() { return window.innerWidth <= 960; }

    // --- User identity persistence ---
    function getSavedIdentity() {
      try { return JSON.parse(localStorage.getItem(USER_KEY)) || {}; } catch(e) { return {}; }
    }
    function saveIdentity(nickname, email, website) {
      localStorage.setItem(USER_KEY, JSON.stringify({ nickname: nickname, email: email, website: website || '' }));
    }
    function restoreIdentity() {
      var id = getSavedIdentity();
      if (id.nickname) {
        if (cipNickname) cipNickname.value = id.nickname;
        if (bcNickname) bcNickname.value = id.nickname;
      }
      if (id.email) {
        if (cipEmailInput) cipEmailInput.value = id.email;
        if (bcEmail) { bcEmail.value = id.email; updateComposeAvatar(id.email); }
      }
      if (id.website && bcWebsite) bcWebsite.value = id.website;
    }

    var AUTHOR_EMAILS = {
      'me@ursb.me': 'https://avatars.githubusercontent.com/u/10513408?v=4&s=80',
      'airing@ursb.me': 'https://avatars.githubusercontent.com/u/10513408?v=4&s=80',
    };
    var gravatarCache = {};
    async function sha256Hex(str) {
      var buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
      return Array.from(new Uint8Array(buf)).map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');
    }
    function gravatarUrl(email) {
      var e = (email || '').trim().toLowerCase();
      if (AUTHOR_EMAILS[e]) return AUTHOR_EMAILS[e];
      if (gravatarCache[e]) return gravatarCache[e];
      // Start async hash, return placeholder for now
      sha256Hex(e).then(function(h) { gravatarCache[e] = 'https://gravatar.com/avatar/' + h + '?d=robohash&s=80'; });
      return 'https://gravatar.com/avatar/?d=robohash&s=80';
    }
    function commentAvatarUrl(comment) {
      if (comment && comment.avatar) return comment.avatar;
      return gravatarUrl(comment ? comment.email : '');
    }
    function updateComposeAvatar(email) {
      if (email && bcComposeAvatar) bcComposeAvatar.src = gravatarUrl(email);
    }

    var avatarTimer;
    if (bcEmail) {
      bcEmail.addEventListener('input', function() {
        clearTimeout(avatarTimer);
        avatarTimer = setTimeout(function() { updateComposeAvatar(bcEmail.value); }, 500);
      });
    }

    // --- API helpers ---
    function handleResponse(r) {
      return r.json().then(function(data) {
        if (!r.ok) return Promise.reject(data);
        return data;
      });
    }
    function apiGet(path) {
      return fetch(API + path, { headers: { 'Origin': location.origin } }).then(handleResponse);
    }
    function apiPost(path, body) {
      return fetch(API + path, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      }).then(handleResponse);
    }

    // =====================================================================
    // INLINE (HIGHLIGHT) COMMENTS — right rail
    // =====================================================================

    function wrapRange(range, id) {
      var mark = document.createElement('mark');
      mark.className = 'comment-highlight';
      mark.dataset.commentId = id;
      try { range.surroundContents(mark); }
      catch(e) {
        var fragment = range.extractContents();
        mark.appendChild(fragment);
        range.insertNode(mark);
      }
      return mark;
    }

    function restoreHighlights() {
      if (!postContent) return;
      inlineComments.forEach(function(c) {
        if (postContent.querySelector('mark[data-comment-id="' + c.id + '"]')) return;
        var searchText = c.selected_text;
        if (!searchText) return;
        var walker = document.createTreeWalker(postContent, NodeFilter.SHOW_TEXT, null, false);
        var node;
        while (node = walker.nextNode()) {
          var idx = node.textContent.indexOf(searchText);
          if (idx === -1) continue;
          var range = document.createRange();
          range.setStart(node, idx);
          range.setEnd(node, idx + searchText.length);
          wrapRange(range, c.id);
          break;
        }
      });
    }

    function removeHighlight(id) {
      if (!postContent) return;
      var marks = postContent.querySelectorAll('mark[data-comment-id="' + id + '"]');
      marks.forEach(function(mark) {
        var parent = mark.parentNode;
        while (mark.firstChild) parent.insertBefore(mark.firstChild, mark);
        parent.removeChild(mark);
        parent.normalize();
      });
    }

    function offsetFromGrid(el) {
      var top = 0;
      while (el && el !== contentGrid) { top += el.offsetTop; el = el.offsetParent; }
      return top;
    }

    function layoutCards() {
      if (!commentCards || !commentRail || !postContent) return;
      var cards = commentCards.querySelectorAll('.cm-card');
      if (!cards.length) return;
      var railOffset = offsetFromGrid(commentRail);
      var positions = [];
      cards.forEach(function(card) {
        var id = card.dataset.commentId;
        var mark = postContent.querySelector('mark[data-comment-id="' + id + '"]');
        var desiredTop = 0;
        if (mark) desiredTop = offsetFromGrid(mark) - railOffset;
        positions.push({ card: card, desired: desiredTop, height: card.offsetHeight });
      });
      positions.sort(function(a, b) { return a.desired - b.desired; });
      var GAP = 8, nextAvailable = 0;
      positions.forEach(function(p) {
        var top = Math.max(p.desired, nextAvailable);
        p.card.style.top = top + 'px';
        nextAvailable = top + p.height + GAP;
      });
      commentCards.style.minHeight = nextAvailable + 'px';
    }

    function renderInlineComments() {
      if (!commentCards) return;
      commentCards.innerHTML = '';

      inlineComments.forEach(function(c) {
        if (!c.replies) c.replies = [];
        var card = document.createElement('div');
        card.className = 'cm-card';
        card.dataset.commentId = c.id;
        var mark = postContent ? postContent.querySelector('mark[data-comment-id="' + c.id + '"]') : null;

        var time = new Date(c.created_at);
        var timeStr = time.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })
          + ' ' + time.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });

        var repliesHtml = '';
        if (c.replies && c.replies.length) {
          repliesHtml = '<div class="cm-replies">';
          c.replies.forEach(function(r) {
            var rTime = new Date(r.created_at);
            var rTimeStr = rTime.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })
              + ' ' + rTime.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
            repliesHtml +=
              '<div class="cm-reply">' +
                '<div class="cm-reply-header">' +
                  '<img class="cm-reply-avatar" src="' + commentAvatarUrl(r) + '" />' +
                  '<span class="cm-reply-name">' + esc(r.nickname) + '</span>' +
                  '<span class="cm-reply-time">' + rTimeStr + '</span>' +
                '</div>' +
                '<div class="cm-reply-body">' + esc(r.comment) + '</div>' +
              '</div>';
          });
          repliesHtml += '</div>';
        }

        card.innerHTML =
          '<div class="cm-card-author">' +
            '<img src="' + commentAvatarUrl(c) + '" class="cm-card-avatar" />' +
            '<span class="cm-card-name">' + esc(c.nickname) + '</span>' +
          '</div>' +
          '<div class="cm-card-quote">\u201c' + esc(trunc(c.selected_text, 50)) + '\u201d</div>' +
          '<div class="cm-card-body">' + esc(c.comment) + '</div>' +
          '<div class="cm-card-footer">' +
            '<span class="cm-card-time">' + timeStr + '</span>' +
          '</div>' +
          repliesHtml +
          '<button class="cm-reply-btn" data-parent-id="' + c.id + '">Reply</button>' +
          '<div class="cm-reply-form" style="display:none;">' +
            '<div class="cm-rf-identity">' +
              '<input class="cm-rf-input" placeholder="Nickname" />' +
              '<input class="cm-rf-input" placeholder="Email" />' +
            '</div>' +
            '<textarea class="cm-rf-textarea" placeholder="Write a reply..." rows="2"></textarea>' +
            '<label class="cm-rf-notify"><input type="checkbox" checked /> Notify me of replies</label>' +
            '<div class="cm-rf-actions">' +
              '<button class="cm-rf-cancel">Cancel</button>' +
              '<button class="cm-rf-submit">Reply</button>' +
            '</div>' +
          '</div>';

        card.addEventListener('mouseenter', function() {
          if (mark) mark.classList.add('highlight-active');
          card.classList.add('cm-card-active');
        });
        card.addEventListener('mouseleave', function() {
          if (mark) mark.classList.remove('highlight-active');
          card.classList.remove('cm-card-active');
        });
        card.addEventListener('click', function(e) {
          if (e.target.closest('.cm-reply-btn') || e.target.closest('.cm-reply-form')) return;
          if (mark) {
            mark.scrollIntoView({ behavior: 'smooth', block: 'center' });
            mark.classList.add('highlight-flash');
            setTimeout(function() { mark.classList.remove('highlight-flash'); }, 1000);
          }
        });
        if (mark) {
          mark.addEventListener('mouseenter', function() { card.classList.add('cm-card-active'); mark.classList.add('highlight-active'); });
          mark.addEventListener('mouseleave', function() { card.classList.remove('cm-card-active'); mark.classList.remove('highlight-active'); });
          mark.addEventListener('click', function(e) {
            if (!isMobile()) return;
            e.preventDefault(); e.stopPropagation();
            openMobileSheet(c);
          });
        }

        commentCards.appendChild(card);

        // Reply button handler
        var replyBtn = card.querySelector('.cm-reply-btn');
        var replyForm = card.querySelector('.cm-reply-form');
        var rfInputs = replyForm.querySelectorAll('.cm-rf-input');
        var rfNickname = rfInputs[0];
        var rfEmail = rfInputs[1];
        var rfTextarea = replyForm.querySelector('.cm-rf-textarea');
        var rfNotify = replyForm.querySelector('.cm-rf-notify input');
        var rfCancel = replyForm.querySelector('.cm-rf-cancel');
        var rfSubmit = replyForm.querySelector('.cm-rf-submit');

        replyBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          replyForm.style.display = '';
          replyBtn.style.display = 'none';
          var identity = getSavedIdentity();
          if (identity.nickname) rfNickname.value = identity.nickname;
          if (identity.email) rfEmail.value = identity.email;
          rfNickname.focus();
          layoutCards();
        });

        rfCancel.addEventListener('click', function(e) {
          e.stopPropagation();
          replyForm.style.display = 'none';
          replyBtn.style.display = '';
          layoutCards();
        });

        rfSubmit.addEventListener('click', function(e) {
          e.stopPropagation();
          var nickname = rfNickname.value.trim();
          var email = rfEmail.value.trim();
          var comment = rfTextarea.value.trim();
          var rfValid = true;
          rfNickname.classList.remove('cip-error');
          rfTextarea.classList.remove('cip-error');
          if (!nickname) { rfNickname.classList.add('cip-error'); rfValid = false; }
          if (!comment) { rfTextarea.classList.add('cip-error'); rfValid = false; }
          if (!rfValid) return;

          saveIdentity(nickname, email);
          rfSubmit.disabled = true;

          apiPost('/api/inline-comments', {
            post_slug: NOTE_SLUG,
            nickname: nickname,
            email: email,
            comment: comment,
            parent_id: c.id,
            notify_replies: rfNotify.checked
          }).then(function(res) {
            if (res.comment) {
              c.replies.push(res.comment);
              renderInlineComments();
            }
          }).finally(function() {
            rfSubmit.disabled = false;
          });
        });
      });

      requestAnimationFrame(function() { requestAnimationFrame(layoutCards); });
    }

    // --- Mobile bottom sheet ---
    function openMobileSheet(comment) {
      activeMobileCommentId = comment.id;
      msQuote.textContent = '\u201c' + trunc(comment.selected_text, 80) + '\u201d';
      msBody.textContent = comment.comment;
      msAuthor.textContent = comment.nickname;
      var time = new Date(comment.created_at);
      msTime.textContent = time.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })
        + ' ' + time.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });

      var repliesEl = document.getElementById('msReplies');
      repliesEl.innerHTML = '';
      if (comment.replies && comment.replies.length) {
        comment.replies.forEach(function(r) {
          var rTime = new Date(r.created_at);
          var rTimeStr = rTime.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })
            + ' ' + rTime.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
          var div = document.createElement('div');
          div.className = 'ms-reply-item';
          div.innerHTML =
            '<div class="ms-reply-header">' +
              '<img src="' + commentAvatarUrl(r) + '" class="ms-reply-avatar" />' +
              '<span class="ms-reply-name">' + esc(r.nickname) + '</span>' +
              '<span class="ms-reply-time">' + rTimeStr + '</span>' +
            '</div>' +
            '<div class="ms-reply-body">' + esc(r.comment) + '</div>';
          repliesEl.appendChild(div);
        });
      }

      document.getElementById('msReplyForm').style.display = 'none';
      document.getElementById('msReplyToggle').style.display = '';
      mobileOverlay.classList.add('active');
      mobileSheet.classList.add('active');
    }

    function closeMobileSheet() {
      mobileOverlay.classList.remove('active');
      mobileSheet.classList.remove('active');
      activeMobileCommentId = null;
    }

    mobileOverlay.addEventListener('click', closeMobileSheet);

    document.getElementById('msReplyToggle').addEventListener('click', function() {
      var form = document.getElementById('msReplyForm');
      form.style.display = 'block';
      this.style.display = 'none';
      var id = getSavedIdentity();
      if (id.nickname) document.getElementById('msRfNickname').value = id.nickname;
      if (id.email) document.getElementById('msRfEmail').value = id.email;
      document.getElementById('msRfNickname').focus();
    });

    document.getElementById('msRfCancel').addEventListener('click', function() {
      document.getElementById('msReplyForm').style.display = 'none';
      document.getElementById('msReplyToggle').style.display = '';
    });

    document.getElementById('msRfSubmit').addEventListener('click', function() {
      var nickname = document.getElementById('msRfNickname').value.trim();
      var email = document.getElementById('msRfEmail').value.trim();
      var text = document.getElementById('msRfTextarea').value.trim();
      var notify = document.getElementById('msRfNotify').checked;
      var msNickEl = document.getElementById('msRfNickname');
      var msTextEl = document.getElementById('msRfTextarea');
      var msValid = true;
      msNickEl.classList.remove('cip-error');
      msTextEl.classList.remove('cip-error');
      if (!nickname) { msNickEl.classList.add('cip-error'); msValid = false; }
      if (!text) { msTextEl.classList.add('cip-error'); msValid = false; }
      if (!msValid || !activeMobileCommentId) return;

      saveIdentity(nickname, email);
      var submitBtn = this;
      submitBtn.disabled = true;
      submitBtn.textContent = '...';

      apiPost('/api/inline-comments', {
        post_slug: NOTE_SLUG,
        nickname: nickname,
        email: email,
        comment: text,
        parent_id: activeMobileCommentId,
        notify_replies: notify,
      }).then(function(res) {
        if (res.comment) {
          var parent = inlineComments.find(function(c) { return c.id === activeMobileCommentId; });
          if (parent) {
            if (!parent.replies) parent.replies = [];
            parent.replies.push(res.comment);
          }
          closeMobileSheet();
          renderInlineComments();
        }
      }).finally(function() {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Reply';
      });
    });

    // --- FAB: show on text selection ---
    fab.style.display = 'none';
    popover.style.display = 'none';

    document.addEventListener('mouseup', function(e) {
      if (popover.style.display !== 'none') return;
      if (isMobile()) { fab.style.display = 'none'; return; }
      var sel = window.getSelection();
      if (!sel || sel.isCollapsed || !sel.rangeCount) { fab.style.display = 'none'; return; }
      var range = sel.getRangeAt(0);
      if (!postContent || !postContent.contains(range.commonAncestorContainer)) { fab.style.display = 'none'; return; }
      var text = sel.toString().trim();
      if (!text) { fab.style.display = 'none'; return; }
      var rect = range.getBoundingClientRect();
      fab.style.display = 'flex';
      fab.style.top = (rect.top + window.scrollY - 36) + 'px';
      fab.style.left = (rect.right + window.scrollX + 8) + 'px';
      pendingRange = range.cloneRange();
    });

    document.addEventListener('selectionchange', function() {
      if (!isMobile()) return;
      var sel = window.getSelection();
      if (!sel || sel.isCollapsed || !sel.rangeCount) { fab.style.display = 'none'; return; }
      var range = sel.getRangeAt(0);
      if (!postContent || !postContent.contains(range.commonAncestorContainer)) { fab.style.display = 'none'; return; }
      var text = sel.toString().trim();
      if (!text) { fab.style.display = 'none'; return; }
      var rect = range.getBoundingClientRect();
      fab.style.display = 'flex';
      fab.style.top = (rect.bottom + window.scrollY + 8) + 'px';
      fab.style.left = (rect.left + window.scrollX + (rect.width / 2) - 14) + 'px';
      pendingRange = range.cloneRange();
    });

    document.addEventListener('mousedown', function(e) {
      if (fab.contains(e.target) || popover.contains(e.target)) return;
      if (popover.style.display === 'none') fab.style.display = 'none';
    });

    fab.addEventListener('click', function(e) {
      e.preventDefault(); e.stopPropagation();
      if (!pendingRange) return;
      var selectedText = pendingRange.toString().trim();
      if (!selectedText) return;
      cipText.textContent = '\u201c' + trunc(selectedText, 60) + '\u201d';
      cipArea.value = '';
      var rect = pendingRange.getBoundingClientRect();
      if (isMobile()) {
        popover.style.top = (rect.bottom + window.scrollY + 12) + 'px';
        popover.style.left = '50%';
        popover.style.transform = 'translateX(-50%)';
      } else {
        popover.style.top = (rect.top + window.scrollY) + 'px';
        popover.style.left = (postContent.getBoundingClientRect().right + 24) + 'px';
        popover.style.transform = '';
      }
      popover.style.display = 'block';
      fab.style.display = 'none';
      cipNickname.focus();
    });

    cipCancel.addEventListener('click', function() {
      popover.style.display = 'none';
      pendingRange = null;
      window.getSelection().removeAllRanges();
    });

    cipSubmit.addEventListener('click', function() {
      var text = cipArea.value.trim();
      var nickname = cipNickname.value.trim();
      var email = cipEmailInput.value.trim();

      var valid = true;
      cipNickname.classList.remove('cip-error');
      cipArea.classList.remove('cip-error');
      if (!nickname) { cipNickname.classList.add('cip-error'); valid = false; }
      if (!text) { cipArea.classList.add('cip-error'); valid = false; }
      if (!valid || !pendingRange) return;

      var selectedText = pendingRange.toString().trim();
      saveIdentity(nickname, email);
      cipSubmit.disabled = true;
      cipSubmit.textContent = '...';

      apiPost('/api/inline-comments', {
        post_slug: NOTE_SLUG,
        nickname: nickname,
        email: email,
        selected_text: selectedText,
        comment: text,
        range_start: 0,
        range_end: selectedText.length,
        notify_replies: true
      }).then(function(res) {
        if (res.comment) {
          wrapRange(pendingRange, res.comment.id);
          inlineComments.push(res.comment);
          renderInlineComments();
        }
        popover.style.display = 'none';
        pendingRange = null;
        window.getSelection().removeAllRanges();
      }).finally(function() {
        cipSubmit.disabled = false;
        cipSubmit.textContent = 'Comment';
      });
    });

    cipArea.addEventListener('keydown', function(e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') cipSubmit.click();
      if (e.key === 'Escape') cipCancel.click();
    });

    var layoutTimer;
    window.addEventListener('resize', function() {
      clearTimeout(layoutTimer);
      layoutTimer = setTimeout(layoutCards, 60);
    });

    // =====================================================================
    // ARTICLE LIKES
    // =====================================================================
    var articleLiked = false;

    function loadArticleLikes() {
      apiGet('/api/posts/' + encodeURIComponent(NOTE_SLUG) + '/likes').then(function(res) {
        articleLikeCount.textContent = res.count;
        articleLiked = res.liked;
        if (articleLiked) articleLikeBtn.classList.add('liked');
        if (res.count > 0) {
          var lkEl = document.getElementById('noteLikesDisplay');
          if (lkEl) { lkEl.textContent = res.count.toLocaleString() + ' likes'; lkEl.style.display = 'block'; }
          showStatsBlock();
        }
        try {
          var stored = JSON.parse(localStorage.getItem('post_likes') || '[]');
          var set = new Set(stored);
          if (res.liked) set.add(NOTE_SLUG); else set.delete(NOTE_SLUG);
          localStorage.setItem('post_likes', JSON.stringify(Array.from(set)));
        } catch(e) {}
      });
    }

    articleLikeBtn.addEventListener('click', function() {
      var prevLiked = articleLiked;
      var prevCount = parseInt(articleLikeCount.textContent) || 0;
      var newLiked = !prevLiked;
      var newCount = newLiked ? prevCount + 1 : Math.max(0, prevCount - 1);

      articleLiked = newLiked;
      articleLikeCount.textContent = newCount;
      articleLikeBtn.classList.toggle('liked', newLiked);
      var icon = articleLikeBtn.querySelector('.al-icon path');
      icon.setAttribute('fill', newLiked ? 'currentColor' : 'none');

      apiPost('/api/posts/' + encodeURIComponent(NOTE_SLUG) + '/like', {}).then(function(res) {
        articleLiked = res.liked;
        articleLikeCount.textContent = res.count;
        articleLikeBtn.classList.toggle('liked', res.liked);
        icon.setAttribute('fill', res.liked ? 'currentColor' : 'none');
        var lkEl = document.getElementById('noteLikesDisplay');
        if (res.count > 0) {
          if (lkEl) { lkEl.textContent = res.count.toLocaleString() + ' likes'; lkEl.style.display = 'block'; }
          showStatsBlock();
        } else {
          if (lkEl) lkEl.style.display = 'none';
        }
        try {
          var stored = JSON.parse(localStorage.getItem('post_likes') || '[]');
          var set = new Set(stored);
          if (res.liked) set.add(NOTE_SLUG); else set.delete(NOTE_SLUG);
          localStorage.setItem('post_likes', JSON.stringify(Array.from(set)));
        } catch(e) {}
      }).catch(function() {
        articleLiked = prevLiked;
        articleLikeCount.textContent = prevCount;
        articleLikeBtn.classList.toggle('liked', prevLiked);
        icon.setAttribute('fill', prevLiked ? 'currentColor' : 'none');
      });
    });

    // =====================================================================
    // BOTTOM COMMENTS
    // =====================================================================

    function loadBottomComments() {
      apiGet('/api/comments?post_slug=' + encodeURIComponent(NOTE_SLUG)).then(function(res) {
        bottomComments = res.comments || [];
        renderBottomComments();
      });
    }

    function renderBottomComments() {
      bcThread.innerHTML = '';
      var count = bottomComments.length;
      bcCount.textContent = count + ' comment' + (count !== 1 ? 's' : '');
      if (count > 0) {
        var cmEl = document.getElementById('noteCommentsDisplay');
        if (cmEl) { cmEl.textContent = count.toLocaleString() + ' comments'; cmEl.style.display = 'block'; }
        showStatsBlock();
      }

      var roots = [];
      var byId = {};
      bottomComments.forEach(function(c) { c._replies = []; byId[c.id] = c; });
      bottomComments.forEach(function(c) {
        if (c.parent_id && byId[c.parent_id]) byId[c.parent_id]._replies.push(c);
        else roots.push(c);
      });

      roots.forEach(function(c) { bcThread.appendChild(buildCommentEl(c, false)); });
    }

    function buildCommentEl(c, isReply) {
      var div = document.createElement('div');
      div.className = 'bc-item' + (isReply ? ' bc-reply' : '');

      var time = new Date(c.created_at);
      var timeStr = time.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });

      var avatarSize = isReply ? 32 : 40;
      var nameHtml = c.website
        ? '<a class="bc-name bc-name-link" href="' + esc(c.website) + '" target="_blank" rel="noopener noreferrer">' + esc(c.nickname) + '</a>'
        : '<span class="bc-name">' + esc(c.nickname) + '</span>';
      div.innerHTML =
        '<div class="bc-avatar-wrap"><img src="' + commentAvatarUrl(c) + '" class="bc-avatar-img" style="width:' + avatarSize + 'px;height:' + avatarSize + 'px" /></div>' +
        '<div class="bc-body">' +
          '<div class="bc-meta">' +
            nameHtml +
            '<span class="bc-dot">&middot;</span>' +
            '<time class="bc-time">' + timeStr + '</time>' +
          '</div>' +
          '<div class="bc-text"><p>' + linkify(esc(c.content)).replace(/\n/g, '<br>') + '</p></div>' +
          '<div class="bc-actions">' +
            '<button class="bc-like-btn' + (c._userLiked ? ' liked' : '') + '" data-id="' + c.id + '">' +
              '<svg viewBox="0 0 24 24" width="14" height="14"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>' +
              '<span>' + (c.likes || 0) + '</span>' +
            '</button>' +
            '<button class="bc-reply-btn" data-id="' + c.id + '">Reply</button>' +
          '</div>' +
          '<div class="bc-replies-container"></div>' +
        '</div>';

      div.querySelector('.bc-like-btn').addEventListener('click', function() {
        var btn = this;
        var icon = btn.querySelector('path');
        var span = btn.querySelector('span');
        var wasLiked = btn.classList.contains('liked');
        var prevCount = parseInt(span.textContent) || 0;
        var newLiked = !wasLiked;
        var newCount = newLiked ? prevCount + 1 : Math.max(0, prevCount - 1);

        btn.classList.toggle('liked', newLiked);
        span.textContent = newCount;
        icon.setAttribute('fill', newLiked ? 'currentColor' : 'none');

        apiPost('/api/comments/' + c.id + '/like', {}).then(function(res) {
          btn.classList.toggle('liked', res.liked);
          span.textContent = res.count;
          icon.setAttribute('fill', res.liked ? 'currentColor' : 'none');
        }).catch(function() {
          btn.classList.toggle('liked', wasLiked);
          span.textContent = prevCount;
          icon.setAttribute('fill', wasLiked ? 'currentColor' : 'none');
        });
      });

      div.querySelector('.bc-reply-btn').addEventListener('click', function() {
        bcTextarea.value = '@' + c.nickname + ' ';
        bcTextarea.dataset.parentId = c.id;
        bcTextarea.focus();
        bcTextarea.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });

      var repliesContainer = div.querySelector('.bc-replies-container');
      if (c._replies && c._replies.length) {
        c._replies.forEach(function(r) {
          repliesContainer.appendChild(buildCommentEl(r, true));
        });
      }

      return div;
    }

    bcSubmit.addEventListener('click', function() {
      var content = bcTextarea.value.trim();
      var nickname = bcNickname.value.trim();
      var email = bcEmail.value.trim();
      var website = bcWebsite.value.trim();
      if (!content || !nickname || !email) return;

      saveIdentity(nickname, email, website);
      bcSubmit.disabled = true;
      bcSubmit.textContent = '...';

      var parentId = bcTextarea.dataset.parentId || null;
      var body = {
        post_slug: NOTE_SLUG,
        nickname: nickname,
        email: email,
        content: content,
        parent_id: parentId ? parseInt(parentId) : null,
        notify_replies: bcNotify.checked
      };
      if (website) body.website = website;

      apiPost('/api/comments', body).then(function(res) {
        if (res.comment) {
          bottomComments.push(res.comment);
          renderBottomComments();
          bcTextarea.value = '';
          delete bcTextarea.dataset.parentId;
        }
      }).finally(function() {
        bcSubmit.disabled = false;
        bcSubmit.textContent = 'Submit';
      });
    });

    bcTextarea.addEventListener('keydown', function(e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') bcSubmit.click();
    });

    // =====================================================================
    // INIT
    // =====================================================================
    restoreIdentity();

    apiGet('/api/inline-comments?post_slug=' + encodeURIComponent(NOTE_SLUG)).then(function(res) {
      inlineComments = res.comments || [];
      restoreHighlights();
      renderInlineComments();
    });

    loadArticleLikes();
    loadBottomComments();

    // --- Helpers ---
    function trunc(s, n) { return s.length > n ? s.slice(0, n) + '\u2026' : s; }
    function esc(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function linkify(s) { return s.replace(/(https?:\/\/[^\s<)]+)/g, '<a href="$1" target="_blank" rel="noopener noreferrer">$1</a>'); }
  })();
  </script>
</BaseLayout>

<style is:global>
  body:has(.note-detail-page) {
    display: block;
    padding: 0;
    align-items: stretch;
    justify-content: stretch;
  }

  /* Prose styles for notes */
  .note-detail-page .prose {
    font-size: 18px;
    line-height: 2.0;
    color: var(--c-text);
    font-family: 'Noto Serif SC', 'Source Han Serif CN', 'Source Han Serif SC', 'Songti SC', STSong, serif;
    letter-spacing: 0.02em;
  }
  .note-detail-page .prose p { margin-bottom: 24px; }
  .note-detail-page .prose h2 {
    font-family: 'Noto Serif SC', 'Source Han Serif CN', 'Songti SC', serif;
    font-size: 24px; font-weight: 700;
    margin-top: 48px; margin-bottom: 20px;
    color: var(--c-text);
    line-height: 1.4; letter-spacing: 0.01em;
  }
  .note-detail-page .prose h3 {
    font-family: 'Noto Serif SC', 'Source Han Serif CN', 'Songti SC', serif;
    font-size: 19px; font-weight: 600;
    margin-top: 40px; margin-bottom: 16px;
    color: var(--c-text);
    line-height: 1.45;
  }
  .note-detail-page .prose a {
    color: var(--accent); text-decoration: none;
    border-bottom: 1px solid rgba(var(--accent-rgb, 74,222,128), 0.25);
  }
  .note-detail-page .prose a:hover { border-bottom-color: var(--accent); }
  .note-detail-page .prose code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
    background: rgba(var(--c-overlay-rgb), 0.06);
    padding: 2px 6px;
    border-radius: 4px;
  }
  .note-detail-page .prose pre {
    background: #1e1e2e;
    border-radius: 10px;
    padding: 20px;
    overflow-x: auto;
    margin: 24px 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    line-height: 1.7;
  }
  .note-detail-page .prose pre code {
    background: none;
    padding: 0;
    border-radius: 0;
    color: #cdd6f4;
  }
  .note-detail-page .prose blockquote {
    border-left: 3px solid var(--accent);
    padding-left: 16px;
    margin: 24px 0;
    color: var(--c-text-dim);
  }
  .note-detail-page .prose img {
    max-width: 100%;
    border-radius: 8px;
    margin: 16px 0;
  }
  .note-detail-page .prose ul, .note-detail-page .prose ol {
    padding-left: 24px;
    margin-bottom: 20px;
  }
  .note-detail-page .prose li { margin-bottom: 6px; }

  /* Interactive component blocks */
  .note-detail-page .interactive-block {
    margin: 32px 0;
    border: 1px solid var(--c-border);
    border-radius: 12px;
    overflow: hidden;
    background: rgba(var(--c-overlay-rgb), 0.02);
  }
  .note-detail-page .interactive-block-header {
    padding: 12px 20px;
    display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1px solid var(--c-border);
    font-size: 12px; color: var(--c-text-dim);
  }
  .note-detail-page .interactive-block-body {
    padding: 32px;
    min-height: 200px;
  }

  /* Wikilink style */
  .note-detail-page .wikilink {
    color: var(--accent);
    border-bottom: 1px dashed var(--accent);
    padding-bottom: 1px;
  }
  .note-detail-page .wikilink:hover { border-bottom-style: solid; }

  /* ===== Highlights ===== */
  .note-detail-page .prose mark.comment-highlight {
    background: rgba(var(--accent-rgb, 74,222,128), 0.08);
    color: inherit;
    border-bottom: 2px solid rgba(var(--accent-rgb, 74,222,128), 0.35);
    padding: 1px 0;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .note-detail-page .prose mark.comment-highlight.highlight-active {
    background: rgba(var(--accent-rgb, 74,222,128), 0.18);
    border-bottom-color: var(--accent);
  }
  .note-detail-page .prose mark.comment-highlight.highlight-flash {
    animation: highlightFlash 1s ease;
  }

  /* ===== Comment cards in meta sidebar ===== */
  .cr-cards {
    position: absolute;
    top: 0; left: 0; right: 0;
    pointer-events: none;
  }
  .cr-cards .cm-card {
    pointer-events: auto;
  }
  .cr-cards .cm-card {
    position: absolute;
    left: 0; right: 0;
    background: transparent;
    border: 1px solid var(--c-border);
    border-radius: 6px;
    padding: 12px;
    font-size: 12px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    animation: fadeInCard 0.2s ease;
  }
  .cr-cards .cm-card-active,
  .cr-cards .cm-card:hover {
    border-color: rgba(74,222,128,0.4);
    background: rgba(74,222,128,0.03);
    box-shadow: -3px 0 0 0 var(--accent);
