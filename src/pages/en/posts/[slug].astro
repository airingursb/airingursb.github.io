---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const enPosts = (await getCollection('postsEn', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  const allZhPosts = (await getCollection('posts', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  // English post IDs already match Chinese post IDs directly (both live under
  // their respective content directories with identical filenames).
  const enSlugs = new Set(enPosts.map(p => p.id));

  return enPosts.map((enPost) => {
    const zhSlug = enPost.id;

    // Find prev/next among English-translated posts (by date)
    const enPostsSorted = [...enPosts].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
    const idx = enPostsSorted.findIndex(p => p.id === enPost.id);

    const prevPost = idx > 0
      ? { slug: enPostsSorted[idx - 1].id, title: enPostsSorted[idx - 1].data.title }
      : null;
    const nextPost = idx < enPostsSorted.length - 1
      ? { slug: enPostsSorted[idx + 1].id, title: enPostsSorted[idx + 1].data.title }
      : null;

    // Related posts: only show posts that have English translations.
    // Better to show fewer (or none) than send EN readers to a Chinese page.
    const primaryTag = enPost.data.tags[0];
    const relatedPosts = primaryTag
      ? enPosts
          .filter(p => p.id !== enPost.id && p.data.tags.includes(primaryTag))
          .slice(0, 5)
          .map(p => ({
            slug: p.id,
            title: p.data.title,
          }))
      : [];

    // Series info
    const seriesTags = ['weekly', 'annually'];
    const seriesTag = enPost.data.tags.find((t: string) => seriesTags.includes(t));
    let seriesInfo = null;
    if (seriesTag) {
      const seriesPosts = allZhPosts
        .filter(p => p.data.tags.includes(seriesTag))
        .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
      const seriesIdx = seriesPosts.findIndex(p => p.id === zhSlug);
      if (seriesIdx >= 0) {
        const prevSeries = seriesIdx > 0 ? seriesPosts[seriesIdx - 1] : null;
        const nextSeries = seriesIdx < seriesPosts.length - 1 ? seriesPosts[seriesIdx + 1] : null;
        seriesInfo = {
          tag: seriesTag,
          total: seriesPosts.length,
          current: seriesIdx + 1,
          prev: prevSeries ? {
            slug: prevSeries.id,
            title: (() => {
              const enVer = enPosts.find(ep => ep.id === prevSeries.id);
              return enVer ? enVer.data.title : prevSeries.data.title;
            })(),
          } : null,
          next: nextSeries ? {
            slug: nextSeries.id,
            title: (() => {
              const enVer = enPosts.find(ep => ep.id === nextSeries.id);
              return enVer ? enVer.data.title : nextSeries.data.title;
            })(),
          } : null,
        };
      }
    }

    return {
      params: { slug: zhSlug },
      props: { enPost, relatedPosts, prevPost, nextPost, seriesInfo, zhSlug },
    };
  });
}

const { enPost, relatedPosts, prevPost, nextPost, seriesInfo, zhSlug } = Astro.props;
const { Content } = await render(enPost);

// Reading time: English word count / 200
const contentOnly = enPost.body ?? '';
const wordCount = contentOnly.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const hreflang = {
  zh: new URL(`/posts/${zhSlug}/`, Astro.site).href,
  en: new URL(`/en/posts/${zhSlug}/`, Astro.site).href,
};
---

<PostLayout
  title={enPost.data.title}
  date={enPost.data.date}
  tags={enPost.data.tags}
  description={enPost.data.description}
  cover={enPost.data.cover}
  prevPost={prevPost}
  nextPost={nextPost}
  relatedPosts={relatedPosts}
  seriesInfo={seriesInfo}
  readingTime={readingTime}
  lang="en"
  hreflang={hreflang}
>
  <Content />
</PostLayout>
