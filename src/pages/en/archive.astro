---
/**
 * Archive List B — Two-Column with Year Sidebar
 * Sticky year navigation on the left, scrollable post list on the right.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LangSwitch from '../../components/LangSwitch.astro';
import { tSite } from '../../lib/i18n';

const s = tSite('en').archive;

const posts = (await getCollection('postsEn', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postsByYear = posts.reduce((acc, post) => {
  const year = post.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof posts>);

const years = Object.keys(postsByYear).map(Number).sort((a, b) => b - a);

function formatDate(date: Date) {
  return date.toLocaleDateString(s.dateLocale, { month: 'short', day: 'numeric' });
}

const tagColors: Record<string, string> = {
  tech: 'var(--accent)', weekly: '#60a5fa', annually: '#f59e0b',
};
function getTagColor(tag: string) {
  return tagColors[tag] || 'var(--c-text-muted)';
}
---

<BaseLayout title={`${s.title} | Airing`} lang="en">
  <div class="archive-page">
    <header class="masthead">
      <div class="mast-inner">
        <div class="mast-top-rule"></div>
        <div class="mast-bar">
          <a href="/en/blog" class="mast-brand">Airing's Blog</a>
          <div class="mast-links">
            <a href="/en/blog" class="mast-hide-mobile">Blog</a>
            <a href="/en/archive" class="mast-hide-mobile">Archive</a>
            <a href="/en/moments">Moment</a>
            <a href="/en/notes">Notes</a>
            <a href="/en/friends">Friends</a>
          </div>
        </div>
        <div class="mast-lang-line">
          <LangSwitch lang="en" currentPath="/en/archive" hasEnVersion={true} />
        </div>
        <div class="mast-bottom-rule"></div>
      </div>
    </header>

    <header class="page-header">
      <div class="header-inner">
        <h1 class="page-title">{s.title}</h1>
        <p class="page-desc">{s.desc(posts.length)}</p>
      </div>
    </header>

    <main class="archive-main">
      <div class="two-col">
        <!-- Sidebar: year nav -->
        <aside class="year-sidebar">
          <div class="sidebar-sticky">
            {years.map(year => (
              <a href={`#year-${year}`} class="sidebar-year">
                <span class="sy-num">{year}</span>
                <span class="sy-count">{postsByYear[year].length}</span>
              </a>
            ))}
          </div>
        </aside>

        <!-- Main: post list -->
        <div class="post-list">
          {years.map(year => (
            <section class="year-section" id={`year-${year}`}>
              <div class="year-label">
                <h2 class="year-num">{year}</h2>
                <div class="year-line"></div>
              </div>
              <div class="year-posts">
                {postsByYear[year].map(post => (
                  <a href={`/en/posts/${post.id}`} class="feed-item">
                    <time class="fi-date">{formatDate(post.data.date)}</time>
                    <div class="fi-body">
                      <div class="fi-tags">
                        {post.data.tags.map(tag => (
                          <span style={`color: ${getTagColor(tag)}`}>{tag}</span>
                        ))}
                      </div>
                      <h3 class="fi-title">{post.data.title}</h3>
                      {post.data.description && (
                        <p class="fi-desc">{post.data.description}</p>
                      )}
                    </div>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </main>

    <footer class="blog-footer">
      <div class="footer-inner">
        <span>&copy; 2026 Airing</span>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/en/archive">Archive</a>
          <a href="/en/blog/feed.xml">RSS</a>
        </div>
      </div>
    </footer>
  </div>
  <script is:inline>
  (function() {
    var sidebar = document.querySelector('.year-sidebar');
    if (sidebar) sidebar.addEventListener('click', function(e) {
      var a = e.target.closest('.sidebar-year');
      if (!a) return;
      var year = a.querySelector('.sy-num').textContent;
      if (typeof umami !== 'undefined') umami.track('archive-year', { year: year });
    });
  })();
  </script>
  <script is:inline>
    if (localStorage.getItem('preferred_lang') === 'zh') {
      window.location.replace('/archive');
    }
  </script>
</BaseLayout>

<style is:global>
  body:has(.archive-page) {
    display: block;
    padding: 0;
    align-items: stretch;
    justify-content: stretch;
  }
</style>

<style>
  .archive-page {
    min-height: 100vh;
    width: 100%;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  /* Nav */
  .masthead { width: 100%; }
  .mast-inner { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
  .mast-top-rule { height: 4px; background: var(--c-text); margin-top: 24px; }
  .mast-bar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 0; position: relative;
  }
  .mast-brand {
    font-size: 11px; color: var(--c-text-muted); text-decoration: none;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
  }
  .mast-brand:hover { color: var(--c-text); }
  .mast-links { display: flex; gap: 16px; }
  .mast-links a {
    font-size: 11px; color: var(--c-text-dim); text-decoration: none;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .mast-links a:hover { color: var(--c-text); }
  .mast-bottom-rule { height: 1px; background: var(--c-border); }
  .mast-lang-line {
    display: flex;
    justify-content: flex-end;
    padding: 4px 0 8px 0;
  }

  /* Header */
  .page-header {
    border-bottom: 1px solid var(--c-border);
    padding: 48px 0;
  }
  .header-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 48px;
  }
  .page-title {
    font-size: 36px; font-weight: 800; color: var(--c-text);
    letter-spacing: -0.03em; margin-bottom: 8px;
  }
  .page-desc { font-size: 15px; color: var(--c-text-dim); }

  /* Two-column layout */
  .archive-main { padding: 0; }
  .two-col {
    max-width: 1200px; margin: 0 auto;
    padding: 0 48px;
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 48px;
    align-items: start;
  }

  /* Sidebar */
  .year-sidebar {
    padding-top: 40px;
  }
  .sidebar-sticky {
    position: sticky; top: 80px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .sidebar-year {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 16px;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .sidebar-year:hover {
    background: rgba(var(--c-overlay-rgb),0.04);
  }
  .sy-num {
    font-size: 15px; font-weight: 700; color: var(--c-text);
  }
  .sy-count {
    font-size: 12px; color: var(--c-text-dim);
    background: rgba(var(--c-overlay-rgb),0.06);
    padding: 2px 8px; border-radius: 10px;
  }

  /* Post list */
  .post-list { }

  .year-section {
    padding: 40px 0 0;
  }
  .year-label {
    display: flex; align-items: center; gap: 16px;
    margin-bottom: 8px;
  }
  .year-num {
    font-size: 14px; font-weight: 700; color: var(--c-text-dim);
    text-transform: uppercase; letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .year-line {
    flex: 1; height: 1px;
    background: var(--c-border);
  }

  .feed-item {
    display: flex; align-items: flex-start;
    gap: 20px; text-decoration: none;
    padding: 16px 0;
    border-bottom: 1px solid rgba(var(--c-overlay-rgb),0.04);
    transition: all 0.15s;
  }
  .feed-item:last-child { border-bottom: none; }
  .feed-item:hover .fi-title { color: var(--accent); }
  .fi-date {
    font-size: 13px; color: var(--c-text-dim); flex-shrink: 0;
    width: 70px; padding-top: 2px;
    font-variant-numeric: tabular-nums;
  }
  .fi-body { flex: 1; min-width: 0; }
  .fi-tags {
    display: flex; gap: 8px; margin-bottom: 4px;
    font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.06em; font-weight: 600;
  }
  .fi-title {
    font-size: 17px; font-weight: 600; color: var(--c-text);
    line-height: 1.4; margin-bottom: 4px; transition: color 0.2s;
  }
  .fi-desc {
    font-size: 14px; color: var(--c-text-dim); line-height: 1.5;
    display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Footer */
  .blog-footer {
    border-top: 1px solid var(--c-border);
    padding: 32px 0; margin-top: 40px;
  }
  .footer-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 48px;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 12px; color: var(--c-border-light);
  }
  .footer-links { display: flex; gap: 20px; }
  .footer-links a {
    font-size: 12px; color: var(--c-text-dim); text-decoration: none;
  }
  .footer-links a:hover { color: var(--c-text); }

  @media (max-width: 768px) {
    .mast-hide-mobile { display: none; }
.mast-inner { padding: 0 20px; }
    .header-inner { padding: 0 20px; }
    .two-col {
      padding: 0 20px;
      grid-template-columns: 1fr;
      gap: 0;
    }
    .year-sidebar { display: none; }
    .footer-inner { padding: 0 20px; }
    .page-title { font-size: 28px; }
  }
</style>
