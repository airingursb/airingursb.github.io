---
import BaseLayout from '../layouts/BaseLayout.astro';
import telegramData from '../data/telegram.json';
---

<BaseLayout title="Moments | Airing">
  <div class="moments-page">
    <header class="masthead">
      <div class="mast-inner">
        <div class="mast-top-rule"></div>
        <div class="mast-bar">
          <a href="/blog" class="mast-brand">Airing's Blog</a>
          <div class="mast-links">
            <a href="/blog">Blog</a>
            <a href="/archive">Archive</a>
            <a href="/friends">Friends</a>
          </div>
        </div>
        <div class="mast-bottom-rule"></div>
      </div>
    </header>

    <header class="page-header">
      <div class="header-inner">
        <h1 class="page-title">Moments</h1>
        <p class="page-desc">Thoughts and shares from <a href="https://t.me/airingchannel" target="_blank" style="color:var(--accent);text-decoration:none">Telegram Channel</a>.</p>
      </div>
    </header>

    <main class="moments-main">
      <div class="timeline">
        {telegramData.map(item => (
          <a href={item.link} target="_blank" rel="noopener" class="moment-item">
            <time class="moment-date">{item.date}</time>
            <div class="moment-content">
              <p class="moment-text">{item.title}</p>
            </div>
          </a>
        ))}
      </div>
    </main>

    <footer class="blog-footer">
      <div class="footer-inner">
        <span>&copy; 2026 Airing</span>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/archive">Archive</a>
          <a href="/blog/feed.xml">RSS</a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>

<style is:global>
  body:has(.moments-page) {
    display: block;
    padding: 0;
    align-items: stretch;
    justify-content: stretch;
  }
</style>

<style>
  .moments-page {
    min-height: 100vh;
    width: 100%;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  /* Masthead */
  .masthead { width: 100%; }
  .mast-inner { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
  .mast-top-rule { height: 4px; background: var(--c-text); margin-top: 24px; }
  .mast-bar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 0; position: relative;
  }
  .mast-brand {
    font-size: 11px; color: var(--c-text-muted); text-decoration: none;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
  }
  .mast-brand:hover { color: var(--c-text); }
  .mast-links { display: flex; gap: 16px; }
  .mast-links a {
    font-size: 11px; color: var(--c-text-dim); text-decoration: none;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .mast-links a:hover { color: var(--c-text); }
  .mast-bottom-rule { height: 1px; background: var(--c-border); }

  /* Header */
  .page-header {
    border-bottom: 1px solid var(--c-border);
    padding: 48px 0;
  }
  .header-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 48px;
  }
  .page-title {
    font-size: 36px; font-weight: 800; color: var(--c-text);
    letter-spacing: -0.03em; margin-bottom: 8px;
  }
  .page-desc { font-size: 15px; color: var(--c-text-dim); }

  /* Timeline */
  .moments-main { padding: 0; }
  .timeline {
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 48px 60px;
  }
  .moment-item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    text-decoration: none;
    padding: 16px 0;
    border-bottom: 1px solid rgba(var(--c-overlay-rgb),0.04);
    transition: all 0.15s;
  }
  .moment-item:last-child { border-bottom: none; }
  .moment-item:hover .moment-text { color: var(--accent); }
  .moment-date {
    font-size: 13px;
    color: var(--c-text-dim);
    flex-shrink: 0;
    width: 50px;
    padding-top: 2px;
    font-variant-numeric: tabular-nums;
  }
  .moment-text {
    font-size: 15px;
    color: var(--c-text);
    line-height: 1.5;
    transition: color 0.2s;
  }

  /* Footer */
  .blog-footer {
    border-top: 1px solid var(--c-border);
    padding: 32px 0; margin-top: 40px;
  }
  .footer-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 48px;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 12px; color: var(--c-border-light);
  }
  .footer-links { display: flex; gap: 20px; }
  .footer-links a {
    font-size: 12px; color: var(--c-text-dim); text-decoration: none;
  }
  .footer-links a:hover { color: var(--c-text); }

  @media (max-width: 768px) {
    .mast-inner { padding: 0 20px; }
    .header-inner { padding: 0 20px; }
    .timeline { padding: 16px 20px 40px; }
    .footer-inner { padding: 0 20px; }
    .page-title { font-size: 28px; }
  }
</style>
