---
import BaseLayout from '../layouts/BaseLayout.astro';

// ── Build-time: fetch moments from Supabase ──
const SUPABASE_URL = import.meta.env.BLOG_SUPABASE_URL || process.env.BLOG_SUPABASE_URL || '';
const SUPABASE_KEY = import.meta.env.BLOG_SUPABASE_SERVICE_KEY || process.env.BLOG_SUPABASE_SERVICE_KEY || '';

let staticMoments: any[] = [];
if (SUPABASE_URL && SUPABASE_KEY) {
  try {
    const res = await fetch(
      `${SUPABASE_URL}/rest/v1/moments?select=id,telegram_post_id,content,images,link_previews,published_at&order=published_at.desc&limit=20`,
      {
        headers: {
          apikey: SUPABASE_KEY,
          Authorization: `Bearer ${SUPABASE_KEY}`,
        },
      }
    );
    if (res.ok) {
      staticMoments = await res.json();
    }
  } catch (e) {
    console.error('[moments] Build-time fetch failed:', e);
  }
}

// ── Helpers for static rendering ──
function escHtml(str: string): string {
  if (!str) return '';
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

function relativeTimeStatic(dateStr: string): string {
  const date = new Date(dateStr);
  if (isNaN(date.getTime())) return dateStr || '';
  const diff = Date.now() - date.getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return '刚刚';
  if (mins < 60) return `${mins} 分钟前`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours} 小时前`;
  const days = Math.floor(hours / 24);
  if (days < 30) return `${days} 天前`;
  const months = Math.floor(days / 30);
  if (months < 12) return `${months} 个月前`;
  return `${Math.floor(months / 12)} 年前`;
}

const AVATAR = 'https://avatars.githubusercontent.com/u/10513408?v=4&s=64';
const TWEMOJI_BASE = 'https://cdn.jsdelivr.net/gh/twitter/twemoji@14.0.2/assets/svg';
const EMOJI_CODES: Record<string, string> = {
  '👍': '1f44d', '❤️': '2764', '🔥': '1f525', '😄': '1f604',
  '🎉': '1f389', '🙏': '1f64f', '😢': '1f622', '🤔': '1f914',
};
const EMOJIS_LIST = ['👍', '❤️', '🔥', '😄', '🎉', '🙏', '😢', '🤔'];

function twemojiUrl(emoji: string): string {
  return `${TWEMOJI_BASE}/${EMOJI_CODES[emoji] || '1f44d'}.svg`;
}

function linkifyStatic(text: string): string {
  if (!text) return '';
  const urlRe = /https?:\/\/[^\s，。、！？；：）》\]'"<>]+/g;
  let result = '';
  let lastIndex = 0;
  let match: RegExpExecArray | null;
  while ((match = urlRe.exec(text)) !== null) {
    result += escHtml(text.slice(lastIndex, match.index));
    const url = match[0];
    result += `<a href="${escHtml(url)}" target="_blank" rel="noopener noreferrer">${escHtml(url)}</a>`;
    lastIndex = urlRe.lastIndex;
  }
  result += escHtml(text.slice(lastIndex));
  return result;
}
---

<BaseLayout title="Moment | Airing">
  <div class="moments-page">
    <!-- Masthead -->
    <header class="masthead">
      <div class="mast-inner">
        <div class="mast-top-rule"></div>
        <div class="mast-bar">
          <a href="/blog" class="mast-brand">Airing's Blog</a>
          <span class="mast-motto">应无所住而生其心</span>
          <div class="mast-links">
            <a href="/blog">Blog</a>
            <a href="/archive">Archive</a>
            <a href="/moments" class="mast-link-active">Moment</a>
            <a href="/friends">Friends</a>
          </div>
        </div>
        <div class="mast-bottom-rule"></div>
      </div>
    </header>

    <!-- Page Header -->
    <header class="page-header">
      <div class="header-inner">
        <h1 class="page-title">Moment</h1>
        <p class="page-desc">Thoughts and shares from <a href="https://t.me/airingchannel" target="_blank" style="color:var(--accent);text-decoration:none">Telegram Channel</a>.</p>
      </div>
    </header>

    <!-- Content -->
    <section class="content-section">
      <div class="content-inner">
        <!-- Timeline -->
        <div class="timeline-wrap">
          <div class="timeline-line"></div>
          <div class="moments-container" id="momentsContainer">
            {staticMoments.map((m) => {
              const content = m.content || '';
              const truncated = content.length > 200;
              const previews = m.link_previews || [];
              const images = m.images || [];
              const emojiPickerHtml = EMOJIS_LIST.map(e =>
                `<button class="emoji-pick-btn" data-moment-id="${m.id}" data-emoji="${e}" title="${e}"><img src="${twemojiUrl(e)}" alt="${e}" width="20" height="20" style="vertical-align:-3px" draggable="false"></button>`
              ).join('');
              return (
                <div class="moment-item" data-moment-id={m.id}>
                  <div class="moment-dot"></div>
                  <div class="moment-card">
                    <div class="card-header">
                      <img class="card-avatar" src={AVATAR} alt="Airing" />
                      <span class="card-author">Airing</span>
                      <time class="card-time" title={m.published_at || ''}>{relativeTimeStatic(m.published_at)}</time>
                    </div>
                    <div class={`card-text${truncated ? ' truncated' : ''}`} set:html={linkifyStatic(content)} />
                    {truncated && <button class="text-expand-btn">展开全文</button>}
                    {previews.length > 0 && previews.map((p: any) => {
                      const domain = p.url.replace(/^https?:\/\//, '').split('/')[0];
                      return (
                        <a class="link-preview" href={p.url} target="_blank" rel="noopener noreferrer">
                          {p.image && <img class="link-preview-image" src={p.image} alt="" loading="lazy" />}
                          <div class="link-preview-body">
                            <div class="link-preview-title">{p.title}</div>
                            {p.description && <div class="link-preview-desc">{p.description}</div>}
                            <div class="link-preview-domain">{domain}</div>
                          </div>
                        </a>
                      );
                    })}
                    {images.length > 0 && (
                      <div class={`card-images ${images.length === 1 ? 'single' : 'multi'}`}>
                        {images.map((u: string) => <img class="card-img" src={u} alt="" loading="lazy" />)}
                      </div>
                    )}
                    <div class="card-actions">
                      <button class="action-btn like-btn" data-moment-id={m.id} title="Like">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        <span class="like-count">0</span>
                      </button>
                      <button class="action-btn comment-toggle-btn" data-moment-id={m.id} title="Comments">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        <span class="comment-count">0</span>
                      </button>
                      <div class="reactions-row" data-moment-id={m.id}></div>
                    </div>
                    <div class="card-expanded">
                      <div class="emoji-picker" set:html={emojiPickerHtml} />
                      <div class="comments-list" id={`comments-${m.id}`}>
                        <div class="spinner" style="width:18px;height:18px;margin:8px auto;"></div>
                      </div>
                      <form class="comment-form" data-moment-id={m.id}>
                        <div class="comment-form-row">
                          <input class="comment-input" name="nickname" placeholder="昵称 *" required style="flex:1" />
                          <input class="comment-input" name="email" type="email" placeholder="邮箱 (可选)" style="flex:1" />
                        </div>
                        <textarea class="comment-input" name="content" rows={2} placeholder="发表评论..." required></textarea>
                        <button class="comment-submit" type="submit">发送</button>
                      </form>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
          <div class="loader-wrap" id="loaderWrap" style="display:none">
            <div class="spinner"></div>
          </div>
          <div class="end-message" id="endMessage" style={staticMoments.length > 0 && staticMoments.length < 20 ? '' : 'display:none'}>
            <span>— 已经到底了 —</span>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="author-sidebar">
          <div class="sidebar-sticky">
            <div class="author-card">
              <img
                src="https://avatars.githubusercontent.com/u/10513408?v=4&s=96"
                alt="Airing"
                class="author-avatar"
                loading="lazy"
              />
              <h3 class="author-name"><a href="/">Airing</a></h3>
              <p class="author-bio">哲学硕士｜终端全栈</p>
              <div class="author-links">
                <a href="https://github.com/airingursb" target="_blank" rel="noopener" title="GitHub" class="author-link-icon">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                </a>
                <a href="https://x.com/airingursb" target="_blank" rel="noopener" title="X / Twitter" class="author-link-icon">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <a href="https://t.me/s/airingchannel" target="_blank" rel="noopener" title="Telegram" class="author-link-icon">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                </a>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <!-- Footer -->
    <footer class="blog-footer">
      <div class="footer-inner">
        <span>&copy; 2026 Airing</span>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/archive">Archive</a>
          <a href="/blog/feed.xml">RSS</a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>

<style is:global>
  body:has(.moments-page) {
    display: block;
    padding: 0;
    align-items: stretch;
    justify-content: stretch;
  }
</style>

<style is:global>
  .moments-page {
    min-height: 100vh;
    width: 100%;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  /* ── Masthead ── */
  .masthead { width: 100%; }
  .mast-inner { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
  .mast-top-rule { height: 4px; background: var(--c-text); margin-top: 24px; }
  .mast-bar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 0; position: relative;
  }
  .mast-brand {
    font-size: 11px; color: var(--c-text-muted); text-decoration: none;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
  }
  .mast-brand:hover { color: var(--c-text); }
  .mast-motto {
    position: absolute; left: 50%; transform: translateX(-50%);
    font-size: 12px; color: var(--c-text-dim); letter-spacing: 0.08em;
    font-style: italic; pointer-events: none;
  }
  .mast-links { display: flex; gap: 16px; }
  .mast-links a {
    font-size: 11px; color: var(--c-text-dim); text-decoration: none;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .mast-links a:hover, .mast-link-active { color: var(--c-text) !important; }
  .mast-bottom-rule { height: 1px; background: var(--c-border); }

  /* ── Page Header ── */
  .page-header { border-bottom: 1px solid var(--c-border); padding: 48px 0; }
  .header-inner { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
  .page-title {
    font-size: 36px; font-weight: 800; color: var(--c-text);
    letter-spacing: -0.03em; margin-bottom: 8px;
  }
  .page-desc { font-size: 15px; color: var(--c-text-dim); }

  /* ── Content Layout ── */
  .content-section { padding: 40px 0 60px; }
  .content-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 48px;
    display: flex; gap: 48px; align-items: flex-start;
  }

  /* ── Timeline ── */
  .timeline-wrap {
    flex: 1; min-width: 0; max-width: 720px;
    position: relative; padding-left: 28px;
  }
  .timeline-line {
    position: absolute; left: 4px; top: 0; bottom: 0;
    width: 2px; background: var(--c-border);
  }

  /* ── Moment Item ── */
  .moment-item {
    position: relative; margin-bottom: 24px; cursor: pointer;
  }
  .moment-dot {
    position: absolute; left: -32px; top: 18px;
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--accent); flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(var(--accent-rgb), 0.15);
    transition: box-shadow 0.2s;
  }
  .moment-item.expanded .moment-dot {
    box-shadow: 0 0 0 4px rgba(var(--accent-rgb), 0.3);
  }
  .moment-card {
    background: var(--c-bg-alt);
    border: 1px solid var(--c-border);
    border-radius: 12px;
    padding: 16px;
    transition: border-color 0.2s;
  }
  .moment-item.expanded .moment-card {
    border-color: var(--accent);
  }
  .moment-card:hover {
    border-color: rgba(var(--accent-rgb), 0.5);
  }

  /* Card header */
  .card-header {
    display: flex; align-items: center; gap: 10px; margin-bottom: 12px;
  }
  .card-avatar {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
  }
  .card-author { font-size: 13px; font-weight: 600; color: var(--c-text); }
  .card-time {
    font-size: 12px; color: var(--c-text-dim);
    margin-left: auto; flex-shrink: 0;
  }

  /* Card body */
  .card-text {
    font-size: 14px; color: var(--c-text); line-height: 1.7;
    white-space: pre-wrap; word-break: break-word; margin-bottom: 12px;
  }
  .card-text.truncated {
    max-height: 7.2em; /* ~4 lines at 1.7 line-height */
    overflow: hidden;
    position: relative;
  }
  .card-text.truncated::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 2.4em;
    background: linear-gradient(transparent, var(--c-bg-alt));
    pointer-events: none;
  }
  .text-expand-btn {
    display: none; font-size: 13px; color: var(--accent); cursor: pointer;
    background: none; border: none; padding: 0; margin-bottom: 12px;
    font-family: inherit;
  }
  .text-expand-btn:hover { text-decoration: underline; }
  .card-text.truncated + .text-expand-btn { display: inline-block; }
  .card-text a { color: var(--accent); text-decoration: none; }
  .card-text a:hover { text-decoration: underline; }

  /* Link preview */
  .link-preview {
    display: flex; border: 1px solid var(--c-border); border-radius: 8px;
    overflow: hidden; margin-bottom: 12px; text-decoration: none;
    color: var(--c-text); background: var(--c-bg); transition: border-color 0.15s;
    max-height: 96px;
  }
  .link-preview:hover { border-color: var(--accent); }
  .link-preview-image {
    width: 96px; min-width: 96px; height: 96px; object-fit: cover; flex-shrink: 0;
  }
  .link-preview-body {
    padding: 10px 14px; overflow: hidden; display: flex;
    flex-direction: column; justify-content: center; min-width: 0;
  }
  .link-preview-title {
    font-size: 13px; font-weight: 600; color: var(--c-text);
    line-height: 1.4; margin-bottom: 4px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .link-preview-desc {
    font-size: 12px; color: var(--c-text-dim); line-height: 1.4;
    overflow: hidden; text-overflow: ellipsis;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  }
  .link-preview-domain {
    font-size: 11px; color: var(--c-text-muted); margin-top: 4px;
  }

  /* Image grid */
  .card-images {
    display: grid; gap: 4px; margin-bottom: 12px; border-radius: 8px; overflow: hidden;
  }
  .card-images.single { grid-template-columns: 1fr; }
  .card-images.multi { grid-template-columns: 1fr 1fr; }
  .card-img {
    width: 100%; aspect-ratio: 1; object-fit: cover; display: block;
    background: var(--c-bg); cursor: pointer;
  }
  .card-images.single .card-img { aspect-ratio: 16/9; max-height: 360px; object-fit: cover; }

  /* Lightbox */
  .lightbox-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0, 0, 0, 0.85); backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center;
    cursor: zoom-out; opacity: 0; transition: opacity 0.2s;
  }
  .lightbox-overlay.active { opacity: 1; }
  .lightbox-overlay img {
    max-width: 90vw; max-height: 90vh; object-fit: contain;
    border-radius: 4px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    cursor: default; transform: scale(0.95); transition: transform 0.2s;
  }
  .lightbox-overlay.active img { transform: scale(1); }

  /* Action bar */
  .card-actions {
    display: flex; align-items: center; gap: 12px; padding-top: 8px;
    border-top: 1px solid var(--c-border);
  }
  .action-btn {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 13px; color: var(--c-text-dim);
    background: none; border: none; cursor: pointer; padding: 4px 6px;
    border-radius: 6px; transition: color 0.15s, background 0.15s;
    font-family: inherit;
  }
  .action-btn:hover { color: var(--c-text); background: rgba(var(--c-overlay-rgb), 0.06); }
  .action-btn.liked { color: #e05d68; }
  .action-btn svg { flex-shrink: 0; }

  .reactions-row {
    display: flex; align-items: center; gap: 4px; flex-wrap: wrap;
    margin-left: auto;
  }
  .reaction-bubble {
    display: inline-flex; align-items: center; gap: 2px;
    font-size: 12px; line-height: 1;
    background: var(--c-bg); border: 1px solid var(--c-border); border-radius: 12px;
    padding: 3px 8px 3px 6px; cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    user-select: none;
  }
  .reaction-bubble .reaction-emoji { line-height: 0; display: inline-flex; }
  .reaction-bubble .reaction-emoji img { pointer-events: none; }
  .reaction-bubble .reaction-count {
    font-size: 11px; font-weight: 500; color: var(--c-text-dim);
    font-variant-numeric: tabular-nums;
  }
  .reaction-bubble:hover { border-color: var(--accent); background: rgba(var(--accent-rgb), 0.04); }
  .reaction-bubble.reacted {
    border-color: var(--accent); background: rgba(var(--accent-rgb), 0.08);
  }
  .reaction-bubble.reacted .reaction-count { color: var(--accent); font-weight: 600; }

  /* Expanded area */
  .card-expanded {
    display: none; padding-top: 12px; margin-top: 12px;
    border-top: 1px solid var(--c-border);
  }
  .moment-item.expanded .card-expanded { display: block; }

  /* Emoji picker */
  .emoji-picker {
    display: flex; gap: 2px; margin-bottom: 16px;
    background: var(--c-bg); border: 1px solid var(--c-border);
    border-radius: 8px; padding: 4px; width: fit-content;
  }
  .emoji-pick-btn {
    display: inline-flex; align-items: center; justify-content: center;
    background: none; border: none;
    border-radius: 6px; padding: 5px 6px; cursor: pointer;
    transition: background 0.12s, transform 0.1s;
    line-height: 0;
  }
  .emoji-pick-btn:hover { background: rgba(var(--c-overlay-rgb), 0.1); transform: scale(1.2); }
  .emoji-pick-btn img { pointer-events: none; }

  /* Comments */
  .comments-list { margin-bottom: 16px; }
  .comment-item {
    display: flex; gap: 10px; padding: 10px 0;
    border-bottom: 1px solid rgba(var(--c-overlay-rgb), 0.04);
  }
  .comment-item:last-child { border-bottom: none; }
  .comment-avatar {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
  }
  .comment-body { flex: 1; min-width: 0; }
  .comment-nick { font-size: 13px; font-weight: 600; color: var(--c-text); }
  .comment-time { font-size: 11px; color: var(--c-text-dim); margin-left: 6px; }
  .comment-text {
    font-size: 13px; color: var(--c-text); line-height: 1.6;
    margin-top: 4px; word-break: break-word;
  }
  .comment-children { padding-left: 42px; }

  /* Comment form */
  .comment-form { display: flex; flex-direction: column; gap: 8px; }
  .comment-form-row { display: flex; gap: 8px; }
  .comment-input {
    width: 100%; background: var(--c-bg); border: 1px solid var(--c-border);
    border-radius: 8px; padding: 8px 12px; font-size: 13px; color: var(--c-text);
    font-family: inherit; resize: vertical;
    transition: border-color 0.15s;
    outline: none;
  }
  .comment-input:focus { border-color: var(--accent); }
  .comment-input::placeholder { color: var(--c-text-dim); }
  .comment-submit {
    align-self: flex-end; background: var(--accent); color: #fff;
    border: none; border-radius: 8px; padding: 8px 16px;
    font-size: 13px; font-weight: 600; cursor: pointer;
    transition: opacity 0.15s; font-family: inherit;
  }
  .comment-submit:hover { opacity: 0.85; }
  .comment-submit:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Loader / End */
  .loader-wrap {
    display: flex; justify-content: center; padding: 32px 0;
  }
  .spinner {
    width: 24px; height: 24px;
    border: 2px solid var(--c-border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .end-message {
    text-align: center; padding: 32px 0;
    font-size: 13px; color: var(--c-text-dim);
  }

  /* ── Sidebar ── */
  .author-sidebar { width: 280px; flex-shrink: 0; }
  .sidebar-sticky { position: sticky; top: 24px; }
  .author-card {
    background: var(--c-bg-alt); border: 1px solid var(--c-border);
    border-radius: 12px; padding: 24px; text-align: center;
  }
  .author-avatar {
    width: 64px; height: 64px; border-radius: 50%; margin-bottom: 12px;
  }
  .author-name {
    font-size: 16px; font-weight: 700; color: var(--c-text); margin-bottom: 4px;
  }
  .author-name a { color: inherit; text-decoration: none; }
  .author-name a:hover { color: var(--accent); }
  .author-bio { font-size: 13px; color: var(--c-text-muted); margin-bottom: 16px; }
  .author-links { display: flex; justify-content: center; gap: 12px; }
  .author-link-icon {
    color: var(--c-text-dim); transition: color 0.15s;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 6px; border-radius: 6px;
  }
  .author-link-icon:hover { color: var(--c-text); }

  /* ── Footer ── */
  .blog-footer { border-top: 1px solid var(--c-border); padding: 32px 0; margin-top: 40px; }
  .footer-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 48px;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 12px; color: var(--c-text-dim);
  }
  .footer-links { display: flex; gap: 20px; }
  .footer-links a { font-size: 12px; color: var(--c-text-dim); text-decoration: none; }
  .footer-links a:hover { color: var(--c-text); }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .author-sidebar { display: none; }
    .content-inner { padding: 0 24px; }
    .timeline-wrap { max-width: 100%; }
  }
  @media (max-width: 768px) {
    .mast-inner { padding: 0 20px; }
    .mast-motto { display: none; }
    .header-inner { padding: 0 20px; }
    .content-inner { padding: 0 20px; }
    .footer-inner { padding: 0 20px; }
    .page-title { font-size: 28px; }
    .page-header { padding: 32px 0; }
    .card-images.multi { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
(function () {
  'use strict';

  const API_BASE = 'https://ursb.me';
  const AVATAR = 'https://avatars.githubusercontent.com/u/10513408?v=4&s=64';
  const GRAVATAR = 'https://www.gravatar.com/avatar/?d=robohash&s=48';
  const EMOJIS = ['👍', '❤️', '🔥', '😄', '🎉', '🙏', '😢', '🤔'];
  // Twemoji SVG CDN — consistent, well-designed emoji across all platforms
  const TWEMOJI_BASE = 'https://cdn.jsdelivr.net/gh/twitter/twemoji@14.0.2/assets/svg';
  const EMOJI_CODE = {
    '👍': '1f44d', '❤️': '2764', '🔥': '1f525', '😄': '1f604',
    '🎉': '1f389', '🙏': '1f64f', '😢': '1f622', '🤔': '1f914',
  };
  function twemojiUrl(emoji) {
    return `${TWEMOJI_BASE}/${EMOJI_CODE[emoji] || '1f44d'}.svg`;
  }
  function twemojiImg(emoji, size) {
    const s = size || 18;
    return `<img src="${twemojiUrl(emoji)}" alt="${emoji}" width="${s}" height="${s}" style="vertical-align:-3px" draggable="false">`;
  }
  const LIMIT = 20;

  let page = 1;
  let loading = false;
  let finished = false;
  let total = 0;

  const container = document.getElementById('momentsContainer');
  const loaderWrap = document.getElementById('loaderWrap');
  const endMessage = document.getElementById('endMessage');

  // ── LocalStorage helpers ──
  function getLikes() {
    try { return JSON.parse(localStorage.getItem('moment_likes') || '[]'); } catch { return []; }
  }
  function setLikes(arr) {
    try { localStorage.setItem('moment_likes', JSON.stringify(arr)); } catch {}
  }
  function getReactions() {
    try { return JSON.parse(localStorage.getItem('moment_reactions') || '{}'); } catch { return {}; }
  }
  function setReactions(obj) {
    try { localStorage.setItem('moment_reactions', JSON.stringify(obj)); } catch {}
  }

  // ── Utils ──
  function esc(str) {
    if (!str) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function relativeTime(dateStr) {
    const date = new Date(dateStr);
    if (isNaN(date)) return dateStr || '';
    const diff = Date.now() - date.getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return '刚刚';
    if (mins < 60) return `${mins} 分钟前`;
    const hours = Math.floor(mins / 60);
    if (hours < 24) return `${hours} 小时前`;
    const days = Math.floor(hours / 24);
    if (days < 30) return `${days} 天前`;
    const months = Math.floor(days / 30);
    if (months < 12) return `${months} 个月前`;
    return `${Math.floor(months / 12)} 年前`;
  }

  const TEXT_MAX_LEN = 200; // Characters before truncation
  const URL_RE = /https?:\/\/[^\s，。、！？；：）》\]'"<>]+/g;

  function linkifyAndEsc(text) {
    // Escape text while converting URLs to clickable <a> tags
    if (!text) return '';
    let result = '';
    let lastIndex = 0;
    let match;
    URL_RE.lastIndex = 0;
    while ((match = URL_RE.exec(text)) !== null) {
      result += esc(text.slice(lastIndex, match.index));
      const url = match[0];
      result += `<a href="${esc(url)}" target="_blank" rel="noopener noreferrer">${esc(url)}</a>`;
      lastIndex = URL_RE.lastIndex;
    }
    result += esc(text.slice(lastIndex));
    return result;
  }

  function buildLinkPreviewHtml(previews) {
    if (!previews || previews.length === 0) return '';
    return previews.map(p => {
      const domain = p.url.replace(/^https?:\/\//, '').split('/')[0];
      const imgHtml = p.image
        ? `<img class="link-preview-image" src="${esc(p.image)}" alt="" loading="lazy">`
        : '';
      return `
        <a class="link-preview" href="${esc(p.url)}" target="_blank" rel="noopener noreferrer">
          ${imgHtml}
          <div class="link-preview-body">
            <div class="link-preview-title">${esc(p.title)}</div>
            ${p.description ? `<div class="link-preview-desc">${esc(p.description)}</div>` : ''}
            <div class="link-preview-domain">${esc(domain)}</div>
          </div>
        </a>
      `;
    }).join('');
  }

  function buildImagesHtml(images) {
    if (!images || images.length === 0) return '';
    const cls = images.length === 1 ? 'single' : 'multi';
    const imgs = images.map(u => `<img class="card-img" src="${esc(u)}" alt="" loading="lazy">`).join('');
    return `<div class="card-images ${cls}">${imgs}</div>`;
  }

  function buildReactionsHtml(reactions, momentId) {
    if (!reactions || Object.keys(reactions).length === 0) return '';
    const myReactions = getReactions()[momentId] || [];
    return Object.entries(reactions)
      .filter(([, count]) => count > 0)
      .map(([emoji, count]) => {
        const reacted = myReactions.includes(emoji) ? ' reacted' : '';
        return `<span class="reaction-bubble${reacted}" data-moment-id="${esc(momentId)}" data-emoji="${esc(emoji)}" title="${esc(emoji)}"><span class="reaction-emoji">${twemojiImg(emoji, 14)}</span><span class="reaction-count">${count}</span></span>`;
      }).join('');
  }

  function buildMomentHtml(m) {
    const myLikes = getLikes();
    const likeCount = m.likeCount || m.likes || 0;
    // Clear stale localStorage if server says 0 likes
    let liked = '';
    if (myLikes.includes(m.id)) {
      if (likeCount > 0) { liked = ' liked'; }
      else { const idx = myLikes.indexOf(m.id); myLikes.splice(idx, 1); setLikes(myLikes); }
    }
    const commentCount = m.commentCount || m.comments || 0;
    const reactions = m.reactions || {};
    const reactionsHtml = buildReactionsHtml(reactions, m.id);

    const emojiPickerHtml = EMOJIS.map(e =>
      `<button class="emoji-pick-btn" data-moment-id="${esc(m.id)}" data-emoji="${esc(e)}" title="${esc(e)}">${twemojiImg(e, 20)}</button>`
    ).join('');

    return `
      <div class="moment-item" data-moment-id="${esc(m.id)}">
        <div class="moment-dot"></div>
        <div class="moment-card">
          <div class="card-header">
            <img class="card-avatar" src="${AVATAR}" alt="Airing">
            <span class="card-author">Airing</span>
            <time class="card-time" title="${esc(m.published_at || '')}">${relativeTime(m.published_at)}</time>
          </div>
          <div class="card-text${(m.content || '').length > TEXT_MAX_LEN ? ' truncated' : ''}">${linkifyAndEsc(m.content || m.text || '')}</div>
          ${(m.content || '').length > TEXT_MAX_LEN ? '<button class="text-expand-btn">展开全文</button>' : ''}
          ${buildLinkPreviewHtml(m.link_previews)}
          ${buildImagesHtml(m.images)}
          <div class="card-actions">
            <button class="action-btn like-btn${liked}" data-moment-id="${esc(m.id)}" title="Like">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="${liked ? '#e05d68' : 'none'}" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              <span class="like-count">${likeCount}</span>
            </button>
            <button class="action-btn comment-toggle-btn" data-moment-id="${esc(m.id)}" title="Comments">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <span class="comment-count">${commentCount}</span>
            </button>
            <div class="reactions-row" data-moment-id="${esc(m.id)}">
              ${reactionsHtml}
            </div>
          </div>
          <div class="card-expanded">
            <div class="emoji-picker">${emojiPickerHtml}</div>
            <div class="comments-list" id="comments-${esc(m.id)}">
              <div class="spinner" style="width:18px;height:18px;margin:8px auto;"></div>
            </div>
            <form class="comment-form" data-moment-id="${esc(m.id)}">
              <div class="comment-form-row">
                <input class="comment-input" name="nickname" placeholder="昵称 *" required style="flex:1">
                <input class="comment-input" name="email" type="email" placeholder="邮箱 (可选)" style="flex:1">
              </div>
              <textarea class="comment-input" name="content" rows="2" placeholder="发表评论..." required></textarea>
              <button class="comment-submit" type="submit">发送</button>
            </form>
          </div>
        </div>
      </div>
    `;
  }

  function buildCommentsHtml(comments) {
    if (!comments || comments.length === 0) {
      return '<p style="font-size:13px;color:var(--c-text-dim);text-align:center;padding:8px 0;">暂无评论</p>';
    }

    // Build tree: top-level + children
    const roots = comments.filter(c => !c.parentId);
    const children = {};
    comments.filter(c => c.parentId).forEach(c => {
      if (!children[c.parentId]) children[c.parentId] = [];
      children[c.parentId].push(c);
    });

    function renderComment(c) {
      const avatarSrc = c.email
        ? `https://www.gravatar.com/avatar/${c.emailMd5 || ''}?d=robohash&s=48`
        : GRAVATAR;
      const childHtml = (children[c.id] || [])
        .map(ch => `<div class="comment-children">${renderComment(ch)}</div>`).join('');
      return `
        <div class="comment-item">
          <img class="comment-avatar" src="${esc(avatarSrc)}" alt="" loading="lazy">
          <div class="comment-body">
            <span class="comment-nick">${esc(c.nickname || c.name || '匿名')}</span>
            <span class="comment-time">${relativeTime(c.created_at)}</span>
            <p class="comment-text">${esc(c.content)}</p>
          </div>
        </div>
        ${childHtml}
      `;
    }

    return roots.map(renderComment).join('');
  }

  // ── API calls ──
  async function fetchMoments(p) {
    const res = await fetch(`${API_BASE}/api/moments?page=${p}&limit=${LIMIT}`);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return res.json();
  }

  async function fetchComments(momentId) {
    const res = await fetch(`${API_BASE}/api/moments/${momentId}/comments`);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return res.json();
  }

  async function postLike(momentId) {
    const res = await fetch(`${API_BASE}/api/moments/${momentId}/like`, { method: 'POST' });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return res.json();
  }

  async function postReact(momentId, emoji) {
    const res = await fetch(`${API_BASE}/api/moments/${momentId}/react`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ emoji }),
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return res.json();
  }

  async function postComment(momentId, data) {
    const res = await fetch(`${API_BASE}/api/moments/${momentId}/comments`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return res.json();
  }

  // ── Hydrate static cards with fresh interaction data ──
  async function hydrateMoments() {
    try {
      const data = await fetchMoments(1);
      const moments = data.moments || [];
      total = data.total || 0;

      const existingIds = new Set();
      container.querySelectorAll('.moment-item').forEach(el => existingIds.add(el.dataset.momentId));

      for (const m of moments) {
        const el = container.querySelector(`[data-moment-id="${m.id}"]`);
        if (el) {
          // Update like count and state
          const likeBtn = el.querySelector('.like-btn');
          const likeCount = m.likeCount || m.likes || 0;
          if (likeBtn) {
            likeBtn.querySelector('.like-count').textContent = likeCount;
            const myLikes = getLikes();
            if (myLikes.includes(m.id) && likeCount > 0) {
              likeBtn.classList.add('liked');
              likeBtn.querySelector('path').setAttribute('fill', '#e05d68');
            } else if (myLikes.includes(m.id) && likeCount === 0) {
              const idx = myLikes.indexOf(m.id);
              myLikes.splice(idx, 1); setLikes(myLikes);
            }
          }
          // Update comment count
          const commentBtn = el.querySelector('.comment-toggle-btn .comment-count');
          if (commentBtn) commentBtn.textContent = m.commentCount || m.comments || 0;
          // Update reactions
          const reactionsRow = el.querySelector('.reactions-row');
          if (reactionsRow) reactionsRow.innerHTML = buildReactionsHtml(m.reactions || {}, m.id);
          // Update relative time
          const timeEl = el.querySelector('.card-time');
          if (timeEl && m.published_at) timeEl.textContent = relativeTime(m.published_at);
        } else {
          // New moment not in static build — prepend it
          container.insertAdjacentHTML('afterbegin', buildMomentHtml(m));
        }
      }

      page = 2; // Static build covered page 1
      const loaded = container.querySelectorAll('.moment-item').length;
      if (loaded >= total || moments.length < LIMIT) {
        finished = true;
        endMessage.style.display = 'block';
      }
    } catch (err) {
      console.error('Failed to hydrate moments:', err);
    }
  }

  // ── Load more moments (page 2+) ──
  async function loadMoments() {
    if (loading || finished) return;
    loading = true;
    loaderWrap.style.display = 'flex';

    try {
      const data = await fetchMoments(page);
      const moments = data.moments || [];
      total = data.total || 0;

      if (moments.length === 0) {
        finished = true;
      } else {
        const html = moments.map(buildMomentHtml).join('');
        container.insertAdjacentHTML('beforeend', html);
        page++;

        const loaded = container.querySelectorAll('.moment-item').length;
        if (loaded >= total || moments.length < LIMIT) {
          finished = true;
        }
      }
    } catch (err) {
      console.error('Failed to load moments:', err);
      finished = true;
    }

    loading = false;
    loaderWrap.style.display = 'none';
    if (finished) endMessage.style.display = 'block';
  }

  // ── Infinite scroll ──
  function checkScroll() {
    if (finished || loading) return;
    const scrollY = window.scrollY || document.documentElement.scrollTop;
    const windowH = window.innerHeight;
    const docH = document.documentElement.scrollHeight;
    if (docH - scrollY - windowH < 400) {
      loadMoments();
    }
  }

  // ── Load comments ──
  async function loadComments(momentId) {
    const el = document.getElementById(`comments-${momentId}`);
    if (!el) return;
    try {
      const data = await fetchComments(momentId);
      el.innerHTML = buildCommentsHtml(data.comments || []);
    } catch {
      el.innerHTML = '<p style="font-size:13px;color:var(--c-text-dim);text-align:center;">评论加载失败</p>';
    }
  }

  // ── Toggle expand ──
  function toggleExpand(momentEl) {
    const wasExpanded = momentEl.classList.contains('expanded');
    // Collapse all others
    document.querySelectorAll('.moment-item.expanded').forEach(el => {
      if (el !== momentEl) el.classList.remove('expanded');
    });
    if (wasExpanded) {
      momentEl.classList.remove('expanded');
    } else {
      momentEl.classList.add('expanded');
      const momentId = momentEl.dataset.momentId;
      // Load comments on first expand
      const commentsEl = document.getElementById(`comments-${momentId}`);
      if (commentsEl && commentsEl.querySelector('.spinner')) {
        loadComments(momentId);
      }
    }
  }

  // ── Update reactions UI ──
  function updateReactions(momentEl, reactions) {
    const momentId = momentEl.dataset.momentId;
    const row = momentEl.querySelector('.reactions-row');
    if (!row) return;
    row.innerHTML = buildReactionsHtml(reactions, momentId);
  }

  // ── Event delegation ──
  container.addEventListener('click', async function (e) {
    const target = e.target;

    // Like button
    const likeBtn = target.closest('.like-btn');
    if (likeBtn) {
      e.stopPropagation();
      const momentId = likeBtn.dataset.momentId;
      const likes = getLikes();
      try {
        const data = await postLike(momentId);
        const countEl = likeBtn.querySelector('.like-count');
        if (countEl) countEl.textContent = data.count;
        const svgPath = likeBtn.querySelector('path');
        if (data.liked) {
          likeBtn.classList.add('liked');
          if (svgPath) svgPath.setAttribute('fill', '#e05d68');
          if (!likes.includes(momentId)) { likes.push(momentId); setLikes(likes); }
        } else {
          likeBtn.classList.remove('liked');
          if (svgPath) svgPath.setAttribute('fill', 'none');
          const idx = likes.indexOf(momentId);
          if (idx > -1) { likes.splice(idx, 1); setLikes(likes); }
        }
      } catch (err) {
        console.error('Like failed:', err);
      }
      return;
    }

    // Emoji reaction bubble
    const reactionBubble = target.closest('.reaction-bubble');
    if (reactionBubble) {
      e.stopPropagation();
      const momentId = reactionBubble.dataset.momentId;
      const emoji = reactionBubble.dataset.emoji;
      try {
        const data = await postReact(momentId, emoji);
        // Update localStorage BEFORE re-rendering so reacted class is correct
        const myReactions = getReactions();
        if (!myReactions[momentId]) myReactions[momentId] = [];
        const idx = myReactions[momentId].indexOf(emoji);
        if (data.reacted) {
          if (idx === -1) myReactions[momentId].push(emoji);
        } else {
          if (idx > -1) myReactions[momentId].splice(idx, 1);
        }
        setReactions(myReactions);
        const momentEl = container.querySelector(`[data-moment-id="${momentId}"]`);
        if (momentEl) updateReactions(momentEl, data.reactions);
      } catch (err) {
        console.error('React failed:', err);
      }
      return;
    }

    // Emoji picker button
    const emojiPickBtn = target.closest('.emoji-pick-btn');
    if (emojiPickBtn) {
      e.stopPropagation();
      const momentId = emojiPickBtn.dataset.momentId;
      const emoji = emojiPickBtn.dataset.emoji;
      try {
        const data = await postReact(momentId, emoji);
        // Update localStorage BEFORE re-rendering so reacted class is correct
        const myReactions = getReactions();
        if (!myReactions[momentId]) myReactions[momentId] = [];
        const idx = myReactions[momentId].indexOf(emoji);
        if (data.reacted) {
          if (idx === -1) myReactions[momentId].push(emoji);
        } else {
          if (idx > -1) myReactions[momentId].splice(idx, 1);
        }
        setReactions(myReactions);
        const momentEl = container.querySelector(`[data-moment-id="${momentId}"]`);
        if (momentEl) updateReactions(momentEl, data.reactions);
      } catch (err) {
        console.error('React failed:', err);
      }
      return;
    }

    // Comment toggle button
    const commentToggleBtn = target.closest('.comment-toggle-btn');
    if (commentToggleBtn) {
      e.stopPropagation();
      const momentEl = commentToggleBtn.closest('.moment-item');
      if (momentEl) toggleExpand(momentEl);
      return;
    }

    // Image lightbox
    if (target.classList.contains('card-img')) {
      e.stopPropagation();
      openLightbox(target.src);
      return;
    }

    // Text expand/collapse button
    const expandBtn = target.closest('.text-expand-btn');
    if (expandBtn) {
      e.stopPropagation();
      const cardText = expandBtn.previousElementSibling;
      if (cardText && cardText.classList.contains('truncated')) {
        cardText.classList.remove('truncated');
        expandBtn.textContent = '收起';
        expandBtn.style.display = 'inline-block';
      } else if (cardText) {
        cardText.classList.add('truncated');
        expandBtn.textContent = '展开全文';
      }
      return;
    }

    // Click on card (not action buttons) → toggle expand
    const card = target.closest('.moment-card');
    if (card) {
      const actionBtn = target.closest('.action-btn');
      const form = target.closest('.comment-form');
      const link = target.closest('a');
      const linkPreview = target.closest('.link-preview');
      const textExpandBtn = target.closest('.text-expand-btn');
      const cardImg = target.closest('.card-img');
      if (!actionBtn && !form && !link && !linkPreview && !textExpandBtn && !cardImg) {
        const momentEl = card.closest('.moment-item');
        if (momentEl) toggleExpand(momentEl);
      }
    }
  });

  // Comment form submit via delegation
  container.addEventListener('submit', async function (e) {
    const form = e.target.closest('.comment-form');
    if (!form) return;
    e.preventDefault();

    const momentId = form.dataset.momentId;
    const nickname = form.querySelector('[name="nickname"]').value.trim();
    const email = form.querySelector('[name="email"]').value.trim();
    const content = form.querySelector('[name="content"]').value.trim();

    if (!nickname || !content) return;

    const submitBtn = form.querySelector('.comment-submit');
    submitBtn.disabled = true;
    submitBtn.textContent = '发送中...';

    try {
      const data = await postComment(momentId, { nickname, email, content });
      // Reload comments
      const commentsEl = document.getElementById(`comments-${momentId}`);
      if (commentsEl) {
        const refetch = await fetchComments(momentId);
        commentsEl.innerHTML = buildCommentsHtml(refetch.comments || []);
      }
      // Update comment count
      const countEl = container.querySelector(`[data-moment-id="${momentId}"] .comment-count`);
      if (countEl) {
        const current = parseInt(countEl.textContent || '0', 10);
        countEl.textContent = current + 1;
      }
      // Clear form
      form.querySelector('[name="content"]').value = '';
    } catch (err) {
      console.error('Comment failed:', err);
      alert('评论发送失败，请稍后重试');
    }

    submitBtn.disabled = false;
    submitBtn.textContent = '发送';
  });

  // ── Lightbox ──
  let lightboxEl = null;

  function openLightbox(src) {
    if (lightboxEl) closeLightbox();
    lightboxEl = document.createElement('div');
    lightboxEl.className = 'lightbox-overlay';
    lightboxEl.innerHTML = `<img src="${src}" alt="">`;
    lightboxEl.addEventListener('click', function (e) {
      if (e.target === lightboxEl) closeLightbox();
    });
    document.body.appendChild(lightboxEl);
    requestAnimationFrame(() => lightboxEl.classList.add('active'));
    document.addEventListener('keydown', lightboxKeyHandler);
  }

  function closeLightbox() {
    if (!lightboxEl) return;
    const el = lightboxEl;
    lightboxEl = null;
    document.removeEventListener('keydown', lightboxKeyHandler);
    el.classList.remove('active');
    el.addEventListener('transitionend', () => el.remove(), { once: true });
    // Fallback: remove after 300ms in case transitionend doesn't fire
    setTimeout(() => { if (el.parentNode) el.remove(); }, 300);
  }

  function lightboxKeyHandler(e) {
    if (e.key === 'Escape') closeLightbox();
  }

  // ── Init ──
  const hasStaticContent = container.querySelectorAll('.moment-item').length > 0;
  window.addEventListener('scroll', checkScroll, { passive: true });
  if (hasStaticContent) {
    // Static cards exist from build — hydrate with fresh interaction data
    hydrateMoments();
  } else {
    // Fallback: no static content (e.g. env vars missing at build) — fetch everything
    loadMoments();
  }
})();
</script>
