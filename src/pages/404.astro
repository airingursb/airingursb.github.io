---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 · Page Not Found | Airing">
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>
  <div class="nf-page">
    <p class="nf-code">404</p>
    <h1 class="nf-title">页面不存在 / Page Not Found</h1>
    <p class="nf-desc">你要找的页面可能已被移动或删除。The page you are looking for may have been moved or deleted.</p>
    <div class="nf-links">
      <a href="/">首页 Home</a>
      <a href="/blog/">博客 Blog</a>
      <a href="/notes/">笔记 Notes</a>
      <a href="/archive/">归档 Archive</a>
    </div>
  </div>
</BaseLayout>

<style>
  .nf-page {
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1.5rem;
    color: var(--c-fg, inherit);
  }
  .nf-code {
    font-size: 6rem;
    font-weight: 700;
    line-height: 1;
    margin: 0 0 1rem;
    opacity: 0.15;
    letter-spacing: 0.05em;
  }
  .nf-title {
    font-size: 1.5rem;
    margin: 0 0 0.75rem;
  }
  .nf-desc {
    opacity: 0.65;
    max-width: 32rem;
    margin: 0 0 2rem;
  }
  .nf-links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .nf-links a {
    text-decoration: underline;
    text-underline-offset: 4px;
    opacity: 0.85;
  }
  .nf-links a:hover { opacity: 1; }
</style>
