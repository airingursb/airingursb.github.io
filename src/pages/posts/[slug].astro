---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return allPosts.map((post, idx) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: idx > 0 ? { slug: allPosts[idx - 1].id, title: allPosts[idx - 1].data.title } : null,
      nextPost: idx < allPosts.length - 1 ? { slug: allPosts[idx + 1].id, title: allPosts[idx + 1].data.title } : null,
      relatedPosts: (() => {
        const primaryTag = post.data.tags[0];
        return primaryTag
          ? allPosts
              .filter(p => p.id !== post.id && p.data.tags.includes(primaryTag))
              .slice(0, 5)
              .map(p => ({ slug: p.id, title: p.data.title }))
          : [];
      })(),
      seriesInfo: (() => {
        const seriesTags = ['weekly', 'annually'];
        const seriesTag = post.data.tags.find(t => seriesTags.includes(t));
        if (!seriesTag) return null;
        const seriesPosts = allPosts
          .filter(p => p.data.tags.includes(seriesTag))
          .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
        const idx = seriesPosts.findIndex(p => p.id === post.id);
        return {
          tag: seriesTag,
          total: seriesPosts.length,
          current: idx + 1,
          prev: idx > 0 ? { slug: seriesPosts[idx - 1].id, title: seriesPosts[idx - 1].data.title } : null,
          next: idx < seriesPosts.length - 1 ? { slug: seriesPosts[idx + 1].id, title: seriesPosts[idx + 1].data.title } : null,
        };
      })(),
    },
  }));
}

const { post, prevPost, nextPost, relatedPosts, seriesInfo } = Astro.props;
const { Content } = await render(post);
---

<PostLayout
  title={post.data.title}
  date={post.data.date}
  tags={post.data.tags}
  description={post.data.description}
  cover={post.data.cover}
  prevPost={prevPost}
  nextPost={nextPost}
  relatedPosts={relatedPosts}
  seriesInfo={seriesInfo}
>
  <Content />
</PostLayout>
