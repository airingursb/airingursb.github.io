---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap(p => p.data.tags))];
  const tagCounts: Record<string, number> = {};
  tags.forEach(t => {
    tagCounts[t] = posts.filter(p => p.data.tags.includes(t)).length;
  });
  return tags.map(tag => ({
    params: { tag },
    props: {
      tag,
      allTags: tags,
      tagCounts,
      posts: posts
        .filter(p => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, allTags, tagCounts, posts } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });
}

const tagColors: Record<string, string> = {
  tech: 'var(--accent)', weekly: '#60a5fa', annually: '#f59e0b',
};
function getTagColor(t: string) {
  return tagColors[t] || 'var(--c-text-muted)';
}
const tagColor = getTagColor(tag);
---

<BaseLayout title={`#${tag} | Airing`}>
  <div class="tag-page">
    <header class="masthead">
      <div class="mast-inner">
        <div class="mast-top-rule"></div>
        <div class="mast-bar">
          <a href="/blog" class="mast-brand">Airing's Blog</a>
          <div class="mast-links">
            <a href="/blog">Blog</a>
            <a href="/archive">Archive</a>
            <a href="/moments">Moment</a>
            <a href="/friends">Friends</a>
          </div>
        </div>
        <div class="mast-bottom-rule"></div>
      </div>
    </header>

    <!-- Tags Navigation -->
    <div class="tags-nav">
      <div class="tags-nav-inner">
        {allTags.map(t => (
          <a
            href={`/tags/${t}`}
            class={`tag-pill ${t === tag ? 'active' : ''}`}
            style={t === tag ? `--active-color: ${getTagColor(t)}` : ''}
          >
            <span class="tp-name">{t}</span>
            <span class="tp-count">{tagCounts[t]}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Header -->
    <header class="page-header">
      <div class="content-wrap">
        <h1 class="page-title" style={`color: ${tagColor}`}>#{tag}</h1>
        <p class="page-desc">{posts.length} posts tagged with <strong style={`color: ${tagColor}`}>{tag}</strong></p>
      </div>
    </header>

    <!-- Card Grid -->
    <main class="tag-main">
      <div class="content-wrap">
        <div class="card-grid">
          {posts.map(post => (
            <a href={`/posts/${post.id}`} class="post-card">
              <div class="card-top">
                <div class="card-tags">
                  {post.data.tags.map(t => (
                    <span class="card-tag" style={`--c: ${getTagColor(t)}`}>{t}</span>
                  ))}
                </div>
                <time class="card-date">{formatDate(post.data.date)}</time>
              </div>
              <h3 class="card-title">{post.data.title}</h3>
              {post.data.description && (
                <p class="card-desc">{post.data.description}</p>
              )}
            </a>
          ))}
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="blog-footer">
      <div class="content-wrap footer-row">
        <span>&copy; 2026 Airing</span>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/archive">Archive</a>
          <a href="/blog/feed.xml">RSS</a>
        </div>
      </div>
    </footer>
  </div>
  <script is:inline>
  (function() {
    var nav = document.querySelector('.tags-nav-inner');
    if (nav) nav.addEventListener('click', function(e) {
      var a = e.target.closest('.tag-pill');
      if (!a) return;
      var tag = a.querySelector('.tp-name').textContent;
      if (typeof umami !== 'undefined') umami.track('tag-filter', { tag: tag });
    });
  })();
  </script>
</BaseLayout>

<style is:global>
  body:has(.tag-page) {
    display: block;
    padding: 0;
    align-items: stretch;
    justify-content: stretch;
  }
</style>

<style>
  .tag-page {
    min-height: 100vh;
    width: 100%;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  .content-wrap {
    max-width: 1200px; margin: 0 auto; padding: 0 48px;
  }

  /* Nav */
  .masthead { width: 100%; }
  .mast-inner { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
  .mast-top-rule { height: 4px; background: var(--c-text); margin-top: 24px; }
  .mast-bar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 0; position: relative;
  }
  .mast-brand {
    font-size: 11px; color: var(--c-text-muted); text-decoration: none;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
  }
  .mast-brand:hover { color: var(--c-text); }
  .mast-links { display: flex; gap: 16px; }
  .mast-links a {
    font-size: 11px; color: var(--c-text-dim); text-decoration: none;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .mast-links a:hover { color: var(--c-text); }
  .mast-bottom-rule { height: 1px; background: var(--c-border); }

  /* Tags Navigation */
  .tags-nav {
    border-bottom: 1px solid var(--c-border);
    padding: 16px 0;
  }
  .tags-nav-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 48px;
    display: flex; gap: 10px; flex-wrap: wrap;
  }
  .tag-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 20px;
    border: 1px solid var(--c-border);
    background: rgba(var(--c-overlay-rgb),0.02);
    text-decoration: none;
    transition: all 0.2s;
  }
  .tag-pill:hover {
    border-color: var(--c-border-light);
    background: rgba(var(--c-overlay-rgb),0.05);
  }
  .tag-pill.active {
    border-color: var(--active-color);
    background: color-mix(in srgb, var(--active-color) 10%, transparent);
  }
  .tag-pill.active .tp-name {
    color: var(--active-color);
  }
  .tp-name {
    font-size: 13px; font-weight: 600; color: var(--c-text-muted);
    text-transform: uppercase; letter-spacing: 0.03em;
  }
  .tp-count {
    font-size: 11px; color: var(--c-text-dim);
    background: rgba(var(--c-overlay-rgb),0.06);
    padding: 1px 7px; border-radius: 10px;
  }

  /* Header */
  .page-header {
    border-bottom: 1px solid var(--c-border);
    padding: 40px 0;
  }
  .page-title {
    font-size: 36px; font-weight: 800;
    letter-spacing: -0.03em; margin-bottom: 8px;
  }
  .page-desc { font-size: 15px; color: var(--c-text-dim); }

  /* Card Grid */
  .tag-main { padding: 40px 0 0; }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .post-card {
    text-decoration: none;
    padding: 24px;
    border: 1px solid var(--c-border);
    border-radius: 12px;
    background: rgba(var(--c-overlay-rgb),0.02);
    transition: all 0.2s;
    display: flex; flex-direction: column;
  }
  .post-card:hover {
    border-color: var(--c-border-light);
    background: rgba(var(--c-overlay-rgb),0.04);
    transform: translateY(-2px);
  }
  .post-card:hover .card-title { color: var(--accent); }

  .card-top {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 12px;
  }
  .card-tags { display: flex; gap: 8px; }
  .card-tag {
    font-size: 11px; color: var(--c); text-transform: uppercase;
    letter-spacing: 0.06em; font-weight: 600;
  }
  .card-date { font-size: 12px; color: var(--c-text-dim); }

  .card-title {
    font-size: 16px; font-weight: 600; color: var(--c-text);
    line-height: 1.4; margin-bottom: 8px; transition: color 0.2s;
  }
  .card-desc {
    font-size: 13px; color: var(--c-text-dim); line-height: 1.5;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  /* Footer */
  .blog-footer {
    border-top: 1px solid var(--c-border);
    padding: 32px 0; margin-top: 48px;
  }
  .footer-row {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 12px; color: var(--c-border-light);
  }
  .footer-links { display: flex; gap: 20px; }
  .footer-links a {
    font-size: 12px; color: var(--c-text-dim); text-decoration: none;
  }
  .footer-links a:hover { color: var(--c-text); }

  @media (max-width: 1024px) {
    .card-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .mast-inner { padding: 0 20px; }
    .tags-nav-inner { padding: 0 20px; }
    .content-wrap { padding: 0 20px; }
    .card-grid { grid-template-columns: 1fr; }
    .page-title { font-size: 28px; }
  }
</style>
