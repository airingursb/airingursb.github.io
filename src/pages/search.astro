---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search | Airing">
  <div class="search-page">
    <nav class="top-nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">Airing</a>
        <div class="nav-tabs">
          <a href="/archive" class="nav-tab">Archive</a>
          <a href="/search" class="nav-tab active">Search</a>
          <a href="/feed.xml" class="nav-tab">RSS</a>
        </div>
      </div>
    </nav>

    <header class="page-header">
      <div class="header-inner">
        <h1 class="page-title">Search</h1>
      </div>
    </header>

    <main class="search-main">
      <div id="search"></div>
    </main>
  </div>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      new PagefindUI({
        element: "#search",
        showSubResults: true,
        showImages: false,
      });
    });
  </script>

  <style is:inline>
    .search-page {
      min-height: 100vh;
    }
    .top-nav {
      border-bottom: 1px solid var(--c-border, rgba(255,255,255,0.1));
      padding: 0.75rem 1.5rem;
    }
    .nav-inner {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-brand {
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--c-text, #e5e5e5);
      text-decoration: none;
    }
    .nav-tabs { display: flex; gap: 1rem; }
    .nav-tab {
      font-size: 0.85rem;
      color: var(--c-text-muted, #888);
      text-decoration: none;
    }
    .nav-tab.active, .nav-tab:hover { color: var(--accent, #4ade80); }
    .page-header { padding: 2rem 1.5rem 1rem; max-width: 900px; margin: 0 auto; }
    .page-title { font-size: 1.8rem; font-weight: 700; }
    .search-main {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 1.5rem 4rem;
    }
    :root {
      --pagefind-ui-scale: 0.9;
      --pagefind-ui-primary: var(--accent, #4ade80);
      --pagefind-ui-text: var(--c-text, #e5e5e5);
      --pagefind-ui-background: transparent;
      --pagefind-ui-border: var(--c-border, rgba(255,255,255,0.15));
      --pagefind-ui-tag: var(--c-border, rgba(255,255,255,0.1));
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 6px;
      --pagefind-ui-font: inherit;
    }
  </style>
</BaseLayout>
