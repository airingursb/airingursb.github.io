---
// World loading splash — shown while R3F + assets warm up, fades out
// when scene's first frame paints (we wire to canvas mount event).
---
<div id="world-loader" class="world-loader">
  <div class="world-loader-card">
    <div class="world-loader-flower">🌿</div>
    <div class="world-loader-title">走进林间…</div>
    <div class="world-loader-bar"><div class="world-loader-fill"></div></div>
    <div class="world-loader-hint">第一次来加载约 2-3 秒</div>
  </div>
</div>

<script is:inline>
  // Fade-out once the R3F canvas is mounted (first frame painted)
  const loader = document.getElementById('world-loader')
  if (loader) {
    const start = Date.now()
    const FADE_MIN_MS = 600
    function fade() {
      const dt = Date.now() - start
      const wait = Math.max(0, FADE_MIN_MS - dt)
      setTimeout(() => {
        loader.style.opacity = '0'
        setTimeout(() => loader.remove(), 400)
      }, wait)
    }
    // Watch for canvas appearing
    const obs = new MutationObserver(() => {
      const c = document.querySelector('#world-root canvas')
      if (c) {
        // wait until canvas actually has content
        requestAnimationFrame(() => requestAnimationFrame(fade))
        obs.disconnect()
      }
    })
    obs.observe(document.body, { childList: true, subtree: true })
    // Safety: hide after 8s regardless
    setTimeout(() => { if (loader.isConnected) fade() }, 8000)
  }
</script>

<style is:global>
  .world-loader {
    position: fixed; inset: 0;
    background: linear-gradient(180deg, #F4E4C8 0%, #E0D0A8 100%);
    display: flex; align-items: center; justify-content: center;
    z-index: 200;
    color: #5C3D24;
    font-family: ui-monospace, monospace;
    transition: opacity 400ms ease-out;
  }
  .world-loader-card {
    text-align: center;
    padding: 32px 40px;
  }
  .world-loader-flower {
    font-size: 56px;
    margin-bottom: 18px;
    animation: world-loader-pulse 2.5s ease-in-out infinite;
  }
  @keyframes world-loader-pulse {
    0%, 100% { transform: scale(1) rotate(-3deg); opacity: 0.9; }
    50%      { transform: scale(1.1) rotate(3deg); opacity: 1; }
  }
  .world-loader-title {
    font-size: 14px;
    color: #5C3D24;
    margin-bottom: 16px;
  }
  .world-loader-bar {
    width: 200px; height: 4px;
    background: rgba(92, 61, 36, 0.18);
    border-radius: 2px;
    overflow: hidden;
    margin: 0 auto 12px;
  }
  .world-loader-fill {
    width: 0;
    height: 100%;
    background: linear-gradient(90deg, #C97B5C, #E89A4A, #FCD757);
    animation: world-loader-progress 2.5s ease-out forwards;
  }
  @keyframes world-loader-progress {
    0% { width: 0; }
    60% { width: 80%; }
    100% { width: 100%; }
  }
  .world-loader-hint {
    font-size: 10px;
    color: rgba(92, 61, 36, 0.55);
  }
</style>
