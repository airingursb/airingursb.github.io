---
// World loading splash — shown while R3F + assets warm up, fades out
// when scene's first frame paints (we wire to canvas mount event).
---
<div id="world-loader" class="world-loader" role="status" aria-live="polite" aria-label="正在加载 3D 场景">
  <div class="world-loader-card">
    <div class="world-loader-flower" aria-hidden="true">🌿</div>
    <div class="world-loader-title">走进林间…</div>
    <div class="world-loader-bar" aria-hidden="true"><div class="world-loader-fill"></div></div>
    <div class="world-loader-hint">Airing 的木屋岛 · 拖动旋转 · 点击进入</div>
  </div>
</div>

<!-- V40: WebGL-failed fallback DOM — only shown if canvas never appears
     or context creation fails. Addresses real user-reported blackscreen
     bug from WebGL-blocked browsers. -->
<div id="world-webgl-fallback" class="world-webgl-fallback" role="alert" hidden>
  <div class="world-fallback-card">
    <div class="world-fallback-flower">🪧</div>
    <div class="world-fallback-title">无法加载 3D 场景</div>
    <p class="world-fallback-body">
      您的浏览器似乎禁用了 WebGL（硬件加速），或被扩展拦了。<br/>
      请到 <code>chrome://settings/system</code> 开启「使用硬件加速」，<br/>
      或换 Chrome / Firefox / Safari 再试。
    </p>
    <div class="world-fallback-actions">
      <a href="/nook/" class="world-fallback-btn">前往 nook 2D 版本 →</a>
      <a href="/" class="world-fallback-btn world-fallback-btn-ghost">回首页</a>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const loader = document.getElementById('world-loader')
    const fallback = document.getElementById('world-webgl-fallback')
    if (!loader) return

    // V40 fast-path: synchronous WebGL capability check
    const HAS_WEBGL = (
      'WebGL2RenderingContext' in window ||
      'WebGLRenderingContext' in window
    )
    if (!HAS_WEBGL) {
      loader.remove()
      if (fallback) fallback.hidden = false
      return
    }

    const start = Date.now()
    const FADE_MIN_MS = 600

    function isCanvasWorking(canvas) {
      if (!canvas) return false
      try {
        const ctx = canvas.getContext('webgl2') || canvas.getContext('webgl')
        return !!ctx && !ctx.isContextLost?.()
      } catch { return false }
    }

    function fade() {
      const dt = Date.now() - start
      const wait = Math.max(0, FADE_MIN_MS - dt)
      setTimeout(() => {
        loader.style.opacity = '0'
        // 50ms buffer past the 400ms CSS transition prevents the
        // race-window flash on slow CPUs where DOM removal fires
        // before the opacity animation has fully committed.
        setTimeout(() => loader.remove(), 450)
      }, wait)
    }

    function showFallback() {
      if (loader.isConnected) loader.remove()
      if (fallback) fallback.hidden = false
    }

    const obs = new MutationObserver(() => {
      const c = document.querySelector('#world-root canvas')
      if (c && isCanvasWorking(c)) {
        requestAnimationFrame(() => requestAnimationFrame(fade))
        obs.disconnect()
      }
    })
    obs.observe(document.body, { childList: true, subtree: true })

    // V40: extended 12s patience + escalate to fallback if canvas not
    // working (was: silently fade splash even on failure → user saw black).
    setTimeout(() => {
      const c = document.querySelector('#world-root canvas')
      if (c && isCanvasWorking(c)) {
        if (loader.isConnected) fade()
      } else {
        obs.disconnect()
        showFallback()
      }
    }, 12000)
  })()
</script>

<style is:global>
  .world-loader {
    position: fixed; inset: 0;
    background: linear-gradient(180deg, #F4E4C8 0%, #E0D0A8 100%);
    display: flex; align-items: center; justify-content: center;
    z-index: 200;
    color: #5C3D24;
    font-family: ui-monospace, monospace;
    transition: opacity 400ms ease-out;
  }
  .world-loader-card {
    text-align: center;
    padding: 32px 40px;
  }
  .world-loader-flower {
    font-size: 56px;
    margin-bottom: 18px;
    animation: world-loader-pulse 2.5s ease-in-out infinite;
  }
  @keyframes world-loader-pulse {
    0%, 100% { transform: scale(1) rotate(-3deg); opacity: 0.9; }
    50%      { transform: scale(1.1) rotate(3deg); opacity: 1; }
  }
  .world-loader-title {
    font-size: 14px;
    color: #5C3D24;
    margin-bottom: 16px;
  }
  .world-loader-bar {
    width: 200px; height: 4px;
    background: rgba(92, 61, 36, 0.18);
    border-radius: 2px;
    overflow: hidden;
    margin: 0 auto 12px;
  }
  .world-loader-fill {
    width: 0;
    height: 100%;
    background: linear-gradient(90deg, #C97B5C, #E89A4A, #FCD757);
    animation: world-loader-progress 2.5s ease-out forwards;
  }
  @keyframes world-loader-progress {
    0% { width: 0; }
    60% { width: 80%; }
    100% { width: 100%; }
  }
  .world-loader-hint {
    font-size: 10px;
    color: rgba(92, 61, 36, 0.55);
  }

  /* V40: WebGL-failed fallback */
  .world-webgl-fallback {
    position: fixed; inset: 0;
    background: linear-gradient(180deg, #2a2438 0%, #14101c 100%);
    display: flex; align-items: center; justify-content: center;
    z-index: 100;
    color: #f4ead5;
    font-family: ui-monospace, monospace;
    padding: 24px;
  }
  .world-fallback-card {
    text-align: center;
    max-width: 480px;
  }
  .world-fallback-flower {
    font-size: 56px;
    margin-bottom: 18px;
  }
  .world-fallback-title {
    font-family: "Songti SC", "Noto Serif SC", serif;
    font-size: 22px;
    margin-bottom: 16px;
    color: #FFD9A8;
  }
  .world-fallback-body {
    font-size: 13px;
    line-height: 1.75;
    color: rgba(244, 234, 213, 0.7);
    margin: 0 0 26px;
  }
  .world-fallback-body code {
    background: rgba(244, 234, 213, 0.12);
    padding: 2px 8px;
    border-radius: 4px;
    color: #FFE4C0;
  }
  .world-fallback-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .world-fallback-btn {
    padding: 10px 22px;
    background: #C97B5C;
    color: #FFF4DC;
    border-radius: 8px;
    text-decoration: none;
    font-size: 13px;
    transition: background 200ms ease;
  }
  .world-fallback-btn:hover {
    background: #B86E50;
  }
  .world-fallback-btn:focus-visible {
    outline: 2px solid #FCD757;
    outline-offset: 3px;
  }
  .world-fallback-btn-ghost {
    background: transparent;
    border: 1px solid rgba(244, 234, 213, 0.3);
    color: rgba(244, 234, 213, 0.85);
  }
  .world-fallback-btn-ghost:hover {
    background: rgba(244, 234, 213, 0.08);
  }

  /* Respect users with vestibular sensitivity — kill the loader
     animations but keep all info readable + clickable. */
  @media (prefers-reduced-motion: reduce) {
    .world-loader-flower {
      animation: none;
    }
    .world-loader-fill {
      animation: none;
      width: 60%;
    }
    .world-loader {
      transition: opacity 200ms linear;
    }
  }
</style>
