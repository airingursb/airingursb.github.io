---
/**
 * B1: Broadsheet — 经典大报
 * - 左侧窄栏 metadata + 右侧宽内容
 * - 标题跨全宽，巨大字号
 * - 上方细线 + 粗线双层报头
 * - 内容区无衬线标题 + 等宽正文
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  tags: string[];
  description?: string;
  cover?: string;
}

const { title, date, tags, description, cover } = Astro.props;

const dateStr = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const shortDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<BaseLayout title={`${title} | Airing`} description={description} ogType="article" ogImage={cover}>
  <div class="post-page">
    <!-- Masthead -->
    <header class="masthead">
      <div class="mast-inner">
        <div class="mast-top-rule"></div>
        <div class="mast-bar">
          <a href="/" class="mast-brand">Airing's Blog</a>
          <span class="mast-date">{dateStr}</span>
          <div class="mast-links">
            <a href="/archive">Archive</a>
            <a href="/feed.xml">RSS</a>
          </div>
        </div>
        <div class="mast-bottom-rule"></div>
      </div>
    </header>

    <!-- Headline: full width -->
    <div class="headline-section">
      <div class="headline-inner">
        <div class="headline-tags">
          {tags.map(tag => (
            <a href={`/tags/${tag}`} class="hl-tag">{tag}</a>
          ))}
        </div>
        <h1 class="headline">{title}</h1>
        {description && <p class="headline-deck">{description}</p>}
      </div>
    </div>

    {cover && (
      <div class="cover-section">
        <img src={cover} alt={title} />
        <div class="cover-caption">{title}</div>
      </div>
    )}

    <!-- Two-column: sidebar left + content right -->
    <div class="content-grid">
      <aside class="sidebar-left">
        <div class="sb-block">
          <div class="sb-label">Date</div>
          <div class="sb-value">{shortDate}</div>
        </div>
        {tags.length > 0 && (
          <div class="sb-block">
            <div class="sb-label">Tags</div>
            <div class="sb-tags">
              {tags.map(tag => (
                <a href={`/tags/${tag}`} class="sb-tag">#{tag}</a>
              ))}
            </div>
          </div>
        )}
        <div class="sb-block">
          <div class="sb-label">Author</div>
          <div class="sb-value">Airing</div>
        </div>
        <div class="sb-divider"></div>
        <a href="/archive" class="sb-nav">&larr; All Posts</a>
      </aside>

      <article class="post-content">
        <slot />
      </article>
    </div>

    <footer class="page-footer">
      <div class="footer-inner">
        <div class="footer-rule"></div>
        <div class="footer-bar">
          <a href="/">&larr; Home</a>
          <span class="footer-copy">&copy; Airing</span>
          <a href="/archive">Archive &rarr;</a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>

<style>
  .post-page { width: 100%; min-height: 100vh; }

  /* ===== Masthead ===== */
  .masthead { width: 100%; }
  .mast-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .mast-top-rule {
    height: 4px;
    background: #e6edf3;
    margin-top: 24px;
  }
  .mast-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
  }
  .mast-brand {
    font-size: 11px;
    color: #7d8590;
    text-decoration: none;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .mast-brand:hover { color: #e6edf3; }
  .mast-date {
    font-size: 12px;
    color: #484f58;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  .mast-links {
    display: flex;
    gap: 16px;
  }
  .mast-links a {
    font-size: 11px;
    color: #484f58;
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .mast-links a:hover { color: #e6edf3; }
  .mast-bottom-rule {
    height: 1px;
    background: #21262d;
  }

  /* ===== Headline ===== */
  .headline-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 48px 40px;
    border-bottom: 1px solid #21262d;
  }
  .headline-inner {
    max-width: 860px;
  }
  .headline-tags {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
  }
  .hl-tag {
    font-size: 11px;
    color: #4ade80;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
  .headline {
    font-size: clamp(30px, 5vw, 52px);
    font-weight: 800;
    color: #e6edf3;
    line-height: 1.08;
    letter-spacing: -0.03em;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  .headline-deck {
    font-size: 18px;
    color: #7d8590;
    margin-top: 16px;
    line-height: 1.5;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  /* ===== Cover ===== */
  .cover-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 48px;
    border-bottom: 1px solid #21262d;
  }
  .cover-section img {
    width: 100%;
    border-radius: 4px;
    display: block;
  }
  .cover-caption {
    font-size: 11px;
    color: #484f58;
    margin-top: 8px;
    font-style: italic;
  }

  /* ===== Content Grid: left sidebar ===== */
  .content-grid {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 48px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 48px 60px;
    align-items: start;
  }

  /* Sidebar */
  .sidebar-left {
    position: sticky;
    top: 40px;
    border-right: 1px solid #21262d;
    padding-right: 24px;
    padding-top: 4px;
  }
  .sb-block { margin-bottom: 24px; }
  .sb-label {
    font-size: 9px;
    color: #484f58;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 4px;
    font-weight: 600;
  }
  .sb-value {
    font-size: 13px;
    color: #7d8590;
  }
  .sb-tags {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sb-tag {
    font-size: 13px;
    color: #4ade80;
    text-decoration: none;
  }
  .sb-tag:hover { opacity: 0.7; }
  .sb-divider {
    height: 1px;
    background: #21262d;
    margin: 20px 0;
  }
  .sb-nav {
    font-size: 12px;
    color: #484f58;
    text-decoration: none;
  }
  .sb-nav:hover { color: #e6edf3; }

  /* ===== Content ===== */
  .post-content {
    color: #c9d1d9;
    font-size: 15px;
    line-height: 1.9;
    min-width: 0;
    max-width: 72ch;
  }
  .post-content :global(h2) {
    font-size: 24px;
    font-weight: 700;
    margin-top: 48px;
    margin-bottom: 16px;
    color: #e6edf3;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    letter-spacing: -0.01em;
  }
  .post-content :global(h3) {
    font-size: 18px;
    font-weight: 600;
    margin-top: 36px;
    margin-bottom: 12px;
    color: #e6edf3;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  .post-content :global(p) { margin-bottom: 18px; }
  .post-content :global(a) {
    color: #4ade80;
    text-decoration: none;
    border-bottom: 1px solid rgba(74,222,128,0.25);
  }
  .post-content :global(a:hover) { border-bottom-color: #4ade80; }
  .post-content :global(img) {
    max-width: calc(100% + 60px);
    width: calc(100% + 60px);
    margin-left: -30px;
    border-radius: 4px;
    margin-top: 24px;
    margin-bottom: 24px;
    display: block;
  }
  .post-content :global(pre) {
    max-width: calc(100% + 80px);
    width: calc(100% + 80px);
    margin-left: -40px;
    background: #0d1117;
    border: 1px solid #21262d;
    border-radius: 4px;
    padding: 20px 28px;
    overflow-x: auto;
    margin-top: 24px;
    margin-bottom: 24px;
    font-size: 13px;
    line-height: 1.65;
  }
  .post-content :global(code:not(pre code)) {
    background: rgba(255,255,255,0.05);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 13px;
  }
  .post-content :global(blockquote) {
    border-left: 3px solid #4ade80;
    padding-left: 20px;
    color: #8b949e;
    margin: 24px 0;
  }
  .post-content :global(ul), .post-content :global(ol) {
    margin-bottom: 18px;
    padding-left: 24px;
  }
  .post-content :global(li) { margin-bottom: 6px; }
  .post-content :global(hr) {
    border: none;
    height: 1px;
    background: #21262d;
    margin: 40px 0;
  }
  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 13px;
  }
  .post-content :global(th), .post-content :global(td) {
    border: 1px solid #21262d;
    padding: 8px 14px;
    text-align: left;
  }
  .post-content :global(th) {
    background: rgba(255,255,255,0.02);
    font-weight: 600;
    color: #7d8590;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ===== Footer ===== */
  .page-footer {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px 48px;
  }
  .footer-rule {
    height: 4px;
    background: #e6edf3;
    margin-bottom: 14px;
  }
  .footer-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-bar a {
    font-size: 11px;
    color: #484f58;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .footer-bar a:hover { color: #e6edf3; }
  .footer-copy {
    font-size: 11px;
    color: #30363d;
  }

  @media (max-width: 860px) {
    .mast-inner, .headline-section, .content-grid,
    .cover-section, .page-footer { padding-left: 20px; padding-right: 20px; }
    .mast-date { display: none; }
    .content-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .sidebar-left {
      position: static;
      border-right: none;
      border-bottom: 1px solid #21262d;
      padding-right: 0;
      padding-bottom: 20px;
      margin-bottom: 32px;
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
    }
    .sb-block { margin-bottom: 0; }
    .sb-divider { display: none; }
    .post-content :global(img),
    .post-content :global(pre) {
      max-width: 100%; width: 100%; margin-left: 0;
    }
  }
</style>
