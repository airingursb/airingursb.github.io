---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = "Airing's Homepage - Software Engineer @ Singapore",
  ogImage,
  ogType = 'website',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content="airing, homepage, blog">
  <meta name="robots" content="index, follow">
  <meta name="author" content="Airing">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content={ogType}>
  {ogImage && <meta property="og:image" content={ogImage} />}
  <link rel="shortcut icon" href="https://airing.ursb.me/image/favicon.ico">
  <link rel="apple-touch-icon" href="https://airing.ursb.me/image/favicon.ico">
  <link rel="icon" href="https://airing.ursb.me/image/favicon.ico">
  <link rel="alternate" type="application/rss+xml" title="Airing's Blog" href="/feed.xml">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-W604S49M4X"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-W604S49M4X');
  </script>
  <!-- Cal.com Embed -->
  <script is:inline type="text/javascript">
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = api;
            p(api, ar);
          } else {
            p(cal, ar);
          }
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");
    Cal("init", { origin: "https://cal.com" });
    Cal("ui", {
      theme: "dark",
      styles: { branding: { brandColor: "#f59e0b" } },
      hideEventTypeDetails: false,
      layout: "month_view"
    });
  </script>
  <slot name="head" />
  <script is:inline>
    // Apply saved theme before render to prevent flash
    (function() {
      var t = localStorage.getItem('blog-theme');
      if (t) document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
  <slot />

  <!-- Theme Switcher -->
  <div class="theme-switcher" id="themeSwitcher">
    <button class="theme-toggle" id="themeToggle" aria-label="Switch theme">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="8" cy="8" r="3" fill="currentColor"/>
      </svg>
    </button>
    <div class="theme-dots" id="themeDots">
      <button class="theme-dot" data-theme="green" style="--dot-color:#4ade80" title="Green"></button>
      <button class="theme-dot" data-theme="blue" style="--dot-color:#60a5fa" title="Blue"></button>
      <button class="theme-dot" data-theme="purple" style="--dot-color:#a78bfa" title="Purple"></button>
      <button class="theme-dot" data-theme="amber" style="--dot-color:#fbbf24" title="Amber"></button>
      <button class="theme-dot" data-theme="rose" style="--dot-color:#fb7185" title="Rose"></button>
      <button class="theme-dot" data-theme="cyan" style="--dot-color:#22d3ee" title="Cyan"></button>
    </div>
  </div>

  <script is:inline>
    (function() {
      var toggle = document.getElementById('themeToggle');
      var dots = document.getElementById('themeDots');
      var switcher = document.getElementById('themeSwitcher');
      var open = false;

      toggle.addEventListener('click', function(e) {
        e.stopPropagation();
        open = !open;
        dots.classList.toggle('active', open);
        toggle.classList.toggle('active', open);
      });

      dots.addEventListener('click', function(e) {
        var btn = e.target.closest('.theme-dot');
        if (!btn) return;
        var theme = btn.dataset.theme;
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('blog-theme', theme);
        dots.querySelectorAll('.theme-dot').forEach(function(d) {
          d.classList.toggle('selected', d.dataset.theme === theme);
        });
      });

      document.addEventListener('click', function(e) {
        if (!switcher.contains(e.target) && open) {
          open = false;
          dots.classList.remove('active');
          toggle.classList.remove('active');
        }
      });

      // Mark current theme
      var current = localStorage.getItem('blog-theme') || 'green';
      dots.querySelectorAll('.theme-dot').forEach(function(d) {
        d.classList.toggle('selected', d.dataset.theme === current);
      });
    })();
  </script>
</body>
</html>
