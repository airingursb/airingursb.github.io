---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  hreflang?: { zh?: string; en?: string };
}

const {
  title,
  description = "Airing's Homepage - Software Engineer @ Singapore",
  ogImage,
  ogType = 'website',
  hreflang,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content="airing, homepage, blog">
  <meta name="robots" content="index, follow">
  <meta name="author" content="Airing">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content={ogType}>
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href}>
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href}>
  <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  {ogImage && <meta property="og:image" content={ogImage} />}
  <link rel="shortcut icon" href="https://airing.ursb.me/image/favicon.ico">
  <link rel="apple-touch-icon" href="https://airing.ursb.me/image/favicon.ico">
  <link rel="icon" href="https://airing.ursb.me/image/favicon.ico">
  <link rel="alternate" type="application/rss+xml" title="Airing's Blog" href="/blog/feed.xml">
  <link rel="alternate" type="application/rss+xml" title="Airing's Blog (English)" href="/en/blog/feed.xml">
  {hreflang?.zh && <link rel="alternate" hreflang="zh" href={hreflang.zh} />}
  {hreflang?.en && <link rel="alternate" hreflang="en" href={hreflang.en} />}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-W604S49M4X"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-W604S49M4X');
  </script>
  <!-- Umami Analytics -->
  <script is:inline defer src="https://analytics.ursb.me/script.js" data-website-id="aa8d5a16-df21-4058-a0a8-0191cdd3798d"></script>
  <script is:inline>
    (function() {
      function identifySession() {
        if (typeof umami === 'undefined') return;
        var theme = localStorage.getItem('blog-mode') || 'dark';
        var lang = localStorage.getItem('preferred_lang') || 'zh';
        var visited = localStorage.getItem('visited');
        var returning = visited ? 'yes' : 'no';
        if (!visited) localStorage.setItem('visited', '1');
        umami.identify({ theme: theme, language: lang, returning: returning });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() { setTimeout(identifySession, 500); });
      } else {
        setTimeout(identifySession, 500);
      }
    })();
  </script>
  <!-- Cal.com Embed -->
  <script is:inline type="text/javascript">
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = api;
            p(api, ar);
          } else {
            p(cal, ar);
          }
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");
    Cal("init", { origin: "https://cal.com" });
    Cal("ui", {
      theme: "dark",
      styles: { branding: { brandColor: "#f59e0b" } },
      hideEventTypeDetails: false,
      layout: "month_view"
    });
  </script>
  <slot name="head" />
  <script is:inline>
    // Apply saved theme & mode before render to prevent flash
    (function() {
      var t = localStorage.getItem('blog-theme');
      if (t) document.documentElement.setAttribute('data-theme', t);
      var userSet = localStorage.getItem('blog-mode-set');
      if (userSet) {
        // User has manually toggled — respect their choice
        var m = localStorage.getItem('blog-mode');
        if (m) document.documentElement.setAttribute('data-mode', m);
      } else {
        // No manual toggle — use path-based default: homepage=dark, blog=light
        var path = window.location.pathname;
        var isBlog = path.startsWith('/blog') || path.startsWith('/posts/') || path.startsWith('/archive') || path.startsWith('/moments') || path.startsWith('/friends') || path.startsWith('/search') || path.startsWith('/tags/') || path.startsWith('/notes');
        document.documentElement.setAttribute('data-mode', isBlog ? 'light' : 'dark');
      }
    })();
  </script>
</head>
<body>
  <slot />

  <!-- Mode Toggle (light/dark) -->
  <div class="theme-switcher" id="themeSwitcher">
    <button class="mode-toggle" id="modeToggle" aria-label="Toggle light/dark mode">
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 16 16" fill="none">
        <circle cx="8" cy="8" r="3.5" stroke="currentColor" stroke-width="1.5"/>
        <line x1="8" y1="0.5" x2="8" y2="2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="8" y1="13.5" x2="8" y2="15.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="0.5" y1="8" x2="2.5" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="13.5" y1="8" x2="15.5" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="2.7" y1="2.7" x2="4.1" y2="4.1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="11.9" y1="11.9" x2="13.3" y2="13.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="2.7" y1="13.3" x2="4.1" y2="11.9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="11.9" y1="4.1" x2="13.3" y2="2.7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M13.5 9.5a5.5 5.5 0 01-7-7 5.5 5.5 0 107 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

  <script is:inline>
    (function() {
      var switcher = document.getElementById('themeSwitcher');
      var modeToggle = document.getElementById('modeToggle');

      // Mode toggle (light/dark)
      function updateModeIcon() {
        var isLight = document.documentElement.getAttribute('data-mode') === 'light';
        switcher.classList.toggle('light-mode', isLight);
      }
      modeToggle.addEventListener('click', function(e) {
        e.stopPropagation();
        var current = document.documentElement.getAttribute('data-mode');
        var next = current === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-mode', next);
        localStorage.setItem('blog-mode', next);
        localStorage.setItem('blog-mode-set', '1');
        updateModeIcon();
        if (typeof umami !== 'undefined') {
          umami.track('dark-mode-toggle', { mode: next });
          umami.identify({ theme: next });
        }
      });
      updateModeIcon();
    })();
  </script>
</body>
</html>
