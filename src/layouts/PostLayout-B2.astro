---
/**
 * B2: Tabloid — 特刊/Mook 风格
 * - 全宽彩色 hero 区域（暗绿渐变背景）
 * - 标题在 hero 内，超大字号
 * - 内容区右侧浮动 sidebar card
 * - 图片全宽突破，代码宽出
 * - 更有视觉张力的杂志感
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  tags: string[];
  description?: string;
  cover?: string;
}

const { title, date, tags, description, cover } = Astro.props;

const dateStr = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | Airing`} description={description} ogType="article" ogImage={cover}>
  <div class="post-page">
    <!-- Hero with gradient bg -->
    <header class="hero">
      <div class="hero-inner">
        <nav class="hero-nav">
          <a href="/" class="nav-link">&larr; Home</a>
          <div class="nav-right">
            <a href="/archive" class="nav-link">Archive</a>
            <a href="/feed.xml" class="nav-link">RSS</a>
          </div>
        </nav>
        <div class="hero-body">
          <div class="hero-tags">
            {tags.map(tag => (
              <a href={`/tags/${tag}`} class="hero-tag">{tag}</a>
            ))}
          </div>
          <h1 class="hero-title">{title}</h1>
          {description && <p class="hero-desc">{description}</p>}
          <div class="hero-byline">
            <span class="byline-author">Airing</span>
            <span class="byline-dot">&middot;</span>
            <time datetime={date.toISOString()}>{dateStr}</time>
          </div>
        </div>
      </div>
      <div class="hero-bottom-edge"></div>
    </header>

    {cover && (
      <div class="cover-bleed">
        <img src={cover} alt={title} />
      </div>
    )}

    <!-- Content area with floating sidebar -->
    <div class="content-wrap">
      <article class="post-content">
        <slot />
      </article>

      <aside class="float-sidebar">
        <div class="fs-card">
          <div class="fs-section">
            <div class="fs-label">Published</div>
            <div class="fs-value">{dateStr}</div>
          </div>
          {tags.length > 0 && (
            <div class="fs-section">
              <div class="fs-label">Topics</div>
              <div class="fs-tags">
                {tags.map(tag => (
                  <a href={`/tags/${tag}`} class="fs-tag">#{tag}</a>
                ))}
              </div>
            </div>
          )}
          <div class="fs-section">
            <a href="/archive" class="fs-link">Browse all posts &rarr;</a>
          </div>
        </div>
      </aside>
    </div>

    <footer class="page-footer">
      <div class="footer-inner">
        <a href="/" class="footer-link">&larr; Home</a>
        <span class="footer-sep">|</span>
        <a href="/archive" class="footer-link">Archive</a>
      </div>
    </footer>
  </div>
</BaseLayout>

<style>
  .post-page { width: 100%; min-height: 100vh; }

  /* ===== Hero ===== */
  .hero {
    width: 100%;
    background: linear-gradient(160deg, #0d1117 0%, #0f1d15 50%, #0d1117 100%);
    position: relative;
  }
  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 48px 64px;
  }
  .hero-nav {
    display: flex;
    justify-content: space-between;
    margin-bottom: 56px;
  }
  .nav-link {
    font-size: 12px;
    color: #484f58;
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .nav-link:hover { color: #e6edf3; }
  .nav-right { display: flex; gap: 16px; }

  .hero-body { max-width: 860px; }
  .hero-tags {
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
  }
  .hero-tag {
    font-size: 11px;
    color: #4ade80;
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 3px 10px;
    border: 1px solid rgba(74,222,128,0.25);
    border-radius: 3px;
  }
  .hero-tag:hover { border-color: #4ade80; }
  .hero-title {
    font-size: clamp(32px, 5.5vw, 58px);
    font-weight: 800;
    color: #e6edf3;
    line-height: 1.08;
    letter-spacing: -0.03em;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    margin-bottom: 16px;
  }
  .hero-desc {
    font-size: 18px;
    color: #7d8590;
    line-height: 1.55;
    max-width: 640px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    margin-bottom: 20px;
  }
  .hero-byline {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: #484f58;
  }
  .byline-author { color: #7d8590; }
  .byline-dot { color: #30363d; }

  .hero-bottom-edge {
    height: 1px;
    background: linear-gradient(90deg, transparent, #4ade80 30%, #4ade80 70%, transparent);
    opacity: 0.3;
  }

  /* ===== Cover ===== */
  .cover-bleed {
    max-width: 1100px;
    margin: -20px auto 0;
    padding: 0 48px;
    position: relative;
    z-index: 1;
  }
  .cover-bleed img {
    width: 100%;
    border-radius: 8px;
    display: block;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }

  /* ===== Content Grid ===== */
  .content-wrap {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 56px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 48px 60px;
    align-items: start;
  }

  /* Floating sidebar */
  .float-sidebar {
    position: sticky;
    top: 40px;
  }
  .fs-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid #21262d;
    border-radius: 8px;
    padding: 20px;
  }
  .fs-section {
    margin-bottom: 20px;
  }
  .fs-section:last-child { margin-bottom: 0; }
  .fs-label {
    font-size: 10px;
    color: #484f58;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 6px;
    font-weight: 600;
  }
  .fs-value {
    font-size: 13px;
    color: #7d8590;
  }
  .fs-tags { display: flex; flex-direction: column; gap: 4px; }
  .fs-tag {
    font-size: 13px;
    color: #4ade80;
    text-decoration: none;
  }
  .fs-tag:hover { opacity: 0.7; }
  .fs-link {
    font-size: 12px;
    color: #7d8590;
    text-decoration: none;
    transition: color 0.2s;
  }
  .fs-link:hover { color: #4ade80; }

  /* ===== Content ===== */
  .post-content {
    color: #c9d1d9;
    font-size: 16px;
    line-height: 1.85;
    min-width: 0;
  }
  .post-content :global(h2) {
    font-size: 26px;
    font-weight: 700;
    margin-top: 52px;
    margin-bottom: 16px;
    color: #e6edf3;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    letter-spacing: -0.015em;
  }
  .post-content :global(h3) {
    font-size: 19px;
    font-weight: 600;
    margin-top: 40px;
    margin-bottom: 12px;
    color: #e6edf3;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  .post-content :global(p) { margin-bottom: 20px; }
  .post-content :global(a) {
    color: #4ade80;
    text-decoration: none;
    border-bottom: 1px solid rgba(74,222,128,0.3);
  }
  .post-content :global(a:hover) { border-bottom-color: #4ade80; }

  .post-content :global(img) {
    max-width: calc(100% + 80px);
    width: calc(100% + 80px);
    margin-left: -40px;
    border-radius: 8px;
    margin-top: 28px;
    margin-bottom: 28px;
    display: block;
  }
  .post-content :global(pre) {
    max-width: calc(100% + 60px);
    width: calc(100% + 60px);
    margin-left: -30px;
    background: #0a0e14;
    border: 1px solid #21262d;
    border-radius: 8px;
    padding: 22px 28px;
    overflow-x: auto;
    margin-top: 24px;
    margin-bottom: 24px;
    font-size: 13px;
    line-height: 1.65;
  }
  .post-content :global(code:not(pre code)) {
    background: rgba(255,255,255,0.06);
    padding: 2px 7px;
    border-radius: 4px;
    font-size: 14px;
  }
  .post-content :global(blockquote) {
    border-left: 3px solid #4ade80;
    padding: 4px 0 4px 24px;
    color: #8b949e;
    margin: 28px 0;
    font-size: 17px;
    line-height: 1.7;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-style: italic;
  }
  .post-content :global(ul), .post-content :global(ol) {
    margin-bottom: 20px;
    padding-left: 24px;
  }
  .post-content :global(li) { margin-bottom: 8px; }
  .post-content :global(hr) {
    border: none;
    height: 1px;
    background: #21262d;
    margin: 48px 0;
  }
  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 14px;
  }
  .post-content :global(th), .post-content :global(td) {
    border: 1px solid #21262d;
    padding: 10px 14px;
    text-align: left;
  }
  .post-content :global(th) {
    background: rgba(255,255,255,0.02);
    font-weight: 600;
    color: #7d8590;
  }

  /* ===== Footer ===== */
  .page-footer {
    border-top: 1px solid #21262d;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 48px 48px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .footer-link {
    font-size: 12px;
    color: #484f58;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .footer-link:hover { color: #e6edf3; }
  .footer-sep { color: #21262d; font-size: 12px; }

  @media (max-width: 900px) {
    .hero-inner, .content-wrap, .cover-bleed,
    .footer-inner { padding-left: 20px; padding-right: 20px; }
    .content-wrap {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .float-sidebar {
      position: static;
      margin-top: 40px;
    }
    .post-content :global(img),
    .post-content :global(pre) {
      max-width: 100%; width: 100%; margin-left: 0;
    }
  }
</style>
