  }
  .post-content :global(code:not(pre code)) {
    background: rgba(var(--c-overlay-rgb),0.05); padding: 2px 6px;
    border-radius: 3px; font-size: 14px;
    font-family: 'SF Mono', 'Fira Code', Menlo, Consolas, monospace;
  }
  .post-content :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 20px; color: var(--c-text-muted); margin: 32px 0;
    font-size: 17px; line-height: 1.9;
  }
  .post-content :global(ul), .post-content :global(ol) { margin-bottom: 24px; padding-left: 24px; }
  .post-content :global(li) { margin-bottom: 8px; }
  .post-content :global(hr) { border: none; height: 1px; background: var(--c-border); margin: 48px 0; }
  .post-content :global(table) { width: 100%; border-collapse: collapse; margin: 24px 0; font-size: 14px; }
  .post-content :global(th), .post-content :global(td) { border: 1px solid var(--c-border); padding: 8px 14px; text-align: left; }
  .post-content :global(th) {
    background: rgba(var(--c-overlay-rgb),0.02); font-weight: 600; color: var(--c-text-muted);
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;
  }
  .post-content :global(strong) {
    font-weight: 700;
  }

  /* ===== Highlights ===== */
  .post-content :global(mark.comment-highlight) {
    background: rgba(var(--accent-rgb), 0.08);
    color: inherit;
    border-bottom: 2px solid rgba(var(--accent-rgb), 0.35);
    padding: 1px 0;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .post-content :global(mark.comment-highlight.highlight-active) {
    background: rgba(var(--accent-rgb), 0.18);
    border-bottom-color: var(--accent);
  }
  .post-content :global(mark.comment-highlight.highlight-flash) {
    animation: highlightFlash 1s ease;
  }

  /* ===== Comment Rail (right column) ===== */
  .comment-rail {
    border-left: 1px solid var(--c-border);
    padding-left: 0;
    position: relative;
  }
  .cr-header {
    display: flex; justify-content: space-between; align-items: center;
    padding-left: 16px; margin-bottom: 12px;
  }
  .cr-label {
    font-size: 9px; color: var(--c-text-dim);
