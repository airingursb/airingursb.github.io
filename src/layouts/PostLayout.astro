  }
  .comment-rail :global(.cm-card-delete:hover) {
    color: #f85149; background: rgba(248,81,73,0.1);
  }

  /* ===== Reply Elements ===== */
  .comment-rail :global(.cm-replies) { margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(127,127,127,0.12); }
  .comment-rail :global(.cm-reply) { margin-bottom: 6px; }
  .comment-rail :global(.cm-reply-header) { display: flex; align-items: center; gap: 4px; margin-bottom: 2px; }
  .comment-rail :global(.cm-reply-avatar) { width: 16px; height: 16px; border-radius: 50%; }
  .comment-rail :global(.cm-reply-name) { font-size: 11px; font-weight: 600; color: var(--c-text-muted, #666); }
  .comment-rail :global(.cm-reply-time) { font-size: 10px; color: var(--c-text-dim, #999); margin-left: auto; }
  .comment-rail :global(.cm-reply-body) { font-size: 11px; line-height: 1.4; color: var(--c-text, #333); padding-left: 20px; }
  .comment-rail :global(.cm-reply-btn) { display: block; margin-top: 6px; padding: 2px 8px; font-size: 11px; color: var(--accent, #4ade80); background: none; border: 1px solid var(--accent, #4ade80); border-radius: 4px; cursor: pointer; opacity: 0.7; transition: opacity 0.2s; }
  .comment-rail :global(.cm-reply-btn:hover) { opacity: 1; }
  .comment-rail :global(.cm-reply-form) { margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(127,127,127,0.12); }
  .comment-rail :global(.cm-rf-identity) { display: flex; gap: 4px; margin-bottom: 4px; }
  .comment-rail :global(.cm-rf-input) { flex: 1; padding: 4px 6px; font-size: 11px; border: 1px solid rgba(127,127,127,0.2); border-radius: 4px; background: var(--c-bg-alt, #f9f9f9); color: var(--c-text, #333); }
  .comment-rail :global(.cm-rf-textarea) { width: 100%; padding: 4px 6px; font-size: 11px; border: 1px solid rgba(127,127,127,0.2); border-radius: 4px; background: var(--c-bg-alt, #f9f9f9); color: var(--c-text, #333); resize: vertical; box-sizing: border-box; }
  .comment-rail :global(.cm-rf-notify) { display: flex; align-items: center; gap: 4px; font-size: 10px; color: var(--c-text-dim, #999); margin: 4px 0; }
  .comment-rail :global(.cm-rf-notify input) { width: 12px; height: 12px; }
  .comment-rail :global(.cm-rf-actions) { display: flex; justify-content: flex-end; gap: 4px; margin-top: 4px; }
  .comment-rail :global(.cm-rf-cancel), .comment-rail :global(.cm-rf-submit) { padding: 3px 10px; font-size: 11px; border-radius: 4px; cursor: pointer; border: none; }
  .comment-rail :global(.cm-rf-cancel) { background: transparent; color: var(--c-text-dim, #999); }
  .comment-rail :global(.cm-rf-submit) { background: var(--accent, #4ade80); color: #000; font-weight: 600; }
  .comment-rail :global(.cm-rf-submit:disabled) { opacity: 0.5; cursor: default; }

  /* ===== FAB ===== */
  .fab-comment {
    position: absolute; z-index: 100; display: none;
    align-items: center; justify-content: center;
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--accent); color: var(--c-bg); border: none; cursor: pointer;
    box-shadow: 0 2px 8px rgba(74,222,128,0.3);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .fab-comment:hover { transform: scale(1.1); box-shadow: 0 3px 12px rgba(74,222,128,0.4); }

  /* ===== Comment Input Popover ===== */
  .comment-input-popover {
    position: absolute; z-index: 200; width: 300px; display: none;
    background: var(--c-bg-alt); border: 1px solid var(--c-border-light); border-radius: 8px;
    padding: 14px; box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    animation: fadeInCard 0.15s ease;
  }
  .cip-header { margin-bottom: 10px; }
  .cip-selected {
    font-size: 12px; color: var(--accent); font-style: italic;
    line-height: 1.5; display: -webkit-box;
    -webkit-line-clamp: 4; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .cip-textarea {
    width: 100%; box-sizing: border-box;
    background: rgba(var(--c-overlay-rgb),0.03);
    border: 1px solid var(--c-border-light); border-radius: 4px;
    color: var(--c-text); font-family: inherit; font-size: 13px;
    padding: 8px 10px; resize: vertical; min-height: 60px;
    outline: none; transition: border-color 0.2s;
  }
  .cip-textarea:focus { border-color: var(--accent); }
  .cip-actions { display: flex; justify-content: flex-end; gap: 8px; margin-top: 10px; }
  .cip-cancel, .cip-submit {
    font-family: inherit; font-size: 12px; padding: 5px 14px;
    border-radius: 4px; cursor: pointer; border: none; transition: all 0.15s;
  }
  .cip-cancel { background: none; color: var(--c-text-muted); }
  .cip-cancel:hover { color: var(--c-text); }
  .cip-submit { background: var(--accent); color: var(--c-bg); font-weight: 600; }
  .cip-submit:hover { background: #6ee7a0; }
  .cip-error { border-color: #ef4444 !important; }

  /* ===== Mobile Bottom Sheet ===== */
  .mobile-sheet-overlay {
    display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 900;
  }
  .mobile-sheet-overlay.active { display: block; }
  .mobile-sheet {
    display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 901;
    background: var(--c-bg-alt); border-top: 1px solid var(--c-border-light);
    border-radius: 16px 16px 0 0; padding: 12px 20px 32px;
    transform: translateY(100%); transition: transform 0.3s ease;
  }
  .mobile-sheet.active { display: block; transform: translateY(0); }
  .ms-handle {
    width: 36px; height: 4px; background: var(--c-border-light); border-radius: 2px;
    margin: 0 auto 16px;
  }
  .ms-quote {
    font-size: 13px; color: var(--accent); font-style: italic;
    margin-bottom: 12px; padding-bottom: 12px;
    border-bottom: 1px solid rgba(var(--c-overlay-rgb),0.06);
    line-height: 1.5;
  }
  .ms-body {
    font-size: 14px; color: var(--c-text); line-height: 1.6; margin-bottom: 12px;
  }
  .ms-time {
    font-size: 11px; color: var(--c-text-dim); margin-bottom: 16px;
  }
  .ms-delete {
    width: 100%; padding: 10px; border-radius: 8px;
    background: rgba(248,81,73,0.08); border: 1px solid rgba(248,81,73,0.2);
    color: #f85149; font-family: inherit; font-size: 13px;
    cursor: pointer; transition: background 0.2s;
