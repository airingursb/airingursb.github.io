  }

  /* Cards container: no extra positioning needed, rail is the context */
  .cr-cards { }
  .cr-empty {
    color: var(--c-text-dim); font-size: 12px; padding: 16px 16px;
    opacity: 0.6;
  }
  .cr-empty p { margin: 0; }

  /* Comment card */
  .comment-rail :global(.cm-card) {
    position: absolute;
    left: 0; right: 0;
