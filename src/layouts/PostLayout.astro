    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 0; position: relative;
  }
  .mast-brand {
    font-size: 11px; color: var(--c-text-muted); text-decoration: none;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
  }
  .mast-brand:hover { color: var(--c-text); }
  .mast-date {
    font-size: 12px; color: var(--c-text-dim);
    position: absolute; left: 50%; transform: translateX(-50%);
  }
  .mast-links { display: flex; gap: 16px; }
  .mast-links a {
    font-size: 11px; color: var(--c-text-dim); text-decoration: none;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .mast-links a:hover { color: var(--c-text); }
  .mast-bottom-rule { height: 1px; background: var(--c-border); }

  /* ===== Headline ===== */
  .headline-section {
    max-width: 1440px; margin: 0 auto;
    padding: 48px 48px 0; position: relative;
  }
  .headline-section::after {
    content: ''; display: block; height: 1px;
    background: var(--c-border); margin-top: 40px;
  }
  .headline-inner { max-width: 860px; }
  .headline-tags { display: flex; gap: 8px; margin-bottom: 12px; }
  .hl-tag {
    font-size: 11px; color: var(--accent); text-decoration: none;
    text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;
  }
  .headline {
    font-size: clamp(30px, 5vw, 52px); font-weight: 800; color: var(--c-text);
    line-height: 1.08; letter-spacing: -0.03em;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  .headline-deck {
    font-size: 18px; color: var(--c-text-muted); margin-top: 16px; line-height: 1.5;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  /* ===== Cover ===== */
  .cover-section {
    max-width: 900px; margin: 0 auto 2rem; padding: 32px 48px 0;
  }
  .cover-section img {
    width: 100%; height: auto; border-radius: 8px; display: block;
    object-fit: cover; max-height: 480px;
  }

  /* ===== Series Nav ===== */
  .series-nav {
    text-align: center;
    margin: 1.5rem 0 0.5rem;
  }
  .series-inner {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .series-badge {
    font-size: 11px;
    padding: 0;
    border: none;
    color: var(--c-text-dim, #666);
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .series-badge:hover { color: var(--accent, #4ade80); }
  .series-arrow {
    color: var(--c-text-muted, #888);
    text-decoration: none;
    font-size: 14px;
    padding: 6px 12px;
    border: 1px solid var(--c-border, rgba(255,255,255,0.15));
    border-radius: 4px;
    transition: all 0.15s;
  }
  .series-arrow:hover { color: var(--accent, #4ade80); border-color: var(--accent, #4ade80); }

  /* ===== Three-Column Grid ===== */
  .content-grid {
    display: grid;
    grid-template-columns: 160px 1fr 280px;
    gap: 40px;
    max-width: 1440px;
    margin: 0 auto;
    padding: 40px 48px 60px;
    align-items: start;
    position: relative;
  }

  /* Left sidebar */
  .sidebar-left {
    position: sticky; top: 40px;
    border-right: 1px solid var(--c-border); padding-right: 20px;
  }
  .sb-block { margin-bottom: 24px; }
  .sb-label {
    font-size: 9px; color: var(--c-text-dim);
    text-transform: uppercase; letter-spacing: 0.12em;
    margin-bottom: 4px; font-weight: 600;
  }
  .sb-value { font-size: 13px; color: var(--c-text-muted); }
  .sb-tags { display: flex; flex-direction: column; gap: 2px; }
  .sb-tag { font-size: 13px; color: var(--accent); text-decoration: none; }
  .sb-tag:hover { opacity: 0.7; }
  .sb-divider { height: 1px; background: var(--c-border); margin: 20px 0; }
  .sb-nav { font-size: 12px; color: var(--c-text-dim); text-decoration: none; }
  .sb-nav:hover { color: var(--c-text); }
  .sb-related {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .sb-related-link {
    font-size: 0.8rem;
    color: var(--c-text-muted, #888);
    text-decoration: none;
    line-height: 1.4;
    display: block;
  }
  .sb-related-link:hover {
    color: var(--accent, #4ade80);
  }

  /* TOC — :global because links are JS-generated */
  .toc-nav {
    display: flex; flex-direction: column; gap: 0;
    max-height: 40vh; overflow-y: auto;
  }
  .toc-nav::-webkit-scrollbar { width: 2px; }
  .toc-nav::-webkit-scrollbar-thumb { background: var(--c-border); border-radius: 2px; }
  .toc-nav :global(.toc-link) {
    font-size: 12px; line-height: 1.4;
    color: var(--c-text-muted, #888);
    text-decoration: none;
    padding: 3px 0 3px 8px;
    border-left: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .toc-nav :global(.toc-link[data-level="3"]) { padding-left: 20px; font-size: 11px; }
  .toc-nav :global(.toc-link:hover) { color: var(--c-text); }
  .toc-nav :global(.toc-link.active) {
    color: var(--accent, #4ade80);
    border-left-color: var(--accent, #4ade80);
  }

  /* ===== Content ===== */
  .post-content {
    color: var(--c-text); font-size: 18px; line-height: 2.0;
    min-width: 0; max-width: 72ch; position: relative;
    font-family: 'Noto Serif SC', 'Source Han Serif CN', 'Source Han Serif SC', 'Songti SC', STSong, serif;
    letter-spacing: 0.02em;
  }
  .post-content :global(h2) {
    font-size: 24px; font-weight: 700; margin-top: 48px; margin-bottom: 20px;
    color: var(--c-text);
    font-family: 'Noto Serif SC', 'Source Han Serif CN', 'Songti SC', serif;
    line-height: 1.4; letter-spacing: 0.01em;
  }
  .post-content :global(:first-child) { margin-top: 0; }
  .post-content :global(h3) {
    font-size: 19px; font-weight: 600; margin-top: 40px; margin-bottom: 16px;
    color: var(--c-text);
    font-family: 'Noto Serif SC', 'Source Han Serif CN', 'Songti SC', serif;
    line-height: 1.45;
  }
  .post-content :global(p) { margin-bottom: 24px; }
  .post-content :global(a) {
    color: var(--accent); text-decoration: none;
    border-bottom: 1px solid rgba(var(--accent-rgb),0.25);
  }
  .post-content :global(a:hover) { border-bottom-color: var(--accent); }
  .post-content :global(img) {
    max-width: 100%;
    border-radius: 10px;
    margin-top: 28px; margin-bottom: 4px; display: block;
    height: auto;
    max-height: 70vh;
    object-fit: contain;
    box-shadow: none;
  }
  .post-content :global(.img-caption) {
    display: block;
    text-align: center;
    font-size: 13px;
    color: var(--c-text-muted, #888);
    margin-bottom: 24px;
    line-height: 1.6;
    letter-spacing: 0.01em;
  }

  /* Gallery: consecutive images laid out in flex rows */
  .post-content :global(.img-gallery) {
    margin-top: 28px;
    margin-bottom: 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .post-content :global(.img-gallery-row) {
    display: flex;
    gap: 6px;
  }
  .post-content :global(.img-gallery-item) {
    margin: 0;
    padding: 0;
    min-width: 0;
    overflow: hidden;
    border-radius: 10px;
  }
  .post-content :global(.img-gallery-item img) {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
    border-radius: 10px;
    box-shadow: none;
    max-height: none;
  }
  .post-content :global(.img-gallery-item figcaption) {
    text-align: center;
    font-size: 12px;
    color: var(--c-text-muted, #888);
    margin-top: 4px;
    line-height: 1.4;
  }

  .post-content :global(pre) {
    max-width: calc(100% + 80px); width: calc(100% + 80px);
    margin-left: -40px; background: var(--c-bg);
    border: 1px solid var(--c-border); border-radius: 4px;
    padding: 20px 28px; overflow-x: auto;
    margin-top: 24px; margin-bottom: 24px;
