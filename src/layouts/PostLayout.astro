  }
  .comment-rail :global(.cm-card-footer) {
    display: flex; justify-content: space-between; align-items: center;
  }
  .comment-rail :global(.cm-card-time) { color: var(--c-border-light); font-size: 10px; }
  .comment-rail :global(.cm-card-delete) {
