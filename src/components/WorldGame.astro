---
// World · 3D floating-island diorama scene.
// Full procedural geometry + Codex panda billboard + lighting + post-fx.
import App from '../world/App'
import WorldUI from '../world/WorldUI'
import ZonePanel from '../world/ZonePanel'
import WhisperOverlay from '../world/WhisperOverlay'
import AmbientHUD from '../world/AmbientHUD'
import AccountIndicator from '../world/AccountIndicator'
import SkipNav from '../world/SkipNav'
import WorldLoader from '../world/WorldLoader.astro'
import ErrorBoundary from '../world/ErrorBoundary'
import articlesData from '../data/articles.json'
import musicData from '../data/music.json'
import highlightsData from '../data/highlights.json'
import { fetchComics } from '../lib/comics'

// Build-time comics fetch (best-effort; returns [] if Supabase env missing)
const comicsRaw = await fetchComics().catch(() => [])
const comics = comicsRaw.slice(0, 10).map(c => ({
  issue: c.issue_number,
  title_zh: c.title?.zh ?? `第 ${c.issue_number} 期`,
  title_en: c.title?.en ?? `Issue ${c.issue_number}`,
}))

const initialData = {
  blog: (articlesData as any[]).slice(0, 12),
  music: ((musicData as any).periods?.find((p: any) => p.key === '1month')?.artists
    ?? (musicData as any).periods?.[0]?.artists ?? []).slice(0, 12),
  reading: ((highlightsData as any).highlights ?? []).slice(0, 10),
  comics,
}
---
<div id="world-root">
  <WorldLoader />
  <ErrorBoundary client:only="react">
    <App client:only="react" initialData={initialData} />
  </ErrorBoundary>
  <WorldUI client:only="react" />
  <ZonePanel client:only="react" initialData={initialData} />
  <WhisperOverlay client:only="react" />
  <AmbientHUD client:only="react" />
  <AccountIndicator client:only="react" />
  <SkipNav client:only="react" />
  <div class="world-help" role="note" aria-label="操作提示">
    <span class="world-help-keys" aria-hidden="true">drag</span> 旋转 · <span class="world-help-keys" aria-hidden="true">scroll</span> 缩放 · <span class="world-help-keys" aria-hidden="true">click</span> 互动 · <span class="world-help-keys" aria-hidden="true">Tab</span> 键盘菜单 · <span class="world-help-keys" aria-hidden="true">ESC</span> 关面板
  </div>
</div>

<style is:global>
  body { margin: 0; overflow: hidden; background: #0e0817; }
  #world-root {
    position: fixed; inset: 0;
    background: radial-gradient(ellipse at center top,
      #2a2438 0%,
      #1a1424 55%,
      #0e0817 100%);
  }
  #world-root > canvas { display: block; }
  .world-help {
    position: fixed; bottom: 16px; left: 50%;
    transform: translateX(-50%);
    color: rgba(244, 234, 213, 0.6);
    font-family: ui-monospace, monospace;
    font-size: 11px;
    background: rgba(20, 14, 22, 0.6);
    padding: 6px 14px;
    border-radius: 12px;
    pointer-events: none;
    z-index: 10;
    animation: world-help-fade 12s ease-out forwards;
    animation-delay: 10s;
  }
  @keyframes world-help-fade {
    from { opacity: 0.8; }
    to   { opacity: 0; }
  }
  /* Respect reduced-motion: keep the hint at full opacity instead of
     fading it (animations of any kind can disorient sensitive users;
     the hint also benefits keyboard/AT users who can't 'see' it
     fade and need it to stay readable). */
  @media (prefers-reduced-motion: reduce) {
    .world-help {
      animation: none;
      opacity: 0.8;
    }
  }

  /* V2 a11y final: visually-hidden keyboard/AT-accessible zone nav.
     Mirrors the in-canvas Three.js hitboxes so keyboard + screen-reader
     users can activate any zone (chat/blog/comics/music/reading) without
     needing to click on the 3D scene. Visible only on focus-within so
     sighted keyboard users see what they Tab into. */
  .world-skip-nav {
    position: fixed;
    top: 16px;
    left: 16px;
    z-index: 15;
    /* sr-only clip — fully removed from layout + visual but kept in AT tree */
    width: 1px; height: 1px;
    margin: -1px; padding: 0;
    border: 0; overflow: hidden;
    clip: rect(0 0 0 0); clip-path: inset(50%);
    white-space: nowrap;
  }
  .world-skip-nav:focus-within {
    /* Reveal on Tab focus — sighted keyboard users see the nav */
    width: auto; height: auto;
    margin: 0; padding: 12px 16px;
    overflow: visible;
    clip: auto; clip-path: none;
    white-space: normal;
    background: rgba(20, 14, 22, 0.95);
    color: #f4ead5;
    border-radius: 10px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5);
    max-width: 300px;
    font-family: ui-monospace, monospace;
  }
  .world-skip-nav-title {
    margin: 0 0 8px;
    font-size: 12px;
    font-weight: 600;
    color: rgba(244, 234, 213, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .world-skip-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .world-skip-nav button {
    width: 100%;
    text-align: left;
    background: transparent;
    border: 1px solid rgba(244, 234, 213, 0.15);
    color: #f4ead5;
    padding: 6px 10px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 12px;
    font-family: inherit;
    transition: background 120ms ease, border-color 120ms ease;
  }
  .world-skip-nav button:hover,
  .world-skip-nav button:focus-visible {
    background: rgba(244, 234, 213, 0.1);
    border-color: rgba(244, 234, 213, 0.4);
    outline: none;
  }
  @media (max-width: 720px) {
    .world-help { font-size: 10px; padding: 4px 10px; }
    .world-panel { right: 8px; left: 8px; width: auto; max-width: none; }
    .world-ui {
      right: 8px;
      top: max(18px, env(safe-area-inset-top, 18px));
    }
  }
  .world-help-keys {
    color: #f4ead5;
    background: rgba(244, 234, 213, 0.12);
    padding: 1px 6px;
    border-radius: 4px;
    margin: 0 2px;
  }
  .world-ui {
    position: fixed;
    top: 66px;            /* room for account pill at top:18 above */
    right: 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 20;
  }
  .world-btn {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid rgba(244, 234, 213, 0.22);
    background: rgba(244, 234, 213, 0.92);
    cursor: pointer;
    transition: background 120ms ease, transform 120ms ease, box-shadow 120ms ease;
    backdrop-filter: blur(6px);
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-shadow: 0 2px 6px rgba(20, 14, 22, 0.3);
  }
  .world-btn:hover {
    background: rgba(255, 244, 220, 1);
    transform: scale(1.08);
    box-shadow: 0 3px 10px rgba(20, 14, 22, 0.45);
  }
  /* V2 a11y: visible focus ring for keyboard users. Without this,
     tabbing through the toolbar shows no indication of focus
     position (default browser ring is suppressed by box-shadow). */
  .world-btn:focus-visible {
    outline: 2px solid #FCD757;
    outline-offset: 3px;
    background: rgba(255, 244, 220, 1);
  }
  .world-btn-icon {
    width: 36px;
    height: 36px;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
  }
  .world-btn--off {
    opacity: 0.45;
    filter: grayscale(0.7);
  }
  .world-btn--active {
    background: rgba(255, 217, 168, 0.95);
    box-shadow: 0 0 0 2px rgba(232, 130, 80, 0.45), 0 3px 10px rgba(20, 14, 22, 0.45);
  }

  /* === Secondary control column (BGM + Pomodoro) ===
     Sits just below the main world-ui icon stack. */
  .world-ui-extra {
    position: fixed;
    top: calc(66px + 4 * 46px + 3 * 8px + 14px);
    right: 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 20;
  }
  /* Button with hand-painted icon + tiny sub-label underneath.
     Used by BGM (state name) and Pomodoro (countdown). */
  .world-btn-with-sub {
    flex-direction: column;
    gap: 0;
    padding: 4px 0 2px;
    background: rgba(244, 234, 213, 0.92);
  }
  .world-btn-with-sub .world-btn-icon {
    width: 28px;
    height: 28px;
  }
  .world-btn-sub-label {
    font-size: 9px;
    color: #8C6B47;
    font-family: ui-monospace, monospace;
    letter-spacing: 0;
    line-height: 1;
    margin-top: 1px;
    pointer-events: none;
  }

  /* === Bottom-left time HUD === */
  .world-hud-time {
    position: fixed;
    bottom: 16px;
    left: 16px;
    z-index: 18;
    pointer-events: none;
    user-select: none;
    color: rgba(244, 234, 213, 0.85);
    font-family: "Songti SC", Georgia, serif;
    font-size: 13px;
    line-height: 1.5;
    text-shadow: 0 1px 4px rgba(20, 14, 22, 0.75);
    background: rgba(20, 14, 22, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 8px 14px;
    border-radius: 12px;
    border: 1px solid rgba(244, 234, 213, 0.08);
  }
  .world-hud-time-main {
    color: #FFE4C0;
  }
  .world-hud-time-sub {
    color: rgba(244, 234, 213, 0.55);
    font-size: 11px;
    font-family: ui-monospace, monospace;
  }
  .world-hud-pomo {
    margin-top: 4px;
    padding-top: 4px;
    border-top: 1px dotted rgba(244, 234, 213, 0.18);
    font-size: 12px;
    font-family: ui-monospace, monospace;
    letter-spacing: 0.04em;
  }
  .world-hud-pomo--focus { color: #FFD080; }
  .world-hud-pomo--break { color: #80D0B0; }

  @media (max-width: 720px) {
    .world-ui {
      top: max(60px, env(safe-area-inset-top, 60px));
    }
    .world-ui-extra {
      top: auto;
      bottom: 90px;
      right: 8px;
    }
    .world-hud-time {
      font-size: 11px;
      padding: 6px 10px;
      bottom: 10px;
      left: 10px;
    }
    .world-account {
      top: 12px;
      left: 12px;
      right: auto;
    }
  }

  /* === Account indicator pill (top-right) + login modal === */
  .world-account {
    position: fixed;
    top: 18px;
    right: 18px;
    z-index: 22;
    font-family: "Songti SC", Georgia, serif;
  }
  .world-account-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 38px;
    padding: 0 14px 0 4px;
    border-radius: 999px;
    border: 1px solid rgba(244, 234, 213, 0.22);
    background: rgba(244, 234, 213, 0.92);
    color: #5D3B1F;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background 120ms ease, transform 120ms ease, box-shadow 120ms ease;
    backdrop-filter: blur(6px);
    box-shadow: 0 2px 6px rgba(20, 14, 22, 0.3);
  }
  .world-account-pill:hover {
    background: rgba(255, 244, 220, 1);
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(20, 14, 22, 0.45);
  }
  .world-account-pill:focus-visible {
    outline: 2px solid #FCD757;
    outline-offset: 3px;
    background: rgba(255, 244, 220, 1);
  }
  .world-account-avatar {
    display: inline-flex;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #C97B5C, #8B5E3C);
    color: #FFF4DC;
    font-size: 14px;
    font-weight: 700;
  }
  .world-account-pill--out .world-account-avatar {
    background: linear-gradient(135deg, #6B6358, #4A2D1A);
    color: #FFE4C0;
  }
  .world-account-name {
    max-width: 110px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .world-account-menu {
    position: absolute;
    top: 46px;
    right: 0;
    min-width: 150px;
    background: rgba(20, 14, 22, 0.92);
    border: 1px solid rgba(244, 234, 213, 0.18);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    z-index: 23;
  }
  .world-account-menu-item {
    display: block;
    width: 100%;
    padding: 10px 16px;
    background: transparent;
    border: none;
    color: #f4ead5;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    font-size: 13px;
    text-decoration: none;
    box-sizing: border-box;
  }
  .world-account-menu-item:focus-visible {
    outline: 2px solid #FCD757;
    outline-offset: -2px;
    background: rgba(255, 217, 168, 0.12);
  }
  .world-account-menu-item:hover {
    background: rgba(244, 234, 213, 0.12);
  }

  /* === Login modal === */
  .world-login-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(8, 4, 12, 0.55);
    backdrop-filter: blur(4px);
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: world-login-bg-in 200ms ease-out;
  }
  @keyframes world-login-bg-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .world-login-modal {
    width: min(380px, 92vw);
    background: rgba(244, 234, 213, 0.98);
    color: #3A2516;
    border-radius: 16px;
    padding: 22px 26px 24px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(140, 107, 71, 0.25);
    font-family: "Songti SC", Georgia, serif;
    animation: world-login-modal-in 220ms ease-out;
  }
  @keyframes world-login-modal-in {
    from { opacity: 0; transform: translateY(8px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .world-login-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
  }
  .world-login-title {
    font-size: 18px;
    font-weight: 700;
    color: #5D3B1F;
  }
  .world-login-close {
    background: transparent;
    border: none;
    color: #8C6B47;
    font-size: 18px;
    cursor: pointer;
    padding: 0 4px;
  }
  .world-login-blurb {
    margin: 0 0 16px;
    color: #8C6B47;
    font-size: 13px;
    line-height: 1.5;
  }
  .world-login-oauth {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 16px;
  }
  .world-login-btn {
    width: 100%;
    padding: 10px 16px;
    background: #5D3B1F;
    color: #FFE4C0;
    border: 1px solid #3A2516;
    border-radius: 10px;
    font-family: inherit;
    font-size: 14px;
    cursor: pointer;
    transition: background 120ms ease;
  }
  .world-login-btn:hover {
    background: #4A2D1A;
  }
  .world-login-btn:focus-visible {
    outline: 2px solid #FCD757;
    outline-offset: 2px;
  }
  .world-login-btn--magic {
    background: #C97B5C;
    border-color: #8B5E3C;
  }
  .world-login-btn--magic:hover {
    background: #B86E50;
  }
  .world-login-btn:disabled {
    opacity: 0.5;
    cursor: default;
  }
  .world-login-divider {
    text-align: center;
    color: #8C6B47;
    font-size: 11px;
    margin: 4px 0 14px;
    position: relative;
  }
  .world-login-divider::before,
  .world-login-divider::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 38%;
    height: 1px;
    background: rgba(140, 107, 71, 0.3);
  }
  .world-login-divider::before { left: 0; }
  .world-login-divider::after { right: 0; }
  .world-login-divider span {
    background: rgba(244, 234, 213, 0.98);
    padding: 0 12px;
    position: relative;
  }
  .world-login-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .world-login-input {
    padding: 10px 14px;
    border: 1px solid rgba(140, 107, 71, 0.4);
    border-radius: 10px;
    font-family: inherit;
    font-size: 14px;
    background: #FFF8E8;
    color: #3A2516;
    outline: none;
  }
  .world-login-input:focus {
    border-color: #C97B5C;
    box-shadow: 0 0 0 3px rgba(201, 123, 92, 0.15);
  }
  .world-login-error {
    color: #C13E3E;
    font-size: 12px;
    margin-top: 4px;
  }
  .world-login-sent {
    color: #4A8B6E;
    font-size: 14px;
    text-align: center;
    line-height: 1.6;
  }
  .world-login-sent small {
    color: #8C6B47;
    font-size: 12px;
  }
  /* === Whisper overlay (island speaks) === */
  .world-whisper {
    position: fixed;
    top: 22%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: rgba(255, 244, 220, 0.92);
    font-family: "Songti SC", "Noto Serif SC", Georgia, serif;
    font-style: italic;
    font-size: 22px;
    letter-spacing: 0.04em;
    text-align: center;
    text-shadow:
      0 1px 0 rgba(0, 0, 0, 0.6),
      0 2px 8px rgba(20, 14, 22, 0.65);
    padding: 14px 28px;
    border-radius: 999px;
    background: rgba(20, 14, 22, 0.28);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 244, 220, 0.06);
    pointer-events: none;
    user-select: none;
    z-index: 15;
    max-width: min(560px, 86vw);
    opacity: 0;
    transition: opacity 1.5s ease, transform 1.6s ease;
  }
  .world-whisper--in {
    opacity: 1;
    transform: translate(-50%, -50%);
  }
  .world-whisper--out {
    opacity: 0;
    transform: translate(-50%, calc(-50% - 6px));
    transition: opacity 2s ease, transform 2s ease;
  }
  @media (max-width: 720px) {
    .world-whisper { font-size: 17px; padding: 10px 20px; top: 18%; }
  }
  /* Click-outside-to-close transparent backdrop */
  .world-panel-backdrop {
    position: fixed; inset: 0;
    z-index: 25;
    pointer-events: auto;
  }
  /* Zone panel — slides in from right */
  .world-panel {
    position: fixed;
    top: 18px; right: 76px;
    width: min(380px, 90vw);
    max-height: calc(100vh - 36px);
    background: rgba(20, 14, 22, 0.92);
    color: #f4ead5;
    border-radius: 14px;
    border: 1px solid rgba(244, 234, 213, 0.18);
    backdrop-filter: blur(12px);
    z-index: 30;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    font-family: ui-monospace, monospace;
    font-size: 13px;
    animation: world-panel-slide 200ms ease-out;
  }
  @keyframes world-panel-slide {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes world-panel-slide-out {
    from { opacity: 1; transform: translateX(0); }
    to { opacity: 0; transform: translateX(20px); }
  }
  .world-panel--closing {
    animation: world-panel-slide-out 180ms ease-in forwards !important;
  }
  .world-panel-more {
    color: #FFD9A8 !important;
    font-weight: 600;
  }
  .world-panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px;
    border-bottom: 1px solid rgba(244, 234, 213, 0.12);
  }
  .world-panel-title {
    font-weight: 700;
    color: #FFD9A8;
  }
  .world-panel-close {
    background: transparent;
    border: none;
    color: #f4ead5;
    font-size: 18px;
    cursor: pointer;
    padding: 0 4px;
  }
  .world-panel-close:focus-visible {
    outline: 2px solid #FCD757;
    outline-offset: 2px;
    border-radius: 4px;
  }
  .world-panel-body {
    overflow-y: auto;
    flex: 1;
    padding: 12px 18px;
  }
  .world-panel-list { list-style: none; margin: 0; padding: 0; }
  .world-panel-row {
    padding: 8px 0;
    border-bottom: 1px dotted rgba(244, 234, 213, 0.08);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }
  .world-panel-link {
    color: #f4ead5;
    text-decoration: none;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .world-panel-link:hover { color: #FFD9A8; text-decoration: underline; }
  .world-panel-meta {
    color: rgba(244, 234, 213, 0.5);
    font-size: 11px;
    flex-shrink: 0;
  }
  .world-panel-message {
    padding: 24px 0;
    text-align: center;
    color: rgba(244, 234, 213, 0.7);
  }
  .world-panel-loading, .world-panel-error {
    padding: 24px 0;
    text-align: center;
    color: rgba(244, 234, 213, 0.6);
  }
  .world-panel-error { color: #E25A4C; }

  /* Chat panel inner */
  .world-chat {
    display: flex; flex-direction: column;
    height: 60vh;
    max-height: 480px;
  }
  .world-chat-history {
    flex: 1;
    overflow-y: auto;
    padding-bottom: 10px;
    display: flex; flex-direction: column; gap: 10px;
  }
  .world-chat-msg {
    padding: 8px 12px;
    border-radius: 12px;
    line-height: 1.5;
    max-width: 85%;
    word-wrap: break-word;
  }
  .world-chat-msg-assistant {
    background: rgba(244, 234, 213, 0.1);
    color: #f4ead5;
    align-self: flex-start;
  }
  .world-chat-msg-user {
    background: rgba(255, 217, 168, 0.18);
    color: #FFD9A8;
    align-self: flex-end;
  }
  .world-chat-pending {
    opacity: 0.5;
    font-style: italic;
  }
  .world-chat-error {
