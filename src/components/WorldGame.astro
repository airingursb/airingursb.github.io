---
// World · 3D floating-island diorama scene.
// Full procedural geometry + Codex panda billboard + lighting + post-fx.
import App from '../world/App'
import WorldUI from '../world/WorldUI'
---
<div id="world-root">
  <App client:only="react" />
  <WorldUI client:only="react" />
  <div class="world-help">
    <span class="world-help-keys">drag</span> 旋转 · <span class="world-help-keys">scroll</span> 缩放
  </div>
</div>

<style is:global>
  body { margin: 0; overflow: hidden; background: #0e0817; }
  #world-root {
    position: fixed; inset: 0;
    background: radial-gradient(ellipse at center top,
      #2a2438 0%,
      #1a1424 55%,
      #0e0817 100%);
  }
  #world-root > canvas { display: block; }
  .world-help {
    position: fixed; bottom: 16px; left: 50%;
    transform: translateX(-50%);
    color: rgba(244, 234, 213, 0.6);
    font-family: ui-monospace, monospace;
    font-size: 11px;
    background: rgba(20, 14, 22, 0.6);
    padding: 6px 14px;
    border-radius: 12px;
    pointer-events: none;
    z-index: 10;
  }
  .world-help-keys {
    color: #f4ead5;
    background: rgba(244, 234, 213, 0.12);
    padding: 1px 6px;
    border-radius: 4px;
    margin: 0 2px;
  }
  .world-ui {
    position: fixed;
    top: 18px;
    right: 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 20;
  }
  .world-btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid rgba(244, 234, 213, 0.18);
    background: rgba(20, 14, 22, 0.6);
    color: #f4ead5;
    font-size: 18px;
    cursor: pointer;
    transition: background 120ms ease, transform 120ms ease;
    backdrop-filter: blur(6px);
  }
  .world-btn:hover {
    background: rgba(40, 28, 44, 0.85);
    transform: scale(1.06);
  }
</style>
