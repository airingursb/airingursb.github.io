---
// World · 3D floating-island diorama scene.
// Full procedural geometry + Codex panda billboard + lighting + post-fx.
import App from '../world/App'
import WorldUI from '../world/WorldUI'
import ZonePanel from '../world/ZonePanel'
import WorldLoader from '../world/WorldLoader.astro'
import articlesData from '../data/articles.json'
import musicData from '../data/music.json'
import highlightsData from '../data/highlights.json'

const initialData = {
  blog: (articlesData as any[]).slice(0, 12),
  music: ((musicData as any).periods?.find((p: any) => p.key === '1month')?.artists
    ?? (musicData as any).periods?.[0]?.artists ?? []).slice(0, 12),
  reading: ((highlightsData as any).highlights ?? []).slice(0, 10),
}
---
<div id="world-root">
  <WorldLoader />
  <App client:only="react" />
  <WorldUI client:only="react" />
  <ZonePanel client:only="react" initialData={initialData} />
  <div class="world-help">
    <span class="world-help-keys">drag</span> 旋转 · <span class="world-help-keys">scroll</span> 缩放 · <span class="world-help-keys">click</span> 互动 · <span class="world-help-keys">ESC</span> 关面板
  </div>
</div>

<style is:global>
  body { margin: 0; overflow: hidden; background: #0e0817; }
  #world-root {
    position: fixed; inset: 0;
    background: radial-gradient(ellipse at center top,
      #2a2438 0%,
      #1a1424 55%,
      #0e0817 100%);
  }
  #world-root > canvas { display: block; }
  .world-help {
    position: fixed; bottom: 16px; left: 50%;
    transform: translateX(-50%);
    color: rgba(244, 234, 213, 0.6);
    font-family: ui-monospace, monospace;
    font-size: 11px;
    background: rgba(20, 14, 22, 0.6);
    padding: 6px 14px;
    border-radius: 12px;
    pointer-events: none;
    z-index: 10;
    animation: world-help-fade 12s ease-out forwards;
    animation-delay: 10s;
  }
  @keyframes world-help-fade {
    from { opacity: 0.8; }
    to   { opacity: 0; }
  }
  @media (max-width: 720px) {
    .world-help { font-size: 10px; padding: 4px 10px; }
    .world-panel { right: 8px; left: 8px; width: auto; max-width: none; }
    .world-ui {
      right: 8px;
      top: max(18px, env(safe-area-inset-top, 18px));
    }
  }
  .world-help-keys {
    color: #f4ead5;
    background: rgba(244, 234, 213, 0.12);
    padding: 1px 6px;
    border-radius: 4px;
    margin: 0 2px;
  }
  .world-ui {
    position: fixed;
    top: 18px;
    right: 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 20;
  }
  .world-btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid rgba(244, 234, 213, 0.18);
    background: rgba(20, 14, 22, 0.6);
    color: #f4ead5;
    font-size: 18px;
    cursor: pointer;
    transition: background 120ms ease, transform 120ms ease;
    backdrop-filter: blur(6px);
  }
  .world-btn:hover {
    background: rgba(40, 28, 44, 0.85);
    transform: scale(1.06);
  }
  /* Click-outside-to-close transparent backdrop */
  .world-panel-backdrop {
    position: fixed; inset: 0;
    z-index: 25;
    pointer-events: auto;
  }
  /* Zone panel — slides in from right */
  .world-panel {
    position: fixed;
    top: 18px; right: 76px;
    width: min(380px, 90vw);
    max-height: calc(100vh - 36px);
    background: rgba(20, 14, 22, 0.92);
    color: #f4ead5;
    border-radius: 14px;
    border: 1px solid rgba(244, 234, 213, 0.18);
    backdrop-filter: blur(12px);
    z-index: 30;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    font-family: ui-monospace, monospace;
    font-size: 13px;
    animation: world-panel-slide 200ms ease-out;
  }
  @keyframes world-panel-slide {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes world-panel-slide-out {
    from { opacity: 1; transform: translateX(0); }
    to { opacity: 0; transform: translateX(20px); }
  }
  .world-panel--closing {
    animation: world-panel-slide-out 180ms ease-in forwards !important;
  }
  .world-panel-more {
    color: #FFD9A8 !important;
    font-weight: 600;
  }
  .world-panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px;
    border-bottom: 1px solid rgba(244, 234, 213, 0.12);
  }
  .world-panel-title {
    font-weight: 700;
    color: #FFD9A8;
  }
  .world-panel-close {
    background: transparent;
    border: none;
    color: #f4ead5;
    font-size: 18px;
    cursor: pointer;
    padding: 0 4px;
  }
  .world-panel-body {
    overflow-y: auto;
    flex: 1;
    padding: 12px 18px;
  }
  .world-panel-list { list-style: none; margin: 0; padding: 0; }
  .world-panel-row {
    padding: 8px 0;
    border-bottom: 1px dotted rgba(244, 234, 213, 0.08);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }
  .world-panel-link {
    color: #f4ead5;
    text-decoration: none;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .world-panel-link:hover { color: #FFD9A8; text-decoration: underline; }
  .world-panel-meta {
    color: rgba(244, 234, 213, 0.5);
    font-size: 11px;
    flex-shrink: 0;
  }
  .world-panel-message {
    padding: 24px 0;
    text-align: center;
    color: rgba(244, 234, 213, 0.7);
  }
  .world-panel-loading, .world-panel-error {
    padding: 24px 0;
    text-align: center;
    color: rgba(244, 234, 213, 0.6);
  }
  .world-panel-error { color: #E25A4C; }

  /* Chat panel inner */
  .world-chat {
    display: flex; flex-direction: column;
    height: 60vh;
    max-height: 480px;
  }
  .world-chat-history {
    flex: 1;
    overflow-y: auto;
    padding-bottom: 10px;
    display: flex; flex-direction: column; gap: 10px;
  }
  .world-chat-msg {
    padding: 8px 12px;
    border-radius: 12px;
    line-height: 1.5;
    max-width: 85%;
    word-wrap: break-word;
  }
  .world-chat-msg-assistant {
    background: rgba(244, 234, 213, 0.1);
    color: #f4ead5;
    align-self: flex-start;
  }
  .world-chat-msg-user {
    background: rgba(255, 217, 168, 0.18);
    color: #FFD9A8;
    align-self: flex-end;
  }
  .world-chat-pending {
    opacity: 0.5;
    font-style: italic;
  }
  .world-chat-error {
    align-self: center;
    color: #E25A4C;
    font-size: 11px;
    text-align: center;
  }
  .world-chat-form {
    display: flex; gap: 8px;
    padding-top: 10px;
    border-top: 1px solid rgba(244, 234, 213, 0.1);
  }
  .world-chat-input {
    flex: 1;
    background: rgba(244, 234, 213, 0.08);
    border: 1px solid rgba(244, 234, 213, 0.15);
    border-radius: 8px;
    padding: 8px 12px;
    color: #f4ead5;
    font-family: inherit;
    font-size: 13px;
    outline: none;
  }
  .world-chat-input:focus {
    border-color: #FFD9A8;
  }
  .world-chat-send {
    background: rgba(255, 217, 168, 0.18);
    border: 1px solid rgba(255, 217, 168, 0.3);
    border-radius: 8px;
    color: #FFD9A8;
    padding: 0 16px;
    cursor: pointer;
    font-size: 16px;
    transition: background 120ms ease;
  }
  .world-chat-send:hover { background: rgba(255, 217, 168, 0.3); }
  .world-chat-send:disabled { opacity: 0.4; cursor: default; }
  .world-chat-link {
    color: #FFD9A8;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .world-chat-link:hover { color: #FFE4C0; }
</style>
