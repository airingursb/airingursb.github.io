---
// World · 2.5D diorama — R3F scene mounted as an Astro client island.
// Stage 1 = pure geometry blockout. Sprites + character + interaction
// come in later stages.
import App from '../world/App'
---
<div id="world-root">
  <App client:only="react" />
  <div class="world-help">
    <span class="world-help-keys">drag</span> 旋转 · <span class="world-help-keys">scroll</span> 缩放
  </div>
</div>

<style is:global>
  body { margin: 0; overflow: hidden; background: #0e0817; }
  #world-root {
    position: fixed; inset: 0;
    background: radial-gradient(ellipse at center top,
      #2a2438 0%,
      #1a1424 55%,
      #0e0817 100%);
  }
  #world-root > canvas { display: block; }
  .world-help {
    position: fixed; bottom: 16px; left: 50%;
    transform: translateX(-50%);
    color: rgba(244, 234, 213, 0.6);
    font-family: ui-monospace, monospace;
    font-size: 11px;
    background: rgba(20, 14, 22, 0.6);
    padding: 6px 14px;
    border-radius: 12px;
    pointer-events: none;
    z-index: 10;
  }
  .world-help-keys {
    color: #f4ead5;
    background: rgba(244, 234, 213, 0.12);
    padding: 1px 6px;
    border-radius: 4px;
    margin: 0 2px;
  }
</style>
