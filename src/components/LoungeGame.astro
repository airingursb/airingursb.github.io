---
// Astro client island — mounts Phaser game on /lounge.
---

<div id="lounge-root">
  <div id="lounge-mount"></div>
  <div id="lounge-ui">
    <button id="lounge-mute" class="ui-mute-btn" aria-label="Toggle sound">🔊</button>
    <button id="lounge-volume-btn" class="ui-volume-btn" aria-label="Volume settings">⚙</button>
    <button id="lounge-info-btn" class="ui-info-btn" aria-label="Identity">ⓘ</button>
    <button id="lounge-inventory-btn" class="ui-inventory-btn" aria-label="Inventory">📦</button>
    <div id="lounge-inventory-panel" class="ui-inventory-panel" hidden>
      <h3>Pebbles</h3>
      <p class="count"><span id="lounge-inv-count">0</span> / <span id="lounge-inv-total">0</span></p>
      <ul id="lounge-inv-list"></ul>
    </div>
    <div id="lounge-info-panel" class="ui-info-panel" hidden>
      <h3>Identity</h3>
      <dl>
        <dt>Name</dt><dd id="lounge-info-name">—</dd>
        <dt>Region</dt><dd id="lounge-info-region">—</dd>
        <dt>ID</dt><dd id="lounge-info-id">—</dd>
      </dl>
      <button type="button" id="lounge-info-rename">Change name</button>
      <h4 class="friends-heading">Friends</h4>
      <ul id="lounge-info-friends" class="friends-list"></ul>
      <p id="lounge-info-friends-empty" class="friends-empty">No friendships yet — spend time with peers.</p>
    </div>
    <div id="lounge-name-modal" class="ui-name-modal" hidden>
      <div class="ui-name-modal-backdrop"></div>
      <div class="ui-name-modal-card">
        <h3 id="lounge-name-modal-title">How should we call you?</h3>
        <input type="text" id="lounge-name-input" maxlength="16" autocomplete="off" placeholder="Your name">
        <p class="hint">1–16 chars</p>
        <p id="lounge-name-error" class="error" hidden></p>
        <div class="actions">
          <button type="button" id="lounge-name-skip">Skip</button>
          <button type="button" id="lounge-name-save">Save</button>
        </div>
      </div>
    </div>
    <div id="lounge-booth-picker" class="ui-booth-picker" hidden>
      <h3>🎧 Listening Booth</h3>
      <ul id="lounge-booth-list"></ul>
      <div class="actions">
        <button type="button" id="lounge-booth-stop">Stop</button>
        <button type="button" id="lounge-booth-close">Close</button>
      </div>
    </div>
    <div id="lounge-now-playing" class="ui-now-playing" hidden>
      🎧 Now: <span id="lounge-now-playing-name"></span>
    </div>
    <div id="lounge-replaced-overlay" class="ui-replaced-overlay" hidden>
      <div>
        <p>This tab was replaced by a newer session.</p>
        <p class="hint">Close this tab — your character is active elsewhere.</p>
      </div>
    </div>
    <div id="lounge-volume-panel" class="ui-volume-panel" hidden>
      <label><span>Master</span><input type="range" data-channel="master" min="0" max="100"></label>
      <label><span>SFX</span><input type="range" data-channel="sfx" min="0" max="100"></label>
      <label><span>BGM</span><input type="range" data-channel="bgm" min="0" max="100"></label>
      <label><span>Ambient</span><input type="range" data-channel="ambient" min="0" max="100"></label>
    </div>
    <div id="lounge-emote-menu" class="ui-emote-menu" hidden>
      <button data-verb="wave" title="Wave">👋</button>
      <button data-verb="sit" title="Sit">🪑</button>
      <button data-verb="dance" title="Dance">💃</button>
      <button data-verb="say" title="Say">💬</button>
    </div>
    <form id="lounge-say-form" class="ui-say" hidden>
      <input type="text" id="lounge-say-input" maxlength="60" placeholder="say something…" autocomplete="off">
    </form>
    <div id="lounge-bubbles" class="ui-bubbles"></div>
    <div id="lounge-interact-prompt" class="ui-interact-prompt" hidden>
      <kbd>E</kbd> <span id="lounge-interact-verb">interact</span>
    </div>
    <div id="lounge-dialog" class="ui-dialog" hidden></div>
  </div>
  <a href="/" class="lounge-back" title="Back to homepage">←</a>
</div>

<style is:global>
  body:has(#lounge-root) {
    overflow: hidden;
    background: #0d1117;
  }
  #lounge-root {
    position: fixed;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #lounge-mount {
    width: 100vw;
    height: 100vh;
  }
  #lounge-mount canvas {
    image-rendering: pixelated;
    cursor: crosshair;
  }
  .lounge-back {
    position: absolute; top: 16px; left: 16px;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    display: flex; align-items: center; justify-content: center;
    font-family: ui-monospace, monospace;
    font-size: 18px;
    text-decoration: none;
    z-index: 100;
    transition: background .15s;
  }
  .lounge-back:hover { background: rgba(255,255,255,.16); }
  .lounge-status {
    position: absolute; bottom: 24px; left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,.7);
    color: #e6edf3;
    padding: 10px 18px;
    border-radius: 8px;
    font-family: ui-monospace, monospace;
    font-size: 13px;
    z-index: 100;
  }
  #lounge-ui {
    position: absolute; inset: 0;
    pointer-events: none;
    z-index: 50;
  }
  #lounge-ui > * { pointer-events: auto; }
  #lounge-bubbles { pointer-events: none; }
  #lounge-interact-prompt { pointer-events: none; }
  .ui-mute-btn {
    position: absolute;
    top: 16px; right: 16px;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    font-size: 18px;
    cursor: pointer;
    transition: background .15s;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .ui-mute-btn:hover { background: rgba(255,255,255,.16); }
  .ui-mute-btn:focus-visible { outline: 2px solid #4ade80; outline-offset: 2px; }

  .ui-volume-btn {
    position: absolute;
    top: 16px; right: 62px;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    font-size: 16px;
    cursor: pointer;
    transition: background .15s;
    display: flex; align-items: center; justify-content: center;
    line-height: 1;
  }
  .ui-volume-btn:hover { background: rgba(255,255,255,.16); }
  .ui-volume-btn:focus-visible { outline: 2px solid #4ade80; outline-offset: 2px; }

  .ui-volume-panel {
    position: absolute;
    top: 60px; right: 16px;
    width: 220px;
    background: rgba(0,0,0,.85);
    border-radius: 10px;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: #e6edf3;
    font-family: ui-monospace, monospace;
    font-size: 12px;
  }
  .ui-volume-panel[hidden] { display: none; }
  .ui-volume-panel label {
    display: grid;
    grid-template-columns: 70px 1fr;
    align-items: center;
    gap: 8px;
  }
  .ui-volume-panel input[type=range] {
    width: 100%;
    accent-color: #4ade80;
  }

  .ui-info-btn {
    position: absolute;
    top: 16px; right: 108px;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    font-size: 16px;
    cursor: pointer;
    transition: background .15s;
    display: flex; align-items: center; justify-content: center;
    line-height: 1;
  }
  .ui-info-btn:hover { background: rgba(255,255,255,.16); }
  .ui-info-btn:focus-visible { outline: 2px solid #4ade80; outline-offset: 2px; }

  .ui-info-panel {
    position: absolute;
    top: 60px; right: 16px;
    width: 240px;
    background: rgba(0,0,0,.85);
    border-radius: 10px;
    padding: 12px 14px;
    color: #e6edf3;
    font-family: ui-monospace, monospace;
    font-size: 12px;
  }
  .ui-info-panel[hidden] { display: none; }
  .ui-info-panel h3 { margin: 0 0 8px; font-size: 13px; font-weight: 600; }
  .ui-info-panel dl { margin: 0 0 12px; display: grid; grid-template-columns: 60px 1fr; gap: 4px 8px; }
  .ui-info-panel dt { color: #888; }
  .ui-info-panel dd { margin: 0; word-break: break-all; }
  .ui-info-panel button {
    width: 100%;
    padding: 6px 10px;
    border: 1px solid rgba(255,255,255,.2);
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    border-radius: 6px;
    font-family: ui-monospace, monospace;
    font-size: 12px;
    cursor: pointer;
    transition: background .15s;
  }
  .ui-info-panel button:hover { background: rgba(255,255,255,.16); }
  .ui-info-panel .friends-heading {
    margin: 14px 0 6px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: #aaa;
    font-weight: 600;
  }
  .ui-info-panel .friends-list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 4px;
  }
  .ui-info-panel .friends-list li {
    display: grid;
    grid-template-columns: 18px 1fr auto;
    gap: 6px;
    align-items: center;
    padding: 4px 6px;
    border-radius: 4px;
    background: rgba(255,255,255,.04);
    font-size: 11px;
  }
  .ui-info-panel .friends-list .heart-1 { color: #ffb0c0; }
  .ui-info-panel .friends-list .heart-2 { color: #ff4060; }
  .ui-info-panel .friends-list .heart-3 { color: #ffd166; }
  .ui-info-panel .friends-list .name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .ui-info-panel .friends-list .score { color: #888; font-variant-numeric: tabular-nums; }
  .ui-info-panel .friends-empty {
    margin: 6px 0 0; font-size: 11px; color: #666; font-style: italic;
  }

  .ui-inventory-btn {
    position: absolute;
    top: 16px; right: 154px;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    font-size: 16px;
    cursor: pointer;
    transition: background .15s;
    display: flex; align-items: center; justify-content: center;
    line-height: 1;
  }
  .ui-inventory-btn:hover { background: rgba(255,255,255,.16); }
  .ui-inventory-btn:focus-visible { outline: 2px solid #4ade80; outline-offset: 2px; }

  .ui-inventory-panel {
    position: absolute;
    top: 60px; right: 16px;
    width: 240px;
    max-height: 60vh;
    overflow-y: auto;
    background: rgba(0,0,0,.85);
    border-radius: 10px;
    padding: 12px 14px;
    color: #e6edf3;
    font-family: ui-monospace, monospace;
    font-size: 12px;
  }
  .ui-inventory-panel[hidden] { display: none; }
  .ui-inventory-panel h3 { margin: 0 0 4px; font-size: 13px; font-weight: 600; }
  .ui-inventory-panel .count { margin: 0 0 10px; color: #ffd166; font-size: 14px; }
  .ui-inventory-panel ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 4px; }
  .ui-inventory-panel li {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 8px;
    border-radius: 6px;
    background: rgba(255,255,255,.05);
  }
  .ui-inventory-panel li.is-collected { background: rgba(255,209,102,.15); color: #ffd166; }
  .ui-inventory-panel li.is-locked { color: #555; }
  .ui-inventory-panel li::before { content: '◯'; font-size: 14px; }
  .ui-inventory-panel li.is-collected::before { content: '✦'; }

  .ui-name-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ui-name-modal[hidden] { display: none; }
  .ui-name-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.6);
    backdrop-filter: blur(2px);
  }
  .ui-name-modal-card {
    position: relative;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 12px;
    padding: 24px;
    width: 320px;
    color: #e6edf3;
    font-family: ui-monospace, monospace;
    box-shadow: 0 10px 40px rgba(0,0,0,.5);
  }
  .ui-name-modal-card h3 {
    margin: 0 0 16px;
    font-size: 15px;
    font-weight: 600;
  }
  .ui-name-modal-card input {
    width: 100%;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,.2);
    background: rgba(0,0,0,.4);
    color: #fff;
    font-family: ui-monospace, monospace;
    font-size: 14px;
    outline: none;
    box-sizing: border-box;
  }
  .ui-name-modal-card input:focus { border-color: #4ade80; }
  .ui-name-modal-card .hint { margin: 6px 0 0; font-size: 11px; color: #888; }
  .ui-name-modal-card .error { margin: 6px 0 0; font-size: 11px; color: #ff7070; }
  .ui-name-modal-card .actions { margin-top: 16px; display: flex; gap: 8px; justify-content: flex-end; }
  .ui-name-modal-card button {
    padding: 8px 16px;
    border: 1px solid rgba(255,255,255,.2);
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    border-radius: 6px;
    font-family: ui-monospace, monospace;
    font-size: 12px;
    cursor: pointer;
    transition: background .15s;
  }
  .ui-name-modal-card button#lounge-name-save {
    background: #4ade80;
    color: #0d1117;
    border-color: #4ade80;
    font-weight: 600;
  }
  .ui-name-modal-card button:hover { background: rgba(255,255,255,.16); }
  .ui-name-modal-card button#lounge-name-save:hover { background: #5fea8e; }

  .ui-replaced-overlay {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,.85);
    color: #e6edf3;
    font-family: ui-monospace, monospace;
    text-align: center;
  }
  .ui-replaced-overlay[hidden] { display: none; }
  .ui-replaced-overlay p { margin: 0 0 8px; font-size: 14px; }
  .ui-replaced-overlay .hint { font-size: 12px; color: #888; }

  .ui-booth-picker {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(0,0,0,.92);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 12px;
    padding: 18px 22px;
    width: 280px;
    color: #e6edf3;
    font-family: ui-monospace, monospace;
    z-index: 150;
  }
  .ui-booth-picker[hidden] { display: none; }
  .ui-booth-picker h3 { margin: 0 0 12px; font-size: 14px; font-weight: 600; }
  .ui-booth-picker ul { list-style: none; margin: 0 0 14px; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .ui-booth-picker li button {
    width: 100%;
    text-align: left;
    padding: 8px 12px;
    border: 1px solid rgba(255,255,255,.15);
    background: rgba(255,255,255,.06);
    color: #e6edf3;
    border-radius: 6px;
    font-family: ui-monospace, monospace;
    font-size: 12px;
    cursor: pointer;
    transition: background .15s, border-color .15s;
  }
  .ui-booth-picker li button:hover { background: rgba(255,255,255,.14); border-color: rgba(255,255,255,.3); }
  .ui-booth-picker li button.is-playing { background: rgba(74,222,128,.18); border-color: #4ade80; color: #4ade80; }
  .ui-booth-picker .actions { display: flex; gap: 8px; justify-content: flex-end; }
  .ui-booth-picker .actions button {
    padding: 6px 12px;
    border: 1px solid rgba(255,255,255,.2);
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    border-radius: 6px;
    font-family: ui-monospace, monospace;
    font-size: 12px;
    cursor: pointer;
  }
  .ui-booth-picker .actions button:hover { background: rgba(255,255,255,.16); }

  .ui-now-playing {
    position: absolute;
    bottom: 24px; left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,.8);
    color: #4ade80;
    padding: 6px 14px;
    border-radius: 16px;
    font-family: ui-monospace, monospace;
    font-size: 12px;
    border: 1px solid rgba(74,222,128,.4);
    pointer-events: none;
  }
  .ui-now-playing[hidden] { display: none; }
  .ui-now-playing span { color: #e6edf3; margin-left: 4px; }

  /* Radial emote menu */
  .ui-emote-menu {
    position: absolute;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    padding: 8px;
    background: rgba(0,0,0,.85);
    border-radius: 12px;
    transform: translate(-50%, -50%) scale(1);
    transform-origin: center;
    transition: transform .15s ease-out, opacity .15s;
    opacity: 1;
  }
  .ui-emote-menu[hidden] { display: none; }
  .ui-emote-menu.is-opening {
    transform: translate(-50%, -50%) scale(0.6);
    opacity: 0;
  }
  .ui-emote-menu button {
    width: 44px; height: 44px;
    border: none;
    border-radius: 50%;
    background: rgba(255,255,255,.1);
    color: #fff;
    font-size: 22px;
    cursor: pointer;
    transition: background .15s, transform .1s;
  }
  .ui-emote-menu button:hover { background: rgba(255,255,255,.25); }
  .ui-emote-menu button:active { transform: scale(0.92); }
  .ui-emote-menu button:focus-visible { outline: 2px solid #4ade80; outline-offset: 2px; }

  /* Say input */
  .ui-say {
    position: absolute;
    bottom: 64px; left: 50%;
    transform: translateX(-50%);
  }
  .ui-say[hidden] { display: none; }
  .ui-say input {
    width: 320px;
    padding: 10px 14px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,.2);
    background: rgba(0,0,0,.7);
    color: #fff;
    font-family: ui-monospace, monospace;
    font-size: 14px;
    outline: none;
  }
  .ui-say input:focus { border-color: #4ade80; }

  /* Speech bubbles */
  .ui-bubbles { position: absolute; inset: 0; pointer-events: none; }
  .ui-bubble {
    position: absolute;
    background: #fff;
    color: #1a1a1a;
    border: 1.5px solid #1a1a1a;
    border-radius: 8px;
    padding: 4px 10px;
    font-family: ui-monospace, monospace;
    font-size: 13px;
    line-height: 1.2;
    white-space: nowrap;
    transform: translate(-50%, -100%);
    opacity: 1;
    transition: opacity .2s;
  }
  .ui-bubble.is-fading { opacity: 0; }

  /* Dialog (reserved for V2.2+; styled but not used in V2.1) */
  .ui-dialog {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 25vh;
    background: linear-gradient(180deg, rgba(20,14,8,0.92), rgba(20,14,8,0.98));
    border-top: 4px solid #6b4226;
    color: #f5e8d8;
    padding: 16px 24px;
    font-family: ui-monospace, monospace;
    font-size: 14px;
    line-height: 1.5;
    box-shadow: 0 -8px 24px rgba(0,0,0,0.4);
  }
  .ui-dialog[hidden] { display: none; }

  .ui-interact-prompt {
    position: absolute;
    background: rgba(0,0,0,.85);
    color: #fff;
    padding: 3px 8px;
    border-radius: 6px;
    font-family: ui-monospace, monospace;
    font-size: 12px;
    transform: translate(-50%, -100%);
    pointer-events: none;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ui-interact-prompt[hidden] { display: none; }
  .ui-interact-prompt kbd {
    background: #fff;
    color: #1a1a1a;
    border-radius: 3px;
    padding: 1px 5px;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .ui-emote-menu,
    .ui-bubble,
    .ui-mute-btn { transition: none !important; }
  }
</style>

<script>
  import { bootGame } from '../lounge/game'
  import { isMuted, toggleMute, playSfx } from '../lounge/audio'
  import { initUI } from '../lounge/ui'

  function start() {
    const mount = document.getElementById('lounge-mount')
    if (!mount) return
    bootGame(mount)
    initUI()

    const muteBtn = document.getElementById('lounge-mute') as HTMLButtonElement | null
    if (muteBtn) {
      const refresh = () => { muteBtn.textContent = isMuted() ? '🔇' : '🔊' }
      refresh()
      muteBtn.addEventListener('click', () => {
        toggleMute()
        refresh()
        playSfx('click')
      })
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start)
  } else {
    start()
  }
</script>
