  .mg-results-best { color: #ffd166; font-weight: 700; margin-bottom: 4px; }
  .mg-results-reward { color: #4ade80; margin-bottom: 12px; }
  .mg-results-actions { display: flex; gap: 8px; justify-content: center; }
  .mg-results-actions button { padding: 6px 14px; cursor: pointer; }

  /* Dice game */
  .mg-dice-board { display: flex; justify-content: center; gap: 16px; margin-bottom: 12px; }
  .mg-dice {
    width: 64px; height: 64px;
    background: linear-gradient(135deg, #fff, #ddd);
    color: #222;
    border-radius: 10px; font-size: 32px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 3px 8px rgba(0,0,0,.4);
  }
  .mg-dice-meta, .mg-dice-best { text-align: center; font-size: 12px; margin: 4px 0; opacity: .85; }
  .mg-dice-board + .mg-dice-meta { margin-top: 4px; }
  .mg-dice + .mg-dice-best { margin-bottom: 12px; }
  #mg-roll { display: block; margin: 12px auto 0; }

  /* Rhythm game */
  .mg-rhythm-meta { text-align: center; font-size: 12px; opacity: .85; margin-bottom: 8px; }
  .mg-rhythm-board { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px; height: 220px; background: rgba(0,0,0,.4); padding: 4px; border-radius: 6px; position: relative; overflow: hidden; }
  .mg-rh-lane { position: relative; background: rgba(255,255,255,.04); border-radius: 4px; cursor: pointer; }
  .mg-rh-lane:active { background: rgba(255,255,255,.1); }
  .mg-rh-key { position: absolute; bottom: 4px; left: 0; right: 0; text-align: center; font-size: 14px; opacity: .5; }
  .mg-rh-lane::after { content: ''; position: absolute; left: 0; right: 0; bottom: 22px; height: 2px; background: rgba(255,209,102,.6); }
  .mg-rh-note { position: absolute; left: 4px; right: 4px; top: -22px; height: 22px; background: linear-gradient(135deg, #4ade80, #60d090); border-radius: 4px; animation: mg-rh-fall linear forwards; }
  .mg-rh-note.mg-rh-hit { background: linear-gradient(135deg, #ffd166, #ffaa50); transform: scale(0.8); transition: transform .15s; }
  .mg-rh-note.mg-rh-fade { opacity: 0; transition: opacity .3s; }
  @keyframes mg-rh-fall { to { top: calc(100% - 22px); } }
  .mg-rhythm-stats { text-align: center; font-size: 12px; margin: 8px 0; }
  #mg-rh-start { display: block; margin: 0 auto; }

  /* Cook game */
  .mg-cook-meta { text-align: center; font-size: 12px; opacity: .85; margin-bottom: 12px; }
  .mg-cook-bar { position: relative; height: 32px; background: rgba(255,255,255,.08); border-radius: 4px; overflow: hidden; margin-bottom: 12px; }
  .mg-cook-zone { position: absolute; top: 0; bottom: 0; background: rgba(74,222,128,.4); }
  .mg-cook-marker { position: absolute; top: 0; bottom: 0; width: 4px; background: #ffd166; box-shadow: 0 0 6px #ffd166; }
  .mg-cook-stats { text-align: center; font-size: 12px; margin-bottom: 12px; }
  #mg-cook-stop { display: block; margin: 0 auto; }

  /* V11.7 — Word puzzle */
  .mg-word-meta { text-align: center; font-size: 12px; opacity: .85; margin-bottom: 16px; }
  .mg-word-display { text-align: center; font-size: 36px; letter-spacing: 8px; font-family: ui-monospace, monospace; margin-bottom: 20px; color: #ffd166; }
  .mg-word-choices { display: flex; gap: 8px; justify-content: center; }
  .mg-word-choice { width: 50px; height: 50px; font-size: 20px; font-weight: 700; background: rgba(255,255,255,.1); color: inherit; border: 1px solid rgba(255,255,255,.2); border-radius: 6px; cursor: pointer; font-family: inherit; }
  .mg-word-choice:hover { background: rgba(255,255,255,.2); }
  .mg-word-choice.correct { background: rgba(74,222,128,.5); }
  .mg-word-choice.wrong { background: rgba(255,80,80,.5); }

  /* V11.7 — Shell hunt */
  .mg-shell-meta { text-align: center; font-size: 12px; opacity: .85; margin-bottom: 12px; }
  .mg-shell-grid { display: grid; gap: 4px; max-width: 280px; margin: 0 auto; }
  .mg-shell-cell { aspect-ratio: 1; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15); border-radius: 4px; cursor: pointer; color: inherit; font-size: 18px; padding: 0; }
  .mg-shell-cell:hover:not(:disabled) { background: rgba(255,255,255,.15); }
  .mg-shell-cell.hit { background: rgba(255,209,102,.4); cursor: default; }
  .mg-shell-cell.miss { background: rgba(255,255,255,.02); opacity: .5; cursor: default; }

  /* V11.7 — Garden tending */
  .mg-garden-meta { text-align: center; font-size: 12px; opacity: .85; margin-bottom: 12px; }
  .mg-garden-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .mg-garden-plant { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1); border-radius: 6px; padding: 6px; text-align: center; transition: all .15s; }
  .mg-garden-plant.needing { background: rgba(255,209,102,.15); border-color: rgba(255,209,102,.5); }
  .mg-garden-plant.mg-garden-correct { background: rgba(74,222,128,.5); }
  .mg-garden-plant.mg-garden-wrong { background: rgba(255,80,80,.5); }
  .mg-garden-icon { font-size: 24px; margin-bottom: 4px; }
  .mg-garden-need { font-size: 18px; height: 22px; }
  .mg-garden-actions { display: flex; flex-direction: column; gap: 2px; margin-top: 4px; }
  .mg-garden-act { background: rgba(255,255,255,.08); color: inherit; border: 1px solid rgba(255,255,255,.15); border-radius: 4px; padding: 4px; cursor: pointer; font-family: inherit; font-size: 12px; }
  .mg-garden-act:hover { background: rgba(255,255,255,.15); }

  /* V11.8-review I1 fix — bottom-strip math for 10 buttons. Width 32px +
     spacing 34px = 10*34 = 340px total ≤ 360px viewport. */
  @media (max-width: 600px) {
    .ui-mute-btn, .ui-volume-btn, .ui-info-btn, .ui-pet-btn, .ui-ach-btn,
    .ui-photos-btn, .ui-inventory-btn, .ui-messages-btn, .ui-wishboard-btn,
    .ui-mg-btn, .ui-board-btn, .ui-transit-btn {
      width: 28px !important; height: 28px !important;
    }
    .ui-mg-btn, .ui-board-btn, .ui-transit-btn {
      position: fixed !important;
      top: auto !important; right: auto !important;
      bottom: 10px !important;
      z-index: 90 !important;
    }
    /* Centered strip: 12 buttons × 28 width + 30px spacing = 360px exactly. */
    .ui-mute-btn      { left: calc(50vw - 180px) !important; }
    .ui-volume-btn    { left: calc(50vw - 150px) !important; }
    .ui-info-btn      { left: calc(50vw - 120px) !important; }
    .ui-inventory-btn { left: calc(50vw - 90px)  !important; }
    .ui-messages-btn  { left: calc(50vw - 60px)  !important; }
    .ui-wishboard-btn { left: calc(50vw - 30px)  !important; }
    .ui-pet-btn       { left: calc(50vw)         !important; }
    .ui-ach-btn       { left: calc(50vw + 30px)  !important; }
    .ui-photos-btn    { left: calc(50vw + 60px)  !important; }
    .ui-mg-btn        { left: calc(50vw + 90px)  !important; }
    .ui-board-btn     { left: calc(50vw + 120px) !important; }
    .ui-transit-btn   { left: calc(50vw + 150px) !important; }
    .mg-card { max-height: calc(100vh - 100px); }
  }

  /* V11.9c — extra-narrow phones (≤400px, e.g. iPhone SE 1). The 10-button
     single row no longer fits even at 32px buttons. Switch to a 2×5 grid.
     Placed AFTER the 600px block so source order makes these win at 320. */
  @media (max-width: 400px) {
    .ui-mute-btn, .ui-volume-btn, .ui-info-btn, .ui-inventory-btn,
    .ui-messages-btn, .ui-wishboard-btn, .ui-pet-btn, .ui-ach-btn,
    .ui-photos-btn, .ui-mg-btn, .ui-board-btn, .ui-transit-btn {
      width: 28px !important; height: 28px !important;
      font-size: 13px !important;
    }
    /* 12 buttons → 6 + 6 grid, 30px spacing → 180px row width */
    /* Row 1 */
    .ui-mute-btn      { left: calc(50vw - 90px)  !important; bottom: 46px !important; }
    .ui-volume-btn    { left: calc(50vw - 60px)  !important; bottom: 46px !important; }
    .ui-info-btn      { left: calc(50vw - 30px)  !important; bottom: 46px !important; }
    .ui-inventory-btn { left: calc(50vw)         !important; bottom: 46px !important; }
    .ui-messages-btn  { left: calc(50vw + 30px)  !important; bottom: 46px !important; }
    .ui-wishboard-btn { left: calc(50vw + 60px)  !important; bottom: 46px !important; }
    /* Row 2 */
    .ui-pet-btn       { left: calc(50vw - 90px)  !important; bottom: 12px !important; }
    .ui-ach-btn       { left: calc(50vw - 60px)  !important; bottom: 12px !important; }
    .ui-photos-btn    { left: calc(50vw - 30px)  !important; bottom: 12px !important; }
    .ui-mg-btn        { left: calc(50vw)         !important; bottom: 12px !important; }
    .ui-board-btn     { left: calc(50vw + 30px)  !important; bottom: 12px !important; }
    .ui-transit-btn   { left: calc(50vw + 60px)  !important; bottom: 12px !important; }
    /* Door label and D-pad lift further so 2-row strip clears */
    .ui-door-label { bottom: 90px !important; }
    .touch-dpad    { bottom: 90px !important; }
    .touch-action-btn { bottom: 100px !important; }
  }

