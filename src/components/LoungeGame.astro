---
// Astro client island — mounts Phaser game on /lounge.
---

<div id="lounge-root">
  <div id="lounge-mount"></div>
  <div id="lounge-ui">
    <button id="lounge-mute" class="ui-mute-btn" aria-label="Toggle sound">🔊</button>
    <button id="lounge-volume-btn" class="ui-volume-btn" aria-label="Volume settings">⚙</button>
    <button id="lounge-info-btn" class="ui-info-btn" aria-label="Identity">ⓘ</button>
    <button id="lounge-inventory-btn" class="ui-inventory-btn" aria-label="Inventory">📦</button>
    <button id="lounge-messages-btn" class="ui-messages-btn" aria-label="Messages">✉<span id="lounge-messages-badge" class="badge" hidden>0</span></button>
    <button id="lounge-wishboard-btn" class="ui-wishboard-btn" aria-label="Wishboard">🌟</button>
    <div id="lounge-wishboard-panel" class="ui-wishboard-panel" hidden>
      <h3>🌟 Wishboard</h3>
      <p class="subtitle">Suggest a sprite, room, dialog or anything else for the lounge. Vote on others' ideas.</p>
      <form id="lounge-wish-form">
        <select id="lounge-wish-category">
          <option value="sprite">Sprite</option>
          <option value="room">Room</option>
          <option value="dialog">Dialog</option>
          <option value="other">Other</option>
        </select>
        <textarea id="lounge-wish-input" maxlength="140" placeholder="My wish for the lounge..." rows="2"></textarea>
        <div class="form-foot">
          <span id="lounge-wish-count">0</span> / 140
          <button type="submit">Submit</button>
        </div>
      </form>
      <ul id="lounge-wish-list" class="wishes"></ul>
      <p id="lounge-wish-empty" class="empty" hidden>No wishes yet — be the first.</p>
    </div>
    <div id="lounge-messages-panel" class="ui-messages-panel" hidden>
      <h3>Messages</h3>
      <div id="lounge-messages-empty" class="empty">No messages yet. Wave to a friend, then send one.</div>
      <ul id="lounge-messages-list" class="threads"></ul>
      <div id="lounge-thread-view" class="thread-view" hidden>
        <button type="button" class="back" id="lounge-thread-back">← Back</button>
        <h4 id="lounge-thread-name">Friend</h4>
        <ul id="lounge-thread-messages"></ul>
        <form id="lounge-thread-form">
          <input type="text" id="lounge-thread-input" maxlength="140" placeholder="Say something…" autocomplete="off">
          <button type="submit">Send</button>
        </form>
      </div>
    </div>
    <div id="lounge-peer-menu" class="ui-peer-menu" hidden>
      <button type="button" data-action="wave">👋 Wave</button>
      <button type="button" data-action="gift">🎁 Gift pebble</button>
      <button type="button" data-action="dm">✉ Send DM</button>
    </div>
    <div id="lounge-gift-modal" class="ui-gift-modal" hidden>
      <div class="ui-gift-modal-backdrop"></div>
      <div class="ui-gift-modal-card">
        <h3>Pick a pebble to gift</h3>
        <p class="gift-recipient">to <span id="lounge-gift-to-name">Friend</span></p>
        <ul id="lounge-gift-list"></ul>
        <p id="lounge-gift-empty" class="empty" hidden>You haven't collected any pebbles yet.</p>
        <div class="actions">
          <button type="button" id="lounge-gift-cancel">Cancel</button>
        </div>
      </div>
    </div>
    <div id="lounge-toast" class="ui-toast" hidden></div>
    <div id="lounge-minimap" class="ui-minimap" hidden>
      <div class="mm-title">📍 <span id="lounge-mm-room-name">Lobby</span></div>
      <svg id="lounge-mm-svg" viewBox="0 0 140 100" xmlns="http://www.w3.org/2000/svg"></svg>
      <div class="mm-legend">
        <span class="dot here"></span> here
        <span class="dot npc"></span> NPC
      </div>
    </div>
    <div id="lounge-door-label" class="ui-door-label" hidden></div>
    <div id="lounge-inventory-panel" class="ui-inventory-panel" hidden>
      <div class="inv-header">
        <h3>Inventory</h3>
        <div class="inv-view-toggle" role="tablist">
          <button id="lounge-inv-view-grid" type="button" data-view="grid" class="inv-tab active">Grid</button>
          <button id="lounge-inv-view-list" type="button" data-view="list" class="inv-tab">List</button>
        </div>
      </div>
      <p class="count">Pebbles: <span id="lounge-inv-count">0</span> / <span id="lounge-inv-total">0</span></p>
      <div id="lounge-inv-grid" class="inv-grid"></div>
      <div id="lounge-inv-trash" class="inv-trash" title="Drag a shop decoration here to discard it">🗑</div>
      <ul id="lounge-inv-list" hidden></ul>
    </div>
    <div id="lounge-info-panel" class="ui-info-panel" hidden>
      <h3>Identity</h3>
      <dl>
        <dt>Name</dt><dd id="lounge-info-name">—</dd>
        <dt>Region</dt><dd id="lounge-info-region">—</dd>
        <dt>ID</dt><dd id="lounge-info-id">—</dd>
      </dl>
      <button type="button" id="lounge-info-rename">Change name</button>
      <button type="button" id="lounge-info-species" data-species="bear">Switch to 🐱 Cat</button>
      <button type="button" id="lounge-info-quests">📋 Quests</button>
      <button type="button" id="lounge-info-whosaround">👥 Who's around</button>
      <button type="button" id="lounge-info-memories">📷 Memories</button>
      <button type="button" id="lounge-info-shop">🐚 Mio's Shop</button>
      <button type="button" id="lounge-info-mailbox">📬 Mailbox <span id="lounge-mailbox-badge" class="mb-badge" hidden>0</span></button>
      <button type="button" id="lounge-info-progress">✨ Your Story</button>
      <button type="button" id="lounge-info-gametime" data-on="0">⏰ Game time: off</button>
      <h4 class="friends-heading">Friends</h4>
      <ul id="lounge-info-friends" class="friends-list"></ul>
      <p id="lounge-info-friends-empty" class="friends-empty">No friendships yet — spend time with peers.</p>
    </div>
    <div id="lounge-name-modal" class="ui-name-modal" hidden>
      <div class="ui-name-modal-backdrop"></div>
      <div class="ui-name-modal-card">
        <h3 id="lounge-name-modal-title">How should we call you?</h3>
        <input type="text" id="lounge-name-input" maxlength="16" autocomplete="off" placeholder="Your name">
        <p class="hint">1–16 chars</p>
        <p id="lounge-name-error" class="error" hidden></p>
        <div class="actions">
          <button type="button" id="lounge-name-skip">Skip</button>
          <button type="button" id="lounge-name-save">Save</button>
        </div>
      </div>
    </div>
    <div id="lounge-booth-picker" class="ui-booth-picker" hidden>
      <h3>🎧 Listening Booth</h3>
      <ul id="lounge-booth-list"></ul>
      <div class="actions">
        <button type="button" id="lounge-booth-stop">Stop</button>
        <button type="button" id="lounge-booth-close">Close</button>
      </div>
    </div>
    <div id="lounge-now-playing" class="ui-now-playing" hidden>
      🎧 Now: <span id="lounge-now-playing-name"></span>
    </div>
    <div id="lounge-festival-banner" class="ui-festival-banner" hidden>
      <span id="lounge-festival-banner-emoji" class="festival-emoji">🌸</span>
      <span id="lounge-festival-banner-text">Festival today!</span>
      <button type="button" id="lounge-festival-action" class="festival-action" hidden>Join 🎟</button>
    </div>
    <div id="lounge-clock" class="ui-clock" hidden>
      <span class="clk-icon">🕐</span>
      <span id="lounge-clock-time">06:00</span>
      <span class="clk-mode" id="lounge-clock-mode">game</span>
    </div>
    <div id="lounge-energy" class="ui-energy">
      <span class="en-icon">⚡</span>
      <div class="en-track"><div id="lounge-energy-fill" class="en-fill"></div></div>
      <span id="lounge-energy-num" class="en-num">100</span>
    </div>
    <button type="button" id="lounge-camera-btn" class="ui-camera-btn" title="Equip camera (click anywhere to capture)">📷</button>
    <div id="lounge-shells" class="ui-shells" title="Shells">
      <span class="sh-icon">🐚</span>
      <span id="lounge-shells-num">0</span>
    </div>
    <div id="lounge-whosaround-panel" class="ui-whosaround-panel" hidden>
      <div class="wa-card">
        <h3>👥 Who's around</h3>
        <ul id="lounge-whosaround-list" class="wa-list"></ul>
        <p id="lounge-whosaround-empty" class="wa-empty" hidden>Nobody's on shift right now.</p>
        <div class="wa-actions">
          <button type="button" id="lounge-whosaround-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-progress-panel" class="ui-progress-panel" hidden>
      <div class="prog-card">
        <h3>✨ Your Story</h3>
        <p id="lounge-progress-summary" class="prog-summary"></p>
        <ul id="lounge-progress-list" class="prog-list"></ul>
        <div class="prog-actions">
          <button type="button" id="lounge-progress-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-mailbox-panel" class="ui-mailbox-panel" hidden>
      <div class="mb-card">
        <h3>📬 Mailbox</h3>
        <div id="lounge-mailbox-list" class="mb-list"></div>
        <p id="lounge-mailbox-empty" class="mb-empty" hidden>Mailbox is empty.</p>
        <div class="mb-actions">
          <button type="button" id="lounge-mailbox-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-species-picker" class="ui-species-picker" hidden>
      <div class="sp-card">
        <h3>Choose your shape</h3>
        <p class="sp-blurb">You can change this anytime in the info panel.</p>
        <div class="sp-grid">
          <button type="button" class="sp-tile" data-species="bear">
            <span class="sp-emoji">🐻</span><span class="sp-label">Bear</span>
          </button>
          <button type="button" class="sp-tile" data-species="cat">
            <span class="sp-emoji">🐱</span><span class="sp-label">Cat</span>
          </button>
          <button type="button" class="sp-tile" data-species="fox">
            <span class="sp-emoji">🦊</span><span class="sp-label">Fox</span>
          </button>
          <button type="button" class="sp-tile" data-species="capybara">
            <span class="sp-emoji">🦦</span><span class="sp-label">Capybara</span>
          </button>
          <button type="button" class="sp-tile" data-species="bird">
            <span class="sp-emoji">🐦</span><span class="sp-label">Bird</span>
          </button>
        </div>
      </div>
    </div>
    <div id="lounge-sleep-overlay" class="ui-sleep-overlay" hidden>
      <div class="sleep-card">
        <div class="sleep-time">🌙 <span id="lounge-sleep-time">02:00</span></div>
        <h3 id="lounge-sleep-title">The day ends.</h3>
        <p id="lounge-sleep-blurb">Sleep to restore your energy.</p>
        <div class="sleep-actions">
          <button type="button" id="lounge-sleep-go" class="primary">Sleep 💤</button>
          <button type="button" id="lounge-sleep-stay">Stay up</button>
        </div>
      </div>
    </div>
    <div id="lounge-shop-panel" class="ui-shop-panel" hidden>
      <div class="shop-card">
        <h3>🐚 Mio's Cafe — Shop</h3>
        <p class="shop-balance">You have <span id="lounge-shop-balance">0</span> shells.</p>
        <div id="lounge-shop-list" class="shop-list"></div>
        <div class="shop-actions">
          <button type="button" id="lounge-shop-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-memories-panel" class="ui-memories-panel" hidden>
      <div class="mem-card">
        <h3>📷 Memories</h3>
        <div id="lounge-memories-list" class="mem-list"></div>
        <p id="lounge-memories-empty" class="mem-empty" hidden>No memories yet. Equip 📷 and click a moment.</p>
        <div class="mem-actions">
          <button type="button" id="lounge-memories-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-quests-panel" class="ui-quests-panel" hidden>
      <div class="qp-card">
        <h3>📋 Quests</h3>
        <div id="lounge-quests-list" class="qp-list"></div>
        <p id="lounge-quests-empty" class="qp-empty" hidden>No active quests yet. Talk to an NPC twice — when you're closer, they may give you one.</p>
        <button type="button" id="lounge-quests-close">Close</button>
      </div>
    </div>
    <div id="lounge-replaced-overlay" class="ui-replaced-overlay" hidden>
      <div>
        <p>This tab was replaced by a newer session.</p>
        <p class="hint">Close this tab — your character is active elsewhere.</p>
      </div>
    </div>
    <div id="lounge-volume-panel" class="ui-volume-panel" hidden>
      <label><span>Master</span><input type="range" data-channel="master" min="0" max="100"></label>
      <label><span>SFX</span><input type="range" data-channel="sfx" min="0" max="100"></label>
      <label><span>BGM</span><input type="range" data-channel="bgm" min="0" max="100"></label>
      <label><span>Ambient</span><input type="range" data-channel="ambient" min="0" max="100"></label>
    </div>
    <div id="lounge-emote-menu" class="ui-emote-menu" hidden>
      <button data-verb="wave" title="Wave">👋</button>
      <button data-verb="sit" title="Sit">🪑</button>
      <button data-verb="dance" title="Dance">💃</button>
      <button data-verb="say" title="Say">💬</button>
      <button data-verb="letter" title="Drop note">📜</button>
    </div>
    <div id="lounge-letter-modal" class="ui-letter-modal" hidden>
      <div class="ui-letter-modal-backdrop"></div>
      <div class="ui-letter-modal-card">
        <h3>📜 Drop a note here</h3>
        <p class="hint">Anyone who walks by can read it. 1-80 chars.</p>
        <textarea id="lounge-letter-input" maxlength="80" placeholder="Your note…" rows="3"></textarea>
        <p id="lounge-letter-error" class="error" hidden></p>
        <p class="char-count"><span id="lounge-letter-count">0</span> / 80</p>
        <div class="actions">
          <button type="button" id="lounge-letter-cancel">Cancel</button>
          <button type="button" id="lounge-letter-save">Drop</button>
        </div>
      </div>
    </div>
    <div id="lounge-letter-read" class="ui-letter-read" hidden>
      <div class="ui-letter-read-card">
        <p class="meta">📜 by <span id="lounge-letter-read-author">someone</span> · <span id="lounge-letter-read-ago">just now</span></p>
        <p id="lounge-letter-read-content" class="content"></p>
        <button type="button" id="lounge-letter-read-close">Close</button>
      </div>
    </div>
    <form id="lounge-say-form" class="ui-say" hidden>
      <input type="text" id="lounge-say-input" maxlength="60" placeholder="say something…" autocomplete="off">
    </form>
    <div id="lounge-bubbles" class="ui-bubbles"></div>
    <div id="lounge-interact-prompt" class="ui-interact-prompt" hidden>
      <kbd>E</kbd> <span id="lounge-interact-verb">interact</span>
    </div>
    <div id="lounge-dialog" class="ui-dialog" hidden></div>
  </div>
  <a href="/" class="lounge-back" title="Back to homepage">←</a>
</div>

<style is:global>
  body:has(#lounge-root) {
    overflow: hidden;
    background: #0d1117;
  }
  #lounge-root {
    position: fixed;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #lounge-mount {
    width: 100vw;
    height: 100vh;
  }
  #lounge-mount canvas {
    image-rendering: pixelated;
    cursor: crosshair;
  }
  .lounge-back {
    position: absolute; top: 16px; left: 16px;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    display: flex; align-items: center; justify-content: center;
    font-family: ui-monospace, monospace;
    font-size: 18px;
    text-decoration: none;
    z-index: 100;
    transition: background .15s;
  }
  .lounge-back:hover { background: rgba(255,255,255,.16); }
  .lounge-status {
    position: absolute; bottom: 24px; left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,.7);
    color: #e6edf3;
    padding: 10px 18px;
    border-radius: 8px;
    font-family: ui-monospace, monospace;
    font-size: 13px;
    z-index: 100;
  }
  #lounge-ui {
    position: absolute; inset: 0;
    pointer-events: none;
    z-index: 50;
  }
  #lounge-ui > * { pointer-events: auto; }
  #lounge-bubbles { pointer-events: none; }
  #lounge-interact-prompt { pointer-events: none; }
  .ui-mute-btn {
    position: absolute;
    top: 16px; right: 16px;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    font-size: 18px;
    cursor: pointer;
    transition: background .15s;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .ui-mute-btn:hover { background: rgba(255,255,255,.16); }
  .ui-mute-btn:focus-visible { outline: 2px solid #4ade80; outline-offset: 2px; }

  .ui-volume-btn {
    position: absolute;
    top: 16px; right: 62px;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    font-size: 16px;
    cursor: pointer;
    transition: background .15s;
    display: flex; align-items: center; justify-content: center;
    line-height: 1;
  }
  .ui-volume-btn:hover { background: rgba(255,255,255,.16); }
  .ui-volume-btn:focus-visible { outline: 2px solid #4ade80; outline-offset: 2px; }

  .ui-volume-panel {
    position: absolute;
    top: 60px; right: 16px;
    width: 220px;
    background: rgba(0,0,0,.85);
    border-radius: 10px;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: #e6edf3;
    font-family: ui-monospace, monospace;
    font-size: 12px;
  }
  .ui-volume-panel[hidden] { display: none; }
  .ui-volume-panel label {
    display: grid;
    grid-template-columns: 70px 1fr;
    align-items: center;
    gap: 8px;
  }
  .ui-volume-panel input[type=range] {
    width: 100%;
    accent-color: #4ade80;
  }

  .ui-info-btn {
    position: absolute;
    top: 16px; right: 108px;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    font-size: 16px;
    cursor: pointer;
    transition: background .15s;
    display: flex; align-items: center; justify-content: center;
    line-height: 1;
  }
  .ui-info-btn:hover { background: rgba(255,255,255,.16); }
  .ui-info-btn:focus-visible { outline: 2px solid #4ade80; outline-offset: 2px; }

  .ui-info-panel {
    position: absolute;
    top: 60px; right: 16px;
    width: 240px;
    background: rgba(0,0,0,.85);
    border-radius: 10px;
    padding: 12px 14px;
    color: #e6edf3;
    font-family: ui-monospace, monospace;
    font-size: 12px;
  }
  .ui-info-panel[hidden] { display: none; }
  .ui-info-panel h3 { margin: 0 0 8px; font-size: 13px; font-weight: 600; }
  .ui-info-panel dl { margin: 0 0 12px; display: grid; grid-template-columns: 60px 1fr; gap: 4px 8px; }
  .ui-info-panel dt { color: #888; }
  .ui-info-panel dd { margin: 0; word-break: break-all; }
  .ui-info-panel button {
    width: 100%;
    padding: 6px 10px;
    border: 1px solid rgba(255,255,255,.2);
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    border-radius: 6px;
    font-family: ui-monospace, monospace;
    font-size: 12px;
    cursor: pointer;
    transition: background .15s;
  }
  .ui-info-panel button:hover { background: rgba(255,255,255,.16); }
  .ui-info-panel .friends-heading {
    margin: 14px 0 6px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: #aaa;
    font-weight: 600;
  }
  .ui-info-panel .friends-list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 4px;
  }
  .ui-info-panel .friends-list li {
    display: grid;
    grid-template-columns: 18px 1fr auto;
    gap: 6px;
    align-items: center;
    padding: 4px 6px;
    border-radius: 4px;
    background: rgba(255,255,255,.04);
    font-size: 11px;
  }
  .ui-info-panel .friends-list .heart-1 { color: #ffb0c0; }
  .ui-info-panel .friends-list .heart-2 { color: #ff4060; }
  .ui-info-panel .friends-list .heart-3 { color: #ffd166; }
  .ui-info-panel .friends-list .name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .ui-info-panel .friends-list .score { color: #888; font-variant-numeric: tabular-nums; }
  .ui-info-panel .friends-empty {
    margin: 6px 0 0; font-size: 11px; color: #666; font-style: italic;
  }

  /* V4.1 — Messages */
  .ui-messages-btn {
    position: absolute;
    top: 16px; right: 200px;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,.08);
    color: #e6edf3;
    font-size: 16px;
    cursor: pointer;
    transition: background .15s;
    display: flex; align-items: center; justify-content: center;
    line-height: 1;
    position: absolute;
  }
  .ui-messages-btn:hover { background: rgba(255,255,255,.16); }
  .ui-messages-btn .badge {
    position: absolute;
    top: -2px; right: -2px;
    min-width: 16px; height: 16px;
    background: #ff4060;
    border-radius: 8px;
    font-size: 10px;
    font-weight: 700;
    color: white;
    display: flex; align-items: center; justify-content: center;
    padding: 0 4px;
    box-sizing: border-box;
  }
  .ui-messages-btn .badge[hidden] { display: none; }

  .ui-messages-panel {
    position: absolute;
    top: 60px; right: 16px;
    width: 280px;
    max-height: 70vh;
    overflow-y: auto;
    background: rgba(0,0,0,.92);
