    font-family: ui-monospace, monospace;
    font-size: 13px;
    line-height: 1.2;
    white-space: nowrap;
    transform: translate(-50%, -100%);
    opacity: 1;
    transition: opacity .2s;
  }
  .ui-bubble.is-fading { opacity: 0; }

  /* Dialog (reserved for V2.2+; styled but not used in V2.1) */
  .ui-dialog {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 25vh;
    background: linear-gradient(180deg, rgba(20,14,8,0.92), rgba(20,14,8,0.98));
    border-top: 4px solid #6b4226;
    color: #f5e8d8;
    padding: 16px 24px;
    font-family: ui-monospace, monospace;
    font-size: 14px;
    line-height: 1.5;
    box-shadow: 0 -8px 24px rgba(0,0,0,0.4);
  }
  .ui-dialog[hidden] { display: none; }

  .ui-interact-prompt {
    position: absolute;
    background: rgba(0,0,0,.85);
    color: #fff;
    padding: 3px 8px;
    border-radius: 6px;
    font-family: ui-monospace, monospace;
    font-size: 12px;
    transform: translate(-50%, -100%);
    pointer-events: none;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ui-interact-prompt[hidden] { display: none; }
  .ui-interact-prompt kbd {
    background: #fff;
    color: #1a1a1a;
    border-radius: 3px;
    padding: 1px 5px;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .ui-emote-menu,
    .ui-bubble,
    .ui-mute-btn { transition: none !important; }
  }

  /* V3.0-A — auth overlays (wooden game style, matches V23.34 toolbar) */
  .auth-overlay {
    position: fixed; inset: 0;
    z-index: 300;
    display: flex; align-items: center; justify-content: center;
    padding: 16px;
  }
  .auth-overlay[hidden] { display: none; }
  .auth-backdrop {
    position: absolute; inset: 0;
    background: rgba(20, 14, 8, 0.65);
    backdrop-filter: blur(2px);
  }
  .auth-card {
    position: relative;
    width: 100%; max-width: 380px;
    background: rgba(244, 234, 213, 0.98);
    border: 2px solid rgba(60, 32, 16, 0.85);
    border-radius: 14px;
    padding: 28px 24px 22px;
    color: #2a1810;
    font-family: ui-monospace, monospace;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }
  .auth-card-small { max-width: 320px; padding: 22px 20px; }
  .auth-close {
    position: absolute; top: 8px; right: 8px;
    width: 28px; height: 28px;
    background: transparent; border: none; cursor: pointer;
    color: #5c4030; font-size: 16px; font-family: inherit;
    border-radius: 50%;
  }
  .auth-close:hover { background: rgba(60, 32, 16, 0.1); }
  .auth-title {
    font-size: 18px; font-weight: 700;
    margin: 0 0 6px;
    color: #2a1810;
  }
  .auth-blurb {
    font-size: 12px; line-height: 1.5;
    color: #5c4030;
    margin: 0 0 18px;
  }
  .auth-oauth-btn {
    display: flex; align-items: center; justify-content: center;
    gap: 10px;
    width: 100%;
    background: rgba(232, 216, 176, 0.95);
    border: 2px solid rgba(60, 32, 16, 0.85);
    color: #2a1810;
    padding: 11px 16px;
    border-radius: 10px;
    font-family: inherit; font-size: 14px; font-weight: 700;
    cursor: pointer;
    margin: 0 0 10px;
    box-shadow: 0 2px 0 rgba(60, 32, 16, 0.4);
    transition: transform .1s, background .15s;
  }
  .auth-oauth-btn:hover {
    background: rgba(248, 232, 192, 1);
    transform: translateY(-1px);
    box-shadow: 0 3px 0 rgba(60, 32, 16, 0.45);
  }
  .auth-oauth-btn:active { transform: translateY(1px); box-shadow: 0 1px 0 rgba(60, 32, 16, 0.4); }
  .auth-oauth-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px; border-radius: 50%;
    background: #2a1810; color: #f4ead5;
    font-size: 12px; font-weight: 700;
  }
  .auth-divider {
    display: flex; align-items: center;
    margin: 14px 0;
    color: #8a6a4a;
    font-size: 11px;
  }
  .auth-divider::before, .auth-divider::after {
    content: ''; flex: 1;
    height: 1px; background: rgba(60, 32, 16, 0.25);
  }
  .auth-divider span { padding: 0 12px; }
  .auth-magic-form {
    display: flex; flex-direction: column; gap: 8px;
  }
  .auth-label {
    font-size: 11px; font-weight: 700;
    color: #5c4030; text-transform: uppercase; letter-spacing: 0.5px;
    margin-bottom: 2px;
  }
  .auth-magic-form input[type=email] {
    width: 100%;
    padding: 10px 12px;
    border: 2px solid rgba(60, 32, 16, 0.6);
    border-radius: 8px;
    background: #fbf5e3;
    color: #2a1810;
    font-family: inherit; font-size: 14px;
    box-sizing: border-box;
  }
  .auth-magic-form input[type=email]:focus {
    outline: none;
    border-color: #a26b3a;
    background: #fff;
  }
  .auth-checkbox {
    display: flex; align-items: flex-start; gap: 8px;
    font-size: 12px; color: #5c4030;
    cursor: pointer;
    padding: 6px 0;
    line-height: 1.4;
  }
  .auth-checkbox input { margin-top: 2px; flex-shrink: 0; }
  .auth-magic-btn {
    background: #2a1810;
    color: #f4ead5;
    border: 2px solid #2a1810;
    padding: 12px 16px;
    border-radius: 10px;
    font-family: inherit; font-size: 14px; font-weight: 700;
    cursor: pointer;
    margin-top: 4px;
    box-shadow: 0 2px 0 rgba(0, 0, 0, 0.3);
    transition: transform .1s, background .15s;
  }
  .auth-magic-btn:hover { background: #3d2418; transform: translateY(-1px); }
  .auth-magic-btn:active { transform: translateY(1px); box-shadow: 0 1px 0 rgba(0,0,0,0.3); }
  .auth-magic-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .auth-status {
    font-size: 11px; line-height: 1.4;
    margin: 6px 0 0;
    min-height: 1.2em;
  }
  .auth-footer {
    font-size: 10px; color: #8a6a4a;
    margin: 18px 0 0;
    text-align: center;
  }

  /* Claim modal list */
  .claim-list {
    list-style: none; padding: 0; margin: 0 0 18px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 6px 12px;
    background: rgba(232, 216, 176, 0.6);
    border-radius: 10px;
    padding: 12px 14px;
  }
  .claim-list li {
    display: flex; align-items: center; gap: 6px;
    font-size: 12px;
    color: #5c4030;
  }
  .claim-list .claim-icon { font-size: 14px; }
  .claim-list strong {
    margin-left: auto;
    color: #2a1810;
    font-weight: 700;
  }

  .auth-actions {
    display: flex; flex-direction: column; gap: 8px;
  }
  .auth-primary-btn {
    background: #2a1810; color: #f4ead5;
    border: 2px solid #2a1810;
    padding: 11px 16px; border-radius: 10px;
    font-family: inherit; font-size: 14px; font-weight: 700;
    cursor: pointer;
    box-shadow: 0 2px 0 rgba(0, 0, 0, 0.3);
    transition: transform .1s;
  }
  .auth-primary-btn:hover { background: #3d2418; transform: translateY(-1px); }
  .auth-primary-btn:active { transform: translateY(1px); box-shadow: 0 1px 0 rgba(0,0,0,0.3); }
  .auth-secondary-btn {
    background: rgba(232, 216, 176, 0.95);
    border: 2px solid rgba(60, 32, 16, 0.85);
    color: #2a1810;
    padding: 11px 16px; border-radius: 10px;
    font-family: inherit; font-size: 14px; font-weight: 700;
    cursor: pointer;
    box-shadow: 0 2px 0 rgba(60, 32, 16, 0.4);
    transition: transform .1s, background .15s;
  }
  .auth-secondary-btn:hover { background: rgba(248, 232, 192, 1); transform: translateY(-1px); }
  .auth-secondary-btn:active { transform: translateY(1px); box-shadow: 0 1px 0 rgba(60, 32, 16, 0.4); }

  @media (max-width: 480px) {
    .auth-card { padding: 22px 18px 18px; }
    .claim-list { grid-template-columns: 1fr; }
  }

  /* V3.0-A — account banner inside identity panel */
  .nook-account-banner {
    background: rgba(232, 216, 176, 0.45);
    border: 1px solid rgba(60, 32, 16, 0.3);
    border-radius: 8px;
    padding: 10px 12px;
    margin-bottom: 14px;
  }
  .nook-account-banner[hidden] { display: none; }
  .nook-account-banner > div[hidden] { display: none; }
  .nook-banner-line {
    font-size: 12px; line-height: 1.4;
    margin: 0 0 8px;
    color: #5c4030;
  }
  .nook-banner-line strong { color: #2a1810; }
  .nook-banner-cta {
    background: #2a1810; color: #f4ead5;
    border: 2px solid #2a1810;
    padding: 8px 16px; border-radius: 8px;
    font-family: inherit; font-size: 12px; font-weight: 700;
    cursor: pointer;
    box-shadow: 0 2px 0 rgba(0, 0, 0, 0.3);
  }
  .nook-banner-cta:hover { background: #3d2418; }
  .nook-banner-actions {
    display: flex; gap: 6px; flex-wrap: wrap;
  }
  .nook-banner-cta-mini {
    background: transparent;
    border: 1px solid rgba(60, 32, 16, 0.55);
    color: #5c4030;
    padding: 4px 10px; border-radius: 6px;
    font-family: inherit; font-size: 10px; font-weight: 700;
    cursor: pointer;
  }
  .nook-banner-cta-mini:hover { background: rgba(60, 32, 16, 0.1); color: #2a1810; }
  /* V3.0-A.1 — danger variant for Delete account */
  .nook-banner-cta-danger {
    border-color: rgba(170, 48, 48, 0.6) !important;
    color: #8a3030 !important;
  }
  .nook-banner-cta-danger:hover {
    background: rgba(170, 48, 48, 0.1) !important;
    color: #6a2020 !important;
  }
  /* Inline blog subscription checkbox */
  .nook-banner-checkbox {
    display: flex; align-items: center; gap: 6px;
    font-size: 11px; color: #5c4030;
    cursor: pointer;
    margin: 6px 0 8px;
  }
  .nook-banner-checkbox input { margin: 0; flex-shrink: 0; cursor: pointer; }
  .nook-banner-checkbox:hover { color: #2a1810; }
  .nook-banner-tag {
    background: rgba(60, 32, 16, 0.15);
    color: #5c4030;
    font-size: 9px; padding: 1px 6px; border-radius: 5px;
    font-style: italic;
  }
  /* Delete-modal danger button — different palette from regular primary */
  .auth-danger-btn {
    background: #8a3030 !important;
    border-color: #8a3030 !important;
  }
  .auth-danger-btn:hover { background: #6a2020 !important; }
  .auth-danger-btn:disabled {
    background: rgba(138, 48, 48, 0.4) !important;
    border-color: rgba(138, 48, 48, 0.4) !important;
    cursor: not-allowed;
  }
</style>

<script>
  import { bootGame } from '../lounge/game'
  import { isMuted, toggleMute, playSfx } from '../lounge/audio'
  import { initUI } from '../lounge/ui'
  import { onAccountChange, logout, setBlogSubscription, deleteAccount, getCurrentAccount } from '../lounge/auth'
  import { showLogin } from '../lounge/auth_ui'

  function start() {
    const mount = document.getElementById('lounge-mount')
    if (!mount) return
    bootGame(mount)
    initUI()

    // V3.0-A — wire account banner inside Identity panel
    const banner    = document.getElementById('nook-account-banner')
    const anonBox   = document.getElementById('nook-account-anon')
    const signedBox = document.getElementById('nook-account-signed')
    const emailEl   = document.getElementById('nook-account-email')
    const signinBtn = document.getElementById('nook-account-signin-btn')
    const signoutBtn = document.getElementById('nook-account-signout-btn')
    const blogChk   = document.getElementById('nook-account-blog-checkbox') as HTMLInputElement | null
    const blogStatus = document.getElementById('nook-account-blog-status')
    const deleteBtn = document.getElementById('nook-account-delete-btn')

    signinBtn?.addEventListener('click', () => { showLogin(); playSfx('click') })
    signoutBtn?.addEventListener('click', async () => {
      playSfx('click')
      await logout()
      setTimeout(() => location.reload(), 200)
    })

    // V3.0-A.1 — inline checkbox for blog subscription. Auto-saves on toggle.
    blogChk?.addEventListener('change', async () => {
      if (!blogChk) return
      const wantSub = blogChk.checked
      blogChk.disabled = true
      if (blogStatus) { blogStatus.hidden = false; blogStatus.textContent = 'saving...' }
      const result = await setBlogSubscription(wantSub)
      blogChk.disabled = false
      if (blogStatus) {
        blogStatus.textContent = result.ok ? (wantSub ? 'subscribed ✓' : 'unsubscribed') : `error: ${result.error}`
        setTimeout(() => { if (blogStatus) blogStatus.hidden = true }, 2000)
      }
      if (!result.ok) blogChk.checked = !wantSub // revert
    })

    // V3.0-A.1 — Delete account modal (two-step confirmation)
    const deleteModal      = document.getElementById('nook-delete-modal')
    const deleteCheck      = document.getElementById('nook-delete-confirm-check') as HTMLInputElement | null
    const deleteConfirmBtn = document.getElementById('nook-delete-confirm-btn') as HTMLButtonElement | null
    const deleteCancelBtn  = document.getElementById('nook-delete-cancel-btn')

    deleteBtn?.addEventListener('click', () => {
      if (deleteModal) deleteModal.hidden = false
      if (deleteCheck) deleteCheck.checked = false
      if (deleteConfirmBtn) deleteConfirmBtn.disabled = true
      playSfx('menu_open')
    })
    deleteCheck?.addEventListener('change', () => {
      if (deleteConfirmBtn) deleteConfirmBtn.disabled = !deleteCheck.checked
    })
    deleteCancelBtn?.addEventListener('click', () => {
      if (deleteModal) deleteModal.hidden = true
      playSfx('menu_close')
    })
    deleteModal?.querySelector('.auth-backdrop')?.addEventListener('click', () => {
      if (deleteModal) deleteModal.hidden = true
    })
    deleteConfirmBtn?.addEventListener('click', async () => {
      if (!deleteConfirmBtn) return
      deleteConfirmBtn.disabled = true
      deleteConfirmBtn.textContent = 'Deleting...'
      const result = await deleteAccount()
      if (result.ok) {
        if (deleteModal) deleteModal.hidden = true
        alert('Account deleted. Reloading...')
        setTimeout(() => location.reload(), 200)
      } else {
        deleteConfirmBtn.disabled = false
        deleteConfirmBtn.textContent = 'Delete account permanently'
        alert(`Delete failed: ${result.error}`)
      }
    })

    onAccountChange((account) => {
      if (!banner || !anonBox || !signedBox) return
      banner.hidden = false
      if (account) {
        anonBox.hidden = true
        signedBox.hidden = false
        if (emailEl) emailEl.textContent = account.email
        // Reflect current blog subscription state in checkbox
        if (blogChk) blogChk.checked = !!account.blog_subscriber_id
      } else {
        anonBox.hidden = false
        signedBox.hidden = true
      }
    })

    const muteBtn = document.getElementById('lounge-mute') as HTMLButtonElement | null
    if (muteBtn) {
      const refresh = () => { muteBtn.textContent = isMuted() ? '🔇' : '🔊' }
      refresh()
      muteBtn.addEventListener('click', () => {
        toggleMute()
        refresh()
        playSfx('click')
      })
    }

    // V23.34 — Group-button wiring. Each group toggles a popover whose
    // sub-items forward clicks to legacy buttons (kept in DOM, hidden).
    // Single-item groups (Travel) skip the popover and forward directly.
    const popovers: Record<string, HTMLElement | null> = {
      travel:   null,
      backpack: document.getElementById('lounge-grp-pop-backpack'),
      social:   document.getElementById('lounge-grp-pop-social'),
      settings: document.getElementById('lounge-grp-pop-settings'),
    }
    const groupBtns: Record<string, HTMLButtonElement | null> = {
      travel:   document.getElementById('lounge-grp-travel')   as HTMLButtonElement | null,
      backpack: document.getElementById('lounge-grp-backpack') as HTMLButtonElement | null,
      social:   document.getElementById('lounge-grp-social')   as HTMLButtonElement | null,
      settings: document.getElementById('lounge-grp-settings') as HTMLButtonElement | null,
    }
    const closeAllPopovers = (except?: string) => {
      for (const [k, p] of Object.entries(popovers)) {
        if (k === except || !p) continue
        p.hidden = true
      }
    }
    // Travel → direct open transit (no popover)
    groupBtns.travel?.addEventListener('click', () => {
      closeAllPopovers()
      const t = document.getElementById('lounge-transit-btn') as HTMLButtonElement | null
      t?.click()
      playSfx('click')
    })
    // Other groups → toggle popover
    for (const key of ['backpack', 'social', 'settings'] as const) {
      groupBtns[key]?.addEventListener('click', (e) => {
        e.stopPropagation()
        const pop = popovers[key]
        if (!pop) return
        const wasOpen = !pop.hidden
        closeAllPopovers(key)
        pop.hidden = wasOpen
        playSfx('click')
      })
    }
    // Sub-item click → forward to legacy button, close popover
    document.querySelectorAll<HTMLButtonElement>('.grp-item').forEach((item) => {
      item.addEventListener('click', (e) => {
        e.stopPropagation()
        const targetId = item.getAttribute('data-forward')
        if (!targetId) return
        const target = document.getElementById(targetId) as HTMLButtonElement | null
        target?.click()
        closeAllPopovers()
      })
    })
    // Click outside any popover/group-btn → close all
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement
      if (t.closest('.ui-grp-popover') || t.closest('.ui-grp-btn')) return
      closeAllPopovers()
    })

    // V23.34 — Badge aggregation. Mirror sub-item badges (DM + Board) onto
    // the Social group button so the user sees an unread indicator without
    // having to open the popover. MutationObserver watches the legacy
    // badge nodes; updates the aggregate when they change.
    const socialBadge = document.getElementById('lounge-grp-social-badge') as HTMLElement | null
    const refreshSocialBadge = () => {
      if (!socialBadge) return
      let total = 0
      for (const id of ['lounge-messages-badge', 'lounge-board-badge']) {
        const b = document.getElementById(id)
        if (b && !b.hidden) total += parseInt(b.textContent || '0', 10) || 0
      }
      // Mirror onto popover sub-item badges too
      document.querySelectorAll<HTMLElement>('.grp-item-badge[data-from]').forEach(bb => {
        const src = document.getElementById(bb.getAttribute('data-from')!)
        if (src && !src.hidden) {
          bb.textContent = src.textContent
          bb.hidden = false
        } else {
          bb.hidden = true
        }
      })
      if (total > 0) {
        socialBadge.textContent = String(total)
        socialBadge.hidden = false
      } else {
        socialBadge.hidden = true
      }
    }
    const mo = new MutationObserver(refreshSocialBadge)
    for (const id of ['lounge-messages-badge', 'lounge-board-badge']) {
      const b = document.getElementById(id)
      if (b) mo.observe(b, { attributes: true, attributeFilter: ['hidden'], childList: true, characterData: true, subtree: true })
    }
    refreshSocialBadge()
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start)
  } else {
    start()
  }
</script>
