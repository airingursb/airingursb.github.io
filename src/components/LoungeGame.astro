    border-top: 4px solid #6b4226;
    color: #f5e8d8;
    padding: 16px 24px;
    font-family: ui-monospace, monospace;
    font-size: 14px;
    line-height: 1.5;
    box-shadow: 0 -8px 24px rgba(0,0,0,0.4);
  }
  .ui-dialog[hidden] { display: none; }

  .ui-interact-prompt {
    position: absolute;
    background: rgba(0,0,0,.85);
    color: #fff;
    padding: 3px 8px;
    border-radius: 6px;
    font-family: ui-monospace, monospace;
    font-size: 12px;
    transform: translate(-50%, -100%);
    pointer-events: none;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ui-interact-prompt[hidden] { display: none; }
  .ui-interact-prompt kbd {
    background: #fff;
    color: #1a1a1a;
    border-radius: 3px;
    padding: 1px 5px;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .ui-emote-menu,
    .ui-bubble,
    .ui-mute-btn { transition: none !important; }
  }
</style>

<script>
  import { bootGame } from '../lounge/game'
  import { isMuted, toggleMute, playSfx } from '../lounge/audio'
  import { initUI } from '../lounge/ui'

  function start() {
    const mount = document.getElementById('lounge-mount')
    if (!mount) return
    bootGame(mount)
    initUI()

    const muteBtn = document.getElementById('lounge-mute') as HTMLButtonElement | null
    if (muteBtn) {
      const refresh = () => { muteBtn.textContent = isMuted() ? '🔇' : '🔊' }
      refresh()
      muteBtn.addEventListener('click', () => {
        toggleMute()
        refresh()
        playSfx('click')
      })
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start)
  } else {
    start()
  }
</script>
