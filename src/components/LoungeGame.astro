  /* V8.5 — Day-end sleep overlay */
  .ui-sleep-overlay {
    position: fixed; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(8,12,28,.92);
    z-index: 250;
    backdrop-filter: blur(6px);
