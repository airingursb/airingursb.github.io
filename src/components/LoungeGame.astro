<style is:global>
  body:has(#lounge-root) {
    overflow: hidden;
    background: #0d1117;
    /* V11.0 — prevent iOS double-tap zoom + pull-to-refresh, and forbid
       overscroll so dragging in the canvas doesn't bounce the page. */
    touch-action: manipulation;
    overscroll-behavior: none;
  }
  #lounge-root {
    position: fixed;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #lounge-mount {
    width: 100vw;
    height: 100vh;
  }
  #lounge-mount canvas {
    image-rendering: pixelated;
    cursor: crosshair;
  }

  /* V11.2 — Onboarding overlay. Backdrop + spotlight cutout (via large
     box-shadow) + tooltip card. V23.18 BUG FIX — container was
     pointer-events: auto despite the comment saying otherwise; this
     swallowed clicks meant for HIGHER-z elements like the species
     picker (z 250). The "spotlight stays clickable for live demos"
     intent is preserved because (a) the spotlight child is itself
     pointer-events: none and (b) the holes in the box-shadow cutout
     pass through to whatever is beneath. The tooltip child gets
     pointer-events: auto so its Skip/Next buttons still work. */
  .ui-onboarding {
    position: fixed; inset: 0;
    z-index: 200;
    pointer-events: none;
  }
  .ui-onboarding[hidden] { display: none; }
  .ob-spotlight {
    position: absolute;
    border-radius: 12px;
    box-shadow: 0 0 0 9999px rgba(0,0,0,0.75);
    transition: all .25s ease;
    pointer-events: none;
  }
  .ob-tooltip {
    position: fixed;
    width: 280px;
    background: rgba(20,20,30,.96);
