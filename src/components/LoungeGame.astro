  .sleep-actions button {
    background: rgba(120,140,200,.2);
    border: 1px solid rgba(120,140,200,.4);
    color: #e6edf3;
    padding: 8px 18px; border-radius: 6px;
    font-family: ui-monospace, monospace; font-size: 12px;
