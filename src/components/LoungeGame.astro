---
// Astro client island — mounts Phaser game on /nook.
// (Internal code still uses 'lounge' identifier — folder, IDs, table names.)
---

<div id="lounge-root">
  <div id="lounge-mount"></div>
  <!-- V11.2 — Onboarding overlay (first-visit tour). Hidden until startTour. -->
  <div id="lounge-onboarding" class="ui-onboarding" hidden>
    <div id="lounge-onboarding-spotlight" class="ob-spotlight"></div>
    <div id="lounge-onboarding-tooltip" class="ob-tooltip">
      <div class="ob-head">
        <span id="lounge-onboarding-counter" class="ob-counter">1 / 5</span>
        <button type="button" id="lounge-onboarding-skip" class="ob-skip">Skip</button>
      </div>
      <h3 id="lounge-onboarding-title">Title</h3>
      <p  id="lounge-onboarding-body">Body</p>
      <div class="ob-actions">
        <button type="button" id="lounge-onboarding-next" class="ob-next">Next →</button>
      </div>
    </div>
  </div>
  <!-- V11.1 — Touch input overlay. Hidden by default; CSS reveals when
       body.is-touch.is-narrow (mobile only). Buttons set touchInput flags
       that RoomScene's keyboard reader OR-s into the movement state. -->
  <div id="lounge-touch-overlay" hidden>
    <div id="lounge-dpad" class="touch-dpad">
      <button type="button" id="lounge-dpad-up"    class="td-btn td-up"    aria-label="Up">▲</button>
      <button type="button" id="lounge-dpad-left"  class="td-btn td-left"  aria-label="Left">◀</button>
      <button type="button" id="lounge-dpad-right" class="td-btn td-right" aria-label="Right">▶</button>
      <button type="button" id="lounge-dpad-down"  class="td-btn td-down"  aria-label="Down">▼</button>
    </div>
    <button type="button" id="lounge-action-btn" class="touch-action-btn" aria-label="Interact">A</button>
  </div>
  <div id="lounge-ui">
    <!-- V23.34 — Consolidated toolbar: 4 pixel-art group buttons replace 12
         emoji buttons. The 12 originals stay in the DOM (kept hidden) so
         existing handlers in pet_ui/board_ui/transit_ui/etc. continue to
         bind correctly; group popovers below forward clicks to them. -->
    <button id="lounge-grp-travel"   class="ui-grp-btn ui-grp-travel"   aria-label="Travel"></button>
    <button id="lounge-grp-backpack" class="ui-grp-btn ui-grp-backpack" aria-label="Backpack"></button>
    <button id="lounge-grp-social"   class="ui-grp-btn ui-grp-social"   aria-label="Social"><span id="lounge-grp-social-badge" class="grp-badge" hidden>0</span></button>
    <button id="lounge-grp-settings" class="ui-grp-btn ui-grp-settings" aria-label="Settings"></button>
    <div id="lounge-grp-pop-backpack" class="ui-grp-popover" hidden>
      <button data-forward="lounge-inventory-btn"   class="grp-item" aria-label="Inventory">📦<span class="grp-item-label">Items</span></button>
      <button data-forward="lounge-pet-btn"         class="grp-item" aria-label="Pet">🐾<span class="grp-item-label">Pet</span></button>
      <button data-forward="lounge-photos-btn"      class="grp-item" aria-label="Photos">🖼️<span class="grp-item-label">Album</span></button>
      <button data-forward="lounge-achievements-btn" class="grp-item" aria-label="Achievements">🏆<span class="grp-item-label">Records</span></button>
    </div>
    <div id="lounge-grp-pop-social" class="ui-grp-popover" hidden>
      <button data-forward="lounge-messages-btn"  class="grp-item" aria-label="Messages">✉<span class="grp-item-label">DM</span><span class="grp-item-badge" data-from="lounge-messages-badge" hidden>0</span></button>
      <button data-forward="lounge-board-btn"     class="grp-item" aria-label="Board">📌<span class="grp-item-label">Board</span><span class="grp-item-badge" data-from="lounge-board-badge" hidden>0</span></button>
      <button data-forward="lounge-wishboard-btn" class="grp-item" aria-label="Wishboard">🌟<span class="grp-item-label">Wish</span></button>
      <button data-forward="lounge-minigame-btn"  class="grp-item" aria-label="Mini-games">🎮<span class="grp-item-label">Games</span></button>
    </div>
    <div id="lounge-grp-pop-settings" class="ui-grp-popover" hidden>
      <button data-forward="lounge-mute"       class="grp-item" aria-label="Mute">🔊<span class="grp-item-label">Sound</span></button>
      <button data-forward="lounge-volume-btn" class="grp-item" aria-label="Volume">🎚<span class="grp-item-label">Volume</span></button>
      <button data-forward="lounge-info-btn"   class="grp-item" aria-label="Identity">ⓘ<span class="grp-item-label">Profile</span></button>
    </div>
    <!-- Originals (hidden but functional — handlers in other modules still bind to these ids) -->
    <button id="lounge-mute" class="ui-mute-btn ui-legacy" aria-label="Toggle sound">🔊</button>
    <button id="lounge-volume-btn" class="ui-volume-btn ui-legacy" aria-label="Volume settings">⚙</button>
    <button id="lounge-info-btn" class="ui-info-btn ui-legacy" aria-label="Identity">ⓘ</button>
    <button id="lounge-pet-btn" class="ui-pet-btn ui-legacy" aria-label="Pet">🐾</button>
    <button id="lounge-achievements-btn" class="ui-ach-btn ui-legacy" aria-label="Achievements">🏆</button>
    <button id="lounge-photos-btn" class="ui-photos-btn ui-legacy" aria-label="Photo Album">🖼️</button>
    <button id="lounge-minigame-btn" class="ui-mg-btn ui-legacy" aria-label="Mini-games">🎮</button>
    <button id="lounge-board-btn" class="ui-board-btn ui-legacy" aria-label="Community board">📌<span id="lounge-board-badge" class="badge" hidden>0</span></button>
    <button id="lounge-transit-btn" class="ui-transit-btn ui-legacy" aria-label="Transit hub">🚇</button>
    <button id="lounge-inventory-btn" class="ui-inventory-btn ui-legacy" aria-label="Inventory">📦</button>
    <button id="lounge-messages-btn" class="ui-messages-btn ui-legacy" aria-label="Messages">✉<span id="lounge-messages-badge" class="badge" hidden>0</span></button>
    <button id="lounge-wishboard-btn" class="ui-wishboard-btn ui-legacy" aria-label="Wishboard">🌟</button>
    <div id="lounge-wishboard-panel" class="ui-wishboard-panel" hidden>
      <h3>🌟 Wishboard</h3>
      <p class="subtitle">Suggest a sprite, room, dialog or anything else for the nook. Vote on others' ideas.</p>
      <form id="lounge-wish-form">
        <select id="lounge-wish-category">
          <option value="sprite">Sprite</option>
          <option value="room">Room</option>
          <option value="dialog">Dialog</option>
          <option value="other">Other</option>
        </select>
        <textarea id="lounge-wish-input" maxlength="140" placeholder="My wish for the nook..." rows="2"></textarea>
        <div class="form-foot">
          <span id="lounge-wish-count">0</span> / 140
          <button type="submit">Submit</button>
        </div>
      </form>
      <ul id="lounge-wish-list" class="wishes"></ul>
      <p id="lounge-wish-empty" class="empty" hidden>No wishes yet — be the first.</p>
    </div>
    <div id="lounge-messages-panel" class="ui-messages-panel" hidden>
      <h3>Messages</h3>
      <div id="lounge-messages-empty" class="empty">No messages yet. Wave to a friend, then send one.</div>
      <ul id="lounge-messages-list" class="threads"></ul>
      <div id="lounge-thread-view" class="thread-view" hidden>
        <button type="button" class="back" id="lounge-thread-back">← Back</button>
        <h4 id="lounge-thread-name">Friend</h4>
        <ul id="lounge-thread-messages"></ul>
        <form id="lounge-thread-form">
          <input type="text" id="lounge-thread-input" maxlength="140" placeholder="Say something…" autocomplete="off">
          <button type="submit">Send</button>
        </form>
      </div>
    </div>
    <div id="lounge-peer-menu" class="ui-peer-menu" hidden>
      <button type="button" data-action="profile">👁 View profile</button>
      <button type="button" data-action="wave">👋 Wave</button>
      <button type="button" data-action="gift">🎁 Gift pebble</button>
      <button type="button" data-action="dm">✉ Send DM</button>
      <button type="button" data-action="visit_home">🏠 Visit home</button>
    </div>
    <!-- V17.2 — profile card modal -->
    <div id="lounge-profile-card" class="ui-profile-card" hidden>
      <div class="pc-card">
        <button type="button" id="lounge-profile-card-close" class="pc-close" aria-label="Close">✕</button>
        <div class="pc-header">
          <span id="lounge-profile-card-mood" class="pc-mood"></span>
          <h3 id="lounge-profile-card-name">—</h3>
        </div>
        <p id="lounge-profile-card-status" class="pc-status"></p>
        <p id="lounge-profile-card-bio" class="pc-bio"></p>
        <div id="lounge-profile-card-empty" class="pc-empty" hidden>
          This bear hasn't written a profile yet.
        </div>
        <div id="lounge-profile-card-pinned" class="pc-pinned" hidden>
          <h4>Pinned</h4>
          <ul id="lounge-profile-card-pinned-list"></ul>
        </div>
        <!-- V20.2 — pinned photos -->
        <div id="lounge-profile-card-photos" class="pc-photos" hidden>
          <h4>Photos</h4>
          <div id="lounge-profile-card-photos-grid" class="pc-photos-grid"></div>
        </div>
      </div>
    </div>
    <!-- V21.2 — random world event banner (top-right corner)
         V22.2 — emoji replaced with pixel icon (set via data-icon at runtime) -->
    <div id="lounge-random-event-banner" class="ui-random-event" hidden>
      <span id="lounge-random-event-icon" class="re-icon"></span>
      <div class="re-text">
        <strong id="lounge-random-event-title"></strong>
        <span id="lounge-random-event-meta"></span>
      </div>
    </div>
    <!-- V19.3 — NPC story progress panel -->
    <div id="lounge-stories-panel" class="ui-stories" hidden>
      <div class="st-card">
        <button type="button" id="lounge-stories-close" class="st-close" aria-label="Close">✕</button>
        <h3>📖 NPC Stories</h3>
        <p class="st-blurb">Earn an NPC's trust (heart level) and they'll tell you their stories.</p>
        <div id="lounge-stories-list"></div>
      </div>
    </div>
    <!-- V18.2 — wardrobe modal -->
    <div id="lounge-wardrobe-panel" class="ui-wardrobe" hidden>
      <div class="wr-card">
        <button type="button" id="lounge-wardrobe-close" class="wr-close" aria-label="Close">✕</button>
        <h3>👒 Wardrobe <span id="lounge-wardrobe-shells" class="wr-shells"></span></h3>
        <p class="wr-blurb">Mix one hat, face, neck, and back accessory. Others see what you wear.</p>
        <div id="lounge-wardrobe-sections"></div>
      </div>
    </div>
    <div id="lounge-gift-modal" class="ui-gift-modal" hidden>
      <div class="ui-gift-modal-backdrop"></div>
      <div class="ui-gift-modal-card">
        <h3>Pick a pebble to gift</h3>
        <p class="gift-recipient">to <span id="lounge-gift-to-name">Friend</span></p>
        <ul id="lounge-gift-list"></ul>
        <p id="lounge-gift-empty" class="empty" hidden>You haven't collected any pebbles yet.</p>
        <div class="actions">
          <button type="button" id="lounge-gift-cancel">Cancel</button>
        </div>
      </div>
    </div>
    <div id="lounge-toast" class="ui-toast" hidden></div>
    <div id="lounge-minimap" class="ui-minimap" hidden>
      <div class="mm-title">📍 <span id="lounge-mm-room-name">Lobby</span></div>
      <svg id="lounge-mm-svg" viewBox="0 0 140 100" xmlns="http://www.w3.org/2000/svg"></svg>
      <div class="mm-legend">
        <span class="dot here"></span> here
        <span class="dot npc"></span> NPC
      </div>
    </div>
    <div id="lounge-door-label" class="ui-door-label" hidden></div>
    <div id="lounge-inventory-panel" class="ui-inventory-panel" hidden>
      <div class="inv-header">
        <h3>Inventory</h3>
        <div class="inv-view-toggle" role="tablist">
          <button id="lounge-inv-view-grid" type="button" data-view="grid" class="inv-tab active">Grid</button>
          <button id="lounge-inv-view-list" type="button" data-view="list" class="inv-tab">List</button>
        </div>
      </div>
      <p class="count">Pebbles: <span id="lounge-inv-count">0</span> / <span id="lounge-inv-total">0</span></p>
      <div id="lounge-inv-grid" class="inv-grid"></div>
      <div id="lounge-inv-trash" class="inv-trash" title="Drag a shop decoration here to discard it">🗑</div>
      <ul id="lounge-inv-list" hidden></ul>
    </div>
    <div id="lounge-info-panel" class="ui-info-panel" hidden>
      <h3>Identity</h3>
      <!-- V3.0-A — account banner (anon vs signed-in views, JS toggles) -->
      <div id="nook-account-banner" class="nook-account-banner" hidden>
        <div id="nook-account-anon" class="nook-banner-anon" hidden>
          <p class="nook-banner-line"><strong>🍵 Sign in</strong> to sync across devices, message friends, and meet the AI companion.</p>
          <button type="button" id="nook-account-signin-btn" class="nook-banner-cta">Sign in</button>
        </div>
        <div id="nook-account-signed" class="nook-banner-signed" hidden>
          <p class="nook-banner-line">Signed in as <strong id="nook-account-email">—</strong></p>
          <label class="nook-banner-checkbox">
            <input type="checkbox" id="nook-account-blog-checkbox">
            <span>Subscribe to Airing's blog (weekly)</span>
            <span id="nook-account-blog-status" class="nook-banner-tag" hidden>saving...</span>
          </label>
          <div class="nook-banner-actions">
            <button type="button" id="nook-account-signout-btn" class="nook-banner-cta-mini">Sign out</button>
            <button type="button" id="nook-account-delete-btn" class="nook-banner-cta-mini nook-banner-cta-danger">Delete account</button>
          </div>
        </div>
      </div>
      <dl>
        <dt>Name</dt><dd id="lounge-info-name">—</dd>
        <dt>Region</dt><dd id="lounge-info-region">—</dd>
        <dt>ID</dt><dd id="lounge-info-id">—</dd>
      </dl>
      <button type="button" id="lounge-info-rename">Change name</button>
      <button type="button" id="lounge-info-species" data-species="bear">Switch to 🐱 Cat</button>
      <!-- V17.0 — bio + status (drives the V17.2 profile card others see) -->
      <button type="button" id="lounge-info-profile" data-icon="edit_profile">Edit bio &amp; status</button>
      <!-- V18.2 — wardrobe -->
      <button type="button" id="lounge-info-wardrobe" data-icon="wardrobe">Wardrobe</button>
      <!-- V19.3 — npc story progress -->
      <button type="button" id="lounge-info-stories" data-icon="stories">NPC Stories</button>
      <button type="button" id="lounge-info-quests" data-icon="quests">Quests</button>
      <button type="button" id="lounge-info-whosaround" data-icon="whosaround">Who's around</button>
      <button type="button" id="lounge-info-memories" data-icon="memories">Memories</button>
      <button type="button" id="lounge-info-shop" data-icon="shop">Mio's Shop</button>
      <button type="button" id="lounge-info-mailbox" data-icon="mailbox">Mailbox <span id="lounge-mailbox-badge" class="mb-badge" hidden>0</span></button>
      <button type="button" id="lounge-info-skills" data-icon="skills">Skills</button>
      <button type="button" id="lounge-info-craft" data-icon="recipe">Recipe Book</button>
      <button type="button" id="lounge-info-build" data-icon="build">Build</button>
      <button type="button" id="lounge-info-grovecare" data-icon="grove">Care for Grove</button>
      <button type="button" id="lounge-info-bundles" data-icon="hall">Community Hall</button>
      <button type="button" id="lounge-info-progress" data-icon="story">Your Story</button>
      <button type="button" id="lounge-info-gametime" data-icon="clock" data-on="0">Game time: off</button>
      <button type="button" id="lounge-info-friend-notifs" data-icon="bell" data-on="1">Friend notifications: on</button>
      <button type="button" id="lounge-info-visits" data-icon="door">Home visit log</button>
      <button type="button" id="lounge-info-party" data-icon="party">Party room</button>
      <h4 class="friends-heading">Friends</h4>
      <ul id="lounge-info-friends" class="friends-list"></ul>
      <p id="lounge-info-friends-empty" class="friends-empty">No friendships yet — spend time with peers.</p>
    </div>
    <div id="lounge-name-modal" class="ui-name-modal" hidden>
      <div class="ui-name-modal-backdrop"></div>
      <div class="ui-name-modal-card">
        <h3 id="lounge-name-modal-title">How should we call you?</h3>
        <input type="text" id="lounge-name-input" maxlength="16" autocomplete="off" placeholder="Your name">
        <p class="hint">1–16 chars</p>
        <p id="lounge-name-error" class="error" hidden></p>
        <div class="actions">
          <button type="button" id="lounge-name-skip">Skip</button>
          <button type="button" id="lounge-name-save">Save</button>
        </div>
      </div>
    </div>
    <div id="lounge-booth-picker" class="ui-booth-picker" hidden>
      <h3>🎧 Listening Booth</h3>
      <ul id="lounge-booth-list"></ul>
      <div class="actions">
        <button type="button" id="lounge-booth-stop">Stop</button>
        <button type="button" id="lounge-booth-close">Close</button>
      </div>
    </div>
    <div id="lounge-now-playing" class="ui-now-playing" hidden>
      🎧 Now: <span id="lounge-now-playing-name"></span>
    </div>
    <div id="lounge-coop-banner" class="ui-coop-banner" hidden>
      <span id="lounge-coop-emoji" class="coop-emoji">🍲</span>
      <span id="lounge-coop-text">Cooking circle</span>
      <button type="button" id="lounge-coop-start" class="coop-start">Start</button>
      <span id="lounge-coop-timer" class="coop-timer" hidden>30s</span>
    </div>
    <div id="lounge-festival-banner" class="ui-festival-banner" hidden>
      <span id="lounge-festival-banner-emoji" class="festival-emoji">🌸</span>
      <span id="lounge-festival-banner-text">Festival today!</span>
      <button type="button" id="lounge-festival-action" class="festival-action" hidden>Join 🎟</button>
    </div>
    <!-- V14.1 — Morning Coffee group ritual banner -->
    <div id="lounge-coffee-banner" class="ui-coffee-banner" hidden>
      <span class="banner-icon" data-icon="coffee"></span>
      <span id="lounge-coffee-banner-text">Morning Coffee</span>
    </div>
    <!-- V14.2 — Cook-along banner (Kitchen) -->
    <div id="lounge-cook-banner" class="ui-cook-banner" hidden>
      <span class="banner-icon" data-icon="cook"></span>
      <span id="lounge-cook-banner-text">Cook-along</span>
      <button type="button" id="lounge-cook-join" class="cook-join">Start / Join</button>
    </div>
    <!-- V14.3 — Jam combo banner (DJ Floor) -->
    <div id="lounge-jam-banner" class="ui-jam-banner" hidden>
      <span class="banner-icon" data-icon="jam"></span>
      <span id="lounge-jam-banner-text">Jam Combo</span>
      <button type="button" id="lounge-dance-start" class="jam-dance-btn"><span data-icon="dance"></span> Dance</button>
    </div>
    <!-- V14.5 — Dance overlay (DJ Floor) -->
    <div id="lounge-dance-overlay" class="ui-dance-overlay" hidden>
      <div class="da-card">
        <div class="da-meta">💃 Group Dance · <span id="lounge-dance-countdown">30s</span> · <strong id="lounge-dance-stamina">0 / 30</strong></div>
        <div id="lounge-dance-cue" class="da-cue">–</div>
        <div class="da-hint">Tap ← → ↑ ↓ (or A D W S) when arrow appears</div>
      </div>
    </div>
    <!-- V14.4 — NPC-hosted event banner (global). V22.2 — pixel calendar icon. -->
    <div id="lounge-event-banner" class="ui-event-banner" hidden>
      <span class="banner-icon" data-icon="event"></span>
      <span id="lounge-event-banner-text">Event</span>
      <button type="button" id="lounge-event-banner-cta" class="event-cta" hidden>Watch</button>
    </div>
    <div id="lounge-clock" class="ui-clock" hidden>
      <span class="clk-icon">🕐</span>
      <span id="lounge-clock-time">06:00</span>
      <span class="clk-mode" id="lounge-clock-mode">game</span>
    </div>
    <div id="lounge-energy" class="ui-energy">
      <span class="en-icon">⚡</span>
      <div class="en-track"><div id="lounge-energy-fill" class="en-fill"></div></div>
      <span id="lounge-energy-num" class="en-num">100</span>
    </div>
    <button type="button" id="lounge-camera-btn" class="ui-camera-btn" title="Equip camera (click anywhere to capture)">📷</button>
    <div id="lounge-shells" class="ui-shells" title="Shells">
      <span class="sh-icon">🐚</span>
      <span id="lounge-shells-num">0</span>
    </div>
    <div id="lounge-bundles-panel" class="ui-bundles-panel" hidden>
      <div class="bn-card">
        <h3>🏛 Community Hall — Bundles</h3>
        <p class="bn-blurb">Contribute to seasonal bundles. Memories + friendships count automatically.</p>
        <ul id="lounge-bundles-list" class="bn-list"></ul>
        <div class="bn-actions">
          <button type="button" id="lounge-bundles-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-grovecare-panel" class="ui-grovecare-panel" hidden>
      <div class="gc-card">
        <h3>🌱 Care for the Grove</h3>
        <p class="gc-blurb">Plant a flower in the Grove. Water it once daily for 5 days. It blooms.</p>
        <div id="lounge-grovecare-state" class="gc-state">Loading…</div>
        <div id="lounge-grovecare-controls" class="gc-controls"></div>
        <div class="gc-actions">
          <button type="button" id="lounge-grovecare-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-build-panel" class="ui-build-panel" hidden>
      <div class="bd-card">
        <h3>🏗 Build — Home extensions</h3>
        <p class="bd-blurb">Each tier expands your Home and adds decoration slots.</p>
        <ul id="lounge-build-list" class="bd-list"></ul>
        <div class="bd-actions">
          <button type="button" id="lounge-build-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-craft-panel" class="ui-craft-panel" hidden>
      <div class="cf-card">
        <h3>🧪 Recipe Book</h3>
        <p class="cf-balance">🐚 <span id="lounge-craft-shells">0</span></p>
        <ul id="lounge-craft-list" class="cf-list"></ul>
        <p id="lounge-craft-empty" class="cf-empty" hidden>No recipes unlocked yet. Raise your skills.</p>
        <div class="cf-actions">
          <button type="button" id="lounge-craft-close">Close</button>
        </div>
