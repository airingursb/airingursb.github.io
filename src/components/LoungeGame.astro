---
// Astro client island — mounts Phaser game on /lounge.
---

<div id="lounge-root">
  <div id="lounge-mount"></div>
  <!-- V11.2 — Onboarding overlay (first-visit tour). Hidden until startTour. -->
  <div id="lounge-onboarding" class="ui-onboarding" hidden>
    <div id="lounge-onboarding-spotlight" class="ob-spotlight"></div>
    <div id="lounge-onboarding-tooltip" class="ob-tooltip">
      <div class="ob-head">
        <span id="lounge-onboarding-counter" class="ob-counter">1 / 5</span>
        <button type="button" id="lounge-onboarding-skip" class="ob-skip">Skip</button>
      </div>
      <h3 id="lounge-onboarding-title">Title</h3>
      <p  id="lounge-onboarding-body">Body</p>
      <div class="ob-actions">
        <button type="button" id="lounge-onboarding-next" class="ob-next">Next →</button>
      </div>
    </div>
  </div>
  <!-- V11.1 — Touch input overlay. Hidden by default; CSS reveals when
       body.is-touch.is-narrow (mobile only). Buttons set touchInput flags
       that RoomScene's keyboard reader OR-s into the movement state. -->
  <div id="lounge-touch-overlay" hidden>
    <div id="lounge-dpad" class="touch-dpad">
      <button type="button" id="lounge-dpad-up"    class="td-btn td-up"    aria-label="Up">▲</button>
      <button type="button" id="lounge-dpad-left"  class="td-btn td-left"  aria-label="Left">◀</button>
      <button type="button" id="lounge-dpad-right" class="td-btn td-right" aria-label="Right">▶</button>
      <button type="button" id="lounge-dpad-down"  class="td-btn td-down"  aria-label="Down">▼</button>
    </div>
    <button type="button" id="lounge-action-btn" class="touch-action-btn" aria-label="Interact">A</button>
  </div>
  <div id="lounge-ui">
    <button id="lounge-mute" class="ui-mute-btn" aria-label="Toggle sound">🔊</button>
    <button id="lounge-volume-btn" class="ui-volume-btn" aria-label="Volume settings">⚙</button>
    <button id="lounge-info-btn" class="ui-info-btn" aria-label="Identity">ⓘ</button>
    <button id="lounge-pet-btn" class="ui-pet-btn" aria-label="Pet">🐾</button>
    <button id="lounge-achievements-btn" class="ui-ach-btn" aria-label="Achievements">🏆</button>
    <button id="lounge-photos-btn" class="ui-photos-btn" aria-label="Photo Album">🖼️</button>
    <button id="lounge-minigame-btn" class="ui-mg-btn" aria-label="Mini-games">🎮</button>
    <button id="lounge-board-btn" class="ui-board-btn" aria-label="Community board">📌<span id="lounge-board-badge" class="badge" hidden>0</span></button>
    <button id="lounge-transit-btn" class="ui-transit-btn" aria-label="Transit hub">🚇</button>
    <button id="lounge-inventory-btn" class="ui-inventory-btn" aria-label="Inventory">📦</button>
    <button id="lounge-messages-btn" class="ui-messages-btn" aria-label="Messages">✉<span id="lounge-messages-badge" class="badge" hidden>0</span></button>
    <button id="lounge-wishboard-btn" class="ui-wishboard-btn" aria-label="Wishboard">🌟</button>
    <div id="lounge-wishboard-panel" class="ui-wishboard-panel" hidden>
      <h3>🌟 Wishboard</h3>
      <p class="subtitle">Suggest a sprite, room, dialog or anything else for the lounge. Vote on others' ideas.</p>
      <form id="lounge-wish-form">
        <select id="lounge-wish-category">
          <option value="sprite">Sprite</option>
          <option value="room">Room</option>
          <option value="dialog">Dialog</option>
          <option value="other">Other</option>
        </select>
        <textarea id="lounge-wish-input" maxlength="140" placeholder="My wish for the lounge..." rows="2"></textarea>
        <div class="form-foot">
          <span id="lounge-wish-count">0</span> / 140
          <button type="submit">Submit</button>
        </div>
      </form>
      <ul id="lounge-wish-list" class="wishes"></ul>
      <p id="lounge-wish-empty" class="empty" hidden>No wishes yet — be the first.</p>
    </div>
    <div id="lounge-messages-panel" class="ui-messages-panel" hidden>
      <h3>Messages</h3>
      <div id="lounge-messages-empty" class="empty">No messages yet. Wave to a friend, then send one.</div>
      <ul id="lounge-messages-list" class="threads"></ul>
      <div id="lounge-thread-view" class="thread-view" hidden>
        <button type="button" class="back" id="lounge-thread-back">← Back</button>
        <h4 id="lounge-thread-name">Friend</h4>
        <ul id="lounge-thread-messages"></ul>
        <form id="lounge-thread-form">
          <input type="text" id="lounge-thread-input" maxlength="140" placeholder="Say something…" autocomplete="off">
          <button type="submit">Send</button>
        </form>
      </div>
    </div>
    <div id="lounge-peer-menu" class="ui-peer-menu" hidden>
      <button type="button" data-action="wave">👋 Wave</button>
      <button type="button" data-action="gift">🎁 Gift pebble</button>
      <button type="button" data-action="dm">✉ Send DM</button>
      <button type="button" data-action="visit_home">🏠 Visit home</button>
    </div>
    <div id="lounge-gift-modal" class="ui-gift-modal" hidden>
      <div class="ui-gift-modal-backdrop"></div>
      <div class="ui-gift-modal-card">
        <h3>Pick a pebble to gift</h3>
        <p class="gift-recipient">to <span id="lounge-gift-to-name">Friend</span></p>
        <ul id="lounge-gift-list"></ul>
        <p id="lounge-gift-empty" class="empty" hidden>You haven't collected any pebbles yet.</p>
        <div class="actions">
          <button type="button" id="lounge-gift-cancel">Cancel</button>
        </div>
      </div>
    </div>
    <div id="lounge-toast" class="ui-toast" hidden></div>
    <div id="lounge-minimap" class="ui-minimap" hidden>
      <div class="mm-title">📍 <span id="lounge-mm-room-name">Lobby</span></div>
      <svg id="lounge-mm-svg" viewBox="0 0 140 100" xmlns="http://www.w3.org/2000/svg"></svg>
      <div class="mm-legend">
        <span class="dot here"></span> here
        <span class="dot npc"></span> NPC
      </div>
    </div>
    <div id="lounge-door-label" class="ui-door-label" hidden></div>
    <div id="lounge-inventory-panel" class="ui-inventory-panel" hidden>
      <div class="inv-header">
        <h3>Inventory</h3>
        <div class="inv-view-toggle" role="tablist">
          <button id="lounge-inv-view-grid" type="button" data-view="grid" class="inv-tab active">Grid</button>
          <button id="lounge-inv-view-list" type="button" data-view="list" class="inv-tab">List</button>
        </div>
      </div>
      <p class="count">Pebbles: <span id="lounge-inv-count">0</span> / <span id="lounge-inv-total">0</span></p>
      <div id="lounge-inv-grid" class="inv-grid"></div>
      <div id="lounge-inv-trash" class="inv-trash" title="Drag a shop decoration here to discard it">🗑</div>
      <ul id="lounge-inv-list" hidden></ul>
    </div>
    <div id="lounge-info-panel" class="ui-info-panel" hidden>
      <h3>Identity</h3>
      <dl>
        <dt>Name</dt><dd id="lounge-info-name">—</dd>
        <dt>Region</dt><dd id="lounge-info-region">—</dd>
        <dt>ID</dt><dd id="lounge-info-id">—</dd>
      </dl>
      <button type="button" id="lounge-info-rename">Change name</button>
      <button type="button" id="lounge-info-species" data-species="bear">Switch to 🐱 Cat</button>
      <button type="button" id="lounge-info-quests">📋 Quests</button>
      <button type="button" id="lounge-info-whosaround">👥 Who's around</button>
      <button type="button" id="lounge-info-memories">📷 Memories</button>
      <button type="button" id="lounge-info-shop">🐚 Mio's Shop</button>
      <button type="button" id="lounge-info-mailbox">📬 Mailbox <span id="lounge-mailbox-badge" class="mb-badge" hidden>0</span></button>
      <button type="button" id="lounge-info-skills">🎯 Skills</button>
      <button type="button" id="lounge-info-craft">🧪 Recipe Book</button>
      <button type="button" id="lounge-info-build">🏗 Build</button>
      <button type="button" id="lounge-info-grovecare">🌱 Care for Grove</button>
      <button type="button" id="lounge-info-bundles">🏛 Community Hall</button>
      <button type="button" id="lounge-info-progress">✨ Your Story</button>
      <button type="button" id="lounge-info-gametime" data-on="0">⏰ Game time: off</button>
      <button type="button" id="lounge-info-friend-notifs" data-on="1">🔔 Friend notifications: on</button>
      <button type="button" id="lounge-info-visits">🚪 Home visit log</button>
      <button type="button" id="lounge-info-party">🎉 Party room</button>
      <h4 class="friends-heading">Friends</h4>
      <ul id="lounge-info-friends" class="friends-list"></ul>
      <p id="lounge-info-friends-empty" class="friends-empty">No friendships yet — spend time with peers.</p>
    </div>
    <div id="lounge-name-modal" class="ui-name-modal" hidden>
      <div class="ui-name-modal-backdrop"></div>
      <div class="ui-name-modal-card">
        <h3 id="lounge-name-modal-title">How should we call you?</h3>
        <input type="text" id="lounge-name-input" maxlength="16" autocomplete="off" placeholder="Your name">
        <p class="hint">1–16 chars</p>
        <p id="lounge-name-error" class="error" hidden></p>
        <div class="actions">
          <button type="button" id="lounge-name-skip">Skip</button>
          <button type="button" id="lounge-name-save">Save</button>
        </div>
      </div>
    </div>
    <div id="lounge-booth-picker" class="ui-booth-picker" hidden>
      <h3>🎧 Listening Booth</h3>
      <ul id="lounge-booth-list"></ul>
      <div class="actions">
        <button type="button" id="lounge-booth-stop">Stop</button>
        <button type="button" id="lounge-booth-close">Close</button>
      </div>
    </div>
    <div id="lounge-now-playing" class="ui-now-playing" hidden>
      🎧 Now: <span id="lounge-now-playing-name"></span>
    </div>
    <div id="lounge-coop-banner" class="ui-coop-banner" hidden>
      <span id="lounge-coop-emoji" class="coop-emoji">🍲</span>
      <span id="lounge-coop-text">Cooking circle</span>
      <button type="button" id="lounge-coop-start" class="coop-start">Start</button>
      <span id="lounge-coop-timer" class="coop-timer" hidden>30s</span>
    </div>
    <div id="lounge-festival-banner" class="ui-festival-banner" hidden>
      <span id="lounge-festival-banner-emoji" class="festival-emoji">🌸</span>
      <span id="lounge-festival-banner-text">Festival today!</span>
      <button type="button" id="lounge-festival-action" class="festival-action" hidden>Join 🎟</button>
    </div>
    <div id="lounge-clock" class="ui-clock" hidden>
      <span class="clk-icon">🕐</span>
      <span id="lounge-clock-time">06:00</span>
      <span class="clk-mode" id="lounge-clock-mode">game</span>
    </div>
    <div id="lounge-energy" class="ui-energy">
      <span class="en-icon">⚡</span>
      <div class="en-track"><div id="lounge-energy-fill" class="en-fill"></div></div>
      <span id="lounge-energy-num" class="en-num">100</span>
    </div>
    <button type="button" id="lounge-camera-btn" class="ui-camera-btn" title="Equip camera (click anywhere to capture)">📷</button>
    <div id="lounge-shells" class="ui-shells" title="Shells">
      <span class="sh-icon">🐚</span>
      <span id="lounge-shells-num">0</span>
    </div>
    <div id="lounge-bundles-panel" class="ui-bundles-panel" hidden>
      <div class="bn-card">
        <h3>🏛 Community Hall — Bundles</h3>
        <p class="bn-blurb">Contribute to seasonal bundles. Memories + friendships count automatically.</p>
        <ul id="lounge-bundles-list" class="bn-list"></ul>
        <div class="bn-actions">
          <button type="button" id="lounge-bundles-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-grovecare-panel" class="ui-grovecare-panel" hidden>
      <div class="gc-card">
        <h3>🌱 Care for the Grove</h3>
        <p class="gc-blurb">Plant a flower in the Grove. Water it once daily for 5 days. It blooms.</p>
        <div id="lounge-grovecare-state" class="gc-state">Loading…</div>
        <div id="lounge-grovecare-controls" class="gc-controls"></div>
        <div class="gc-actions">
          <button type="button" id="lounge-grovecare-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-build-panel" class="ui-build-panel" hidden>
      <div class="bd-card">
        <h3>🏗 Build — Home extensions</h3>
        <p class="bd-blurb">Each tier expands your Home and adds decoration slots.</p>
        <ul id="lounge-build-list" class="bd-list"></ul>
        <div class="bd-actions">
          <button type="button" id="lounge-build-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-craft-panel" class="ui-craft-panel" hidden>
      <div class="cf-card">
        <h3>🧪 Recipe Book</h3>
        <p class="cf-balance">🐚 <span id="lounge-craft-shells">0</span></p>
        <ul id="lounge-craft-list" class="cf-list"></ul>
        <p id="lounge-craft-empty" class="cf-empty" hidden>No recipes unlocked yet. Raise your skills.</p>
        <div class="cf-actions">
          <button type="button" id="lounge-craft-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-skills-panel" class="ui-skills-panel" hidden>
      <div class="sk-card">
        <h3>🎯 Skills</h3>
        <ul id="lounge-skills-list" class="sk-list"></ul>
        <p class="sk-hint">XP grows from your everyday actions. Perks unlock at certain levels (see hint per row).</p>
        <div class="sk-actions">
          <button type="button" id="lounge-skills-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-whosaround-panel" class="ui-whosaround-panel" hidden>
      <div class="wa-card">
        <h3>👥 Who's around</h3>
        <ul id="lounge-whosaround-list" class="wa-list"></ul>
        <p id="lounge-whosaround-empty" class="wa-empty" hidden>Nobody's on shift right now.</p>
        <div class="wa-actions">
          <button type="button" id="lounge-whosaround-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-progress-panel" class="ui-progress-panel" hidden>
      <div class="prog-card">
        <h3>✨ Your Story</h3>
        <p id="lounge-progress-summary" class="prog-summary"></p>
        <ul id="lounge-progress-list" class="prog-list"></ul>
        <div class="prog-actions">
          <button type="button" id="lounge-progress-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-mailbox-panel" class="ui-mailbox-panel" hidden>
      <div class="mb-card">
        <h3>📬 Mailbox</h3>
        <div id="lounge-mailbox-list" class="mb-list"></div>
        <p id="lounge-mailbox-empty" class="mb-empty" hidden>Mailbox is empty.</p>
        <div class="mb-actions">
          <button type="button" id="lounge-mailbox-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-species-picker" class="ui-species-picker" hidden>
      <div class="sp-card">
        <h3>Choose your shape</h3>
        <p class="sp-blurb">You can change this anytime in the info panel.</p>
        <div class="sp-grid">
          <button type="button" class="sp-tile" data-species="bear">
            <span class="sp-emoji">🐻</span><span class="sp-label">Bear</span>
          </button>
          <button type="button" class="sp-tile" data-species="cat">
            <span class="sp-emoji">🐱</span><span class="sp-label">Cat</span>
          </button>
          <button type="button" class="sp-tile" data-species="fox">
            <span class="sp-emoji">🦊</span><span class="sp-label">Fox</span>
          </button>
          <button type="button" class="sp-tile" data-species="capybara">
            <span class="sp-emoji">🦦</span><span class="sp-label">Capybara</span>
          </button>
          <button type="button" class="sp-tile" data-species="bird">
            <span class="sp-emoji">🐦</span><span class="sp-label">Bird</span>
          </button>
        </div>
      </div>
    </div>
    <div id="lounge-transit-panel" class="ui-transit-panel" hidden>
      <div class="tr-card">
        <h3>🚇 Transit Hub</h3>
        <p class="tr-blurb">Skip the walking. Energy cost based on zone distance.</p>
        <div id="lounge-transit-list" class="tr-grid"></div>
        <div class="tr-actions">
          <button type="button" id="lounge-transit-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-party-panel" class="ui-party-panel" hidden>
      <div class="pr-card">
        <h3>🎉 Party Room</h3>
        <p class="pr-blurb">Create a private invite room (4-hour TTL) or join one with a code.</p>
        <div class="pr-section">
          <h4>Create</h4>
          <input type="text" id="lounge-party-topic" class="pr-input" maxlength="80" placeholder="Topic (optional)" />
          <button type="button" id="lounge-party-create" class="pr-primary">Create</button>
          <div id="lounge-party-create-result" class="pr-result"></div>
        </div>
        <div class="pr-section">
          <h4>Join</h4>
          <input type="text" id="lounge-party-code" class="pr-input pr-code-input" maxlength="6" placeholder="ABC123" />
          <button type="button" id="lounge-party-join" class="pr-primary">Join</button>
          <div id="lounge-party-join-result" class="pr-result"></div>
        </div>
        <div class="pr-actions">
          <button type="button" id="lounge-party-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-visits-panel" class="ui-visits-panel" hidden>
      <div class="vs-card">
        <h3>🚪 Home Visit Log <span class="vs-meta">last 30 days</span></h3>
        <p id="lounge-visits-empty" class="vs-empty" hidden>Nobody has visited your home yet.</p>
        <ul id="lounge-visits-list" class="vs-list"></ul>
        <div class="vs-actions">
          <button type="button" id="lounge-visits-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-board-panel" class="ui-board-panel" hidden>
      <div class="bd-card">
        <h3>📌 Board · <span id="lounge-board-room">…</span></h3>
        <p class="bd-blurb">Pinned to this room for 7 days. 3 posts/hour, 200 chars.</p>
        <div class="bd-form">
          <select id="lounge-board-cat" class="bd-cat">
            <option value="note">📝 note</option>
            <option value="event">📅 event</option>
            <option value="question">❓ question</option>
            <option value="shout">📣 shout</option>
          </select>
          <textarea id="lounge-board-text" class="bd-text" rows="2" maxlength="200" placeholder="Pin something for everyone in this room…"></textarea>
          <div class="bd-formfoot">
            <span id="lounge-board-count" class="bd-count">0 / 200</span>
            <button type="button" id="lounge-board-submit" class="bd-submit">Pin 📌</button>
          </div>
        </div>
        <div id="lounge-board-list" class="bd-list"></div>
        <div class="bd-actions">
          <button type="button" id="lounge-board-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-minigame-overlay" class="ui-mg-overlay" hidden>
      <div class="mg-card">
        <div class="mg-head">
          <h3 id="lounge-minigame-title">🎮 Mini-games</h3>
          <button type="button" id="lounge-minigame-back" hidden>← Back</button>
        </div>
        <p id="lounge-minigame-blurb" class="mg-blurb-main"></p>
        <div id="lounge-minigame-picker" class="mg-picker"></div>
        <div id="lounge-minigame-stage" class="mg-stage"></div>
        <div class="mg-actions">
          <button type="button" id="lounge-minigame-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-photos-panel" class="ui-photos-panel" hidden>
      <div class="ph-panel-card">
        <h3>🖼️ Photo Album <span id="lounge-photos-count" class="ph-count">0</span></h3>
        <p id="lounge-photos-empty" class="ph-empty" hidden>No photos yet. Equip the camera 📷 and click anywhere in the lounge.</p>
        <div id="lounge-photos-grid" class="ph-grid"></div>
        <div class="ph-actions">
          <button type="button" id="lounge-photos-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-achievements-panel" class="ui-ach-panel" hidden>
      <div class="ach-card">
        <h3>🏆 Achievement Album <span id="lounge-achievements-count" class="ach-count">0 / 0</span></h3>
        <div id="lounge-achievements-list" class="ach-list"></div>
        <div class="ach-actions">
          <button type="button" id="lounge-achievements-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-pet-panel" class="ui-pet-panel" hidden>
      <div class="pet-card">
        <h3 id="lounge-pet-title">🐾 Pet</h3>
        <div id="lounge-pet-body"></div>
        <div class="pet-actions">
          <button type="button" id="lounge-pet-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-sleep-overlay" class="ui-sleep-overlay" hidden>
      <div class="sleep-card">
        <div class="sleep-time">🌙 <span id="lounge-sleep-time">02:00</span></div>
        <h3 id="lounge-sleep-title">The day ends.</h3>
        <p id="lounge-sleep-blurb">Sleep to restore your energy.</p>
        <div class="sleep-actions">
          <button type="button" id="lounge-sleep-go" class="primary">Sleep 💤</button>
          <button type="button" id="lounge-sleep-stay">Stay up</button>
        </div>
      </div>
    </div>
    <div id="lounge-shop-panel" class="ui-shop-panel" hidden>
      <div class="shop-card">
        <h3>🐚 Mio's Cafe — Shop</h3>
        <p class="shop-balance">You have <span id="lounge-shop-balance">0</span> shells.</p>
        <div id="lounge-shop-list" class="shop-list"></div>
        <div class="shop-actions">
          <button type="button" id="lounge-shop-close">Close</button>
        </div>
      </div>
    </div>
    <div id="lounge-memories-panel" class="ui-memories-panel" hidden>
      <div class="mem-card">
        <h3>📷 Memories</h3>
        <div id="lounge-memories-list" class="mem-list"></div>
        <p id="lounge-memories-empty" class="mem-empty" hidden>No memories yet. Equip 📷 and click a moment.</p>
        <div class="mem-actions">
