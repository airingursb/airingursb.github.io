  .ui-sleep-overlay[hidden] { display: none; }
  .sleep-card {
    background: linear-gradient(135deg, #1c1840, #100c28);
    border: 1px solid rgba(120,140,255,.3);
    color: #e6e0ff;
    padding: 28px 36px;
    border-radius: 14px;
