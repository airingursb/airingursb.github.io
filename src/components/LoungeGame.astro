    .ui-bundles-panel, .ui-info-panel {
      position: fixed !important;
      left: 8px !important;
      right: 8px !important;
      top: 56px !important;
      bottom: 60px !important;    /* leave room for the bottom button strip */
      width: auto !important;
      max-width: none !important;
      max-height: none !important;
      overflow-y: auto;
    }
    /* Back arrow stays top-left but smaller and inset for iOS notch. */
