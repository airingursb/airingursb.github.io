---
// src/components/comics/ComicIssueIndex.astro
// Inline "back issues" archive at the bottom of the comic detail page.
// Styled like a newspaper masthead's archive index — hairline separators,
// small-caps label, monospace numbers, serif titles. Replaces the original
// prev/next nav so the reader can jump to any issue with one click without
// breaking the immersion of the comic itself.
import type { Comic } from '../../lib/comics';

interface Props {
  comics: Comic[];
  current: number;
  lang: 'zh' | 'en';
}

const { comics, current, lang } = Astro.props;
const base = lang === 'en' ? '/en/comics' : '/comics';
const label = lang === 'en' ? 'Back Issues' : '往期目录';
const youAreHere = lang === 'en' ? 'You are here' : '正在阅读';

const formatDate = (s: string) =>
  new Date(s).toLocaleDateString(lang === 'en' ? 'en-US' : 'zh-CN', {
    year: 'numeric', month: 'short', day: 'numeric',
  });
---

<section class="comic-toc" aria-label={label}>
  <div class="comic-toc-rule"></div>
  <div class="comic-toc-label">{label}</div>
  <ol class="comic-toc-list">
    {comics.map((c) => {
      const isCurrent = c.issue_number === current;
      const title = c.title[lang] || c.title.zh;
      const dateStr = formatDate(c.published_at || c.created_at);
      const num = `No. ${String(c.issue_number).padStart(2, '0')}`;
      return (
        <li class={isCurrent ? 'is-current' : undefined}>
          {isCurrent ? (
            <span class="toc-row">
              <span class="toc-num">{num}</span>
              <span class="toc-title">
                {title}<span class="toc-here">— {youAreHere}</span>
              </span>
              <span class="toc-date">{dateStr}</span>
            </span>
          ) : (
            <a class="toc-row" href={`${base}/${c.issue_number}`}>
              <span class="toc-num">{num}</span>
              <span class="toc-title">{title}</span>
              <span class="toc-date">{dateStr}</span>
            </a>
          )}
        </li>
      );
    })}
  </ol>
</section>
