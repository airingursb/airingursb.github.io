---
// src/components/comics/ComicPanel.astro
// One quadrant of a 2×2 strip image, with optional dialog bubble overlay.
import type { ComicCell } from '../../lib/comics';

interface Props {
  imgUrl: string;       // the full strip image (2×2)
  altText: string;
  cell: ComicCell;
  lang: 'zh' | 'en';
}
const { imgUrl, altText, cell, lang } = Astro.props;

const bubble = cell.dialog?.[lang] || cell.dialog?.zh || '';
const positionClass: Record<string, string> = {
  'top-left': 'tl',
  'top-right': 'tr',
  'bottom-left': 'bl',
  'bottom-right': 'br',
  'hidden': 'hidden',
};
const pos = positionClass[cell.dialog?.position || 'hidden'] || 'hidden';
---

<div class={`comic-panel q-${cell.quadrant}`}>
  <img src={imgUrl} alt={altText} loading="lazy" />
  {bubble && pos !== 'hidden' && (
    <div class={`bubble ${pos}`}>{bubble}</div>
  )}
</div>
