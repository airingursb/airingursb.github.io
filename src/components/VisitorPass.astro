---
// VisitorPass — 3D boarding-pass card showing visitor rank + online tribe.
// All behavior is in the inline script below; component takes no props.
---

<div class="vp-wrap" id="visitorPass">
  <div class="vp-pass" data-vp-tilt>
    <div class="vp-head">
      <span><span class="vp-dot"></span>URSB.ME</span>
      <span>VISITOR_PASS</span>
    </div>
    <div class="vp-hero">
      <div class="vp-hero-label" data-i18n="vp_label">YOU ARE VISITOR</div>
      <div class="vp-hero-num">
        <span class="vp-hash">#</span><span class="vp-total" id="vpTotal">--,---</span>
      </div>
      <div class="vp-online-row" id="vpOnlineRow" hidden>
        <div class="vp-online-meta">
          <span class="vp-live-dot"></span>
          <span id="vpOnlineMeta">—</span>
        </div>
        <div class="vp-tribe" id="vpTribe"></div>
      </div>
    </div>
    <hr class="vp-perf">
    <div class="vp-data">
      <div class="vp-cell">
        <span class="vp-k" data-i18n="vp_today">TODAY</span>
        <span class="vp-v" id="vpToday">#--</span>
      </div>
      <div class="vp-cell">
        <span class="vp-k" data-i18n="vp_joined">JOINED</span>
        <span class="vp-v" id="vpJoined">----.--.--</span>
      </div>
    </div>
    <div class="vp-foot">
      <span>URSB.ME ■ V1</span>
      <span>WELCOME ABOARD</span>
    </div>
    <div class="vp-glare"></div>
  </div>
</div>

<style is:global>
  /* Global so JS-injected skulls/tribe markup inherits these rules.
     The vp-* prefix provides namespacing. */
  .vp-wrap {
    perspective: 1400px;
    width: 100%;
    max-width: 320px;
    margin: 20px auto 0;
  }
  .vp-pass {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: var(--c-bg);
    color: var(--c-text);
    font-family: ui-monospace, "SF Mono", "Roboto Mono", monospace;
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    transform-style: preserve-3d;
    transition: transform .2s ease-out;
    will-change: transform;
    box-shadow:
      0 20px 50px -22px rgba(0,0,0,.22),
      0 3px 8px rgba(0,0,0,.05),
      inset 0 0 0 1px rgba(0,0,0,.06);
  }
  [data-mode="dark"] .vp-pass {
    box-shadow:
      0 24px 56px -22px rgba(0,0,0,.55),
      0 3px 8px rgba(0,0,0,.25),
      inset 0 0 0 1px rgba(255,255,255,.06);
  }
  .vp-glare {
    position: absolute; inset: 0;
    border-radius: 10px;
    pointer-events: none;
    opacity: 0;
    transition: opacity .25s;
    background: radial-gradient(
      circle 200px at var(--mx, 50%) var(--my, 50%),
      rgba(255,255,255,.35),
      transparent 50%
    );
    mix-blend-mode: overlay;
    z-index: 10;
  }
  [data-mode="dark"] .vp-glare {
    background: radial-gradient(
      circle 200px at var(--mx, 50%) var(--my, 50%),
      rgba(var(--accent-rgb), .2),
      transparent 55%
    );
    mix-blend-mode: screen;
  }
  .vp-pass:hover .vp-glare { opacity: 1; }

  .vp-head {
    height: 28px;
    background: var(--c-bg-alt);
    border-bottom: 1px solid rgba(0,0,0,.06);
    display: flex; justify-content: space-between; align-items: center;
    padding: 0 14px;
    font-size: 9.5px;
    letter-spacing: .2em;
    color: var(--c-text-muted);
    font-weight: 600;
    flex-shrink: 0;
  }
  [data-mode="dark"] .vp-head { border-bottom-color: rgba(255,255,255,.06); }
  .vp-dot {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 2px rgba(var(--accent-rgb), .18);
    margin-right: 6px;
    vertical-align: middle;
    animation: vp-pulse 2s ease-in-out infinite;
  }
  @keyframes vp-pulse {
    0%, 100% { box-shadow: 0 0 0 2px rgba(var(--accent-rgb), .18); }
    50%      { box-shadow: 0 0 0 4px rgba(var(--accent-rgb), .05); }
  }

  .vp-hero {
    flex: 1;
    padding: 14px 18px 8px;
    display: flex; flex-direction: column;
    justify-content: center;
  }
  .vp-hero-label {
    font-size: 9.5px;
    letter-spacing: .26em;
    color: var(--c-text-dim);
    margin-bottom: 4px;
  }
  .vp-hero-num {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -.01em;
    font-feature-settings: "tnum";
    color: var(--c-text);
    line-height: 1.05;
    display: flex; align-items: baseline; gap: 2px;
  }
  .vp-hash { color: var(--accent); }

  .vp-online-row { margin-top: 10px; }
  .vp-online-meta {
    display: flex; align-items: center; gap: 6px;
    font-size: 9px; letter-spacing: .18em;
    color: var(--c-text-dim);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .vp-online-meta b {
    color: var(--c-text);
    font-weight: 700;
  }
  .vp-live-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 4px rgba(var(--accent-rgb), .6);
    animation: vp-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .vp-tribe {
    display: flex; gap: 4px; align-items: center;
    min-height: 12px;
  }
  .vp-skull {
    width: 14px; height: 12px;
    position: relative;
    flex-shrink: 0;
  }
  .vp-skull svg {
    display: block; width: 100%; height: 100%;
    image-rendering: pixelated;
  }
  .vp-skull.vp-you::after {
    content: ""; position: absolute;
    inset: -3px;
    border: 1.5px solid var(--accent);
    border-radius: 3px;
    box-shadow: 0 0 6px rgba(var(--accent-rgb), .5);
    animation: vp-ring-pulse 1.6s ease-in-out infinite;
  }
  @keyframes vp-ring-pulse {
    0%, 100% { box-shadow: 0 0 6px rgba(var(--accent-rgb), .5); }
    50%      { box-shadow: 0 0 10px rgba(var(--accent-rgb), .25); }
  }
  .vp-tribe-more {
    font-size: 9.5px;
    color: var(--c-text-dim);
    margin-left: 4px;
    font-weight: 600;
  }

  .vp-perf {
    border: none;
    border-top: 1.5px dashed rgba(0,0,0,.14);
    margin: 0 14px;
  }
  [data-mode="dark"] .vp-perf { border-top-color: rgba(255,255,255,.14); }

  .vp-data {
    padding: 10px 16px 6px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px 14px;
  }
  .vp-k {
    display: block;
    font-size: 9px; letter-spacing: .22em;
    color: var(--c-text-dim);
    margin-bottom: 2px;
  }
  .vp-v {
    font-size: 13px; color: var(--c-text);
    font-weight: 600;
    font-feature-settings: "tnum";
  }

  .vp-foot {
    height: 26px;
    background: var(--c-bg-alt);
    border-top: 1px solid rgba(0,0,0,.06);
    display: flex; justify-content: space-between; align-items: center;
    padding: 0 14px;
    font-size: 9px; letter-spacing: .18em;
    color: var(--c-text-dim);
    font-weight: 600;
    flex-shrink: 0;
  }
  [data-mode="dark"] .vp-foot { border-top-color: rgba(255,255,255,.06); }

  .vp-pass::before, .vp-pass::after {
    content: "";
    position: absolute;
    width: 12px; height: 12px;
    background: var(--c-bg);
    border-radius: 50%;
    top: 86px;
    z-index: 2;
  }
  .vp-pass::before { left: -6px; }
  .vp-pass::after  { right: -6px; }

  @media (prefers-reduced-motion: reduce) {
    .vp-pass,
    .vp-glare,
    .vp-skull.vp-you::after,
    .vp-dot,
    .vp-live-dot {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<script is:inline>
  (function () {
    var pass = document.querySelector('#visitorPass .vp-pass');
    if (!pass) return;

    // ── 3D tilt + cursor-following glare ──────────────────────────────────
    pass.addEventListener('mousemove', function (e) {
      var r = pass.getBoundingClientRect();
      var dx = (e.clientX - r.left - r.width / 2) / r.width;
      var dy = (e.clientY - r.top - r.height / 2) / r.height;
      var max = 9;
      pass.style.transform =
        'rotateY(' + (dx * max).toFixed(2) + 'deg) ' +
        'rotateX(' + (-dy * max).toFixed(2) + 'deg) ' +
        'translateZ(0)';
      pass.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
      pass.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
    });
    pass.addEventListener('mouseleave', function () {
      pass.style.transform = '';
    });

    // ── Data fetch (total + today rank via Supabase RPC) ─────────────────
    var SB_URL = 'https://pcoyocvqfipuydhvdsle.supabase.co';
    var SB_KEY = 'sb_publishable_jieHU6yu3dPxSww2_B_KIg_9KcWg6wl';
    var HISTORICAL_OFFSET = 28655;
    var CACHE_KEY = 'visitor_v2';

    var totalEl = document.getElementById('vpTotal');
    var todayEl = document.getElementById('vpToday');
    var joinedEl = document.getElementById('vpJoined');

    function fmtTotal(n) {
      return (n + HISTORICAL_OFFSET).toLocaleString('en-US');
    }
    function fmtJoined(d) {
      var y = d.getFullYear();
      var m = String(d.getMonth() + 1).padStart(2, '0');
      var dd = String(d.getDate()).padStart(2, '0');
      return y + '.' + m + '.' + dd;
    }

    function countUp(el, target, durationMs) {
      var start = performance.now();
      function frame(now) {
        var p = Math.min(1, (now - start) / durationMs);
        var eased = 1 - Math.pow(1 - p, 3);
        el.textContent = fmtTotal(Math.round(target * eased));
        if (p < 1) requestAnimationFrame(frame);
        else el.textContent = fmtTotal(target);
      }
      requestAnimationFrame(frame);
    }

    function render(data, animate) {
      if (animate) countUp(totalEl, data.total, 600);
      else totalEl.textContent = fmtTotal(data.total);
      todayEl.textContent = '#' + data.today_rank;
      joinedEl.textContent = fmtJoined(new Date());
    }

    var cached = null;
    try { cached = JSON.parse(sessionStorage.getItem(CACHE_KEY) || 'null'); } catch (_) {}

    if (cached && typeof cached.total === 'number') {
      render(cached, false);
    } else {
      fetch(SB_URL + '/rest/v1/rpc/increment_visitor_v2', {
        method: 'POST',
        headers: {
          'apikey': SB_KEY,
          'Authorization': 'Bearer ' + SB_KEY,
          'Content-Type': 'application/json'
        },
        body: '{}'
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data || typeof data.total !== 'number') return;
          try { sessionStorage.setItem(CACHE_KEY, JSON.stringify(data)); } catch (_) {}
          render(data, true);
        })
        .catch(function () { /* leave placeholders on failure */ });
    }

    // ── Skull tribe (online presence) ──────────────────────────────────────
    var ONLINE_API = 'https://chat.ursb.me/api/online/count';
    var POLL_MS = 30000;
    var MAX_SKULLS = 8;
    var onlineRow = document.getElementById('vpOnlineRow');
    var onlineMeta = document.getElementById('vpOnlineMeta');
    var tribeEl = document.getElementById('vpTribe');

    var REGION_BY_CC = {
      CN: 'asia', JP: 'asia', KR: 'asia', TW: 'asia', HK: 'asia', SG: 'asia',
      IN: 'asia', TH: 'asia', VN: 'asia', PH: 'asia', ID: 'asia', MY: 'asia',
      AE: 'asia', SA: 'asia', IL: 'asia', TR: 'asia', PK: 'asia', BD: 'asia',
      US: 'americas', CA: 'americas', MX: 'americas', BR: 'americas',
      AR: 'americas', CL: 'americas', CO: 'americas', PE: 'americas',
      GB: 'europe', DE: 'europe', FR: 'europe', NL: 'europe', ES: 'europe',
      IT: 'europe', SE: 'europe', NO: 'europe', FI: 'europe', DK: 'europe',
      PL: 'europe', CH: 'europe', AT: 'europe', BE: 'europe', IE: 'europe',
      PT: 'europe', GR: 'europe', CZ: 'europe', RU: 'europe', UA: 'europe',
      AU: 'oceania', NZ: 'oceania',
      ZA: 'africa', EG: 'africa', NG: 'africa', KE: 'africa', MA: 'africa'
    };
    function regionColors() {
      var isDark = document.documentElement.getAttribute('data-mode') !== 'light';
      return isDark
        ? { asia: 'var(--accent)', americas: '#60a5fa', europe: '#a78bfa', oceania: '#22d3ee', africa: '#fbbf24', unknown: 'var(--c-text-dim)' }
        : { asia: 'var(--accent)', americas: '#2563eb', europe: '#7c3aed', oceania: '#0891b2', africa: '#d97706', unknown: 'var(--c-text-dim)' };
    }

    var SKULL_SVG = '<svg viewBox="0 0 16 14" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg"><g fill="{FILL}"><rect x="5" y="2" width="6" height="1"/><rect x="4" y="3" width="8" height="1"/><rect x="3" y="4" width="10" height="1"/><rect x="3" y="5" width="2" height="2"/><rect x="11" y="5" width="2" height="2"/><rect x="5" y="5" width="2" height="2"/><rect x="9" y="5" width="2" height="2"/><rect x="3" y="7" width="10" height="1"/><rect x="3" y="8" width="10" height="1"/><rect x="4" y="9" width="1" height="2"/><rect x="6" y="9" width="1" height="2"/><rect x="8" y="9" width="1" height="2"/><rect x="10" y="9" width="1" height="2"/><rect x="4" y="11" width="8" height="1"/><rect x="5" y="12" width="6" height="1"/></g></svg>';

    function getMyCountry() {
      try { return sessionStorage.getItem('vp_country') || null; } catch (_) { return null; }
    }
    window.addEventListener('visitor-country-ready', function () {
      if (lastCounts) renderTribe(lastCounts);
    });

    function countryName(cc) {
      if (!cc) return 'Unknown';
      try {
        return new Intl.DisplayNames(['en'], { type: 'region' }).of(cc) || cc;
      } catch (_) { return cc; }
    }

    function expandCountriesToSkulls(countries, total) {
      var skulls = [];
      Object.keys(countries).forEach(function (cc) {
        for (var i = 0; i < countries[cc]; i++) skulls.push(cc);
      });
      // Pad with null (unknown) for visitors whose country isn't resolved yet.
      while (skulls.length < total) skulls.push(null);
      return skulls;
    }

    function metaTemplate() {
      if (window.t) {
        var tpl = window.t('vp_online_meta');
        if (tpl && tpl !== 'vp_online_meta') return tpl;
      }
      return '<b>{n}</b> here · <b>{r}</b> regions';
    }

    var lastCounts = null;

    function renderTribe(counts) {
      lastCounts = counts;
      var total = counts.site || 0;
      var countries = counts.countries || {};
      var regionCount = Object.keys(countries).length;

      if (total < 1) {
        onlineRow.hidden = true;
        return;
      }
      onlineRow.hidden = false;

      onlineMeta.innerHTML = metaTemplate()
        .replace('{n}', String(total))
        .replace('{r}', String(regionCount));

      var skulls = expandCountriesToSkulls(countries, total);
      var myCC = getMyCountry();

      skulls.sort(function (a, b) {
        if (myCC) {
          if (a === myCC && b !== myCC) return -1;
          if (b === myCC && a !== myCC) return 1;
        }
        if (a === null && b !== null) return 1;
        if (b === null && a !== null) return -1;
        return (countries[b] || 0) - (countries[a] || 0);
      });

      var visible = skulls.slice(0, MAX_SKULLS);
      var overflow = skulls.length - visible.length;
      var youRendered = false;
      var colors = regionColors();

      tribeEl.innerHTML = '';
      visible.forEach(function (cc) {
        var region = cc ? (REGION_BY_CC[cc] || 'unknown') : 'unknown';
        var fill = colors[region];
        var isYou = !youRendered && myCC && cc === myCC;
        if (isYou) youRendered = true;

        var div = document.createElement('div');
        div.className = 'vp-skull' + (isYou ? ' vp-you' : '');
        div.title = countryName(cc) + (isYou ? ' · You' : '');
        div.innerHTML = SKULL_SVG.replace('{FILL}', fill);
        tribeEl.appendChild(div);
      });

      if (overflow > 0) {
        var more = document.createElement('span');
        more.className = 'vp-tribe-more';
        more.textContent = '+' + overflow;
        tribeEl.appendChild(more);
      }

      // Fallback: if country unknown AND nothing got marked, ring the rightmost
      // skull as "you" so the UX cue still works.
      if (!youRendered) {
        var skullEls = tribeEl.querySelectorAll('.vp-skull');
        if (skullEls.length > 0) {
          var last = skullEls[skullEls.length - 1];
          last.classList.add('vp-you');
          last.title = last.title + ' · You';
        }
      }
    }

    function fetchOnline() {
      fetch(ONLINE_API, { cache: 'no-store' })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) { if (data) renderTribe(data); })
        .catch(function () {});
    }

    fetchOnline();
    setInterval(fetchOnline, POLL_MS);

    // Re-render meta line when language changes (the template comes from i18n).
    window.addEventListener('langchange', function () {
      if (lastCounts) renderTribe(lastCounts);
    });
  })();
</script>
