---
// src/components/workouts/WorkoutCardPreview.astro
import workoutsIndex from '../../data/workouts.json';
import { getCollection } from 'astro:content';
import { formatDistance, defaultWorkoutTitle } from './format.mjs';

const items = workoutsIndex as Array<any>;
const latest = items[0];
const totalKm = items.reduce((s, w) => s + (w.stats?.distanceKm ?? 0), 0);
const totalHours = items.reduce((s, w) => s + (w.durationSec ?? 0), 0) / 3600;

const contentEntries = await getCollection('workouts');
const titleById = new Map(contentEntries.map(e => [e.id.replace(/\.mdx$/, ''), e.data.title]));
const latestTitleZh = latest ? (titleById.get(latest.id)?.zh ?? defaultWorkoutTitle(latest.start, latest.type, 'zh')) : '';
---
{latest && (
  <a href="/workouts" class="workout-preview-card" data-href-zh="/workouts" data-href-en="/en/workouts">
    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px;">
      <strong>Workouts</strong>
      <span style="color: var(--w-fg-muted); font-size: 12px;">
        {items.length} · {formatDistance(totalKm)} · {totalHours.toFixed(1)}h
      </span>
    </div>
    <svg class="track-svg" viewBox="0 0 100 60" preserveAspectRatio="xMidYMid meet" stroke="currentColor" stroke-width="1.5" fill="none">
      {latest.trackSvg && <path d={latest.trackSvg} />}
    </svg>
    <div style="display: flex; justify-content: space-between; margin-top: 8px;">
      <span>{latestTitleZh}</span>
      <span style="color: var(--w-fg-muted);">查看全部 →</span>
    </div>
  </a>
)}
