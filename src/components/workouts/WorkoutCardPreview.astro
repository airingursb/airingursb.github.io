---
// src/components/workouts/WorkoutCardPreview.astro
//
// Full-width homepage card matching .card.card-photos:
// section-title-row + horizontal scroll strip. Each tile renders a
// multi-segment polyline colored by pace (matching the detail map's
// pace gradient), reading from the (gitignored) per-workout detail
// JSON at build time. CI builds without source data render no card.
import { existsSync, readFileSync } from 'node:fs';
import { resolve as resolvePath } from 'node:path';
import { getCollection } from 'astro:content';
import { formatDistance, formatDuration, defaultWorkoutTitle } from './format.mjs';
import { colorFor, percentileRange } from './workoutColors';

const idxPath = resolvePath('./src/data/workouts.json');
const items = (existsSync(idxPath) ? JSON.parse(readFileSync(idxPath, 'utf8')) : []) as Array<any>;

const totalKm = items.reduce((s: number, w: any) => s + (w.stats?.distanceKm ?? 0), 0);
const totalHours = items.reduce((s: number, w: any) => s + (w.durationSec ?? 0), 0) / 3600;

const contentEntries = await getCollection('workouts');
const titleById = new Map(contentEntries.map(e => [e.id.replace(/\.mdx$/, ''), e.data.title]));

// Pre-compute per-tile polyline segments + per-segment pace colors.
// Done at build time so the homepage stays static (no client JS).
// Default to the *light* theme palette for the gradient — the homepage
// is dark mode but pace scale is deliberately bright (red/yellow/green)
// and reads fine on either background.
const VW = 100, VH = 60, PAD = 4;
const tiles = items.map((w: any) => {
  const detailPath = resolvePath(`./src/data/workouts/${w.id}.json`);
  if (!existsSync(detailPath) || !w.bbox || !w.trackSvg) {
    return { id: w.id, segments: [] };
  }
  const detail = JSON.parse(readFileSync(detailPath, 'utf8'));
  const route: Array<{ lat: number; lng: number; pace: number }> = detail.route ?? [];
  if (route.length < 2) return { id: w.id, segments: [] };

  // Equirectangular project to 100x60 viewBox with 4px padding,
  // preserving aspect ratio.
  let minLat = Infinity, maxLat = -Infinity, minLng = Infinity, maxLng = -Infinity;
  for (const p of route) {
    if (p.lat < minLat) minLat = p.lat;
    if (p.lat > maxLat) maxLat = p.lat;
    if (p.lng < minLng) minLng = p.lng;
    if (p.lng > maxLng) maxLng = p.lng;
  }
  const dLat = Math.max(maxLat - minLat, 1e-9);
  const dLng = Math.max(maxLng - minLng, 1e-9);
  const innerW = VW - PAD * 2;
  const innerH = VH - PAD * 2;
  const scale = Math.min(innerW / dLng, innerH / dLat);
  const offX = PAD + (innerW - dLng * scale) / 2;
  const offY = PAD + (innerH - dLat * scale) / 2;

  const paces = route.map(p => p.pace).filter(p => p > 0);
  const [pMin, pMax] = percentileRange(paces);

  const segments: Array<{ x1: number; y1: number; x2: number; y2: number; color: string }> = [];
  for (let i = 0; i < route.length - 1; i++) {
    const a = route[i], b = route[i + 1];
    const x1 = +(offX + (a.lng - minLng) * scale).toFixed(2);
    const y1 = +(offY + (maxLat - a.lat) * scale).toFixed(2);
    const x2 = +(offX + (b.lng - minLng) * scale).toFixed(2);
    const y2 = +(offY + (maxLat - b.lat) * scale).toFixed(2);
    const v = (a.pace + b.pace) / 2;
    const color = colorFor('pace', v, pMin, pMax, 'dark');
    segments.push({ x1, y1, x2, y2, color });
  }
  return { id: w.id, segments };
});
const segmentsById = new Map(tiles.map(t => [t.id, t.segments]));
---
{items.length > 0 && (
  <div class="card card-workouts" id="workouts-card">
    <div class="section-title-row">
      <span class="section-title" data-i18n="sec_workouts">Workouts</span>
      <a class="workouts-strip-more" href="/workouts" data-href-zh="/workouts" data-href-en="/en/workouts" data-i18n="wk_view_all">
        View all →
      </a>
    </div>
    <div class="workouts-strip" role="list">
      {items.map((w: any) => {
        const titleZh = titleById.get(w.id)?.zh ?? defaultWorkoutTitle(w.start, w.type, 'zh');
        const segments = segmentsById.get(w.id) ?? [];
        return (
          <a
            href={`/workouts/${w.id}`}
            class="workouts-strip-item"
            role="listitem"
            data-href-zh={`/workouts/${w.id}`}
            data-href-en={`/en/workouts/${w.id}`}
            aria-label={titleZh}
          >
            <svg class="ws-track" viewBox="0 0 100 60" preserveAspectRatio="xMidYMid meet" fill="none" stroke-linecap="round">
              {segments.length > 0 ? (
                segments.map((s) => (
                  <line x1={s.x1} y1={s.y1} x2={s.x2} y2={s.y2} stroke={s.color} stroke-width="1.6" />
                ))
              ) : (
                w.trackSvg && <path d={w.trackSvg} stroke="currentColor" stroke-width="1.6" />
              )}
            </svg>
            <div class="ws-meta">
              <div class="ws-name">{titleZh}</div>
              <div class="ws-sub">
                <span>{formatDistance(w.stats?.distanceKm ?? 0)}</span>
                <span>·</span>
                <span>{formatDuration(w.durationSec)}</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
)}

<style>
  .card-workouts .workouts-strip-more {
    font-size: 11px;
    color: var(--c-text-muted);
    text-decoration: none;
    letter-spacing: 0.3px;
    transition: color 0.2s;
    font-variant-numeric: tabular-nums;
  }
  .card-workouts .workouts-strip-more:hover { color: var(--accent); }

  .workouts-strip {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 4px;
    scrollbar-width: thin;
  }
  .workouts-strip::-webkit-scrollbar { height: 4px; }
  .workouts-strip::-webkit-scrollbar-thumb {
    background: rgba(var(--c-overlay-rgb), 0.15);
    border-radius: 2px;
  }

  .workouts-strip-item {
    flex: 0 0 auto;
    width: 200px;
    border-radius: 8px;
    background: rgba(var(--c-overlay-rgb), 0.06);
    color: var(--c-text);
    text-decoration: none;
    padding: 12px;
    scroll-snap-align: start;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .workouts-strip-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
    background: rgba(var(--c-overlay-rgb), 0.10);
  }
  .ws-track {
    width: 100%;
    height: 90px;
    background: rgba(var(--c-overlay-rgb), 0.04);
    border-radius: 4px;
  }
  .ws-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .ws-name {
    font-size: 13px;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ws-sub {
    font-size: 11px;
    color: var(--c-text-muted);
    display: flex;
    gap: 6px;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 480px) {
    .workouts-strip-item { width: 168px; padding: 10px; }
    .ws-track { height: 76px; }
  }
</style>
