---
// src/components/workouts/WorkoutCardPreview.astro
//
// Full-width homepage card matching .card.card-photos:
// section-title-row + horizontal scroll strip. Each tile renders a
// non-interactive Mapbox map with a pace-colored polyline overlay
// (lazy mounted via client:visible). Reads each workout's detail JSON
// at build time to inline the route into the static HTML. CI builds
// without source data render no card.
import { existsSync, readFileSync } from 'node:fs';
import { resolve as resolvePath } from 'node:path';
import { getCollection } from 'astro:content';
import { formatDistance, formatDuration, defaultWorkoutTitle } from './format.mjs';
import RouteMini from './RouteMini.tsx';

const idxPath = resolvePath('./src/data/workouts.json');
const items = (existsSync(idxPath) ? JSON.parse(readFileSync(idxPath, 'utf8')) : []) as Array<any>;

const totalKm = items.reduce((s: number, w: any) => s + (w.stats?.distanceKm ?? 0), 0);
const totalHours = items.reduce((s: number, w: any) => s + (w.durationSec ?? 0), 0) / 3600;

const contentEntries = await getCollection('workouts');
const titleById = new Map(contentEntries.map(e => [e.id.replace(/\.mdx$/, ''), e.data.title]));

// Inline the route per tile so RouteMini gets the data at hydration time
// without an extra fetch.
const routesById = new Map<string, any[]>();
for (const w of items) {
  const detailPath = resolvePath(`./src/data/workouts/${w.id}.json`);
  if (!existsSync(detailPath)) continue;
  const detail = JSON.parse(readFileSync(detailPath, 'utf8'));
  routesById.set(w.id, detail.route ?? []);
}
---
{items.length > 0 && (
  <div class="card card-workouts" id="workouts-card">
    <div class="section-title-row">
      <span class="section-title" data-i18n="sec_workouts">Workouts</span>
      <a class="workouts-strip-more" href="/workouts" data-href-zh="/workouts" data-href-en="/en/workouts" data-i18n="wk_view_all">
        View all →
      </a>
    </div>
    <div class="workouts-strip" role="list">
      {items.map((w: any) => {
        const titleZh = titleById.get(w.id)?.zh ?? defaultWorkoutTitle(w.start, w.type, 'zh');
        const route = routesById.get(w.id) ?? [];
        return (
          <a
            href={`/workouts/${w.id}`}
            class="workouts-strip-item"
            role="listitem"
            data-href-zh={`/workouts/${w.id}`}
            data-href-en={`/en/workouts/${w.id}`}
            aria-label={titleZh}
          >
            <div class="ws-track-wrap">
              <RouteMini route={route} bbox={w.bbox} height={90} client:visible />
            </div>
            <div class="ws-meta">
              <div class="ws-name">{titleZh}</div>
              <div class="ws-sub">
                <span>{formatDistance(w.stats?.distanceKm ?? 0)}</span>
                <span>·</span>
                <span>{formatDuration(w.durationSec)}</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
)}

<style>
  .card-workouts .workouts-strip-more {
    font-size: 11px;
    color: var(--c-text-muted);
    text-decoration: none;
    letter-spacing: 0.3px;
    transition: color 0.2s;
    font-variant-numeric: tabular-nums;
  }
  .card-workouts .workouts-strip-more:hover { color: var(--accent); }

  .workouts-strip {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 4px;
    scrollbar-width: thin;
  }
  .workouts-strip::-webkit-scrollbar { height: 4px; }
  .workouts-strip::-webkit-scrollbar-thumb {
    background: rgba(var(--c-overlay-rgb), 0.15);
    border-radius: 2px;
  }

  .workouts-strip-item {
    flex: 0 0 auto;
    width: 200px;
    border-radius: 8px;
    background: rgba(var(--c-overlay-rgb), 0.06);
    color: var(--c-text);
    text-decoration: none;
    padding: 12px;
    scroll-snap-align: start;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .workouts-strip-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
    background: rgba(var(--c-overlay-rgb), 0.10);
  }
  .ws-track-wrap {
    width: 100%;
    height: 90px;
    background: rgba(var(--c-overlay-rgb), 0.04);
    border-radius: 4px;
    overflow: hidden;
  }
  .ws-track-wrap > div { width: 100%; height: 100%; }
  .ws-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .ws-name {
    font-size: 13px;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ws-sub {
    font-size: 11px;
    color: var(--c-text-muted);
    display: flex;
    gap: 6px;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 480px) {
    .workouts-strip-item { width: 168px; padding: 10px; }
    .ws-track-wrap { height: 76px; }
  }
</style>
