---
// Homepage 3D island card — inline in the cards-grid, full-width.
// R3F mounts lazily on scroll-into-view. Click → /world/.
import IslandWidget from './IslandWidget'
---

<div class="card card-island" id="island-3d">
  <div class="island-card-head">
    <div class="section-title" data-i18n="sec_island_3d">Forest Island · 3D</div>
    <a class="island-card-link" href="/world/">進入 →</a>
  </div>
  <a href="/world/" class="island-card-canvas" id="island-3d-canvas-wrap" aria-label="進入森林岛 — Airing 的 3D 漫游">
    <!-- V33: CSS-only loading skeleton. Visible until Canvas mounts;
         MutationObserver swaps `.island-loaded` to fade it. Kills the
         "blank card" flash on slow networks / before client:visible.
         V45: refined silhouettes — irimoya roof + chimney + shoji glow,
         stone lantern, raked gravel ring, slim layered cedars matching
         R3F palette so the fallback looks like a poster, not a wireframe. -->
    <svg class="island-skeleton" viewBox="0 0 600 300" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <defs>
        <!-- Soil rim cliff under the grass disc -->
        <linearGradient id="cliff-grad" x1="0" x2="0" y1="0" y2="1">
          <stop offset="0" stop-color="#B88560" stop-opacity="0.45" />
          <stop offset="1" stop-color="#6B4530" stop-opacity="0.55" />
        </linearGradient>
        <!-- Shoji glow from cabin interior -->
        <radialGradient id="shoji-glow" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0" stop-color="#FFEFD0" stop-opacity="0.85" />
          <stop offset="1" stop-color="#FFEFD0" stop-opacity="0" />
        </radialGradient>
      </defs>

      <!-- V46: distant mountains behind cedars — depth + "world beyond" -->
      <path d="M -10 168 L 60 138 L 110 152 L 175 122 L 240 148 L 310 130 L 380 150 L 460 128 L 540 146 L 610 134 L 610 200 L -10 200 Z"
            fill="rgba(120, 140, 156, 0.32)" />
      <path d="M -10 184 L 80 158 L 160 174 L 240 156 L 330 174 L 420 158 L 510 172 L 610 162 L 610 210 L -10 210 Z"
            fill="rgba(150, 168, 180, 0.22)" />

      <!-- Island base: grass disc + soil cliff rim -->
      <ellipse cx="300" cy="240" rx="240" ry="14" fill="url(#cliff-grad)" />
      <ellipse cx="300" cy="222" rx="222" ry="20" fill="rgba(168, 199, 122, 0.62)" />
      <!-- Raked gravel: moved in FRONT of cabin (was orbiting under it).
           Tiny center stone breaks negative space. -->
      <ellipse cx="340" cy="232" rx="58" ry="6" fill="none"
               stroke="rgba(230, 218, 192, 0.48)" stroke-width="1.4" />
      <ellipse cx="340" cy="232" rx="44" ry="4.5" fill="none"
               stroke="rgba(197, 185, 143, 0.42)" stroke-width="1" />
      <circle cx="340" cy="232" r="2.5" fill="rgba(126, 115, 104, 0.65)" />
      <!-- Foreground anchor stepping stone, breaks bald center -->
      <ellipse cx="300" cy="234" rx="14" ry="3.5" fill="rgba(70, 62, 54, 0.55)" />

      <!-- Cedars (back left): layered slim flames, asymmetric apex offsets.
           V46: apex jittered ±3px (no party-hat look); cedar 3 darkened. -->
      <g opacity="0.88">
        <!-- Cedar 1 -->
        <rect x="111" y="180" width="3" height="22" fill="rgba(42, 24, 18, 0.55)" />
        <polygon points="104,200 120,200 110,158" fill="rgba(56, 88, 48, 0.62)" />
        <polygon points="106,184 118,184 114,146" fill="rgba(78, 110, 64, 0.55)" />
        <!-- Cedar 2 (taller) -->
        <rect x="142" y="175" width="3" height="25" fill="rgba(42, 24, 18, 0.55)" />
        <polygon points="134,200 152,200 145,148" fill="rgba(56, 88, 48, 0.62)" />
        <polygon points="136,178 150,178 141,134" fill="rgba(78, 110, 64, 0.55)" />
        <!-- Cedar 3 (shorter, front — darker for depth separation) -->
        <rect x="166" y="190" width="3" height="18" fill="rgba(34, 20, 14, 0.60)" />
        <polygon points="160,208 175,208 169,168" fill="rgba(48, 76, 42, 0.70)" />
        <polygon points="162,194 173,194 166,156" fill="rgba(64, 94, 56, 0.60)" />
      </g>

      <!-- Cabin: washi walls + irimoya-suggested roof + chimney + shoji glow -->
      <g>
        <!-- Wall (washi pale) -->
        <rect x="208" y="170" width="92" height="48" fill="rgba(245, 232, 200, 0.78)" />
        <!-- Shoji light spill -->
        <ellipse cx="254" cy="200" rx="32" ry="14" fill="url(#shoji-glow)" />
        <!-- Window cross (shoji grid hint) -->
        <line x1="232" y1="186" x2="276" y2="186" stroke="rgba(58, 37, 22, 0.40)" stroke-width="0.8" />
        <line x1="254" y1="178" x2="254" y2="208" stroke="rgba(58, 37, 22, 0.40)" stroke-width="0.8" />
        <rect x="232" y="178" width="44" height="30" fill="none" stroke="rgba(58, 37, 22, 0.45)" stroke-width="1" />
        <!-- Irimoya roof: Ghibli slate-blue (not battleship-grey) -->
        <polygon points="196,170 312,170 295,150 213,150" fill="rgba(74, 86, 108, 0.92)" />
        <polygon points="213,150 295,150 285,134 223,134" fill="rgba(110, 124, 148, 0.90)" />
        <!-- Ridge cap -->
        <rect x="222" y="132" width="64" height="3" fill="rgba(46, 53, 64, 0.90)" />
        <!-- Chimney + two curls of smoke (single thin S looked like a hair) -->
        <rect x="270" y="120" width="6" height="14" fill="rgba(58, 37, 22, 0.70)" />
        <path d="M273 118 Q 279 112, 272 106 Q 265 100, 272 94"
              fill="none" stroke="rgba(220, 210, 200, 0.55)" stroke-width="2.5" stroke-linecap="round" />
        <path d="M278 110 Q 284 104, 278 98 Q 272 92, 278 86"
              fill="none" stroke="rgba(220, 210, 200, 0.28)" stroke-width="2" stroke-linecap="round" />
      </g>

      <!-- Stone lantern (right-mid, low) -->
      <g opacity="0.78">
        <rect x="358" y="208" width="3" height="14" fill="rgba(126, 115, 104, 0.85)" />
        <rect x="354" y="200" width="11" height="8" fill="rgba(168, 158, 142, 0.85)" />
        <polygon points="350,200 369,200 360,193" fill="rgba(126, 115, 104, 0.85)" />
        <!-- Lantern glow -->
        <circle cx="359" cy="204" r="3" fill="rgba(255, 208, 128, 0.85)" />
      </g>

      <!-- Sakura: weeping branches + canopy mass + dark inner -->
      <g>
        <!-- Branch trunk + curve (stops inside canopy mass) -->
        <path d="M410 222 Q 408 200, 405 180 Q 402 168, 400 158"
              stroke="rgba(58, 37, 22, 0.50)" stroke-width="2" fill="none" stroke-linecap="round" />
        <path d="M405 178 Q 420 174, 428 166" stroke="rgba(58, 37, 22, 0.45)" stroke-width="1.4" fill="none" stroke-linecap="round" />
        <path d="M408 188 Q 392 184, 384 180" stroke="rgba(58, 37, 22, 0.40)" stroke-width="1.2" fill="none" stroke-linecap="round" />
        <!-- Canopy: 3 overlapping ellipses for organic mass -->
        <ellipse cx="395" cy="158" rx="34" ry="26" fill="rgba(240, 175, 195, 0.55)" />
        <ellipse cx="418" cy="148" rx="26" ry="22" fill="rgba(255, 200, 215, 0.50)" />
        <ellipse cx="378" cy="170" rx="22" ry="18" fill="rgba(248, 188, 208, 0.50)" />
        <!-- Fallen petals on ground (3 dots) -->
        <circle cx="392" cy="220" r="1.4" fill="rgba(240, 175, 195, 0.70)" />
        <circle cx="402" cy="222" r="1.1" fill="rgba(255, 200, 215, 0.65)" />
        <circle cx="383" cy="219" r="1.0" fill="rgba(240, 175, 195, 0.55)" />
      </g>

      <!-- Torii: proper kasagi overhang + shimaki ridge + nuki + gakuzuka
           strut + ground shadow. V46 Sub-A nit fix: was flag-on-two-posts. -->
      <g>
        <!-- Ground shadow ellipse (anchors it to the plane) -->
        <ellipse cx="470" cy="224" rx="34" ry="3.5" fill="rgba(40, 30, 25, 0.22)" />
        <!-- Posts (entasis: slightly thicker at base) -->
        <polygon points="447,176 452,176 451,222 448,222" fill="rgba(200, 74, 53, 0.85)" />
        <polygon points="488,176 493,176 492,222 489,222" fill="rgba(200, 74, 53, 0.85)" />
        <!-- Nuki: lower crossbeam, slightly thicker, with end blocks -->
        <rect x="442" y="194" width="56" height="5" fill="rgba(200, 74, 53, 0.85)" />
        <rect x="439" y="195" width="3" height="3" fill="rgba(31, 24, 18, 0.70)" />
        <rect x="498" y="195" width="3" height="3" fill="rgba(31, 24, 18, 0.70)" />
        <!-- Gakuzuka: vertical strut between kasagi and nuki (centerline) -->
        <rect x="468.5" y="176" width="3" height="20" fill="rgba(200, 74, 53, 0.75)" />
        <!-- Kasagi: top beam with upturned tips, 14px overhang per side -->
        <path d="M431 172 Q 470 158, 509 172 L 509 178 L 431 178 Z"
              fill="rgba(31, 24, 18, 0.90)" />
        <!-- Shimaki: thin ridge cap on top of kasagi (subtle highlight) -->
        <path d="M433 170 Q 470 160, 507 170"
              stroke="rgba(60, 48, 40, 0.65)" stroke-width="1.2" fill="none" stroke-linecap="round" />
      </g>

      <!-- Sun: warm orb top-center, now with soft halo bloom -->
      <circle cx="345" cy="85" r="32" fill="rgba(255, 220, 170, 0.18)" />
      <circle cx="345" cy="85" r="22" fill="rgba(255, 232, 192, 0.50)" />
      <circle cx="345" cy="85" r="14" fill="rgba(255, 220, 168, 0.60)" />

      <!-- Subtle pulse breath -->
      <animate attributeName="opacity" values="0.92;0.78;0.92" dur="2.4s" repeatCount="indefinite" />
    </svg>
    <IslandWidget client:visible />
  </a>
</div>

<script is:inline>
  // V40: better WebGL fail detection — synchronous capability check
  // first, then patient (12s) wait for slow networks, then proper
  // canvas ctx probe (canvas can exist + be CSS-sized yet WebGL still
  // failed — don't rely on width=0).
  (function () {
    const wrap = document.getElementById('island-3d-canvas-wrap')
    if (!wrap) return

    // Synchronous fast-path: no WebGL support at all in this browser
    const HAS_WEBGL = (
      'WebGL2RenderingContext' in window ||
      'WebGLRenderingContext' in window
    )
    if (!HAS_WEBGL) {
      wrap.classList.add('island-webgl-failed')
      return
    }

    function isCanvasWorking(canvas) {
      if (!canvas) return false
      // Try to get the actual rendering context — proves WebGL works
      try {
        const ctx = canvas.getContext('webgl2') || canvas.getContext('webgl')
        return !!ctx && !ctx.isContextLost?.()
      } catch {
        return false
      }
    }

    function checkCanvas() {
      const canvas = wrap.querySelector('canvas')
      if (canvas && isCanvasWorking(canvas)) {
        wrap.classList.add('island-loaded')
        return true
      }
      return false
    }

    if (checkCanvas()) return
    const obs = new MutationObserver(() => {
      if (checkCanvas()) obs.disconnect()
    })
    obs.observe(wrap, { childList: true, subtree: true })

    // 12s patience (was 8s — too tight on throttled 3G mobile)
    setTimeout(() => {
      const canvas = wrap.querySelector('canvas')
      if (!canvas || !isCanvasWorking(canvas)) {
        obs.disconnect()
        wrap.classList.add('island-webgl-failed')
      } else if (!wrap.classList.contains('island-loaded')) {
        wrap.classList.add('island-loaded')
      }
    }, 12000)
  })()
</script>

<style>
  .card-island {
    /* V32: keep default .card padding 24px to match neighbors (Footprints,
       Reading, Movies). Inner canvas adapts to that. */
    overflow: hidden;
  }
  .island-card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0;  /* .section-title already has 16px margin-bottom */
  }
  /* V32: scope the i18n .section-title margin reset so it matches the
     adjacent cards' baseline */
  .card-island .section-title {
    margin-bottom: 12px;
  }
  .island-card-link {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 11px;
    color: var(--c-text-muted);
    text-decoration: none;
    transition: color 200ms ease, transform 200ms ease;
  }
  .island-card-link:hover {
    color: var(--c-text);
    transform: translateX(2px);
  }
  .island-card-canvas {
    --island-dwell: 0;
    display: block;
    width: 100%;
    height: 300px;   /* V33: tightened 360→300 to match homepage card-grid rhythm */
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    /* V29: stacked dwell-driven sky gradient. V32: desaturated 10%
       so the widget doesn't out-shout adjacent cards (Footprints map,
       Reading/Movies terminal). The full saturation looked great in
       isolation but broke homepage rhythm. */
    background:
      radial-gradient(
        circle at calc(50% + var(--island-dwell) * 8%) calc(28% + var(--island-dwell) * 14%),
        color-mix(in oklab, #F4EED4 calc((1 - var(--island-dwell)) * 100%), #F5DAB0) 0%,
        color-mix(in oklab, #DCE8ED calc((1 - var(--island-dwell)) * 100%), #F4CC9C) 28%,
        color-mix(in oklab, #B8CFDC calc((1 - var(--island-dwell)) * 100%), #DAA888) 60%,
        color-mix(in oklab, #8FAAC0 calc((1 - var(--island-dwell)) * 100%), #B57860) 100%
      );
    cursor: pointer;
    transition: filter 240ms ease, transform 240ms ease;
  }
  .island-card-canvas:hover {
    filter: brightness(1.05) saturate(1.08);
    transform: translateY(-1px);
  }
  .island-card-canvas canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }

  @media (max-width: 800px) {
    .island-card-canvas { height: 220px; }
  }
  @media (max-width: 480px) {
    .island-card-canvas { height: 180px; }
  }

  /* V33: skeleton positioned above canvas, fades out on canvas detect */
  .island-skeleton {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
    transition: opacity 0.9s ease;
  }
  .island-card-canvas.island-loaded .island-skeleton {
    opacity: 0;
  }
  /* V39: WebGL failed → keep skeleton fully visible, add subtle hint */
  .island-card-canvas.island-webgl-failed .island-skeleton {
    opacity: 1 !important;
    animation: none;
  }
  .island-card-canvas.island-webgl-failed::after {
    content: 'WebGL 未启用 — 点击进入完整页面';
    position: absolute;
    bottom: 12px;
    left: 0;
    right: 0;
    text-align: center;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 11px;
    color: rgba(244, 234, 213, 0.82);
    text-shadow: 0 1px 2px rgba(40, 30, 20, 0.45);
    z-index: 3;
    pointer-events: none;
  }
  /* V34: prefers-reduced-motion → show skeleton-only (friendlier than
     hiding the card entirely). Disable auto-fade so skeleton persists. */
  @media (prefers-reduced-motion: reduce) {
    .island-card-canvas .island-skeleton {
      opacity: 1 !important;
      animation: none;
    }
    .island-card-canvas > a-island-mount,
    .island-card-canvas > div[data-react-mount] {
      display: none;
    }
  }
</style>
