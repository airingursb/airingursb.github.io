---
// Floating Forest Island PET — fixed bottom-right of the homepage.
// V51 redesign: was an inline card in the cards-grid (V32-V50). User
// asked to move to corner like a desktop pet, but NOT picture-in-picture
// style — so: no frame, no border, no card shadow, no title bar.
// Just the island silhouette floating freely on the page.
//
// R3F mounts lazily on scroll-into-view (still — first scroll typically
// happens within a few seconds of page load anyway).
// Click the whole pet → /world/.
import IslandWidget from './IslandWidget'
---

<!-- V51 a11y: role=link wrapper (not <a> — interactive canvas inside
     <a> is invalid HTML). Keyboard activation wired via JS. -->
<div role="link" tabindex="0" data-href="/world/" class="island-pet" id="island-3d-canvas-wrap"
     aria-label="进入森林岛 — Airing 的 3D 漫游" aria-busy="true">
  <!-- WebGL-loading / failed skeleton (tiny pet silhouette) -->
  <svg class="island-skeleton" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
    <defs>
      <linearGradient id="pet-cliff" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0" stop-color="#B88560" stop-opacity="0.55" />
        <stop offset="1" stop-color="#6B4530" stop-opacity="0.65" />
      </linearGradient>
      <radialGradient id="pet-shoji" cx="0.5" cy="0.5" r="0.5">
        <stop offset="0" stop-color="#FFEFD0" stop-opacity="0.9" />
        <stop offset="1" stop-color="#FFEFD0" stop-opacity="0" />
      </radialGradient>
    </defs>
    <!-- Distant mountain (single, simpler than full skeleton) -->
    <path d="M 0 100 L 35 78 L 70 92 L 110 68 L 150 88 L 200 76 L 200 130 L 0 130 Z"
          fill="rgba(135, 155, 170, 0.32)" />
    <!-- Island base (grass disc + soil cliff) -->
    <ellipse cx="100" cy="170" rx="92" ry="8" fill="url(#pet-cliff)" />
    <ellipse cx="100" cy="158" rx="86" ry="14" fill="rgba(168, 199, 122, 0.72)" />
    <!-- Two cedars (left) -->
    <g opacity="0.88">
      <polygon points="32,160 46,160 39,108" fill="rgba(56, 88, 48, 0.72)" />
      <polygon points="50,162 64,162 57,114" fill="rgba(48, 76, 42, 0.78)" />
    </g>
    <!-- Cabin: irimoya roof + shoji glow + chimney smoke -->
    <g>
      <rect x="74" y="120" width="48" height="34" fill="rgba(245, 232, 200, 0.88)" />
      <ellipse cx="98" cy="142" rx="18" ry="9" fill="url(#pet-shoji)" />
      <line x1="84" y1="132" x2="112" y2="132" stroke="rgba(58, 37, 22, 0.45)" stroke-width="0.7" />
      <line x1="98" y1="124" x2="98" y2="146" stroke="rgba(58, 37, 22, 0.45)" stroke-width="0.7" />
      <polygon points="64,120 132,120 124,104 72,104" fill="rgba(74, 86, 108, 0.94)" />
      <polygon points="72,104 124,104 117,92 79,92" fill="rgba(110, 124, 148, 0.92)" />
      <rect x="78" y="90" width="40" height="3" fill="rgba(46, 53, 64, 0.92)" />
      <rect x="108" y="80" width="4" height="10" fill="rgba(58, 37, 22, 0.72)" />
      <path d="M110 78 Q 114 72, 110 66" stroke="rgba(220, 210, 200, 0.55)" stroke-width="1.8" fill="none" stroke-linecap="round" />
    </g>
    <!-- Sakura right -->
    <g>
      <path d="M152 158 Q 150 138, 148 124" stroke="rgba(58, 37, 22, 0.50)" stroke-width="1.5" fill="none" stroke-linecap="round" />
      <ellipse cx="148" cy="120" rx="18" ry="14" fill="rgba(240, 175, 195, 0.62)" />
      <ellipse cx="160" cy="112" rx="13" ry="11" fill="rgba(255, 200, 215, 0.55)" />
    </g>
    <!-- Torii (small, right edge) -->
    <g>
      <rect x="172" y="128" width="2.5" height="28" fill="rgba(200, 74, 53, 0.85)" />
      <rect x="186" y="128" width="2.5" height="28" fill="rgba(200, 74, 53, 0.85)" />
      <path d="M168 126 Q 180 119, 192 126 L 192 130 L 168 130 Z" fill="rgba(31, 24, 18, 0.92)" />
      <rect x="170" y="140" width="20" height="2" fill="rgba(200, 74, 53, 0.85)" />
    </g>
    <!-- Subtle breath -->
    <animate attributeName="opacity" values="0.95;0.78;0.95" dur="2.6s" repeatCount="indefinite" />
  </svg>
  <IslandWidget client:visible />
  <!-- V50 a11y: WebGL-failed hint as REAL element (CSS ::after is
       skipped by most screen readers); visibility toggled by JS. -->
  <span class="island-pet-hint" aria-live="polite" hidden>需要 WebGL · 点击进入完整页面</span>

  <!-- V53.4: inline onclick as PRIMARY handler. addEventListener can
       race with hover-state pointer-events flips and gets cancelled by
       the wrapper's click listener if order is wrong; inline onclick
       runs in capture phase before bubbling and can't be intercepted
       by the wrapper. event.stopPropagation() prevents the wrap's
       navigate-to-/world/ from firing on cycle. -->
  <div class="island-pet-panel" aria-hidden="true">
    <p class="island-pet-quote">山深闻鹧鸪。</p>
    <div class="island-pet-actions">
      <button type="button"
              class="island-pet-chip"
              data-action="enter"
              onclick="event.stopPropagation(); window.location.href='/world/';">进入森林岛 →</button>
      <button type="button"
              class="island-pet-chip island-pet-chip-ghost"
              data-action="cycle"
              aria-label="换一句"
              onclick="event.stopPropagation(); event.preventDefault(); window.__islandPetCycle && window.__islandPetCycle();">↻ 换一句</button>
    </div>
  </div>
</div>

<script is:inline>
  // V51 floating pet: same WebGL detection logic as the V40-V50 card
  // version, just applied to the pet wrapper. Keyboard nav, aria-busy
  // toggle, hint reveal — all preserved.
  (function () {
    const wrap = document.getElementById('island-3d-canvas-wrap')
    if (!wrap) return

    const HAS_WEBGL = (
      'WebGL2RenderingContext' in window ||
      'WebGLRenderingContext' in window
    )
    function showHint(visible) {
      const hint = wrap.querySelector('.island-pet-hint')
      if (hint) hint.hidden = !visible
    }
    function setBusy(busy) {
      wrap.setAttribute('aria-busy', busy ? 'true' : 'false')
    }

    if (!HAS_WEBGL) {
      wrap.classList.add('island-webgl-failed')
      showHint(true)
      setBusy(false)
      return
    }

    function isCanvasWorking(canvas) {
      if (!canvas) return false
      try {
        const ctx = canvas.getContext('webgl2') || canvas.getContext('webgl')
        return !!ctx && !ctx.isContextLost?.()
      } catch {
        return false
      }
    }

    function checkCanvas() {
      const canvas = wrap.querySelector('canvas')
      if (canvas && isCanvasWorking(canvas)) {
        wrap.classList.add('island-loaded')
        setBusy(false)
        return true
      }
      return false
    }

    if (checkCanvas()) return
    const obs = new MutationObserver(() => {
      if (checkCanvas()) obs.disconnect()
    })
    obs.observe(wrap, { childList: true, subtree: true })

    setTimeout(() => {
      const canvas = wrap.querySelector('canvas')
      if (!canvas || !isCanvasWorking(canvas)) {
        obs.disconnect()
        wrap.classList.add('island-webgl-failed')
        showHint(true)
        setBusy(false)
      } else if (!wrap.classList.contains('island-loaded')) {
        wrap.classList.add('island-loaded')
        setBusy(false)
      }
    }, 12000)

    // Click + keyboard activation
    wrap.addEventListener('click', (e) => {
      // V53: don't navigate when a chip absorbed the click
      if ((e.target instanceof Element) && e.target.closest('.island-pet-chip')) return
      location.href = wrap.dataset.href || '/world/'
    })
    wrap.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        // Don't fire pet-level enter if a chip is focused
        if ((e.target instanceof Element) && e.target.closest('.island-pet-chip')) return
        e.preventDefault()
        location.href = wrap.dataset.href || '/world/'
      }
    })

    // ─── V53: hover overlay (quote + chips, lang-aware) ───
    // V53.2: wrapped in try/catch. If anything throws, the inline
    // defaults in HTML still show ("山深闻鹧鸪。" + "进入森林岛 →" +
    // "↻ 换一句") so the UI is usable even without JS upgrade.
    try {
    const panel = wrap.querySelector('.island-pet-panel')
    const quoteEl = wrap.querySelector('.island-pet-quote')
    const enterChip = wrap.querySelector('.island-pet-chip[data-action=enter]')
    const cycleChip = wrap.querySelector('.island-pet-chip[data-action=cycle]')
    if (!panel || !quoteEl || !enterChip || !cycleChip) {
      console.warn('[island-pet] panel/chip elements missing — using HTML defaults')
      return
    }

    const QUOTES_ZH = [
      '松风过耳，落英满衣。',
      '此中有真意，欲辨已忘言。',
      '云在青天水在瓶。',
      '一花一世界，一叶一菩提。',
      '白云深处有人家。',
      '万物静观皆自得。',
      '小岛承天地之闲，木屋藏岁月之声。',
      '不识庐山真面目，只缘身在此山中。',
      '山色有无中。',
      '闲来无事不从容。',
      '千江有水千江月。',
      '春有百花秋有月。',
      '心远地自偏。',
      '行到水穷处，坐看云起时。',
      '空山新雨后。',
      '明月松间照。',
      '独坐幽篁里，弹琴复长啸。',
      '君问归期未有期。',
      '山中无历日。',
      '寒山转苍翠。',
      '落叶他乡树，寒灯独夜人。',
      '山高自有客行路。',
      '风起于青萍之末。',
      '此曲只应天上有。',
      '渔舟唱晚。',
      '雨打芭蕉。',
      '月落乌啼霜满天。',
      '浮云一别后，流水十年间。',
      '何当共剪西窗烛。',
      '山光悦鸟性。',
      '但远山长，云山乱，晓山青。',
      '不畏浮云遮望眼。',
      '我心安处是吾乡。',
      '闲云潭影日悠悠。',
      '一蓑烟雨任平生。',
      '也无风雨也无晴。',
      '海上明月共潮生。',
      '大风起兮云飞扬。',
      '山高月小，水落石出。',
      '林尽水源便得一山。',
      '风萧萧兮易水寒。',
      '雁字回时，月满西楼。',
      '念去去，千里烟波。',
      '醉里挑灯看剑。',
      '大江东去。',
      '江山如画。',
      '一江春水向东流。',
      '庭院深深深几许。',
      '寒夜客来茶当酒。',
      '山是眉峰聚。',
      '道法自然。',
      '上善若水。',
      '大道至简。',
      '见素抱朴。',
      '知者不言，言者不知。',
      '涉江采芙蓉。',
      '人闲桂花落。',
      '时见鹿，溪午不闻钟。',
      '山深闻鹧鸪。',
      '山中一夜雨，树杪百重泉。',
      '江流天地外。',
      '雪夜访戴，兴尽而返。',
      '醒时同交欢，醉后各分散。',
      '永结无情游，相期邈云汉。',
      '此情可待成追忆。',
      '沧浪之水清兮。',
      '渡头余落日。',
      '墟里上孤烟。',
      '山雨欲来风满楼。',
      '一片孤城万仞山。',
      '二月春风似剪刀。',
      '沾衣欲湿杏花雨。',
      '吹面不寒杨柳风。',
      '春风又绿江南岸。',
      '谁家玉笛暗飞声，散入春风满洛城。',
      '落霞与孤鹜齐飞，秋水共长天一色。',
      '落木千山天远大。',
      '澄江一道月分明。',
      '万壑树参天，千山响杜鹃。',
      '山中相送罢，日暮掩柴扉。',
      '春草明年绿，王孙归不归。',
      '听取蛙声一片。',
      '稻花香里说丰年。',
      '七八个星天外，两三点雨山前。',
      '旧时茅店社林边，路转溪桥忽见。',
      '千山鸟飞绝，万径人踪灭。',
      '孤舟蓑笠翁，独钓寒江雪。',
      '此心安处，便是吾乡。',
      '采菊东篱下，悠然见南山。',
      '岁月忽已晚。',
      '人生天地之间，若白驹之过隙。',
      '逝者如斯夫。',
      '海内存知己，天涯若比邻。',
      '人生若只如初见。',
      '清风明月本无价。',
      '近水远山皆有情。',
      '世事一场大梦，人生几度新凉。',
      '坐到三更尽，归仍万里赊。',
      '今宵剩把银釭照，犹恐相逢是梦中。',
      '一蓑烟雨，半生归来。',
      '心闲是清福。',
      '万物皆有裂痕，那是光照进来的地方。',
    ]
    const QUOTES_EN = [
      'Pine wind in your ear; petals on your sleeve.',
      'Find meaning here — and forget how to say it.',
      'A small island holds the whole sky.',
      "The chimney smoke knows things you don't.",
      'Sit. Listen. The well still rings.',
      'One leaf, one universe.',
      'Drift in. Drift out.',
      'The cabin is open. Always.',
      'Some doors stay open even when no one is home.',
      'The lantern keeps its own time.',
      'Wind through pine; that is the lesson.',
      'The bridge is short. The view is long.',
      'Trees grow slow. Then everywhere.',
      'Even the smallest pond holds the moon.',
      'Sweep the gravel. Then sweep again.',
      'The sakura forgets nothing.',
      'Old wood, kind weather.',
      'Walk softly. The island is sleeping.',
      'The torii faces somewhere worth going.',
      'A house is just a roof and a hearth.',
      'There are mountains behind the mountains.',
      'The path will not move; you must.',
      'The stones remember where the river was.',
      'A petal in the pond is also the pond.',
      'Cabin: warm. World: large.',
      'The bamboo knows the wind by name.',
      'Some silence is louder than rain.',
      "The lantern is full of yesterday's flame.",
      'Inside every island, a longer road.',
      'The garden is patient with you.',
      'There are rivers in the cedars.',
      'The well is older than the cabin.',
      'The cabin door is shut, but the latch is unsnapped.',
      "The petals fall on schedule. The schedule is not yours.",
      'Sit by the basin until the basin sits in you.',
      'Even fog has favorite places.',
      'The mountain leans toward visitors.',
      'A small fire writes a long letter.',
      'Wind hates closed windows.',
      'The cherry tree is also a clock.',
      'The cabin is awake when the chimney is dreaming.',
      'There is moss under your feet that has never been touched.',
      'A swept path is a quiet conversation.',
      'The torii knows what it is and is unworried.',
      'Forget your name at the threshold.',
      'The lantern goes out, but the warmth stays.',
      'Each stepping stone is a small decision.',
      'The cedar has been waiting for you.',
      'A roof angle this old has its own thoughts.',
      'The path does not bend; the walker does.',
      'There is a longer hour between rooms.',
      'Slow rivers carry the heaviest news.',
      'The well drinks the sky one cupful at a time.',
      'The shoji glow is older than the door.',
      'Some trees grew here for someone else.',
      'Open the window. Close the laptop.',
      'The island floats because nothing is holding it.',
      'Wind is the chair the cabin sits in.',
      'A pine tree is mostly silence.',
      'The bridge is also a place to stand.',
      'The cabin has only one room. It is large.',
      'The lantern is not lonely; it is private.',
      'Even a cedar bends, just slowly.',
      'Sweep first. Decide later.',
      "The basin's water is wiser than the basin.",
      'There is news in the way smoke leaves.',
      'The path forgets nothing but forgives everything.',
      'A single petal is a small chime.',
      'The roof knows seasons by their footsteps.',
      'The forest is loudest at dusk.',
      'Stones in a row are a thought.',
      'The torii leans only toward the inside.',
      'Sky is bigger when you sit down.',
      'A garden is a long, patient sentence.',
      "The cherry tree drops gifts you didn't earn.",
      'Even shadows have favorite corners.',
      'The well is honest about its emptiness.',
      'Cabin firewood remembers being a tree.',
      'The mountain forgot it was a verb.',
      'Petals are the cherry tree saying yes.',
      'The path goes on whether you do or not.',
      'A small house with a low door asks for humility.',
      'The wind is patient — it has all afternoon.',
      'The cedar trunks are warm at noon.',
      'The lantern has burned many evenings to be this dim.',
      'A clean floor is a clean conversation.',
      'There is no rush in the rain.',
      'The mountain holds the sky still for you.',
      'Listen with your knees in the moss.',
      'The path turns left, then forgets why.',
      'The basin holds whatever you put in it.',
      'The cabin door has been opened many ways.',
      'Smoke ties the cabin to the sky.',
      'A torii admits no haste.',
      'The petals fall sideways when no one is looking.',
      'The garden was never asking for visitors.',
      'The path is short; the walk is long.',
      'There is slow news in the pine needles.',
      'Sit with the lantern until the lantern sits with you.',
      'The cabin is small. The night is large.',
      'There is a crack in everything — that is how the light gets in.',
    ]
    const CHIP_LABELS = {
      zh: { enter: '进入森林岛 →', cycle: '↻ 换一句' },
      en: { enter: 'Enter the forest →', cycle: '↻ Another' },
    }

    function detectLang() {
      // Priority: site's window.currentLang (set after i18n loads) →
      // html.lang attribute → localStorage → navigator.
      if (typeof window.currentLang === 'string') {
        if (window.currentLang === 'en' || window.currentLang === 'zh') return window.currentLang
      }
      const htmlLang = (document.documentElement.lang || '').toLowerCase()
      if (htmlLang.startsWith('en')) return 'en'
      if (htmlLang.startsWith('zh')) return 'zh'
      const ls = (typeof localStorage !== 'undefined' && localStorage.getItem('preferred_lang')) || ''
      if (ls === 'en' || ls === 'zh') return ls
      const nav = (navigator.language || 'en').toLowerCase()
      return nav.startsWith('zh') ? 'zh' : 'en'
    }

    let quoteIdx = Math.floor(Math.random() * QUOTES_ZH.length)
    function applyLang() {
      const lang = detectLang()
      const pool = lang === 'zh' ? QUOTES_ZH : QUOTES_EN
      if (quoteEl) quoteEl.textContent = pool[quoteIdx % pool.length]
      if (enterChip) enterChip.textContent = CHIP_LABELS[lang].enter
      if (cycleChip) cycleChip.textContent = CHIP_LABELS[lang].cycle
    }
    applyLang()
    // V53: defer one more pass after site's i18n promise resolves
    // (window.currentLang + html.lang aren't set until then on first load).
    if (window._i18nReady && typeof window._i18nReady.then === 'function') {
      window._i18nReady.then(applyLang).then(() => {
        // and once more after applyTranslations runs (microtask later)
        setTimeout(applyLang, 50)
      })
    }
    window.addEventListener('langchange', applyLang)

    // V53.1: panel show/hide is now PURE CSS (.island-pet:hover →
    // .island-pet-panel) with a 400ms transition-delay reproducing
    // the dwell feel. JS dwell timer was removed because user reported
    // the panel wasn't appearing reliably; CSS :hover is bulletproof.
    // aria-hidden is also driven by the same hover state via the
    // mouseenter/leave listeners below (for SR accessibility).
    wrap.addEventListener('mouseenter', () => panel?.setAttribute('aria-hidden', 'false'))
    wrap.addEventListener('mouseleave', () => panel?.setAttribute('aria-hidden', 'true'))
    wrap.addEventListener('focusin',    () => panel?.setAttribute('aria-hidden', 'false'))
    wrap.addEventListener('focusout', (e) => {
      if (!wrap.contains(e.relatedTarget)) panel?.setAttribute('aria-hidden', 'true')
    })

    // V53.4: cycle function exposed on window so the inline onclick
    // attribute on the cycle chip can call it. addEventListener also
    // wired as fallback in case inline onclick is blocked (CSP etc.).
    window.__islandPetCycle = function () {
      quoteIdx = (quoteIdx + 1) % (detectLang() === 'zh' ? QUOTES_ZH.length : QUOTES_EN.length)
      applyLang()
    }
    function navEnter(e) {
      e.stopPropagation()
      location.href = wrap.dataset.href || '/world/'
    }
    function navCycle(e) {
      e.stopPropagation()
      e.preventDefault()
      window.__islandPetCycle()
    }
    enterChip.addEventListener('click', navEnter)
    enterChip.addEventListener('pointerup', navEnter)
    cycleChip.addEventListener('click', navCycle)
    cycleChip.addEventListener('pointerup', navCycle)
    } catch (err) {
      console.error('[island-pet] panel init failed:', err)
    }
  })()
</script>

<style is:global>
  /* V51 floating pet — fixed bottom-right, NO frame / NO box-shadow /
     NO card. The island silhouette floats freely on the page like a
     desktop pet. User constraint: "不能用画中画的方式" — no PiP
     framing under any circumstance. */
  .island-pet {
    position: fixed;
    /* V53: moved to bottom-LEFT (was bottom-right). Right-bottom had
       theme-switcher + easter-hint sharing the corner; left-bottom is
       wide-open on this site. */
    bottom: 20px;
    left: 20px;
    width: 220px;
    height: 220px;
    z-index: 90;            /* above content, below modals (100+) */
    cursor: pointer;
    background: transparent;
    border: none;
    border-radius: 0;
    overflow: visible;
    pointer-events: auto;
    transition: transform 240ms ease, filter 240ms ease;
    /* Drop-shadow on the SCENE silhouette only, not a card around it.
       filter:drop-shadow follows alpha channel, so it traces the island
       outline — no box. This is what separates "pet" from "PiP frame". */
    filter: drop-shadow(0 6px 14px rgba(40, 50, 60, 0.18));
  }
  .island-pet:hover {
    transform: translateY(-2px) scale(1.02);
    filter: drop-shadow(0 10px 20px rgba(40, 50, 60, 0.26))
            brightness(1.04) saturate(1.06);
  }
  .island-pet:focus-visible {
    outline: 2px solid var(--c-accent, #6ABE5C);
    outline-offset: 4px;
    border-radius: 8px;
  }
  .island-pet canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
    background: transparent;
  }

  /* Skeleton fills the same area, fades out fast when canvas loaded
     (V51 fix: 0.9s fade left a visible ghost overlap — now 0.35s + a
     longer-delayed display:none to fully remove from compositing). */
  .island-pet .island-skeleton {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
