---
// Floating Forest Island PET — fixed bottom-right of the homepage.
// V51 redesign: was an inline card in the cards-grid (V32-V50). User
// asked to move to corner like a desktop pet, but NOT picture-in-picture
// style — so: no frame, no border, no card shadow, no title bar.
// Just the island silhouette floating freely on the page.
//
// R3F mounts lazily on scroll-into-view (still — first scroll typically
// happens within a few seconds of page load anyway).
// Click the whole pet → /world/.
import IslandWidget from './IslandWidget'
---

<!-- V51 a11y: role=link wrapper (not <a> — interactive canvas inside
     <a> is invalid HTML). Keyboard activation wired via JS. -->
<div role="link" tabindex="0" data-href="/world/" class="island-pet" id="island-3d-canvas-wrap"
     aria-label="进入森林岛 — Airing 的 3D 漫游" aria-busy="true">
  <!-- WebGL-loading / failed skeleton (tiny pet silhouette) -->
  <svg class="island-skeleton" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
    <defs>
      <linearGradient id="pet-cliff" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0" stop-color="#B88560" stop-opacity="0.55" />
        <stop offset="1" stop-color="#6B4530" stop-opacity="0.65" />
      </linearGradient>
      <radialGradient id="pet-shoji" cx="0.5" cy="0.5" r="0.5">
        <stop offset="0" stop-color="#FFEFD0" stop-opacity="0.9" />
        <stop offset="1" stop-color="#FFEFD0" stop-opacity="0" />
      </radialGradient>
    </defs>
    <!-- Distant mountain (single, simpler than full skeleton) -->
    <path d="M 0 100 L 35 78 L 70 92 L 110 68 L 150 88 L 200 76 L 200 130 L 0 130 Z"
          fill="rgba(135, 155, 170, 0.32)" />
    <!-- Island base (grass disc + soil cliff) -->
    <ellipse cx="100" cy="170" rx="92" ry="8" fill="url(#pet-cliff)" />
    <ellipse cx="100" cy="158" rx="86" ry="14" fill="rgba(168, 199, 122, 0.72)" />
    <!-- Two cedars (left) -->
    <g opacity="0.88">
      <polygon points="32,160 46,160 39,108" fill="rgba(56, 88, 48, 0.72)" />
      <polygon points="50,162 64,162 57,114" fill="rgba(48, 76, 42, 0.78)" />
    </g>
    <!-- Cabin: irimoya roof + shoji glow + chimney smoke -->
    <g>
      <rect x="74" y="120" width="48" height="34" fill="rgba(245, 232, 200, 0.88)" />
      <ellipse cx="98" cy="142" rx="18" ry="9" fill="url(#pet-shoji)" />
      <line x1="84" y1="132" x2="112" y2="132" stroke="rgba(58, 37, 22, 0.45)" stroke-width="0.7" />
      <line x1="98" y1="124" x2="98" y2="146" stroke="rgba(58, 37, 22, 0.45)" stroke-width="0.7" />
      <polygon points="64,120 132,120 124,104 72,104" fill="rgba(74, 86, 108, 0.94)" />
      <polygon points="72,104 124,104 117,92 79,92" fill="rgba(110, 124, 148, 0.92)" />
      <rect x="78" y="90" width="40" height="3" fill="rgba(46, 53, 64, 0.92)" />
      <rect x="108" y="80" width="4" height="10" fill="rgba(58, 37, 22, 0.72)" />
      <path d="M110 78 Q 114 72, 110 66" stroke="rgba(220, 210, 200, 0.55)" stroke-width="1.8" fill="none" stroke-linecap="round" />
    </g>
    <!-- Sakura right -->
    <g>
      <path d="M152 158 Q 150 138, 148 124" stroke="rgba(58, 37, 22, 0.50)" stroke-width="1.5" fill="none" stroke-linecap="round" />
      <ellipse cx="148" cy="120" rx="18" ry="14" fill="rgba(240, 175, 195, 0.62)" />
      <ellipse cx="160" cy="112" rx="13" ry="11" fill="rgba(255, 200, 215, 0.55)" />
    </g>
    <!-- Torii (small, right edge) -->
    <g>
      <rect x="172" y="128" width="2.5" height="28" fill="rgba(200, 74, 53, 0.85)" />
      <rect x="186" y="128" width="2.5" height="28" fill="rgba(200, 74, 53, 0.85)" />
      <path d="M168 126 Q 180 119, 192 126 L 192 130 L 168 130 Z" fill="rgba(31, 24, 18, 0.92)" />
      <rect x="170" y="140" width="20" height="2" fill="rgba(200, 74, 53, 0.85)" />
    </g>
    <!-- Subtle breath -->
    <animate attributeName="opacity" values="0.95;0.78;0.95" dur="2.6s" repeatCount="indefinite" />
  </svg>
  <IslandWidget client:visible />
  <!-- V50 a11y: WebGL-failed hint as REAL element (CSS ::after is
       skipped by most screen readers); visibility toggled by JS. -->
  <span class="island-pet-hint" aria-live="polite" hidden>需要 WebGL · 点击进入完整页面</span>
</div>

<script is:inline>
  // V51 floating pet: same WebGL detection logic as the V40-V50 card
  // version, just applied to the pet wrapper. Keyboard nav, aria-busy
  // toggle, hint reveal — all preserved.
  (function () {
    const wrap = document.getElementById('island-3d-canvas-wrap')
    if (!wrap) return

    const HAS_WEBGL = (
      'WebGL2RenderingContext' in window ||
      'WebGLRenderingContext' in window
    )
    function showHint(visible) {
      const hint = wrap.querySelector('.island-pet-hint')
      if (hint) hint.hidden = !visible
    }
    function setBusy(busy) {
      wrap.setAttribute('aria-busy', busy ? 'true' : 'false')
    }

    if (!HAS_WEBGL) {
      wrap.classList.add('island-webgl-failed')
      showHint(true)
      setBusy(false)
      return
    }

    function isCanvasWorking(canvas) {
      if (!canvas) return false
      try {
        const ctx = canvas.getContext('webgl2') || canvas.getContext('webgl')
        return !!ctx && !ctx.isContextLost?.()
      } catch {
        return false
      }
    }

    function checkCanvas() {
      const canvas = wrap.querySelector('canvas')
      if (canvas && isCanvasWorking(canvas)) {
        wrap.classList.add('island-loaded')
        setBusy(false)
        return true
      }
      return false
    }

    if (checkCanvas()) return
    const obs = new MutationObserver(() => {
      if (checkCanvas()) obs.disconnect()
    })
    obs.observe(wrap, { childList: true, subtree: true })

    setTimeout(() => {
      const canvas = wrap.querySelector('canvas')
      if (!canvas || !isCanvasWorking(canvas)) {
        obs.disconnect()
        wrap.classList.add('island-webgl-failed')
        showHint(true)
        setBusy(false)
      } else if (!wrap.classList.contains('island-loaded')) {
        wrap.classList.add('island-loaded')
        setBusy(false)
      }
    }, 12000)

    // Click + keyboard activation
    wrap.addEventListener('click', () => { location.href = wrap.dataset.href || '/world/' })
    wrap.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault()
        location.href = wrap.dataset.href || '/world/'
      }
    })
  })()
</script>

<style is:global>
  /* V51 floating pet — fixed bottom-right, NO frame / NO box-shadow /
     NO card. The island silhouette floats freely on the page like a
     desktop pet. User constraint: "不能用画中画的方式" — no PiP
     framing under any circumstance. */
  .island-pet {
    position: fixed;
    /* V51.1: bottom offset clears the theme-switcher button + easter-
       hint pill that also live in the bottom-right corner. */
    bottom: 76px;
    right: 16px;
    width: 220px;
    height: 220px;
    z-index: 90;            /* above content, below modals (100+) */
    cursor: pointer;
    background: transparent;
    border: none;
    border-radius: 0;
    overflow: visible;
    pointer-events: auto;
    transition: transform 240ms ease, filter 240ms ease;
    /* Drop-shadow on the SCENE silhouette only, not a card around it.
       filter:drop-shadow follows alpha channel, so it traces the island
       outline — no box. This is what separates "pet" from "PiP frame". */
    filter: drop-shadow(0 6px 14px rgba(40, 50, 60, 0.18));
  }
  .island-pet:hover {
    transform: translateY(-2px) scale(1.02);
    filter: drop-shadow(0 10px 20px rgba(40, 50, 60, 0.26))
            brightness(1.04) saturate(1.06);
  }
  .island-pet:focus-visible {
    outline: 2px solid var(--c-accent, #6ABE5C);
    outline-offset: 4px;
    border-radius: 8px;
  }
  .island-pet canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
    background: transparent;
  }

  /* Skeleton fills the same area, fades out fast when canvas loaded
     (V51 fix: 0.9s fade left a visible ghost overlap — now 0.35s + a
     longer-delayed display:none to fully remove from compositing). */
  .island-pet .island-skeleton {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .island-pet.island-loaded .island-skeleton {
    opacity: 0;
    /* Wait for fade to finish, then remove from layer tree entirely
       so we never see ghost overlap on slow GPUs. */
    animation: island-skel-disappear 0.4s ease forwards;
  }
  @keyframes island-skel-disappear {
    to { visibility: hidden; }
  }

  /* WebGL-failed: keep skeleton visible (it IS the fallback) + show hint */
  .island-pet.island-webgl-failed .island-skeleton {
    opacity: 1 !important;
    animation: none;
    visibility: visible;
  }
  .island-pet-hint {
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translate(-50%, 100%);
    padding: 4px 10px;
    background: rgba(28, 22, 18, 0.84);
    color: rgba(252, 244, 226, 0.96);
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 10px;
    border-radius: 10px;
    z-index: 3;
    pointer-events: none;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    white-space: nowrap;
  }

  /* Tablet: shrink slightly + still clear theme-switcher */
  @media (max-width: 1024px) and (min-width: 801px) {
    .island-pet {
      width: 180px;
      height: 180px;
      bottom: 70px;
      right: 14px;
    }
  }

  /* Mobile: hide entirely — floating pet over scrolling content on
     touch screens is annoying + steals taps from the actual cards. */
  @media (max-width: 800px) {
    .island-pet {
      display: none;
    }
  }

  /* Reduced motion: kill hover lift + transitions (R3F frameloop also
     drops to "demand" via PREFERS_REDUCED_MOTION in island-shared.ts). */
  @media (prefers-reduced-motion: reduce) {
    .island-pet {
      transition: none;
    }
    .island-pet:hover {
      transform: none;
      filter: drop-shadow(0 6px 14px rgba(40, 50, 60, 0.18));
    }
    .island-pet .island-skeleton {
      animation: none;
    }
  }
</style>
