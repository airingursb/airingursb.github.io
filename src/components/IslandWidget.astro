    const QUOTES_EN = [
      'Pine wind in your ear; petals on your sleeve.',
      'Find meaning here — and forget how to say it.',
      'A small island holds the whole sky.',
      'Sit. Listen. The well still rings.',
      'One leaf, one universe.',
      'Drift in. Drift out.',
      'The cabin is open. Always.',
      'Some doors stay open even when no one is home.',
      'The lantern keeps its own time.',
      'The bridge is short. The view is long.',
      'Trees grow slow. Then everywhere.',
      'Even the smallest pond holds the moon.',
      'Sweep the gravel. Then sweep again.',
      'The sakura forgets nothing.',
      'Old wood, kind weather.',
      'Walk softly. The island is sleeping.',
      'The torii faces somewhere worth going.',
      'A house is just a roof and a hearth.',
      'There are mountains behind the mountains.',
      'The path will not move; you must.',
      'The stones remember where the river was.',
      'A petal in the pond is also the pond.',
      'The bamboo knows the wind by name.',
      'Some silence is louder than rain.',
      "The lantern is full of yesterday's flame.",
      'Inside every island, a longer road.',
      'The garden is patient with you.',
      'There are rivers in the cedars.',
      'The well is older than the cabin.',
      'The cabin door is shut, but the latch is unsnapped.',
      "The petals fall on schedule. The schedule is not yours.",
      'Sit by the basin until the basin sits in you.',
      'Even fog has favorite places.',
      'The mountain leans toward visitors.',
      'A small fire writes a long letter.',
      'Wind hates closed windows.',
      'The cherry tree is also a clock.',
      'The cabin is awake when the chimney is dreaming.',
      'There is moss under your feet that has never been touched.',
      'A swept path is a quiet conversation.',
      'The torii knows what it is and is unworried.',
      'Forget your name at the threshold.',
      'The lantern goes out, but the warmth stays.',
      'Each stepping stone is a small decision.',
      'The cedar has been waiting for you.',
      'A roof angle this old has its own thoughts.',
      'The path does not bend; the walker does.',
      'There is a longer hour between rooms.',
      'Slow rivers carry the heaviest news.',
      'The well drinks the sky one cupful at a time.',
      'The shoji glow is older than the door.',
      'Some trees grew here for someone else.',
      'The island floats because nothing is holding it.',
      'Wind is the chair the cabin sits in.',
      'A pine tree is mostly silence.',
      'The bridge is also a place to stand.',
      'The cabin has only one room. It is large.',
      'The lantern is not lonely; it is private.',
      'Even a cedar bends, just slowly.',
      'Sweep first. Decide later.',
      "The basin's water is wiser than the basin.",
      'There is news in the way smoke leaves.',
      'The path forgets nothing but forgives everything.',
      'A single petal is a small chime.',
      'The roof knows seasons by their footsteps.',
      'The forest is loudest at dusk.',
      'Stones in a row are a thought.',
      'The torii leans only toward the inside.',
      'Sky is bigger when you sit down.',
      'A garden is a long, patient sentence.',
      "The cherry tree drops gifts you didn't earn.",
      'Even shadows have favorite corners.',
      'The well is honest about its emptiness.',
      'Cabin firewood remembers being a tree.',
      'Petals are the cherry tree saying yes.',
      'The path goes on whether you do or not.',
      'A small house with a low door asks for humility.',
      'The wind is patient — it has all afternoon.',
      'The cedar trunks are warm at noon.',
      'The lantern has burned many evenings to be this dim.',
      'A clean floor is a clean conversation.',
      'There is no rush in the rain.',
      'The mountain holds the sky still for you.',
      'Listen with your knees in the moss.',
      'The path turns left, then forgets why.',
      'The basin holds whatever you put in it.',
      'The cabin door has been opened many ways.',
      'Smoke ties the cabin to the sky.',
      'A torii admits no haste.',
      'The petals fall sideways when no one is looking.',
      'The garden was never asking for visitors.',
      'The path is short; the walk is long.',
      'There is slow news in the pine needles.',
      'Sit with the lantern until the lantern sits with you.',
      'The cabin is small. The night is large.',
    ]
    // Chip labels — JUST the text part (arrow/icon are in separate
    // <span>s inside the button HTML, so applyLang() updates only
    // the .island-pet-chip-label span, preserving the icon spans
    // for their hover/spin micro-interactions).
    // EN must be SHORT to fit 220px panel after the cycle chip + gap
    // — anything > ~9 chars truncates. 'Enter the forest' was 16 chars
    // and got clipped to 'Enter the f' on first deploy. Tighten.
    const CHIP_LABELS = {
      zh: { enter: '进入森林岛', cycle: '换一句', cycleIcon: '另' },
      en: { enter: 'Step in',    cycle: 'Next',  cycleIcon: '↻' },
    }

    // Expose quote pools on window so the inline cycle handler can
    // read from the SAME source as applyLang() — without this, the
    // chip cycles within the duplicated data-quotes-* JSON pool while
    // language switches read from this JS pool, silently diverging
    // (off-by-one risk + drift across visits).
    window.__islandQuotes = { zh: QUOTES_ZH, en: QUOTES_EN }

    // Splits text into word-grouped per-character spans:
    //   "Hi 你" → <span.qw><span.qc>H</span><span.qc>i</span></span>
    //             " "
    //             <span.qw><span.qc>你</span></span>
    // .qw is inline-block + white-space:nowrap → atomic, won't break.
    // Whitespace between .qw's is a real text node → legal wrap point.
    // Without this grouping, per-char .qc spans broke EN words mid-
    // character (e.g. "everyth|ing"). Each .qc gets a staggered
    // animation-delay via --i. CJK chars are treated as single-char
    // words so each one is its own atomic unit (Chinese has no inter-
    // word whitespace; CSS line-break handles inter-char wrap).
    window.__setIslandQuote = function(el, text) {
      if (!el || typeof text !== 'string') return
      // CJK + fullwidth punctuation range — each is its own "word"
      var cjk = /[　-〿一-鿿＀-￯]/
      // Classical Chinese couplets are parallel two-clause structures
      // joined by 「，」 — visually they read best with a break after
      // the comma. Detect this pattern (quote contains BOTH ， and 。)
      // and emit a <br> token after each ， to preserve the parallelism.
      var hasCoupletBreak = /，/.test(text) && /。/.test(text)
      var tokens = []
      var i = 0
      while (i < text.length) {
        var ch = text[i]
        if (/\s/.test(ch)) {
          tokens.push({ type: 'space', text: ch })
          i++
        } else if (cjk.test(ch)) {
          tokens.push({ type: 'word', text: ch })
          // After a couplet comma, force a line break
          if (hasCoupletBreak && ch === '，' && i < text.length - 1) {
            tokens.push({ type: 'br' })
          }
          i++
        } else {
          // Latin/digit word — accumulate until whitespace or CJK
          var w = ''
          while (i < text.length && !/\s/.test(text[i]) && !cjk.test(text[i])) {
            w += text[i]
            i++
          }
          tokens.push({ type: 'word', text: w })
        }
      }
      // Build TWO trees in parallel:
      // - visual: per-char .qc spans inside .qw word atoms, aria-hidden
      //   so screen readers don't announce each char/word as a fragment
      // - sr: a .sr-only sibling carrying the plain text. Parent <p>
      //   has aria-live="polite" + aria-atomic — AT announces ONLY the
      //   sr-only content as one cohesive update on cycle.
      var visual = document.createElement('span')
      visual.className = 'island-pet-quote-visual'
      visual.setAttribute('aria-hidden', 'true')
      var charIdx = 0
      for (var t = 0; t < tokens.length; t++) {
        var tok = tokens[t]
        if (tok.type === 'space') {
          visual.appendChild(document.createTextNode(tok.text))
        } else if (tok.type === 'br') {
          visual.appendChild(document.createElement('br'))
        } else {
          var word = document.createElement('span')
          word.className = 'qw'
          var chars = Array.from(tok.text)
          for (var k = 0; k < chars.length; k++) {
            var span = document.createElement('span')
            span.className = 'qc'
            // Cap --i at 16 so the LAST char finishes at 16*20+520=840ms
            // — any higher and the panel feels "still loading".
            var seq = charIdx < 16 ? charIdx : 16
            span.style.setProperty('--i', String(seq))
            span.textContent = chars[k]
            word.appendChild(span)
            charIdx++
          }
          visual.appendChild(word)
        }
      }
      var srOnly = document.createElement('span')
      srOnly.className = 'sr-only'
      srOnly.textContent = text
      el.textContent = ''
      el.appendChild(visual)
      el.appendChild(srOnly)
    }

    function detectLang() {
      // Priority: site's window.currentLang (set after i18n loads) →
      // html.lang attribute → localStorage → navigator.
      if (typeof window.currentLang === 'string') {
        if (window.currentLang === 'en' || window.currentLang === 'zh') return window.currentLang
      }
      const htmlLang = (document.documentElement.lang || '').toLowerCase()
      if (htmlLang.startsWith('en')) return 'en'
      if (htmlLang.startsWith('zh')) return 'zh'
      const ls = (typeof localStorage !== 'undefined' && localStorage.getItem('preferred_lang')) || ''
      if (ls === 'en' || ls === 'zh') return ls
      const nav = (navigator.language || 'en').toLowerCase()
      return nav.startsWith('zh') ? 'zh' : 'en'
    }

    // Clamp random range to the SHORTER pool so an EN viewer who
    // happens to draw idx=101 doesn't wrap-modulo silently to 0
    // (biasing the EN first-quote distribution toward index 0).
    const minPoolLen = Math.min(QUOTES_ZH.length, QUOTES_EN.length)
    // Single source of truth for the current quote index: stored on
    // window so the inline cycle handler can read+write the SAME
    // value applyLang reads. Without this, cycling 3× then switching
    // language would let applyLang read a stale module-local quoteIdx
    // and jump the quote backward.
    window.__islandQuoteIdx = Math.floor(Math.random() * minPoolLen)
    // Track previous language so we can detect actual switches and
    // pick a fresh random idx — without this, switching from ZH idx 67
    // to EN reuses idx 67, which is a semantically unrelated quote in
    // the other pool (tonal jump). Reset = no jarring carry-over.
    let lastLang = null
    function applyLang() {
      const lang = detectLang()
      const pool = lang === 'zh' ? QUOTES_ZH : QUOTES_EN
      if (lastLang !== null && lastLang !== lang) {
        window.__islandQuoteIdx = Math.floor(Math.random() * pool.length)
      }
      lastLang = lang
      const idx = (window.__islandQuoteIdx ?? 0) % pool.length
      if (quoteEl) {
        // Per-char stagger via shared helper. Falls back to plain
        // textContent if helper somehow missing (defensive — the
        // helper is defined a few lines above in the same IIFE).
        if (typeof window.__setIslandQuote === 'function') {
          window.__setIslandQuote(quoteEl, pool[idx])
        } else {
          quoteEl.textContent = pool[idx]
        }
        // Sync data-idx so the inline cycle handler's next click
        // advances from THIS visible quote (idx+1), not from the
        // HTML-default data-idx="0".
        quoteEl.setAttribute('data-idx', String(idx))
        // Set lang attr so VoiceOver/NVDA pronounce ZH/EN with the
        // correct voice instead of the page-wide <html lang> default.
        quoteEl.setAttribute('lang', lang)
      }
      // Update ONLY the label spans — preserve the .island-pet-arrow
      // and .island-pet-cycle-icon spans for their micro-animations.
      const enterLabel = enterChip?.querySelector('.island-pet-chip-label')
      const cycleLabel = cycleChip?.querySelector('.island-pet-chip-label')
      const cycleIcon  = cycleChip?.querySelector('.island-pet-cycle-icon')
      if (enterLabel) enterLabel.textContent = CHIP_LABELS[lang].enter
      if (cycleLabel) cycleLabel.textContent = CHIP_LABELS[lang].cycle
      // Lang-aware icon: ZH "另" (serif), EN "↻" (geometric). The
      // press-down animation works on both — no rotation now so the
      // CJK-vs-geometric divide doesn't matter.
      if (cycleIcon) cycleIcon.textContent = CHIP_LABELS[lang].cycleIcon
    }
    applyLang()
    // V53: defer one more pass after site's i18n promise resolves
    // (window.currentLang + html.lang aren't set until then on first load).
    if (window._i18nReady && typeof window._i18nReady.then === 'function') {
      window._i18nReady.then(applyLang).then(() => {
        // and once more after applyTranslations runs (microtask later)
        setTimeout(applyLang, 50)
      })
    }
    window.addEventListener('langchange', applyLang)
    // Flip aria-live from "off" to "polite" AFTER the initial render +
    // i18n settles. Otherwise screen readers announce the random first-
    // load quote as if it were a live update. Now only true CYCLE
    // events trigger announcements.
    setTimeout(() => {
      if (quoteEl) quoteEl.setAttribute('aria-live', 'polite')
    }, 200)

    // V53.1: panel show/hide is now PURE CSS (.island-pet:hover →
    // .island-pet-panel) with a 400ms transition-delay reproducing
    // the dwell feel. JS dwell timer was removed because user reported
    // the panel wasn't appearing reliably; CSS :hover is bulletproof.
    // Use the `inert` property (instead of aria-hidden) so the chips
    // become both keyboard-reachable AND AT-exposed on hover/focus
    // without triggering the aria-hidden-focus axe rule.
    function setInert(yes) { if (panel) panel.inert = yes }
    wrap.addEventListener('mouseenter', () => setInert(false))
    wrap.addEventListener('mouseleave', () => setInert(true))
    wrap.addEventListener('focusin',    () => setInert(false))
    wrap.addEventListener('focusout', (e) => {
      if (!wrap.contains(e.relatedTarget)) setInert(true)
    })

    // V53.5: chip handlers are ENTIRELY inline (HTML onclick attributes
    // on the buttons). Don't bind addEventListener — it would fire AFTER
    // the inline onclick and stomp on its textContent change with the
    // JS pool's value. Inline onclick is the sole, authoritative chip
    // handler.
    } catch (err) {
      console.error('[island-pet] panel init failed:', err)
    }
  })()
</script>

<style is:global>
  /* V51 floating pet — fixed bottom-right, NO frame / NO box-shadow /
     NO card. The island silhouette floats freely on the page like a
     desktop pet. User constraint: "不能用画中画的方式" — no PiP
     framing under any circumstance. */
  .island-pet {
    position: fixed;
    /* V53: moved to bottom-LEFT (was bottom-right). Right-bottom had
       theme-switcher + easter-hint sharing the corner; left-bottom is
       wide-open on this site. */
    bottom: 20px;
    left: 20px;
    width: 220px;
    height: 220px;
    z-index: 90;            /* above content, below modals (100+) */
    cursor: pointer;
    background: transparent;
    border: none;
    border-radius: 0;
    overflow: visible;
    pointer-events: auto;
    transition: transform 240ms ease, filter 240ms ease;
    /* Drop-shadow on the SCENE silhouette only, not a card around it.
       filter:drop-shadow follows alpha channel, so it traces the island
       outline — no box. This is what separates "pet" from "PiP frame". */
    filter: drop-shadow(0 6px 14px rgba(40, 50, 60, 0.18));
    /* Pet lift transitions immediately (it's the user's hover ack),
       but the brightness/saturate boost is delayed 120ms to match
       the panel's entry delay — otherwise the scene gets "louder"
       at the exact moment the quote is trying to bloom into view. */
    transition: transform 220ms cubic-bezier(0.22, 0.61, 0.36, 1),
                filter 280ms ease-out 120ms;
  }
  .island-pet:hover {
    /* Killed scale(1.02) — was competing with the panel's
       transform animation (translateY 10→0 + scale 0.985→1) for
       visual attention. Just the -2px lift is enough to register
       hover without making the whole frame feel busy. */
    transform: translateY(-2px);
    filter: drop-shadow(0 10px 20px rgba(40, 50, 60, 0.26))
            brightness(1.04) saturate(1.06);
  }
  .island-pet:focus-visible {
    outline: 2px solid var(--c-accent, #6ABE5C);
    outline-offset: 4px;
    border-radius: 8px;
  }
  .island-pet canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
    background: transparent;
  }

  /* Skeleton fills the same area, fades out fast when canvas loaded
     (V51 fix: 0.9s fade left a visible ghost overlap — now 0.35s + a
     longer-delayed display:none to fully remove from compositing). */
  .island-pet .island-skeleton {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .island-pet.island-loaded .island-skeleton {
    opacity: 0;
    /* Wait for fade to finish, then remove from layer tree entirely
       so we never see ghost overlap on slow GPUs. */
    animation: island-skel-disappear 0.4s ease forwards;
  }
  @keyframes island-skel-disappear {
    to { visibility: hidden; }
  }

  /* WebGL-failed: keep skeleton visible (it IS the fallback) + show hint */
  .island-pet.island-webgl-failed .island-skeleton {
    opacity: 1 !important;
    animation: none;
    visibility: visible;
  }

  /* ── Click-fx overlay ──────────────────────────────────────────
     Sits on top of the canvas but below the panel/chips. JS spawns
     burst <div>s in here on pet click; each burst contains particles
     animated by CSS keyframes. Effects spawn where they NATURALLY
     originate (snow/sakura from top, wind from a side, mist from
     bottom, moonglow from click point) — not all from click. */
  .island-pet-fx {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    /* z-index 3 sits between canvas (auto) and panel (z:4).
       transform: translateZ(0) PROMOTES this layer to its own
       compositor layer — without it, Chrome's WebGL canvas paints
       above sibling CSS-positioned elements regardless of z-index. */
    z-index: 3;
    transform: translateZ(0);
    border-radius: inherit;
  }
  .island-fx-burst {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .island-fx-p {
    position: absolute;
    display: block;
    /* Individual z-index so each particle is positioned by browser
       — defensively above the WebGL canvas which can otherwise
       composite on top of CSS-positioned siblings. */
    z-index: 1;
    will-change: transform, opacity;
  }

  /* ── 飘雪 ── Variable-size flakes drift down from top with sin-
     wave horizontal sway. Multi-step keyframe approximates a sine
     curve for natural rocking motion. Staggered delays make the
     burst feel like continuous flow, not a single explosion. */
  .island-fx-snow .island-fx-p {
    top: -8px;
    left: var(--x);
    width: var(--s);
    height: var(--s);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    box-shadow:
      0 0 calc(var(--s) * 1.2) rgba(255, 255, 255, 0.55),
      0 0 calc(var(--s) * 2.4) rgba(255, 250, 240, 0.18);
    opacity: 0;
    animation: fx-snow-drift var(--fall) linear var(--d) forwards;
  }
  /* Parallax strata: far flakes blurred + dim (depth illusion),
     near flakes crisp + slightly larger. */
  .island-fx-snow-far {
    filter: blur(1.2px);
  }
  .island-fx-snow-near {
    filter: blur(0.2px);
  }
  @keyframes fx-snow-drift {
    0%   { opacity: 0;          transform: translate3d(0, 0, 0)                                                       rotate(var(--rot)); }
    6%   { opacity: var(--op); }
    25%  {                       transform: translate3d(calc(var(--wobble)  * 1   * var(--wobble-dir)),  70px, 0)     rotate(calc(var(--rot) + 90deg)); }
    50%  {                       transform: translate3d(calc(var(--wobble)  * -1  * var(--wobble-dir)), 140px, 0)     rotate(calc(var(--rot) + 180deg)); }
    75%  {                       transform: translate3d(calc(var(--wobble)  * 0.6 * var(--wobble-dir)), 200px, 0)     rotate(calc(var(--rot) + 270deg)); }
    92%  { opacity: var(--op); }
    100% { opacity: 0;           transform: translate3d(calc(var(--wobble)  * -0.3 * var(--wobble-dir)), 250px, 0)    rotate(calc(var(--rot) + 360deg)); }
  }

  /* ── 吹风 ── Horizontal streaks cross the scene from one side
     to the other. Pill-shaped with a horizontal gradient so the
     leading edge fades. Each streak has subtle vertical drift +
     opacity envelope for an organic gust feel. */
  /* Wind streaks: ink-wash smear (not pill) using radial-gradient
     ellipse for soft edges all around. Heavy blur eliminates the
     "edge" feel of a line. Air has no edges; sumi-e has no rulers. */
  .island-fx-wind .island-fx-p {
    top: var(--y);
    width: var(--len);
    height: var(--w);
    border-radius: 100px;
    background: radial-gradient(ellipse 80% 60% at 50% 50%,
                  rgba(255, 250, 240, var(--op)) 0%,
                  rgba(255, 250, 240, calc(var(--op) * 0.5)) 50%,
                  transparent 90%);
    opacity: 0;
    filter: blur(2.5px);
  }
  .island-fx-wind-ltr .island-fx-p {
    left: 0;
    animation: fx-wind-ltr var(--cross) cubic-bezier(0.32, 0.6, 0.5, 1) var(--d) forwards;
  }
  .island-fx-wind-rtl .island-fx-p {
    right: 0;
    animation: fx-wind-rtl var(--cross) cubic-bezier(0.32, 0.6, 0.5, 1) var(--d) forwards;
  }
  /* Arc paths: the streak rises slightly then falls (or vice versa)
     during its journey, giving a 3-point bezier curve feel. --arc
     is the mid-flight vertical offset (positive or negative). */
  @keyframes fx-wind-ltr {
    0%   { opacity: 0; transform: translate3d(calc(var(--len) * -1 - 20px), 0, 0); }
    20%  { opacity: 1; }
    50%  {              transform: translate3d(calc(var(--journey) * 0.5), var(--arc), 0); }
    80%  { opacity: 1; }
    100% { opacity: 0; transform: translate3d(var(--journey), var(--vdrift), 0); }
  }
  @keyframes fx-wind-rtl {
    0%   { opacity: 0; transform: translate3d(calc(var(--len) * 1 + 20px), 0, 0); }
    20%  { opacity: 1; }
    50%  {              transform: translate3d(calc(var(--journey) * -0.5), var(--arc), 0); }
    80%  { opacity: 1; }
    100% { opacity: 0; transform: translate3d(calc(var(--journey) * -1), var(--vdrift), 0); }
  }

  /* ── 落樱 ── Cherry petals FLUTTER (don't spin). The rotateY axis
     turns the petal edge-on at mid-flight — opacity drops near 35%
     and 70% to convey "the petal turned away from us." Z rotation
     stays modest (120-280°) so it reads as drift, not fidget-spin.
     The gap (間) where it nearly disappears IS the elegance. */
  .island-fx-sakura .island-fx-p {
    top: -10px;
    left: var(--x);
    width: var(--s);
    height: calc(var(--s) * 1.15);
    background: radial-gradient(ellipse 70% 100% at 50% 30%, #F8D6E2 0%, #EFB1C6 60%, #C77E96 100%);
    border-radius: 50% 50% 50% 50% / 65% 65% 35% 35%;
    box-shadow: 0 1px 2px rgba(180, 90, 120, 0.18);
    filter: hue-rotate(var(--hue));
    opacity: 0;
    transform-style: preserve-3d;
    animation: fx-sakura-fall var(--fall) linear var(--d) forwards;
  }
  @keyframes fx-sakura-fall {
    0%   { opacity: 0;    transform: translate3d(0, 0, 0)                                                rotateZ(0deg)                                  rotateY(0deg); }
    8%   { opacity: 0.95; }
    25%  {                 transform: translate3d(calc(var(--rock) *  1   * var(--rock-dir)),  60px, 0)  rotateZ(calc(var(--rz) * 0.3))                  rotateY(calc(var(--ry) * 0.22)); }
    35%  { opacity: 0.45;  }  /* edge-on: nearly disappears */
    50%  { opacity: 0.92; transform: translate3d(calc(var(--rock) * -1   * var(--rock-dir)), 130px, 0)  rotateZ(calc(var(--rz) * 0.55))                 rotateY(calc(var(--ry) * 0.5)); }
    70%  { opacity: 0.4;  }  /* second edge-on */
    75%  {                 transform: translate3d(calc(var(--rock) *  0.7 * var(--rock-dir)), 195px, 0)  rotateZ(calc(var(--rz) * 0.8))                  rotateY(calc(var(--ry) * 0.78)); }
    92%  { opacity: 0.85; }
    100% { opacity: 0;    transform: translate3d(calc(var(--rock) * -0.4 * var(--rock-dir)), 250px, 0)  rotateZ(var(--rz))                              rotateY(var(--ry)); }
  }

  /* ── 月华 ── Steady warm bloom (lantern-glow) + floating kotodama
     embers rising. NO expansion — lanterns don't ripple. The bloom
     brightens then fades in place; embers drift up like sparks. */
  .island-fx-moonglow .island-fx-bloom-core {
    top: var(--cy);
    left: var(--cx);
    width: 120px;
    height: 120px;
    transform: translate(-50%, -50%) scale(0.9);
    border-radius: 50%;
    background: radial-gradient(circle,
                  rgba(255, 222, 170, 0.55) 0%,
                  rgba(255, 200, 140, 0.32) 30%,
                  rgba(255, 184, 96, 0.12) 60%,
                  transparent 85%);
    filter: blur(4px);
    opacity: 0;
    animation: fx-bloom 2200ms cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
  }
  @keyframes fx-bloom {
    0%   { opacity: 0;   transform: translate(-50%, -50%) scale(0.85); }
    35%  { opacity: 1;   transform: translate(-50%, -50%) scale(1.05); }
    100% { opacity: 0;   transform: translate(-50%, -50%) scale(1); }
  }
  .island-fx-moonglow .island-fx-bloom-ember {
    top: var(--cy);
    left: var(--cx);
    width: var(--es);
    height: var(--es);
    border-radius: 50%;
    background: rgba(255, 220, 160, 0.9);
    box-shadow:
      0 0 6px rgba(255, 200, 140, 0.7),
      0 0 14px rgba(255, 180, 100, 0.3);
    opacity: 0;
    animation: fx-ember 1900ms cubic-bezier(0.4, 0, 0.6, 1) var(--d) forwards;
  }
  @keyframes fx-ember {
    0%   { opacity: 0;   transform: translate(-50%, -50%) scale(0.4); }
    20%  { opacity: 0.95; transform: translate(calc(-50% + var(--dx) * 0.3), calc(-50% + var(--dy) * 0.3), 0) scale(1); }
    100% { opacity: 0;   transform: translate(calc(-50% + var(--dx)),       calc(-50% + var(--dy)),       0) scale(0.6); }
  }

  /* ── 烟雾 ── Wisps rise from the bottom of the fx layer + drift
     laterally. Elongated soft white blobs with low max opacity +
     blur. Reads like steam from the cabin chimney filtering up
     through the scene. */
  .island-fx-mist .island-fx-p {
    bottom: 0;
    left: var(--x);
    width: var(--w);
    height: var(--h);
    border-radius: 50%;
    background: radial-gradient(ellipse 100% 70% at 50% 50%,
                  rgba(255, 255, 255, var(--op)) 0%,
                  rgba(245, 245, 250, calc(var(--op) * 0.6)) 45%,
                  transparent 78%);
    filter: blur(5px);
    /* screen blend mode lifts the highlights of the scene below
       without overwhelming it — fog should make the scene MORE,
       not less, visible. */
    mix-blend-mode: screen;
    opacity: 0;
    transform: translateY(20px);
    animation: fx-mist-rise var(--rise) ease-out var(--d) forwards;
  }
  @keyframes fx-mist-rise {
    0%   { opacity: 0;            transform: translate3d(0,             20px, 0) scale(0.85); }
    20%  { opacity: var(--op); }
    50%  {                         transform: translate3d(calc(var(--drift) * 0.6), -90px, 0) scale(1.05); }
    85%  { opacity: var(--op); }
    100% { opacity: 0;            transform: translate3d(var(--drift), -180px, 0) scale(1.3); }
  }

  /* Honor prefers-reduced-motion — skip the fx animations entirely.
     Brief opacity flash only; no vestibular-disorder triggers. */
  @media (prefers-reduced-motion: reduce) {
    .island-fx-p {
      animation: none !important;
      opacity: 0 !important;
    }
  }
  .island-pet-hint {
    position: absolute;
    /* V52.8 (Sub-A polish): was bottom:-4px which placed the pill
       in the theme-switcher's vertical band (24-60px from viewport
       bottom). Moved to top:-4px translate(-50%, -100%) — pill sits
       above the pet, away from the theme switcher entirely, and
       reads more naturally as a label pointing down at the broken
       widget. */
    top: -4px;
    left: 50%;
    transform: translate(-50%, -100%);
    padding: 4px 10px;
    background: rgba(28, 22, 18, 0.84);
    color: rgba(252, 244, 226, 0.96);
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 10px;
    border-radius: 10px;
    z-index: 3;
    pointer-events: none;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    white-space: nowrap;
  }

  /* V53.1: 1300px gate (per user). Below 1300 the homepage cards
     compress and a left-bottom pet collides with content. */
  @media (max-width: 1300px) {
    .island-pet {
      display: none;
    }
  }

  /* V53.3: hover panel sits FLUSH on top of the pet (no margin gap).
     The 12px gap in V53.2 created a "dead zone" between pet and panel
     where :hover fires off → pointer-events flips back to none →
     clicks miss when cursor traverses up to chips. Flush + transparent
     hover-bridge ::after below the panel guarantees continuous :hover.
     pointer-events: auto held for an extra 250ms on hover-out as a
     belt-and-suspenders measure (instant flip-back could still race
     a slow click). */
  .island-pet-panel {
    position: absolute;
    bottom: 100%;        /* flush with pet top */
    left: 0;
    width: 100%;         /* = 220px (matches pet) */
    padding: 14px 16px;
    /* Slightly warmer near-black — sits between the panel and the
       pet's cedar/soil dominant tones instead of a neutral void. */
    background: rgba(26, 20, 16, 0.88);
    color: rgba(252, 244, 226, 0.96);
    /* Square BOTTOM corners so the panel reads as a continuation of
       the pet (one stacked shape) instead of a popup card with a
       14px notch on either side where it meets the pet's top edge. */
    border-radius: 14px 14px 0 0;
    backdrop-filter: blur(10px) saturate(1.1);
    -webkit-backdrop-filter: blur(10px) saturate(1.1);
    /* Shadow color now matches the pet's drop-shadow blue-grey
       (rgba(40,50,60)) so panel + pet read as lit by the same source. */
    box-shadow: 0 10px 28px rgba(40, 50, 60, 0.32);
    box-sizing: border-box;
    opacity: 0;
    transform: translateY(10px) scale(0.985);
    transform-origin: bottom center;
    /* Ink-unfurl reveal: clip-path collapses the panel against its
       bottom edge so it appears to "unroll upward" like a scroll.
       Round corners ONLY on top (matches border-radius) so the
       bottom edge stays flush against the pet. */
    clip-path: inset(100% 0 0 0 round 14px 14px 0 0);
    /* Slower fade-OUT (380ms ease-in) feels intentional — the panel
       doesn't snap away when the cursor leaves. The :hover rule below
       overrides with a fast cubic-bezier entry curve.
       pointer-events flip-back DELAYED 250ms so if the cursor crosses
       the bottom edge of the pet too quickly while moving to a chip,
       the chip stays clickable through the exit animation. Discrete
       prop, but transition-delay still applies. */
    transition: opacity 380ms ease-in,
                transform 360ms cubic-bezier(0.4, 0.0, 0.2, 1),
                clip-path 360ms cubic-bezier(0.4, 0.0, 0.2, 1),
                pointer-events 0s linear 250ms;
    pointer-events: none;
    z-index: 4;
  }
  .island-pet:hover .island-pet-panel,
  .island-pet:focus-within .island-pet-panel,
  .island-pet.is-revealed .island-pet-panel {
    opacity: 1;
    transform: translateY(0) scale(1);
    clip-path: inset(0 0 0 0 round 14px 14px 0 0);
    pointer-events: auto;
    /* Entry is faster + springier than exit, with a 120ms dwell delay
       so quick mouse-throughs don't flash the panel. Calligraphy /
       contemplative aesthetic — the panel takes a breath before opening.
       pointer-events flips ON immediately (no delay) — chips become
       clickable as soon as the panel starts opening. */
    transition: opacity 260ms cubic-bezier(0.22, 0.61, 0.36, 1) 120ms,
                transform 320ms cubic-bezier(0.16, 0.84, 0.32, 1.06) 120ms,
                clip-path 360ms cubic-bezier(0.22, 0.61, 0.36, 1) 120ms,
                pointer-events 0s linear 0s;
  }
  /* Decorative vermillion 閒 seal — bottom-right of the panel.
     Visually links the panel to the chip's shu-iro red without
     adding a noisy element. Slight rotation echoes a hand-stamped
     calligraphy seal. Suppressed for screen readers (aria-hidden). */
  .island-pet-seal {
    position: absolute;
    right: 12px;
    top: 10px;
    width: 14px;
    height: 14px;
    line-height: 14px;
    text-align: center;
    font-family: "Songti SC", "Noto Serif SC", serif;
    font-size: 10px;
    font-weight: 700;
    color: rgba(252, 240, 224, 0.96);
    /* Unified shu-iro — seal, chip, and the torii in the 3D scene
       all share rgba(208, 86, 54). Earlier crimson push (220,70,40)
       was a SECOND red competing with the chip's red. The seal is
       distinguished by being SQUARE + ROTATED + tiny — color
       differentiation isn't needed. */
    background: rgba(208, 86, 54, 0.95);
    /* 1px not 2px — at 14×14 a 2px radius reads as "rounded square"
       and fights the panel's soft 14px corners. Historical stone-
       carved seals are essentially square; 1px keeps that physics. */
    border-radius: 1px;
    transform: rotate(-5deg);
    opacity: 0;
    pointer-events: none;
    user-select: none;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.22),
                inset 0 0 0 0.5px rgba(252, 240, 224, 0.25);
    letter-spacing: 0;
  }
  /* Seal "stamps" as the LAST beat of the reveal wave — after the
     panel finishes unrolling (~480ms) AND after the first bunch of
     chars have bloomed in. 980ms delay lands it just as the eye
     reaches the end of a 2-line quote. The overshoot scale + ease
     mimics a calligraphy seal being pressed and lifting back. */
  @keyframes seal-stamp {
    0%   { opacity: 0;    transform: rotate(-5deg) scale(1.45); }
    55%  { opacity: 0.86; transform: rotate(-5deg) scale(0.92); }
    100% { opacity: 0.78; transform: rotate(-5deg) scale(1); }
  }
  .island-pet:hover .island-pet-seal,
  .island-pet:focus-within .island-pet-seal,
  .island-pet.is-revealed .island-pet-seal {
    animation: seal-stamp 320ms cubic-bezier(0.34, 1.56, 0.64, 1) 980ms both;
  }
  /* V53.3: invisible safety cushion ABOVE the pet (where the old gap
     used to be). Just in case any layout fluctuation creates a 1-2px
     dead band — this pseudo-element extends the pet's :hover region
     upward by 16px so the cursor can never land between pet and panel
     in a non-hovered state. */
  .island-pet::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 100%;
    height: 16px;
    pointer-events: auto;
  }
  .island-pet-quote {
    /* Right padding (22px) gives the 14px seal in the top-right
       corner a no-overlap gutter so the first line wraps before
       reaching it, instead of mid-word ("cu/pful" was the bug). */
    margin: 0 0 14px;
    padding-right: 22px;
    font-family: "Songti SC", "Noto Serif SC", "Times New Roman", serif;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(248, 232, 200, 0.94);
    letter-spacing: 0.04em;
    /* Reserve two lines of vertical space so cycling between a
       short quote (4 chars) and a long couplet doesn't bounce
       the chip row underneath. */
    min-height: calc(14px * 1.7 * 2);
    /* Subtle text-shadow on dark panel gives the serif strokes a
       hint of ink-on-paper weight without losing legibility. */
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
    /* keep-all: don't break between CJK chars within a "word".
       overflow-wrap: anywhere — safety net for hypothetical 30+
       char unbreakable EN word (URL, technical term) that would
       otherwise overflow the 220px panel. "anywhere" (not "break-
       word") lets the wrap opportunity count toward min-content
       sizing, preventing parent overflow. Combined with keep-all,
       normal CJK + EN wrap unchanged. */
    word-break: keep-all;
    overflow-wrap: anywhere;
    /* Soft-clip runaway quotes at ~3 lines so a hypothetical
       50+ char quote can't push the chips off-screen. */
    max-height: calc(14px * 1.7 * 3);
    overflow: hidden;
  }
  /* Word-grouped per-character ink-bloom.
     .qw = word atom (one EN word, or one CJK char). inline-block +
     nowrap so the chars inside never break across lines. Wrap points
     are the real whitespace text nodes BETWEEN .qw's.
     .qc = single char inside a word. Staggered animation delay via
     --i index assigned in JS. Looks like brushstrokes landing. */
  .island-pet-quote .qw {
    display: inline-block;
    white-space: nowrap;
    /* Safety net for hypothetical 30+ char unbreakable EN word — the
       parent .island-pet-quote already has overflow-wrap: anywhere
       but it can't reach inside .qw without an inner opt-in. */
    overflow-wrap: anywhere;
  }
  /* Visually-hidden screen-reader sibling — carries the plain quote
     text for aria-live announcements. Visual .qw/.qc tree is aria-
     hidden so AT doesn't read each char as a fragment. */
  .island-pet-quote .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
    /* Prevent copy-paste duplication — without this, selecting the
       visible quote text would also pick up the sr-only sibling
       and produce "松风过耳。松风过耳。" in the clipboard. */
    user-select: none;
    -webkit-user-select: none;
  }
  .island-pet-quote .qc {
    display: inline-block;
    opacity: 0;
    transform: translateY(6px);
    filter: blur(2px);
    animation: qc-bloom 520ms cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
    /* Wave timing: chars cascade AFTER panel finishes unrolling.
       Panel hover-in: clip-path 360ms + 120ms entry delay = lands
       at 480ms from :hover. Add ~300ms base to bloom delay so
       chars start at 480ms (after panel settled), last char at
       480 + 15*20 + 520 = 1300ms. Reads as a clean wave instead
       of chars blooming into a still-clipping container. */
    animation-delay: calc(300ms + var(--i, 0) * 20ms);
    /* Pause until the panel actually reveals — otherwise the bloom
       plays on page load while panel is hidden and user never sees
       the theater. Unpaused below on :hover / :focus-within. */
    animation-play-state: paused;
  }
  .island-pet:hover .island-pet-quote .qc,
  .island-pet:focus-within .island-pet-quote .qc,
  .island-pet.is-revealed .island-pet-quote .qc {
    animation-play-state: running;
  }
  @keyframes qc-bloom {
    0%   { opacity: 0; transform: translateY(6px); filter: blur(2px); }
    60%  { opacity: 1; filter: blur(0); }
    100% { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .island-pet-actions {
    display: flex;
    gap: 8px;
    align-items: stretch;
  }
  .island-pet-chip {
    appearance: none;
    border: 0;
    padding: 8px 14px;
    border-radius: 10px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 12px;
    line-height: 1.2;
    cursor: pointer;
    /* shu-iro persimmon (V53.5 palette) — matches torii */
    background: rgba(208, 86, 54, 0.92);
    color: rgba(252, 244, 226, 0.98);
    transition: background 180ms ease, transform 180ms ease, box-shadow 220ms ease;
    flex: 1 1 auto;
    white-space: nowrap;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.15);
    position: relative;
    /* Single-line ellipsis fallback for any future label that's too
       long — won't trigger at current EN 'Step in' / ZH '进入森林岛'. */
    text-overflow: ellipsis;
    overflow: hidden;
    min-width: 0;
    /* Chip "arrives" after the panel finishes unrolling — opacity-
       only fade staggered between the two chips. Originally tried
       adding a slide-up translateY but that conflicted with the
       chip:hover lift (different transition durations on the same
       property — most-specific selector wins, making hover lift slow).
       Opacity fade alone reads as the wave we wanted; chip:hover
       transform stays snappy. */
    opacity: 0;
  }
  /* Wave: chips arrive AFTER panel finishes unrolling (~480ms).
     Enter chip leads at 380ms, cycle chip 80ms later. Reads as
     "placed" by an invisible hand. */
  .island-pet:hover .island-pet-chip[data-action="enter"],
  .island-pet:focus-within .island-pet-chip[data-action="enter"],
  .island-pet.is-revealed .island-pet-chip[data-action="enter"] {
    opacity: 1;
    transition: opacity 320ms ease 380ms,
                background 180ms ease, transform 180ms ease,
                box-shadow 220ms ease;
  }
  .island-pet:hover .island-pet-chip[data-action="cycle"],
  .island-pet:focus-within .island-pet-chip[data-action="cycle"],
  .island-pet.is-revealed .island-pet-chip[data-action="cycle"] {
    opacity: 1;
    transition: opacity 320ms ease 460ms,
                background 180ms ease, transform 180ms ease,
                box-shadow 220ms ease;
  }
  .island-pet-chip:hover {
    background: rgba(220, 100, 68, 1);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(208, 86, 54, 0.32);
  }
  .island-pet-chip:active {
    transform: translateY(1px) scale(0.94);
    background: rgba(180, 68, 48, 1);
    box-shadow: 0 0 0 rgba(0, 0, 0, 0);
  }
  /* Enter-chip arrow: nudges right on hover. Asymmetric easing —
     fast "wanting to go" forward (160ms ease-out), slower return
     (320ms ease-in-back) — mimics a spring that's been pulled. */
  .island-pet-chip[data-action="enter"] .island-pet-arrow {
    display: inline-block;
    transform: translateX(0);
    transition: transform 320ms cubic-bezier(0.55, 0.1, 0.4, 1);
  }
  .island-pet-chip[data-action="enter"]:hover .island-pet-arrow {
    transform: translateX(5px);
    transition: transform 160ms cubic-bezier(0.2, 0.7, 0.3, 1);
  }
  /* Cycle-chip 「另」 serif glyph (replaces geometric ↻). Inherits
     Songti from the quote — visually consistent with the panel's
     calligraphy aesthetic. On hover: subtle 1px lift. On click:
     brief opacity blink + 2px y-translate "press-down" animation
     (set by JS via .is-pressing). No rotation — CJK glyphs look
     broken when spun. */
  .island-pet-chip[data-action="cycle"] .island-pet-cycle-icon {
    display: inline-block;
    font-family: "Songti SC", "Noto Serif SC", "Times New Roman", serif;
    /* 12px not 13px — serif's optical x-height runs ~1.5px taller
       than the 12px mono chip label, so at 13px the icon dominated.
       Matched to label size for cleaner cross-script balance. */
    font-size: 12px;
    /* Cycle chip is monospace by default (chip CSS); icon stays serif */
    transition: transform 200ms ease, opacity 200ms ease;
  }
  .island-pet-chip[data-action="cycle"]:hover .island-pet-cycle-icon {
    transform: translateY(-1px);
  }
  .island-pet-chip[data-action="cycle"] .island-pet-cycle-icon.is-pressing {
    animation: cycle-press 320ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @keyframes cycle-press {
    0%   { transform: translateY(-1px); opacity: 1; }
    35%  { transform: translateY(2px);  opacity: 0.4; }
    100% { transform: translateY(-1px); opacity: 1; }
  }
  .island-pet-chip-ghost:active {
    background: rgba(252, 244, 226, 0.28);
  }
  /* Per-chip focus differentiation so Tab order is visually parseable.
     Enter chip = vermillion glow ring (matches its own fill);
     ghost chip = ivory ring. Without this both chips shared identical
     2px ivory outline and keyboard users couldn't tell which is focused. */
  .island-pet-chip[data-action="enter"]:focus-visible {
    outline: 2px solid rgba(252, 232, 210, 0.95);
    outline-offset: 2px;
    box-shadow: 0 4px 14px rgba(208, 86, 54, 0.46),
                0 0 0 4px rgba(208, 86, 54, 0.18);
  }
  .island-pet-chip-ghost:focus-visible {
    outline: 2px solid rgba(252, 244, 226, 0.85);
    outline-offset: 2px;
    box-shadow: 0 0 0 4px rgba(252, 244, 226, 0.12);
  }
  .island-pet-chip-ghost {
    background: rgba(252, 244, 226, 0.10);
    color: rgba(248, 232, 200, 0.88);
    flex: 0 0 auto;     /* fixed width for cycle chip */
    padding: 8px 12px;
    box-shadow: none;
  }
  .island-pet-chip-ghost:hover {
    background: rgba(252, 244, 226, 0.18);
    box-shadow: 0 4px 12px rgba(252, 244, 226, 0.10);
  }
  /* prefers-reduced-motion: suppress the more dramatic animations
     but preserve the underlying fade so users still see when state
     changes (per WCAG vestibular guidance). */
  @media (prefers-reduced-motion: reduce) {
    .island-pet-quote .qc {
      opacity: 1;
      transform: none;
      filter: none;
      animation: none;
    }
    /* Chip arrive is purely decorative — show chips immediately. */
    .island-pet-chip {
      opacity: 1;
      transition: background 180ms ease, transform 180ms ease,
                  box-shadow 220ms ease;
    }
    .island-pet-chip[data-action="enter"] .island-pet-arrow {
      transition: none;
    }
    .island-pet-chip[data-action="cycle"] .island-pet-cycle-icon.is-pressing {
      animation: none;
    }
    .island-pet-seal {
      opacity: 0.72;
      animation: none;
    }
  }
  /* Reduced motion: skip the slide/unfurl, just fade */
  @media (prefers-reduced-motion: reduce) {
    .island-pet-panel {
      transform: none !important;
      clip-path: none !important;
      transition: opacity 200ms ease;
    }
  }

  /* V52.8 (Sub-A polish): comment correctly describes what this rule
     actually does. Earlier draft claimed "CSS hides astro-island" but
     this rule does NOT hide R3F — that would lose the scene entirely.
     R3F's frameloop drops to "demand" via PREFERS_REDUCED_MOTION (in
     island-shared.ts) so the scene renders ONCE and freezes; this CSS
     rule kills the wrapper-level hover lift + skeleton breath pulse
     so nothing else animates around the static frozen scene. */
  @media (prefers-reduced-motion: reduce) {
    .island-pet {
      transition: none;
    }
    .island-pet:hover {
      transform: none;
      filter: drop-shadow(0 6px 14px rgba(40, 50, 60, 0.18));
    }
    .island-pet .island-skeleton {
      animation: none;
    }
  }

  /* Print: the floating 220×220 R3F pet would render on every page
     and waste ink. Hide entirely. */
  @media print {
    .island-pet { display: none !important; }
  }

  /* Windows High Contrast / forced-colors mode: translucent panel +
     subtle drop-shadow get overridden to system colors and become
     invisible. Fall back to system Canvas/CanvasText + visible
