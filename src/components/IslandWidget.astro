---
// Homepage 3D island card — inline in the cards-grid, full-width.
// R3F mounts lazily on scroll-into-view. Click → /world/.
import IslandWidget from './IslandWidget'
---

<div class="card card-island" id="island-3d">
  <div class="island-card-head">
    <div class="island-card-title">森林岛 · 3D</div>
    <a class="island-card-link" href="/world/">進入 →</a>
  </div>
  <a href="/world/" class="island-card-canvas" aria-label="進入森林岛 — Airing 的 3D 漫游">
    <IslandWidget client:visible />
  </a>
</div>

<style>
  .card-island {
    padding: 14px !important;          /* override .card default 24px so canvas dominates */
    overflow: hidden;
  }
  .island-card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin: 2px 4px 10px;
  }
  .island-card-title {
    font-family: "Songti SC", "Noto Serif SC", "Hiragino Mincho ProN", serif;
    font-size: 14px;
    letter-spacing: 0.08em;
    color: var(--c-text);
    opacity: 0.85;
  }
  .island-card-link {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 11px;
    color: var(--c-text-muted);
    text-decoration: none;
    transition: color 200ms ease, transform 200ms ease;
  }
  .island-card-link:hover {
    color: var(--c-text);
    transform: translateX(2px);
  }
  .island-card-canvas {
    --island-dwell: 0;  /* V29: 0..1, driven by React useFrame on dwell */
    display: block;
    width: 100%;
    height: 360px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    /* V29: two stacked backgrounds — base cool sky + warm golden,
       layered via color-mix. As --island-dwell ramps 0→1, sky lerps
       from bright noon blue → golden-hour amber, agreeing with the
       in-canvas fog/sun shift. */
    background:
      radial-gradient(
        circle at calc(50% + var(--island-dwell) * 8%) calc(28% + var(--island-dwell) * 14%),
        color-mix(in oklab, #FFF6DD calc((1 - var(--island-dwell)) * 100%), #FFE6B0) 0%,
        color-mix(in oklab, #E5F1F6 calc((1 - var(--island-dwell)) * 100%), #FFD498) 28%,
        color-mix(in oklab, #BFD8E8 calc((1 - var(--island-dwell)) * 100%), #E8B080) 60%,
        color-mix(in oklab, #92B1C8 calc((1 - var(--island-dwell)) * 100%), #C88060) 100%
      );
    cursor: pointer;
    transition: filter 240ms ease, transform 240ms ease;
  }
  .island-card-canvas:hover {
    filter: brightness(1.05) saturate(1.08);
    transform: translateY(-1px);
  }
  .island-card-canvas canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }

  @media (max-width: 800px) {
    .island-card-canvas { height: 240px; }
  }
  @media (max-width: 480px) {
    .island-card-canvas { height: 200px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .card-island { display: none; }
  }
</style>
