---
// Floating Forest Island PET — fixed bottom-right of the homepage.
// V51 redesign: was an inline card in the cards-grid (V32-V50). User
// asked to move to corner like a desktop pet, but NOT picture-in-picture
// style — so: no frame, no border, no card shadow, no title bar.
// Just the island silhouette floating freely on the page.
//
// R3F mounts lazily on scroll-into-view (still — first scroll typically
// happens within a few seconds of page load anyway).
// Click the whole pet → /world/.
import IslandWidget from './IslandWidget'
---

<!-- V51 a11y: role=link wrapper (not <a> — interactive canvas inside
     <a> is invalid HTML). Keyboard activation wired via JS. -->
<div role="link" tabindex="0" data-href="/world/" class="island-pet" id="island-3d-canvas-wrap"
     aria-label="进入森林岛 — Airing 的 3D 漫游" aria-busy="true">
  <!-- WebGL-loading / failed skeleton (tiny pet silhouette) -->
  <svg class="island-skeleton" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
    <defs>
      <linearGradient id="pet-cliff" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0" stop-color="#B88560" stop-opacity="0.55" />
        <stop offset="1" stop-color="#6B4530" stop-opacity="0.65" />
      </linearGradient>
      <radialGradient id="pet-shoji" cx="0.5" cy="0.5" r="0.5">
        <stop offset="0" stop-color="#FFEFD0" stop-opacity="0.9" />
        <stop offset="1" stop-color="#FFEFD0" stop-opacity="0" />
      </radialGradient>
    </defs>
    <!-- Distant mountain (single, simpler than full skeleton) -->
    <path d="M 0 100 L 35 78 L 70 92 L 110 68 L 150 88 L 200 76 L 200 130 L 0 130 Z"
          fill="rgba(135, 155, 170, 0.32)" />
    <!-- Island base (grass disc + soil cliff) -->
    <ellipse cx="100" cy="170" rx="92" ry="8" fill="url(#pet-cliff)" />
    <ellipse cx="100" cy="158" rx="86" ry="14" fill="rgba(168, 199, 122, 0.72)" />
    <!-- Two cedars (left) -->
    <g opacity="0.88">
      <polygon points="32,160 46,160 39,108" fill="rgba(56, 88, 48, 0.72)" />
      <polygon points="50,162 64,162 57,114" fill="rgba(48, 76, 42, 0.78)" />
    </g>
    <!-- Cabin: irimoya roof + shoji glow + chimney smoke -->
    <g>
      <rect x="74" y="120" width="48" height="34" fill="rgba(245, 232, 200, 0.88)" />
      <ellipse cx="98" cy="142" rx="18" ry="9" fill="url(#pet-shoji)" />
      <line x1="84" y1="132" x2="112" y2="132" stroke="rgba(58, 37, 22, 0.45)" stroke-width="0.7" />
      <line x1="98" y1="124" x2="98" y2="146" stroke="rgba(58, 37, 22, 0.45)" stroke-width="0.7" />
      <polygon points="64,120 132,120 124,104 72,104" fill="rgba(74, 86, 108, 0.94)" />
      <polygon points="72,104 124,104 117,92 79,92" fill="rgba(110, 124, 148, 0.92)" />
      <rect x="78" y="90" width="40" height="3" fill="rgba(46, 53, 64, 0.92)" />
      <rect x="108" y="80" width="4" height="10" fill="rgba(58, 37, 22, 0.72)" />
      <path d="M110 78 Q 114 72, 110 66" stroke="rgba(220, 210, 200, 0.55)" stroke-width="1.8" fill="none" stroke-linecap="round" />
    </g>
    <!-- Sakura right -->
    <g>
      <path d="M152 158 Q 150 138, 148 124" stroke="rgba(58, 37, 22, 0.50)" stroke-width="1.5" fill="none" stroke-linecap="round" />
      <ellipse cx="148" cy="120" rx="18" ry="14" fill="rgba(240, 175, 195, 0.62)" />
      <ellipse cx="160" cy="112" rx="13" ry="11" fill="rgba(255, 200, 215, 0.55)" />
    </g>
    <!-- Torii (small, right edge) -->
    <g>
      <rect x="172" y="128" width="2.5" height="28" fill="rgba(200, 74, 53, 0.85)" />
      <rect x="186" y="128" width="2.5" height="28" fill="rgba(200, 74, 53, 0.85)" />
      <path d="M168 126 Q 180 119, 192 126 L 192 130 L 168 130 Z" fill="rgba(31, 24, 18, 0.92)" />
      <rect x="170" y="140" width="20" height="2" fill="rgba(200, 74, 53, 0.85)" />
    </g>
    <!-- Skeleton fades out via CSS once the canvas mounts. No SMIL
         <animate> here — SMIL ignores CSS @media (prefers-reduced-motion)
         and would pulse forever for vestibular-disorder users on the
         rare WebGL-failed path. -->
  </svg>
  <IslandWidget client:visible />
  <!-- FX overlay: covers the canvas, particles spawn here on click.
       pointer-events:none so it never blocks the panel/chips below.
       z-index above canvas (z:0) but below panel (z:4). -->
  <div class="island-pet-fx" aria-hidden="true"></div>
  <!-- V50 a11y: WebGL-failed hint as REAL element (CSS ::after is
       skipped by most screen readers); visibility toggled by JS. -->
  <span class="island-pet-hint" aria-live="polite" hidden>需要 WebGL · 点击进入完整页面</span>

  <!-- V53.5: completely self-contained chips. No external JS dependency.
       Quote list embedded as JSON in data-quotes attr; cycle logic
       runs inline. If the main IIFE fails entirely, chips still work.
       Tiny "v53.5" version marker in the corner so we can rule out
       browser cache (if you see "v53.5" you have the latest build). -->
  <!-- Use the modern `inert` attribute (browser-native) instead of
       aria-hidden="true" — aria-hidden on a subtree containing focusable
       buttons is an axe-core 'aria-hidden-focus' violation. `inert`
       correctly removes both AT exposure AND keyboard tab order, then
       reverses cleanly on hover/focus via the JS listeners below. -->
  <div class="island-pet-panel" inert>
    <p class="island-pet-quote" data-idx="0" aria-live="off" aria-atomic="true">松风过耳，落英满衣。</p>
    <span class="island-pet-seal" aria-hidden="true">居</span>
    <div class="island-pet-actions" role="group" aria-label="森林岛操作">
      <button type="button"
              class="island-pet-chip"
              data-action="enter"
              onclick="event.stopPropagation(); window.location.href='/world/'; return false;"><span class="island-pet-chip-label">进入森林岛</span> <span class="island-pet-arrow" aria-hidden="true">→</span></button>
      <button type="button"
              class="island-pet-chip island-pet-chip-ghost"
              data-action="cycle"
              aria-label="换一句"
              onclick="event.stopPropagation(); event.preventDefault(); var q=this.closest('.island-pet-panel').querySelector('.island-pet-quote'); try { var icon=this.querySelector('.island-pet-cycle-icon'); if(icon&&icon.classList.contains('is-pressing')) return false; var pool=(window.__islandQuotes||{}); var lang=(document.documentElement.lang||'').toLowerCase().indexOf('en')===0?'en':'zh'; var arr=pool[lang]; if(!arr||!arr.length) return false; var i=(parseInt(q.getAttribute('data-idx')||'0')+1)%arr.length; q.setAttribute('data-idx', i); if(typeof window.__setIslandQuote==='function'){ window.__setIslandQuote(q, arr[i]); } else { q.textContent=arr[i]; } window.__islandQuoteIdx=i; if(icon){ icon.classList.add('is-pressing'); setTimeout(function(){ icon.classList.remove('is-pressing'); }, 320); } } catch(e){ console.error('[island-pet] cycle error', e); } return false;"><span class="island-pet-cycle-icon" aria-hidden="true">另</span> <span class="island-pet-chip-label">换一句</span></button>
    </div>
  </div>
</div>

<script is:inline>
  // Quote pools live INSIDE the IIFE below, exposed on window
  // (window.__islandQuotes) for the inline cycle handler to read.
  // applyLang() inside the IIFE reads the same arrays — single
  // source of truth.
  (function () {
    const wrap = document.getElementById('island-3d-canvas-wrap')
    if (!wrap) return

    const HAS_WEBGL = (
      'WebGL2RenderingContext' in window ||
      'WebGLRenderingContext' in window
    )
    function showHint(visible) {
      const hint = wrap.querySelector('.island-pet-hint')
      if (hint) hint.hidden = !visible
    }
    function setBusy(busy) {
      wrap.setAttribute('aria-busy', busy ? 'true' : 'false')
    }

    if (!HAS_WEBGL) {
      wrap.classList.add('island-webgl-failed')
      showHint(true)
      setBusy(false)
      return
    }

    function isCanvasWorking(canvas) {
      if (!canvas) return false
      try {
        const ctx = canvas.getContext('webgl2') || canvas.getContext('webgl')
        return !!ctx && !ctx.isContextLost?.()
      } catch {
        return false
      }
    }

    function checkCanvas() {
      const canvas = wrap.querySelector('canvas')
      if (canvas && isCanvasWorking(canvas)) {
        wrap.classList.add('island-loaded')
        setBusy(false)
        return true
      }
      return false
    }

    // Don't early-return if canvas is already ready — the click
    // handler + quote setup + window.__islandQuotes assignment below
    // ALL need to run regardless. (checkCanvas() also has the side
    // effect of adding the 'island-loaded' class + setBusy(false), so
    // calling it here is enough for the ready-state setup.)
    checkCanvas()
    const obs = new MutationObserver(() => {
      if (checkCanvas()) obs.disconnect()
    })
    obs.observe(wrap, { childList: true, subtree: true })

    setTimeout(() => {
      const canvas = wrap.querySelector('canvas')
      if (!canvas || !isCanvasWorking(canvas)) {
        obs.disconnect()
        wrap.classList.add('island-webgl-failed')
        showHint(true)
        setBusy(false)
      } else if (!wrap.classList.contains('island-loaded')) {
        wrap.classList.add('island-loaded')
        setBusy(false)
      }
    }, 12000)

    // Click handler: clicking the pet does NOT navigate (too easy to
    // mis-trigger). It plays a random visual effect overlay (snow,
    // petal burst, sparkle, mist, ripple). Only the "Step in" chip
    // navigates to /world/. Touch UX: on devices without hover, the
    // first tap reveals the panel; subsequent taps fire fx.
    const isTouch = typeof matchMedia === 'function' && matchMedia('(hover: none)').matches
    const fxLayer = wrap.querySelector('.island-pet-fx')
    const FX_TYPES = ['snow', 'wind', 'sakura', 'moonglow', 'mist']
    let lastFxType = null
    const rand = (lo, hi) => lo + Math.random() * (hi - lo)
    // Type-specific spawners — each owns its own particle count, layout,
    // and CSS-var setup. Effects spawn where they naturally originate:
    // snow/sakura from top, wind from a side, mist from bottom, moonglow
    // from click point. NOT all from click point — that's what made the
    // first version feel like cheap material-design click ripples.
    const spawners = {
      // 飘雪 — 48 flakes across full top width, staggered delays for
      // continuous-flow feel (not burst). Each flake drifts with sin-
      // wave horizontal wobble (handled by multi-step keyframe).
      // 飘雪 — 28 flakes in 3 PARALLAX STRATA for depth-of-field
      // (Ghibli vs PowerPoint): 40% far (small, blurred, slow, dim),
      // 40% mid (current), 20% near (large, slight blur, fast). Per-
      // flake fall + wobble cadences don't sync — aperiodic feel.
      snow(burst, rect) {
        const stratum = (i) => {
          if (i < 11) return 'far'    // ~40%
          if (i < 22) return 'mid'    // ~40%
          return 'near'               // ~20%
        }
        for (let i = 0; i < 28; i++) {
          const p = document.createElement('span')
          p.className = 'island-fx-p island-fx-snow-' + stratum(i)
          p.style.setProperty('--x', rand(-10, rect.width + 10) + 'px')
          p.style.setProperty('--wobble', rand(14, 32) + 'px')
          p.style.setProperty('--wobble-dir', Math.random() < 0.5 ? '1' : '-1')
          // Stratum-specific size/speed
          let s, fall, op
          if (i < 11)      { s = rand(2, 3.2);  fall = rand(5200, 7000); op = rand(0.30, 0.55) }
          else if (i < 22) { s = rand(3.5, 6);  fall = rand(3800, 5200); op = rand(0.60, 0.85) }
          else             { s = rand(6.5, 10); fall = rand(3000, 4200); op = rand(0.78, 0.95) }
          p.style.setProperty('--s', s + 'px')
          p.style.setProperty('--fall', fall + 'ms')
          p.style.setProperty('--op', op.toFixed(2))
          p.style.setProperty('--d', rand(0, 2400) + 'ms')
          p.style.setProperty('--rot', rand(-180, 180) + 'deg')
          burst.appendChild(p)
        }
      },
      // 吹风 — 16 ink-wash smears (was 22 pill-shapes — pills read
      // as anime speed lines). Each curves through an arc via separate
      // Y-translate so it doesn't feel like a straight ruler. Heavily
      // blurred, low opacity (0.22-0.36) — air has no edges.
      wind(burst, rect) {
        const dir = Math.random() < 0.5 ? 1 : -1
        burst.classList.add(dir === 1 ? 'island-fx-wind-ltr' : 'island-fx-wind-rtl')
        for (let i = 0; i < 16; i++) {
          const p = document.createElement('span')
          p.className = 'island-fx-p'
          const len = rand(70, 150)
          const journey = (rect.width + len + 80)
          p.style.setProperty('--y',     rand(15, rect.height - 30) + 'px')
          p.style.setProperty('--len',   len + 'px')
          // Down to 1.5-2.5px — the blur will soften this into wash.
          p.style.setProperty('--w',     rand(1.5, 2.6) + 'px')
          // Arc curve: vertical offset at mid-flight (positive or neg)
          p.style.setProperty('--arc',   rand(-22, 22) + 'px')
          p.style.setProperty('--vdrift', rand(-12, 12) + 'px')
          p.style.setProperty('--journey', journey + 'px')
          p.style.setProperty('--cross', rand(1800, 2700) + 'ms')
          p.style.setProperty('--d',     rand(0, 1300) + 'ms')
          // Low opacity — sumi-e ink-wash, not headlight.
          p.style.setProperty('--op',    rand(0.22, 0.4).toFixed(2))
          burst.appendChild(p)
        }
      },
      // 落樱 — 10 petals (was 18 — restraint is the aesthetic).
      // Petals flutter, they don't spin: capped Z rotation + Y-axis
      // flip that momentarily turns the petal edge-on (lower opacity
      // at 35%/70%). Per-petal phase decouples motion from neighbors.
      sakura(burst, rect) {
        for (let i = 0; i < 10; i++) {
          const p = document.createElement('span')
          p.className = 'island-fx-p'
          p.style.setProperty('--x',      rand(10, rect.width - 10) + 'px')
          p.style.setProperty('--rock',   rand(20, 42) + 'px')
          p.style.setProperty('--rock-dir', Math.random() < 0.5 ? '1' : '-1')
          p.style.setProperty('--fall',   rand(4200, 6200) + 'ms')
          p.style.setProperty('--d',      rand(0, 1800) + 'ms')
          p.style.setProperty('--s',      rand(8, 13) + 'px')
          // Modest Z rotation cap (120-280°) — petals flutter, not spin.
          // Two Y-flip cycles via separate keyframe.
          p.style.setProperty('--rz',     rand(120, 280) * (Math.random() < 0.5 ? 1 : -1) + 'deg')
          p.style.setProperty('--ry',     rand(420, 720) + 'deg')   // two-flip-ish
          p.style.setProperty('--hue',    rand(-10, 12) + 'deg')
          burst.appendChild(p)
        }
      },
      // 月华 — Single steady warm bloom (lantern-light, not Material
       // ripple) + 6 floating kotodama embers rising up from click. The
       // expanding-ring metaphor reads as a Google button; lanterns
       // glow in place, they don't propagate.
      moonglow(burst, rect, cx, cy) {
        burst.style.setProperty('--cx', cx + 'px')
        burst.style.setProperty('--cy', cy + 'px')
        // Main bloom (one)
        const bloom = document.createElement('span')
        bloom.className = 'island-fx-p island-fx-bloom-core'
        burst.appendChild(bloom)
        // 6 ember dots drift up + slightly outward
        for (let i = 0; i < 6; i++) {
          const e = document.createElement('span')
          e.className = 'island-fx-p island-fx-bloom-ember'
          e.style.setProperty('--dx', rand(-30, 30) + 'px')
          e.style.setProperty('--dy', rand(-80, -40) + 'px')
          e.style.setProperty('--d',  rand(100, 800) + 'ms')
          e.style.setProperty('--es', rand(2, 4) + 'px')  // ember size
          burst.appendChild(e)
        }
      },
      // 烟雾 — 14 wisps (was 5 — too anemic). Wider opacity range
       // 0.08-0.28, longer rise 5-7s, staggered to 2500ms so it feels
       // like fog SETTLING IN, not a puff. mix-blend-mode: screen on
       // the CSS rule for soft compositing.
      mist(burst, rect) {
        for (let i = 0; i < 14; i++) {
          const p = document.createElement('span')
          p.className = 'island-fx-p'
          p.style.setProperty('--x',     rand(-20, rect.width - 40) + 'px')
          p.style.setProperty('--w',     rand(50, 130) + 'px')
          p.style.setProperty('--h',     rand(20, 44) + 'px')
          p.style.setProperty('--drift', rand(-40, 40) + 'px')
          p.style.setProperty('--rise',  rand(5000, 7000) + 'ms')
          p.style.setProperty('--d',     rand(0, 2500) + 'ms')
          p.style.setProperty('--op',    rand(0.08, 0.28).toFixed(2))
          burst.appendChild(p)
        }
      },
    }
    // Total burst durations (longest particle's full lifetime) per type
    // — used to schedule the burst auto-remove. Safe margin: +500ms.
    const totalMs = { snow: 7900, wind: 3900, sakura: 7400, moonglow: 2600, mist: 5800 }
    function playFx(e) {
      if (!fxLayer) return
      let type
      do { type = FX_TYPES[Math.floor(Math.random() * FX_TYPES.length)] }
      while (type === lastFxType && FX_TYPES.length > 1)
      lastFxType = type
      const rect = fxLayer.getBoundingClientRect()
      const cx = e ? Math.max(0, Math.min(rect.width,  e.clientX - rect.left)) : rect.width / 2
      const cy = e ? Math.max(0, Math.min(rect.height, e.clientY - rect.top))  : rect.height / 2
      const burst = document.createElement('div')
      burst.className = 'island-fx-burst island-fx-' + type
      spawners[type](burst, rect, cx, cy)
      fxLayer.appendChild(burst)
      setTimeout(() => burst.remove(), totalMs[type] || 4000)
    }
    wrap.addEventListener('click', (e) => {
      // Chip click: let it do its own thing (Step in navigates, cycle cycles)
      if ((e.target instanceof Element) && e.target.closest('.island-pet-chip')) return
      // Touch: first tap reveals panel (no fx)
      if (isTouch && !wrap.classList.contains('is-revealed')) {
        wrap.classList.add('is-revealed')
        const p = wrap.querySelector('.island-pet-panel')
        if (p) p.inert = false
        e.preventDefault()
        return
      }
      // Otherwise: play random fx
      playFx(e)
    })
    if (isTouch) {
      document.addEventListener('click', (e) => {
        if (!wrap.classList.contains('is-revealed')) return
        if (e.target instanceof Element && wrap.contains(e.target)) return
        wrap.classList.remove('is-revealed')
        const p = wrap.querySelector('.island-pet-panel')
        if (p) p.inert = true
      })
    }
    wrap.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        // Don't fire pet-level fx if a chip is focused
        if ((e.target instanceof Element) && e.target.closest('.island-pet-chip')) return
        e.preventDefault()
        playFx(null)
      }
    })

    // ─── V53: hover overlay (quote + chips, lang-aware) ───
    // V53.2: wrapped in try/catch. If anything throws, the inline
    // defaults in HTML still show ("山深闻鹧鸪。" + "进入森林岛 →" +
    // "↻ 换一句") so the UI is usable even without JS upgrade.
    try {
    const panel = wrap.querySelector('.island-pet-panel')
    const quoteEl = wrap.querySelector('.island-pet-quote')
    const enterChip = wrap.querySelector('.island-pet-chip[data-action=enter]')
    const cycleChip = wrap.querySelector('.island-pet-chip[data-action=cycle]')
    if (!panel || !quoteEl || !enterChip || !cycleChip) {
      console.warn('[island-pet] panel/chip elements missing — using HTML defaults')
      return
    }

    const QUOTES_ZH = [
      '松风过耳，落英满衣。',
      '此中有真意，欲辨已忘言。',
      '云在青天水在瓶。',
      '白云深处有人家。',
      '万物静观皆自得。',
      '小岛承天地之闲，木屋藏岁月之声。',
      '不识庐山真面目，只缘身在此山中。',
      '山色有无中。',
      '闲来无事不从容。',
      '千江有水千江月。',
      '春有百花秋有月。',
      '心远地自偏。',
      '行到水穷处，坐看云起时。',
      '空山新雨后。',
      '明月松间照。',
      '独坐幽篁里，弹琴复长啸。',
      '君问归期未有期。',
      '山中无历日。',
      '寒山转苍翠。',
      '落叶他乡树，寒灯独夜人。',
      '山高自有客行路。',
      '风起于青萍之末。',
      '此曲只应天上有。',
      '渔舟唱晚。',
      '雨打芭蕉。',
      '月落乌啼霜满天。',
      '浮云一别后，流水十年间。',
      '何当共剪西窗烛。',
      '山光悦鸟性。',
      '但远山长，云山乱，晓山青。',
      '不畏浮云遮望眼。',
      '我心安处是吾乡。',
      '闲云潭影日悠悠。',
      '一蓑烟雨任平生。',
      '也无风雨也无晴。',
      '海上明月共潮生。',
      '山高月小，水落石出。',
      '林尽水源便得一山。',
      '雁字回时，月满西楼。',
      '念去去，千里烟波。',
      '一江春水向东流。',
      '庭院深深深几许。',
      '寒夜客来茶当酒。',
      '山是眉峰聚。',
      '道法自然。',
      '知者不言，言者不知。',
      '涉江采芙蓉。',
      '人闲桂花落。',
      '时见鹿，溪午不闻钟。',
      '山深闻鹧鸪。',
      '山中一夜雨，树杪百重泉。',
      '江流天地外。',
      '雪夜访戴，兴尽而返。',
      '醒时同交欢，醉后各分散。',
      '永结无情游，相期邈云汉。',
      '此情可待成追忆。',
      '沧浪之水清兮。',
      '渡头余落日。',
      '墟里上孤烟。',
      '山雨欲来风满楼。',
      '一片孤城万仞山。',
      '二月春风似剪刀。',
      '沾衣欲湿杏花雨。',
      '吹面不寒杨柳风。',
      '春风又绿江南岸。',
      '落木千山天远大。',
      '澄江一道月分明。',
      '万壑树参天，千山响杜鹃。',
      '山中相送罢，日暮掩柴扉。',
      '春草明年绿，王孙归不归。',
      '听取蛙声一片。',
      '稻花香里说丰年。',
      '七八个星天外，两三点雨山前。',
      '旧时茅店社林边，路转溪桥忽见。',
      '千山鸟飞绝，万径人踪灭。',
      '孤舟蓑笠翁，独钓寒江雪。',
      '采菊东篱下，悠然见南山。',
      '岁月忽已晚。',
      '逝者如斯夫。',
      '海内存知己，天涯若比邻。',
      '人生若只如初见。',
      '清风明月本无价。',
      '近水远山皆有情。',
      '世事一场大梦，人生几度新凉。',
      '坐到三更尽，归仍万里赊。',
      '今宵剩把银釭照，犹恐相逢是梦中。',
