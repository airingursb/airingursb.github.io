---
/**
 * Immersive note badge — sparkle ✨ + label.
 * Indicates a note that links to a full-page standalone article (under /immersive/).
 *
 * Props:
 *   label?: string  - text shown after the sparkle (default: "沉浸式")
 *   size?: number   - icon size in px (default: 12)
 */
interface Props {
  label?: string;
  size?: number;
}
const { label = '沉浸式', size = 12 } = Astro.props;
---

<span class="immersive-badge" title={`${label} · Immersive`}>
  <svg
    class="ib-sparkle"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <!-- Main 4-point star -->
    <path
      d="M12 2 L13.6 9.4 L21 11 L13.6 12.6 L12 20 L10.4 12.6 L3 11 L10.4 9.4 Z"
      fill="currentColor"
    />
    <!-- Top-right small spark -->
    <path
      d="M19 3 L19.5 5 L21.5 5.5 L19.5 6 L19 8 L18.5 6 L16.5 5.5 L18.5 5 Z"
      fill="currentColor"
      opacity="0.7"
    />
    <!-- Bottom-left small spark -->
    <path
      d="M5 17 L5.4 18.6 L7 19 L5.4 19.4 L5 21 L4.6 19.4 L3 19 L4.6 18.6 Z"
      fill="currentColor"
      opacity="0.55"
    />
  </svg>
  <span class="ib-label">{label}</span>
</span>

<style>
  .immersive-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 2px 9px 2px 7px;
    border-radius: 999px;
    background: rgba(217, 119, 6, 0.06);
    border: 1px solid rgba(217, 119, 6, 0.28);
    color: #b45309;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.4;
    white-space: nowrap;
    transition: all 0.18s ease;
  }
  .immersive-badge:hover {
    background: rgba(217, 119, 6, 0.12);
    border-color: rgba(217, 119, 6, 0.5);
    color: #92400e;
  }
  .ib-sparkle {
    flex-shrink: 0;
    color: #d97706;
    transition: transform 0.4s ease;
  }
  .immersive-badge:hover .ib-sparkle {
    transform: rotate(20deg) scale(1.08);
  }
  .ib-label {
    font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Inter", sans-serif;
  }
  /* Dark mode (if blog supports) */
  :global([data-theme="dark"]) .immersive-badge {
    background: rgba(252, 211, 77, 0.08);
    border-color: rgba(252, 211, 77, 0.3);
    color: #fde68a;
  }
  :global([data-theme="dark"]) .ib-sparkle {
    color: #fcd34d;
  }
</style>
